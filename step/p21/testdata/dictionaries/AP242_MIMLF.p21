#26204=EXPRESS_CODE(#11060,('LOCAL\X\0A  source_domain   : maths_space;\X\0A  source_interval : finite_integer_interval;\X\0A  index           : INTEGER                  := 1;\X\0A  base            : INTEGER;\X\0A  shape           : LIST OF positive_integer;\X\0A  ndim            : positive_integer;\X\0A  slo             : INTEGER;\X\0A  shi             : INTEGER;\X\0A  sublo           : LIST OF INTEGER          := [];\X\0A  subhi           : LIST OF INTEGER          := [];\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(fun)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  source_domain := factor1(fun.source.domain);\X\0A  IF (schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(source_domain)\X\0A  THEN\X\0A    source_domain := factor1(source_domain);\X\0A  END_IF;\X\0A  IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(source_domain))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  source_interval := source_domain;\X\0A  base := fun\\explicit_table_function.index_base;\X\0A  shape := fun\\explicit_table_function.shape;\X\0A  IF (schema_prefix + ''STANDARD_TABLE_FUNCTION'') IN TYPEOF(fun)\X\0A  THEN\X\0A    REPEAT j := 1 TO SIZEOF(shape);\X\0A      index := index * shape[j];\X\0A    END_REPEAT;\X\0A    index := fun.first + index - 1;\X\0A    RETURN(bool({source_interval.min <= index <= source_interval.max}));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''REGULAR_TABLE_FUNCTION'') IN TYPEOF(fun)\X\0A  THEN\X\0A    ndim := SIZEOF(fun\\explicit_table_function.shape);\X\0A    REPEAT j := 1 TO ndim;\X\0A      slo := base;\X\0A      shi := base + shape[j] - 1;\X\0A      IF fun\\regular_table_function.increments[j] >= 0\X\0A      THEN\X\0A        INSERT(sublo, slo, j - 1);\X\0A        INSERT(subhi, shi, j - 1);\X\0A      ELSE\X\0A        INSERT(sublo, shi, j - 1);\X\0A        INSERT(subhi, slo, j - 1);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    index := regular_indexing(sublo, base, shape, fun\\regular_table_function.increments, fun.first);\X\0A    IF NOT ({source_interval.min <= index <= source_interval.max})\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    index := regular_indexing(subhi, base, shape, fun\\regular_table_function.increments, fun.first);\X\0A    IF NOT ({source_interval.min <= index <= source_interval.max})\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
