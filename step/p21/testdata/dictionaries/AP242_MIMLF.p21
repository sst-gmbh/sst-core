#28505=EXPRESS_CODE(#11474,('LOCAL\X\0A  adr    : SET OF applied_document_reference             := (QUERY(adr\X\0A                                                                   <* applied_document_reference\X\0A                                                                   | (adr\\document_reference.assigned_document\\document.kind\\document_type.product_data_type =\X\0A                                                                      ''Standards Document'') AND\X\0A                                                                     ((adr\\document_reference.assigned_document\\document.id =\X\0A                                                                       ''ASME Y14.41-2003'') OR\X\0A                                                                      (adr\\document_reference.assigned_document\\document.id =\X\0A                                                                       ''ASME Y14.5M-1994'') OR\X\0A                                                                      (adr\\document_reference.assigned_document\\document.id =\X\0A                                                                       ''ISO 1101: 2004''))));\X\0A  pdca   : SET OF product_definition_context_association := (QUERY(pdca\X\0A                                                                   <* product_definition_context_association\X\0A                                                                   | (pdca\\product_definition_context_association.role\\product_definition_context_role.name =\X\0A                                                                      ''additional context'') AND\X\0A                                                                     (pdca\\product_definition_context_association.frame_of_reference\\application_context_element.name =\X\0A                                                                      ''Geometric Dimensioning and Tolerancing Product Specification'')));\X\0A  ra     : SET OF role_association                       := (QUERY(ra\X\0A                                                                   <* role_association\X\0A                                                                   | ra\\role_association.role\\object_role.name =\X\0A                                                                     ''dimensioning standard''));\X\0A  ra1    : SET OF role_association                       := [];\X\0A  pdpdca : SET OF product_definition                     := [];\X\0A  pdadr  : SET OF product_definition                     := [];\X\0A  pass   : BOOLEAN                                       := true;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(pdca);\X\0A    pdpdca := pdpdca + pdca[i]\\product_definition_context_association.definition;\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO HIINDEX(adr);\X\0A    ra1 := bag_to_set(USEDIN(adr[i],\X\0A                             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ROLE_ASSOCIATION.ITEM_WITH_ROLE''));\X\0A    IF (ra1 * ra) <> ra1\X\0A    THEN\X\0A      pass := false;\X\0A    END_IF;\X\0A    REPEAT j := 1 TO HIINDEX(adr[i]\\applied_document_reference.items);\X\0A      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN\X\0A         TYPEOF(adr[i]\\applied_document_reference.items[j])\X\0A      THEN\X\0A        pdadr := pdadr + adr[i]\\applied_document_reference.items[j];\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_REPEAT;'));
