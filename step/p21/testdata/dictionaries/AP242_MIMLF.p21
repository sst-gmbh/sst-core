#28203=EXPRESS_CODE(#11424,('LOCAL\X\0A  i       : INTEGER;\X\0A  j       : INTEGER;\X\0A  n       : INTEGER                 := 1 + cskhole\\solid_with_stepped_round_hole.segments;\X\0A  smaller : positive_length_measure;\X\0A  larger  : positive_length_measure;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(cskhole.conical_transitions);\X\0A    IF (((cskhole.conical_transitions[i].transition_number = 1) AND\X\0A         (cskhole.conical_transitions[i].cone_apex_angle < 0)) XOR\X\0A        ((cskhole.conical_transitions[i].transition_number = n) AND\X\0A         (cskhole.conical_transitions[i].cone_apex_angle > 0)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    ELSE\X\0A      IF ((cskhole.conical_transitions[i].transition_number <> 1) AND\X\0A          (cskhole.conical_transitions[i].transition_number <> n))\X\0A      THEN\X\0A        BEGIN  \X\0A               j := cskhole.conical_transitions[i].transition_number;\X\0A               IF cskhole\\solid_with_stepped_round_hole.segment_radii[j] >\X\0A                  cskhole\\solid_with_stepped_round_hole.segment_radii[j - 1]\X\0A               THEN\X\0A                 BEGIN  \X\0A                        IF (cskhole.conical_transitions[i].cone_apex_angle > 0)\X\0A                        THEN\X\0A                          RETURN(false);\X\0A                        END_IF;\X\0A                        larger := cskhole\\solid_with_stepped_round_hole.segment_radii[j];\X\0A                        smaller := cskhole\\solid_with_stepped_round_hole.segment_radii[j - 1];\X\0A                 END;\X\0A               ELSE\X\0A                 BEGIN  \X\0A                        IF (cskhole.conical_transitions[i].cone_apex_angle < 0)\X\0A                        THEN\X\0A                          RETURN(false);\X\0A                        END_IF;\X\0A                        larger := cskhole\\solid_with_stepped_round_hole.segment_radii[j - 1];\X\0A                        smaller := cskhole\\solid_with_stepped_round_hole.segment_radii[j];\X\0A                 END;\X\0A               END_IF;\X\0A               IF ((cskhole.conical_transitions[i].cone_base_radius > larger) OR\X\0A                   (cskhole.conical_transitions[i].cone_base_radius < smaller))\X\0A               THEN\X\0A                 RETURN(false);\X\0A               END_IF;\X\0A        END;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#28217=EXPRESS_CODE(#11426,('LOCAL\X\0A  sdqir       : SET OF externally_conditioned_data_quality_inspection_result               := [];\X\0A  dir         : SET OF data_quality_inspection_instance_report                             := [];\X\0A  sdiri       : SET OF externally_conditioned_data_quality_inspection_instance_report_item := [];\X\0A  t_type_list : BAG OF STRING                                                              := [];\X\0AEND_LOCAL;\X\0A  sdqir := QUERY(q\X\0A                 <* bag_to_set(USEDIN(ei,\X\0A                                      ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_QUALITY_INSPECTION_RESULT.CRITERION_INSPECTED''))\X\0A                 | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EXTERNALLY_CONDITIONED_DATA_QUALITY_INSPECTION_RESULT'' IN\X\0A                   TYPEOF(q));\X\0A  IF (SIZEOF(sdqir) = 0)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO SIZEOF(sdqir);\X\0A    dir := dir +\X\0A           QUERY(q\X\0A                 <* bag_to_set(USEDIN(sdqir[i],\X\0A                                      ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_QUALITY_INSPECTION_REPORT.INSPECTION_RESULT''))\X\0A                 | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_QUALITY_INSPECTION_INSTANCE_REPORT'' IN\X\0A                   TYPEOF(q));\X\0A  END_REPEAT;\X\0A  IF (SIZEOF(dir) = 0)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO SIZEOF(dir);\X\0A    sdiri := sdiri +\X\0A             QUERY(q\X\0A                   <* dir[i].inspected_instances\X\0A                   | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EXTERNALLY_CONDITIONED_DATA_QUALITY_INSPECTION_INSTANCE_REPORT_ITEM'' IN\X\0A                     TYPEOF(q));\X\0A  END_REPEAT;\X\0A  IF (SIZEOF(sdiri) = 0)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO SIZEOF(sdiri);\X\0A    IF (SIZEOF(sdiri[i].inspected_elements) <> SIZEOF(type_list))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    t_type_list := type_list;\X\0A    REPEAT j := 1 TO SIZEOF(sdiri[i].inspected_elements);\X\0A      REPEAT k := 1 TO SIZEOF(t_type_list);\X\0A        IF (t_type_list[k] IN TYPEOF(sdiri[i].inspected_elements[j]))\X\0A        THEN\X\0A          t_type_list := t_type_list - t_type_list[k];\X\0A          ESCAPE;\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_REPEAT;\X\0A    IF (SIZEOF(t_type_list) > 0)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
