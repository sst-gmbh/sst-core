primitives(input\\csg_solid_2d.tree_root_expression\\boolean_result_2d.first_operand) AND\X\0A                                                               valid_csg_2d_primitives(input\\csg_solid_2d.tree_root_expression\\boolean_result_2d.second_operand));\X\0A    OTHERWISE: RETURN(false);\X\0A  END_CASE;'));
#28101=EXPRESS_CODE(#11396,('LOCAL\X\0A  rep_set                   : SET OF representation := [];\X\0A  parameter_representations : SET OF representation;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(pdf.representation_associations);\X\0A    rep_set := rep_set + pdf.representation_associations[i].used_representation;\X\0A  END_REPEAT;\X\0A  parameter_representations := QUERY(rep\X\0A                                     <* rep_set\X\0A                                     | (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_REPRESENTATION_WITH_PARAMETERS'' IN\X\0A                                        TYPEOF(rep)));\X\0A  IF (SIZEOF(QUERY(srwp\X\0A                   <* parameter_representations\X\0A                   | (SIZEOF(QUERY(i\X\0A                                   <* srwp.items\X\0A                                   | (i.name = ''orientation'') AND\X\0A                                     (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLACEMENT'' IN TYPEOF(i)))) =\X\0A                      1))) <>\X\0A      1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  CASE pdf\\shape_aspect.description OF\X\0A    ''point'' : RETURN(SIZEOF(QUERY(srwp <* parameter_representations | (SIZEOF(srwp.items) = 1))) = 1);\X\0A    ''circle'', ''circular curve'' : RETURN((SIZEOF(QUERY(srwp <* parameter_representations | (SIZEOF(srwp.items) = 2))) =\X\0A                                         1) AND\X\0A                                        (SIZEOF(QUERY(srwp\X\0A                                                      <* parameter_representations\X\0A                                                      | (SIZEOF(QUERY(i\X\0A                                                                      <* srwp.items\X\0A                                                                      | (i.name = ''target diameter'') AND\X\0A                                                                        (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MEASURE_REPRESENTATION_ITEM'',\X\0A                                                                                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE_WITH_UNIT''] *\X\0A                                                                                TYPEOF(i)) =\X\0A                                                                         2))) =\X\0A                                                         1))) =\X\0A                                         1));\X\0A    ''line'' : RETURN(SIZEOF(QUERY(srwp\X\0A                                 <* parameter_representations\X\0A                                 | (SIZEOF(QUERY(i\X\0A                                                 <* srwp.items\X\0A                                                 | (i.name = ''target length'') AND\X\0A                                                   (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MEASURE_REPRESENTATION_ITEM'',\X\0A                                                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE_WITH_UNIT''] *\X\0A                                                           TYPEOF(i)) =\X\0A                                                    2))) =\X\0A                                    1))) =\X\0A                    1);\X\0A    ''rectangle'' : RETURN((SIZEOF(QUERY(srwp <* parameter_representations | (SIZEOF(srwp.items) = 3))) = 1) AND\X\0A                         (SIZEOF(QUERY(srwp\X\0A                                       <* parameter_representations\X\0A                                       | (SIZEOF(QUERY(i\X\0A                                                       <* srwp.items\X\0A                                                       | (i.name = ''target length'') AND\X\0A                                                         (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MEASURE_REPRESENTATION_ITEM'',\X\0A                                                                  ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE_WITH_UNIT''] *\X\0A                                                                 TYPEOF(i)) =\X\0A                                                          2))) =\X\0A                                          1))) =\X\0A                          1) AND\X\0A                         (SIZEOF(QUERY(srwp\X\0A                                       <* parameter_representations\X\0A                                       | (SIZEOF(QUERY(i\X\0A                                                       <* srwp.items\X\0A                                                       | (i.name = ''target width'') AND\X\0A                                                         (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MEASURE_REPRESENTATION_ITEM'',\X\0A                                                                  ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE_WITH_UNIT''] *\X\0A                                                                 TYPEOF(i)) =\X\0A                                                          2))) =\X\0A                                          1))) =\X\0A                          1));\X\0A    OTHERWISE: RETURN(false);\X\0A  END_CASE;'));
