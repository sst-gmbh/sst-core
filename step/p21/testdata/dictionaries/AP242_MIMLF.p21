#27439=EXPRESS_CODE(#11302,('LOCAL\X\0A  val1 : REAL;\X\0A  val2 : REAL;\X\0A  n    : INTEGER;\X\0AEND_LOCAL;\X\0A  IF (plane_pts[1].dim = 2) OR (test_points[1].dim = 2)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  n := SIZEOF(test_points);\X\0A  val1 := above_plane(plane_pts[1], plane_pts[2], plane_pts[3], test_points[1]);\X\0A  REPEAT i := 2 TO n;\X\0A    val2 := above_plane(plane_pts[1], plane_pts[2], plane_pts[3], test_points[i]);\X\0A    IF (val1 * val2 <= 0.0)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
