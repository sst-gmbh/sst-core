#28837=EXPRESS_CODE(#11556,('LOCAL\X\0A  ds   : SET OF datum_system := [];\X\0A  sa   : SET OF shape_aspect := [];\X\0A  pass : BOOLEAN             := true;\X\0AEND_LOCAL;\X\0A  REPEAT ii := 1 TO SIZEOF(product_definition_shape)\X\0A  WHILE pass;\X\0A    sa := bag_to_set(USEDIN(product_definition_shape[ii],\X\0A                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_ASPECT.OF_SHAPE''));\X\0A    REPEAT iii := 1 TO SIZEOF(sa)\X\0A    WHILE pass;\X\0A      ds := QUERY(ds <* sa | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATUM_SYSTEM'' IN TYPEOF(ds));\X\0A      REPEAT i := 1 TO SIZEOF(ds);\X\0A        REPEAT j := 1 TO SIZEOF(ds);\X\0A          IF (i <> j)\X\0A          THEN\X\0A            IF ds[i]\\datum_system.constituents = ds[j]\\datum_system.constituents\X\0A            THEN\X\0A              pass := false;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A      END_REPEAT;\X\0A    END_REPEAT;\X\0A  END_REPEAT;'));
