#28374=EXPRESS_CODE(#11444,('LOCAL\X\0A  e_prefix  : STRING        := ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.'';\X\0A  typenames : SET OF STRING := TYPEOF(expr);\X\0AEND_LOCAL;\X\0A  IF (schema_prefix + ''MATHS_VARIABLE'') IN typenames\X\0A  THEN\X\0A    RETURN(expr\\maths_variable.values_space);\X\0A  END_IF;\X\0A  IF (e_prefix + ''EXPRESSION'') IN typenames\X\0A  THEN\X\0A    IF (e_prefix + ''NUMERIC_EXPRESSION'') IN typenames\X\0A    THEN\X\0A      IF expr\\numeric_expression.is_int\X\0A      THEN\X\0A        IF (e_prefix + ''INT_LITERAL'') IN typenames\X\0A        THEN\X\0A          RETURN(make_finite_space([expr\\int_literal.the_value]));\X\0A        ELSE\X\0A          RETURN(the_integers);\X\0A        END_IF;\X\0A      ELSE\X\0A        IF (e_prefix + ''REAL_LITERAL'') IN typenames\X\0A        THEN\X\0A          RETURN(make_finite_space([expr\\real_literal.the_value]));\X\0A        ELSE\X\0A          RETURN(the_reals);\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (e_prefix + ''BOOLEAN_EXPRESSION'') IN typenames\X\0A    THEN\X\0A      IF (e_prefix + ''BOOLEAN_LITERAL'') IN typenames\X\0A      THEN\X\0A        RETURN(make_finite_space([expr\\boolean_literal.the_value]));\X\0A      ELSE\X\0A        RETURN(the_booleans);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (e_prefix + ''STRING_EXPRESSION'') IN typenames\X\0A    THEN\X\0A      IF (e_prefix + ''STRING_LITERAL'') IN typenames\X\0A      THEN\X\0A        RETURN(make_finite_space([expr\\string_literal.the_value]));\X\0A      ELSE\X\0A        RETURN(the_strings);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''MATHS_FUNCTION'') IN typenames\X\0A  THEN\X\0A    IF expression_is_constant(expr)\X\0A    THEN\X\0A      RETURN(make_finite_space([expr]));\X\0A    ELSE\X\0A      RETURN(make_function_space(sc_equal, expr\\maths_function.domain, sc_equal, expr\\maths_function.range));\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (schema_prefix + ''FUNCTION_APPLICATION'') IN typenames\X\0A  THEN\X\0A    RETURN(expr\\function_application.func.range);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''MATHS_SPACE'') IN typenames\X\0A  THEN\X\0A    IF expression_is_constant(expr)\X\0A    THEN\X\0A      RETURN(make_finite_space([expr]));\X\0A    ELSE\X\0A      RETURN(make_elementary_space(es_maths_spaces));\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (schema_prefix + ''DEPENDENT_VARIABLE_DEFINITION'') IN typenames\X\0A  THEN\X\0A    RETURN(values_space_of(expr\\unary_generic_expression.operand));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''COMPLEX_NUMBER_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''LOGICAL_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\logical_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''BINARY_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\binary_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''MATHS_ENUM_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\maths_enum_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''REAL_TUPLE_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\real_tuple_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''INTEGER_TUPLE_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\integer_tuple_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''ATOM_BASED_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\atom_based_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''MATHS_TUPLE_LITERAL'') IN typenames\X\0A  THEN\X\0A    RETURN(make_finite_space([expr\\maths_tuple_literal.lit_value]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''PARTIAL_DERIVATIVE_EXPRESSION'') IN typenames\X\0A  THEN\X\0A    RETURN(drop_numeric_constraints(values_space_of(expr\\partial_derivative_expression.derivand)));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''DEFINITE_INTEGRAL_EXPRESSION'') IN typenames\X\0A  THEN\X\0A    RETURN(drop_numeric_constraints(values_space_of(expr\\definite_integral_expression.integrand)));\X\0A  END_IF;\X\0A  RETURN(?);'));
#28381=EXPRESS_CODE(#11446,('LOCAL\X\0A  result : vector;\X\0A  res    : direction;\X\0A  vec1   : direction;\X\0A  vec2   : direction;\X\0A  mag    : REAL;\X\0A  mag1   : REAL;\X\0A  mag2   : REAL;\X\0A  ndim   : INTEGER;\X\0AEND_LOCAL;\X\0A  IF ((NOT EXISTS(arg1)) OR (NOT EXISTS(arg2))) OR (arg1.dim <> arg2.dim)\X\0A  THEN\X\0A    RETURN(?);\X\0A  ELSE\X\0A    BEGIN  \X\0A           IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VECTOR'' IN TYPEOF(arg1)\X\0A           THEN\X\0A             mag1 := arg1\\vector.magnitude;\X\0A             vec1 := arg1\\vector.orientation;\X\0A           ELSE\X\0A             mag1 := 1.0;\X\0A             vec1 := arg1;\X\0A           END_IF;\X\0A           IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VECTOR'' IN TYPEOF(arg2)\X\0A           THEN\X\0A             mag2 := arg2\\vector.magnitude;\X\0A             vec2 := arg2\\vector.orientation;\X\0A           ELSE\X\0A             mag2 := 1.0;\X\0A             vec2 := arg2;\X\0A           END_IF;\X\0A           vec1 := normalise(vec1);\X\0A           vec2 := normalise(vec2);\X\0A           ndim := SIZEOF(vec1.direction_ratios);\X\0A           mag := 0.0;\X\0A           res := dummy_gri || direction(vec1.direction_ratios);\X\0A           REPEAT i := 1 TO ndim;\X\0A             res.direction_ratios[i] := mag1 * vec1.direction_ratios[i] - mag2 * vec2.direction_ratios[i];\X\0A             mag := mag + (res.direction_ratios[i] * res.direction_ratios[i]);\X\0A           END_REPEAT;\X\0A           IF (mag > 0.0)\X\0A           THEN\X\0A             result := dummy_gri || vector(res, SQRT(mag));\X\0A           ELSE\X\0A             result := dummy_gri || vector(vec1, 0.0);\X\0A           END_IF;\X\0A    END;\X\0A  END_IF;\X\0A  RETURN(result);'));
#28392=EXPRESS_CODE(#28391,('ndim'));
#28395=EXPRESS_CODE(#11448,('LOCAL\X\0A  result : BOOLEAN := true;\X\0AEND_LOCAL;\X\0A  REPEAT i := 0 TO b.u_upper;\X\0A    REPEAT j := 0 TO b.v_upper;\X\0A      REPEAT k := 0 TO b.w_upper;\X\0A        IF (b.weights[i][j][k] <= 0.0)\X\0A        THEN\X\0A          result := false;\X\0A          RETURN(result);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
