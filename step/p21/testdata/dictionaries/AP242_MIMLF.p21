#25517=EXPRESS_CODE(#10934,('LOCAL\X\0A  result : BOOLEAN := true;\X\0A  k      : INTEGER;\X\0A  sum    : INTEGER;\X\0AEND_LOCAL;\X\0A  (* Find sum of knot multiplicities. *)\X\0A  sum := knot_mult[1];\X\0A  REPEAT i := 2 TO up_knots;\X\0A    sum := sum + knot_mult[i];\X\0A  END_REPEAT;\X\0A  (* Check limits holding for all B-spline parametrisations *)\X\0A  IF (degree < 1) OR (up_knots < 2) OR (up_cp < degree) OR (sum <> (degree + up_cp + 2))\X\0A  THEN\X\0A    result := false;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  k := knot_mult[1];\X\0A  IF (k < 1) OR (k > degree + 1)\X\0A  THEN\X\0A    result := false;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  REPEAT i := 2 TO up_knots;\X\0A    IF (knot_mult[i] < 1) OR (knots[i] <= knots[i - 1])\X\0A    THEN\X\0A      result := false;\X\0A      RETURN(result);\X\0A    END_IF;\X\0A    k := knot_mult[i];\X\0A    IF (i < up_knots) AND (k > degree)\X\0A    THEN\X\0A      result := false;\X\0A      RETURN(result);\X\0A    END_IF;\X\0A    IF (i = up_knots) AND (k > degree + 1)\X\0A    THEN\X\0A      result := false;\X\0A      RETURN(result);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
#25523=EXPRESS_CODE(#25522,('up_knots'));
#25526=EXPRESS_CODE(#25525,('up_knots'));
#25537=EXPRESS_CODE(#10936,('LOCAL\X\0A  result   : BOOLEAN := true;\X\0A  k        : INTEGER;\X\0A  up_knots : INTEGER;\X\0A  sum      : INTEGER;\X\0AEND_LOCAL;\X\0A  (* Find sum of knot multiplicities. *)\X\0A  up_knots := SIZEOF(knots);\X\0A  sum := knot_mult[1];\X\0A  REPEAT i := 2 TO up_knots;\X\0A    sum := sum + knot_mult[i];\X\0A  END_REPEAT;\X\0A  (* Check limits holding for all B-spline parametrisations *)\X\0A  IF (degree < 1) OR (up_knots < 2) OR (sum <> (degree + 2))\X\0A  THEN\X\0A    result := false;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  k := knot_mult[1];\X\0A  IF (k < 1) OR (k > degree + 1)\X\0A  THEN\X\0A    result := false;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  (* first pointer shall be 1 or more *)\X\0A  IF (knots[1] < 1)\X\0A  THEN\X\0A    result := false;\X\0A  END_IF;\X\0A  REPEAT i := 2 TO up_knots;\X\0A    IF (knot_mult[i] < 1) OR (knots[i] <= knots[i - 1])\X\0A    THEN\X\0A      result := false;\X\0A      RETURN(result);\X\0A    END_IF;\X\0A    k := knot_mult[i];\X\0A    IF (i < up_knots) AND (k > degree)\X\0A    THEN\X\0A      result := false;\X\0A      RETURN(result);\X\0A    END_IF;\X\0A    IF (i = up_knots) AND (k > degree + 1)\X\0A    THEN\X\0A      result := false;\X\0A      RETURN(result);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
