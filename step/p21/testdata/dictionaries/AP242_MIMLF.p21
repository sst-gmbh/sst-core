#27449=EXPRESS_CODE(#11304,('LOCAL\X\0A  v      : direction;\X\0A  mag    : REAL;\X\0A  result : vector;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(scalar) OR NOT EXISTS(vec)\X\0A  THEN\X\0A    RETURN(?);\X\0A  ELSE\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VECTOR'' IN TYPEOF(vec)\X\0A    THEN\X\0A      v := dummy_gri || direction(vec\\vector.orientation.direction_ratios);\X\0A      mag := scalar * vec\\vector.magnitude;\X\0A    ELSE\X\0A      v := dummy_gri || direction(vec.direction_ratios);\X\0A      mag := scalar;\X\0A    END_IF;\X\0A    IF (mag < 0.0)\X\0A    THEN\X\0A      REPEAT i := 1 TO SIZEOF(v.direction_ratios);\X\0A        v.direction_ratios[i] := -v.direction_ratios[i];\X\0A      END_REPEAT;\X\0A      mag := -mag;\X\0A    END_IF;\X\0A    result := dummy_gri || vector(normalise(v), mag);\X\0A  END_IF;\X\0A  RETURN(result);'));
#27459=EXPRESS_CODE(#11306,('LOCAL\X\0A  y_axis : vector;\X\0A  v      : direction;\X\0A  temp   : vector;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(arg)\X\0A  THEN\X\0A    v := dummy_gri || direction([0.0,1.0,0.0]);\X\0A  ELSE\X\0A    v := arg;\X\0A  END_IF;\X\0A  temp := scalar_times_vector(dot_product(v, z_axis), z_axis);\X\0A  y_axis := vector_difference(v, temp);\X\0A  temp := scalar_times_vector(dot_product(v, x_axis), x_axis);\X\0A  y_axis := vector_difference(y_axis, temp);\X\0A  y_axis := normalise(y_axis);\X\0A  RETURN(y_axis.orientation);'));
#27465=EXPRESS_CODE(#11308,('LOCAL\X\0A  the_reverse : set_of_reversible_topology_item;\X\0AEND_LOCAL;\X\0A  the_reverse := [];\X\0A  REPEAT i := 1 TO SIZEOF(a_set);\X\0A    the_reverse := the_reverse + topology_reversed(a_set[i]);\X\0A  END_REPEAT;\X\0A  RETURN(the_reverse);'));
#27474=EXPRESS_CODE(#11310,('LOCAL\X\0A  tspace : tuple_space;\X\0A  temp   : maths_space;\X\0A  result : LIST OF positive_integer := [];\X\0AEND_LOCAL;\X\0A  IF (schema_prefix + ''EXPLICIT_TABLE_FUNCTION'') IN TYPEOF(func)\X\0A  THEN\X\0A    RETURN(func\\explicit_table_function.shape);\X\0A  END_IF;\X\0A  tspace := func.domain;\X\0A  IF (space_dimension(tspace) = 1) AND ((schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(factor1(tspace)))\X\0A  THEN\X\0A    tspace := factor1(tspace);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO space_dimension(tspace);\X\0A    temp := factor_space(tspace, i);\X\0A    IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp))\X\0A    THEN\X\0A      RETURN(?);\X\0A    END_IF;\X\0A    INSERT(result, temp\\finite_integer_interval.size, i - 1);\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
#27483=EXPRESS_CODE(#27482,('space_dimension(tspace)'));
#27486=EXPRESS_CODE(#11312,('IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OPEN_SHELL'' IN TYPEOF(a_shell))\X\0A  THEN\X\0A    RETURN(open_shell_reversed(a_shell));\X\0A  ELSE\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CLOSED_SHELL'' IN TYPEOF(a_shell))\X\0A    THEN\X\0A      RETURN(closed_shell_reversed(a_shell));\X\0A    ELSE\X\0A      RETURN(?);\X\0A    END_IF;\X\0A  END_IF;'));
#27489=EXPRESS_CODE(#11314,('FUNCTION ctmv(x : GENERIC : G) : maths_value;\X\0A  RETURN(convert_to_maths_value(x));\X\0AEND_FUNCTION;\X\0APROCEDURE parts(c : complex_number_literal; VAR x : REAL; VAR y : REAL);\X\0A  x := c.real_part;\X\0A  y := c.imag_part;\X\0AEND_PROCEDURE;\X\0AFUNCTION makec(x : REAL;\X\0A               y : REAL) : complex_number_literal;\X\0A  RETURN(make_complex_number_literal(x, y));\X\0AEND_FUNCTION;\X\0AFUNCTION good_t(v : maths_value;\X\0A                tn : STRING) : BOOLEAN;\X\0ALOCAL\X\0A  tpl : LIST OF maths_value;\X\0AEND_LOCAL;\X\0A  IF ''LIST'' IN TYPEOF(v)\X\0A  THEN\X\0A    tpl := v;\X\0A    REPEAT i := 1 TO SIZEOF(tpl);\X\0A      IF NOT (tn IN TYPEOF(tpl[i]))\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);\X\0AEND_FUNCTION;\X\0A\X\0ACONSTANT\X\0A  cnlit : STRING := schema_prefix + ''COMPLEX_NUMBER_LITERAL'';\X\0AEND_CONSTANT;\X\0ALOCAL\X\0A  types         : SET OF STRING                              := stripped_typeof(expr.func);\X\0A  ef_val        : elementary_function_enumerators;\X\0A  is_elementary : BOOLEAN                                    := false;\X\0A  v             : maths_value;\X\0A  v1            : maths_value;\X\0A  v2            : maths_value;\X\0A  v3            : maths_value;\X\0A  vlist         : LIST OF maths_value                        := [];\X\0A  gexpr         : generic_expression;\X\0A  pairs         : SET [1 : ?] OF LIST [2 : 2] OF maths_value;\X\0A  boo           : BOOLEAN;\X\0A  lgc           : LOGICAL;\X\0A  cum           : LOGICAL;\X\0A  j             : INTEGER;\X\0A  k             : INTEGER;\X\0A  n             : INTEGER;\X\0A  p             : REAL;\X\0A  q             : REAL;\X\0A  r             : REAL;\X\0A  s             : REAL;\X\0A  t             : REAL;\X\0A  u             : REAL;\X\0A  str           : STRING;\X\0A  st2           : STRING;\X\0A  bin           : BINARY;\X\0A  bi2           : BINARY;\X\0A  tpl           : LIST OF maths_value;\X\0A  tp2           : LIST OF maths_value;\X\0A  mem           : SET OF maths_value                         := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(expr.arguments);\X\0A    v := simplify_maths_value(expr.arguments[i]);\X\0A    INSERT(vlist, v, i - 1);\X\0A  END_REPEAT;\X\0A  IF SIZEOF(vlist) >= 1\X\0A  THEN\X\0A    v1 := vlist[1];\X\0A  END_IF;\X\0A  IF SIZEOF(vlist) >= 2\X\0A  THEN\X\0A    v2 := vlist[2];\X\0A  END_IF;\X\0A  IF SIZEOF(vlist) >= 3\X\0A  THEN\X\0A    v3 := vlist[3];\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_FUNCTION_ENUMERATORS'' IN types\X\0A  THEN\X\0A    ef_val := expr.func;\X\0A    is_elementary := true;\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_FUNCTION'' IN types\X\0A  THEN\X\0A    ef_val := expr.func\\elementary_function.func_id;\X\0A    is_elementary := true;\X\0A  END_IF;\X\0A  IF is_elementary\X\0A  THEN\X\0A    CASE ef_val OF\X\0A      ef_and : BEGIN  \X\0A                      cum := true;\X\0A                      REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                        IF ''LOGICAL'' IN TYPEOF(vlist[i])\X\0A                        THEN\X\0A                          lgc := vlist[i];\X\0A                          cum := cum AND lgc;\X\0A                          IF lgc = false\X\0A                          THEN\X\0A                            RETURN(ctmv(false));\X\0A                          END_IF;\X\0A                          REMOVE(vlist, i);\X\0A                        END_IF;\X\0A                      END_REPEAT;\X\0A                      IF SIZEOF(vlist) = 0\X\0A                      THEN\X\0A                        RETURN(ctmv(cum));\X\0A                      END_IF;\X\0A                      IF cum <> true\X\0A                      THEN\X\0A                        INSERT(vlist, ctmv(cum), 0);\X\0A                      END_IF;\X\0A                      IF SIZEOF(vlist) = 1\X\0A                      THEN\X\0A                        RETURN(vlist[1]);\X\0A                      END_IF;\X\0A      END;\X\0A      ef_or : BEGIN  \X\0A                     cum := false;\X\0A                     REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                       IF ''LOGICAL'' IN TYPEOF(vlist[i])\X\0A                       THEN\X\0A                         lgc := vlist[i];\X\0A                         cum := cum OR lgc;\X\0A                         IF lgc = true\X\0A                         THEN\X\0A                           RETURN(ctmv(true));\X\0A                         END_IF;\X\0A                         REMOVE(vlist, i);\X\0A                       END_IF;\X\0A                     END_REPEAT;\X\0A                     IF SIZEOF(vlist) = 0\X\0A                     THEN\X\0A                       RETURN(ctmv(cum));\X\0A                     END_IF;\X\0A                     IF cum <> false\X\0A                     THEN\X\0A                       INSERT(vlist, ctmv(cum), 0);\X\0A                     END_IF;\X\0A                     IF SIZEOF(vlist) = 1\X\0A                     THEN\X\0A                       RETURN(vlist[1]);\X\0A                     END_IF;\X\0A      END;\X\0A      ef_not : IF ''LOGICAL'' IN TYPEOF(v1)\X\0A      THEN\X\0A        lgc := v1;\X\0A        RETURN(ctmv(NOT lgc));\X\0A      END_IF;\X\0A      ef_xor : BEGIN  \X\0A                      IF ''LOGICAL'' IN TYPEOF(v1)\X\0A                      THEN\X\0A                        lgc := v1;\X\0A                        IF ''LOGICAL'' IN TYPEOF(v2)\X\0A                        THEN\X\0A                          cum := v2;\X\0A                          RETURN(ctmv(lgc XOR cum));\X\0A                        ELSE\X\0A                          IF lgc = false\X\0A                          THEN\X\0A                            RETURN(ctmv(v2));\X\0A                          ELSE\X\0A                            IF lgc = unknown\X\0A                            THEN\X\0A                              RETURN(ctmv(unknown));\X\0A                            ELSE\X\0A                              RETURN(make_function_application(ef_not, [v2]));\X\0A                            END_IF;\X\0A                          END_IF;\X\0A                        END_IF;\X\0A                      ELSE\X\0A                        IF ''LOGICAL'' IN TYPEOF(v2)\X\0A                        THEN\X\0A                          lgc := v2;\X\0A                          IF lgc = false\X\0A                          THEN\X\0A                            RETURN(ctmv(v1));\X\0A                          ELSE\X\0A                            IF lgc = unknown\X\0A                            THEN\X\0A                              RETURN(ctmv(unknown));\X\0A                            ELSE\X\0A                              RETURN(make_function_application(ef_not, [v1]));\X\0A                            END_IF;\X\0A                          END_IF;\X\0A                        END_IF;\X\0A                      END_IF;\X\0A      END;\X\0A      ef_negate_i : IF ''INTEGER'' IN TYPEOF(v1)\X\0A      THEN\X\0A        j := v1;\X\0A        RETURN(ctmv(-j));\X\0A      END_IF;\X\0A      ef_add_i : BEGIN  \X\0A                        j := 0;\X\0A                        REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                          IF ''INTEGER'' IN TYPEOF(vlist[i])\X\0A                          THEN\X\0A                            k := vlist[i];\X\0A                            j := j + k;\X\0A                            REMOVE(vlist, i);\X\0A                          END_IF;\X\0A                        END_REPEAT;\X\0A                        IF SIZEOF(vlist) = 0\X\0A                        THEN\X\0A                          RETURN(ctmv(j));\X\0A                        END_IF;\X\0A                        IF j <> 0\X\0A                        THEN\X\0A                          INSERT(vlist, ctmv(j), 0);\X\0A                        END_IF;\X\0A                        IF SIZEOF(vlist) = 1\X\0A                        THEN\X\0A                          RETURN(vlist[1]);\X\0A                        END_IF;\X\0A      END;\X\0A      ef_subtract_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j - k));\X\0A      END_IF;\X\0A      ef_multiply_i : BEGIN  \X\0A                             j := 1;\X\0A                             REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                               IF ''INTEGER'' IN TYPEOF(vlist[i])\X\0A                               THEN\X\0A                                 k := vlist[i];\X\0A                                 j := j * k;\X\0A                                 REMOVE(vlist, i);\X\0A                               END_IF;\X\0A                             END_REPEAT;\X\0A                             IF SIZEOF(vlist) = 0\X\0A                             THEN\X\0A                               RETURN(ctmv(j));\X\0A                             END_IF;\X\0A                             IF j <> 1\X\0A                             THEN\X\0A                               INSERT(vlist, ctmv(j), 0);\X\0A                             END_IF;\X\0A                             IF SIZEOF(vlist) = 1\X\0A                             THEN\X\0A                               RETURN(vlist[1]);\X\0A                             END_IF;\X\0A      END;\X\0A      ef_divide_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j DIV k));\X\0A      END_IF;\X\0A      ef_mod_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j MOD k));\X\0A      END_IF;\X\0A      ef_exponentiate_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        n := 1;\X\0A        REPEAT i := 1 TO ABS(k);\X\0A          n := n * j;\X\0A        END_REPEAT;\X\0A        IF k < 0\X\0A        THEN\X\0A          n := 1 DIV n;\X\0A        END_IF;\X\0A        RETURN(ctmv(n));\X\0A      END_IF;\X\0A      ef_eq_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j = k));\X\0A      END_IF;\X\0A      ef_ne_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j <> k));\X\0A      END_IF;\X\0A      ef_gt_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j > k));\X\0A      END_IF;\X\0A      ef_lt_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j < k));\X\0A      END_IF;\X\0A      ef_ge_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j >= k));\X\0A      END_IF;\X\0A      ef_le_i : IF (''INTEGER'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        j := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(j <= k));\X\0A      END_IF;\X\0A      ef_abs_i : IF ''INTEGER'' IN TYPEOF(v1)\X\0A      THEN\X\0A        j := v1;\X\0A        RETURN(ctmv(ABS(j)));\X\0A      END_IF;\X\0A      ef_max_i : BEGIN  \X\0A                        boo := false;\X\0A                        REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                          IF ''INTEGER'' IN TYPEOF(vlist[i])\X\0A                          THEN\X\0A                            IF boo\X\0A                            THEN\X\0A                              k := vlist[i];\X\0A                              IF k > j\X\0A                              THEN\X\0A                                j := k;\X\0A                              END_IF;\X\0A                            ELSE\X\0A                              j := vlist[i];\X\0A                              boo := true;\X\0A                            END_IF;\X\0A                            REMOVE(vlist, i);\X\0A                          END_IF;\X\0A                        END_REPEAT;\X\0A                        IF SIZEOF(vlist) = 0\X\0A                        THEN\X\0A                          RETURN(ctmv(j));\X\0A                        END_IF;\X\0A                        IF boo\X\0A                        THEN\X\0A                          INSERT(vlist, ctmv(j), 0);\X\0A                        END_IF;\X\0A                        IF SIZEOF(vlist) = 1\X\0A                        THEN\X\0A                          RETURN(vlist[1]);\X\0A                        END_IF;\X\0A      END;\X\0A      ef_min_i : BEGIN  \X\0A                        boo := false;\X\0A                        REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                          IF ''INTEGER'' IN TYPEOF(vlist[i])\X\0A                          THEN\X\0A                            IF boo\X\0A                            THEN\X\0A                              k := vlist[i];\X\0A                              IF k < j\X\0A                              THEN\X\0A                                j := k;\X\0A                              END_IF;\X\0A                            ELSE\X\0A                              j := vlist[i];\X\0A                              boo := true;\X\0A                            END_IF;\X\0A                            REMOVE(vlist, i);\X\0A                          END_IF;\X\0A                        END_REPEAT;\X\0A                        IF SIZEOF(vlist) = 0\X\0A                        THEN\X\0A                          RETURN(ctmv(j));\X\0A                        END_IF;\X\0A                        IF boo\X\0A                        THEN\X\0A                          INSERT(vlist, ctmv(j), 0);\X\0A                        END_IF;\X\0A                        IF SIZEOF(vlist) = 1\X\0A                        THEN\X\0A                          RETURN(vlist[1]);\X\0A                        END_IF;\X\0A      END;\X\0A      ef_negate_r : IF ''REAL'' IN TYPEOF(v1)\X\0A      THEN\X\0A        r := v1;\X\0A        RETURN(ctmv(-r));\X\0A      END_IF;\X\0A      ef_reciprocal_r : IF ''REAL'' IN TYPEOF(v1)\X\0A      THEN\X\0A        r := v1;\X\0A        RETURN(ctmv(1.0 / r));\X\0A      END_IF;\X\0A      ef_add_r : BEGIN  \X\0A                        r := 0.0;\X\0A                        REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                          IF ''REAL'' IN TYPEOF(vlist[i])\X\0A                          THEN\X\0A                            s := vlist[i];\X\0A                            r := r + s;\X\0A                            REMOVE(vlist, i);\X\0A                          END_IF;\X\0A                        END_REPEAT;\X\0A                        IF SIZEOF(vlist) = 0\X\0A                        THEN\X\0A                          RETURN(ctmv(r));\X\0A                        END_IF;\X\0A                        IF r <> 0.0\X\0A                        THEN\X\0A                          INSERT(vlist, ctmv(r), 0);\X\0A                        END_IF;\X\0A                        IF SIZEOF(vlist) = 1\X\0A                        THEN\X\0A                          RETURN(vlist[1]);\X\0A                        END_IF;\X\0A      END;\X\0A      ef_subtract_r : IF (''REAL'' IN TYPEOF(v1)) AND (''REAL'' IN TYPEOF(v2))\X\0A      THEN\X\0A        r := v1;\X\0A        s := v2;\X\0A        RETURN(ctmv(r - s));\X\0A      END_IF;\X\0A      ef_multiply_r : BEGIN  \X\0A                             r := 1.0;\X\0A                             REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                               IF ''REAL'' IN TYPEOF(vlist[i])\X\0A                               THEN\X\0A                                 s := vlist[i];\X\0A                                 r := r * s;\X\0A                                 REMOVE(vlist, i);\X\0A                               END_IF;\X\0A                             END_REPEAT;\X\0A                             IF SIZEOF(vlist) = 0\X\0A 