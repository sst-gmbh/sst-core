#26808=EXPRESS_CODE(#11164,('LOCAL\X\0A  result : LIST OF maths_value := [];\X\0A  j      : INTEGER             := 0;\X\0AEND_LOCAL;\X\0A  REPEAT i := LOINDEX(aggr) TO HIINDEX(aggr);\X\0A    IF k <= SIZEOF(aggr[i])\X\0A    THEN\X\0A      INSERT(result, aggr[i][k], j);\X\0A      j := j + 1;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
