#26256=EXPRESS_CODE(#11070,('LOCAL\X\0A  local_relation  : SET OF assembly_component_usage := [];\X\0A  local_relation2 : BAG OF assembly_component_usage := [];\X\0A  local_parent    : SET OF product_definition       := [];\X\0A  root            : SET OF product_definition;\X\0A  i               : INTEGER                         := 0;\X\0A  j               : INTEGER                         := 0;\X\0AEND_LOCAL;\X\0A  IF ((SIZEOF(constituent) = 1) AND assembly_root(constituent[1]))\X\0A  THEN\X\0A    RETURN([constituent[1]]);\X\0A  ELSE\X\0A    IF (SIZEOF(constituent) = 0)\X\0A    THEN\X\0A      RETURN([]);\X\0A    ELSE\X\0A      REPEAT j := 1 TO HIINDEX(constituent);\X\0A        local_relation2 := local_relation2 +\X\0A                           QUERY(pdr\X\0A                                 <* USEDIN(constituent[j],\X\0A                                           ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_RELATIONSHIP.RELATED_PRODUCT_DEFINITION'')\X\0A                                 | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ASSEMBLY_COMPONENT_USAGE'' IN\X\0A                                   TYPEOF(pdr));\X\0A      END_REPEAT;\X\0A      local_relation := bag_to_set(local_relation2);\X\0A      IF (SIZEOF(local_relation) = 0)\X\0A      THEN\X\0A        IF (SIZEOF(constituent) = 1)\X\0A        THEN\X\0A          RETURN([constituent[1]]);\X\0A        ELSE\X\0A          RETURN([]);\X\0A        END_IF;\X\0A      ELSE\X\0A        REPEAT i := 1 TO HIINDEX(local_relation);\X\0A          REPEAT j := 1 TO HIINDEX(constituent);\X\0A            IF (local_relation[i].relating_product_definition <> constituent[j])\X\0A            THEN\X\0A              local_parent := local_parent + local_relation[i].relating_product_definition;\X\0A            END_IF;\X\0A          END_REPEAT;\X\0A        END_REPEAT;\X\0A        IF ((SIZEOF(local_parent) = 1) AND assembly_root(local_parent[1]))\X\0A        THEN\X\0A          RETURN([local_parent[1]]);\X\0A        ELSE\X\0A          IF (SIZEOF(local_parent) = 0)\X\0A          THEN\X\0A            RETURN([]);\X\0A          ELSE\X\0A            root := find_assembly_root(local_parent);\X\0A            IF (SIZEOF(root) = 1)\X\0A            THEN\X\0A              RETURN(root);\X\0A            ELSE\X\0A              IF (SIZEOF(root) = 0)\X\0A              THEN\X\0A                RETURN([]);\X\0A              END_IF;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN([]);'));
