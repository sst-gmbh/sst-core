#27852=EXPRESS_CODE(#11358,('LOCAL\X\0A  types : SET OF STRING := stripped_typeof(spc);\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(spc) OR NOT EXISTS(es)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_SPACE'' IN types\X\0A  THEN\X\0A    RETURN(es_subspace_of_es(spc\\elementary_space.space_id, es));\X\0A  END_IF;\X\0A  IF ''FINITE_SPACE'' IN types\X\0A  THEN\X\0A    RETURN(all_members_of_es(spc\\finite_space.members, es));\X\0A  END_IF;\X\0A  CASE es OF\X\0A    es_numbers : RETURN((''FINITE_INTEGER_INTERVAL'' IN types) OR (''INTEGER_INTERVAL_FROM_MIN'' IN types) OR\X\0A                        (''INTEGER_INTERVAL_TO_MAX'' IN types) OR (''FINITE_REAL_INTERVAL'' IN types) OR\X\0A                        (''REAL_INTERVAL_FROM_MIN'' IN types) OR (''REAL_INTERVAL_TO_MAX'' IN types) OR\X\0A                        (''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types) OR (''POLAR_COMPLEX_NUMBER_REGION'' IN types));\X\0A    es_complex_numbers : RETURN((''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types) OR\X\0A                                (''POLAR_COMPLEX_NUMBER_REGION'' IN types));\X\0A    es_reals : RETURN((''FINITE_REAL_INTERVAL'' IN types) OR (''REAL_INTERVAL_FROM_MIN'' IN types) OR\X\0A                      (''REAL_INTERVAL_TO_MAX'' IN types));\X\0A    es_integers : RETURN((''FINITE_INTEGER_INTERVAL'' IN types) OR (''INTEGER_INTERVAL_FROM_MIN'' IN types) OR\X\0A                         (''INTEGER_INTERVAL_TO_MAX'' IN types));\X\0A    es_logicals : RETURN(false);\X\0A    es_booleans : RETURN(false);\X\0A    es_strings : RETURN(false);\X\0A    es_binarys : RETURN(false);\X\0A    es_maths_spaces : RETURN(false);\X\0A    es_maths_functions : RETURN(''FUNCTION_SPACE'' IN types);\X\0A    es_generics : RETURN(true);\X\0A  END_CASE;\X\0A  RETURN(unknown);'));
#27865=EXPRESS_CODE(#11360,('LOCAL\X\0A  types  : SET OF STRING                  := stripped_typeof(expr);\X\0A  opnds  : LIST OF generic_expression;\X\0A  op1    : generic_expression;\X\0A  op2    : generic_expression;\X\0A  qvars  : LIST OF generic_variable;\X\0A  srcdom : maths_space_or_function;\X\0A  prpfun : LIST [1 : ?] OF maths_function;\X\0A  finfun : maths_function_select;\X\0AEND_LOCAL;\X\0A  IF SIZEOF(vars) <> SIZEOF(vals)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  IF ''GENERIC_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(expr);\X\0A  END_IF;\X\0A  IF ''GENERIC_VARIABLE'' IN types\X\0A  THEN\X\0A    REPEAT i := 1 TO SIZEOF(vars);\X\0A      IF expr :=: vars[i]\X\0A      THEN\X\0A        RETURN(vals[i]);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(expr);\X\0A  END_IF;\X\0A  IF ''QUANTIFIER_EXPRESSION'' IN types\X\0A  THEN\X\0A    qvars := expr\\quantifier_expression.variables;\X\0A    REPEAT i := SIZEOF(vars) TO 1 BY -1;\X\0A      IF vars[i] IN qvars\X\0A      THEN\X\0A        REMOVE(vars, i);\X\0A        REMOVE(vals, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    opnds := expr\\multiple_arity_generic_expression.operands;\X\0A    REPEAT i := 1 TO SIZEOF(opnds);\X\0A      IF NOT (opnds[i] IN qvars)\X\0A      THEN\X\0A        expr\\multiple_arity_generic_expression.operands[i] := substitute(opnds[i], vars, vals);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(expr);\X\0A  END_IF;\X\0A  IF ''UNARY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    op1 := expr\\unary_generic_expression.operand;\X\0A    expr\\unary_generic_expression.operand := substitute(op1, vars, vals);\X\0A  END_IF;\X\0A  IF ''BINARY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    op1 := expr\\binary_generic_expression.operands[1];\X\0A    expr\\binary_generic_expression.operands[1] := substitute(op1, vars, vals);\X\0A    op2 := expr\\binary_generic_expression.operands[2];\X\0A    expr\\binary_generic_expression.operands[2] := substitute(op2, vars, vals);\X\0A  END_IF;\X\0A  IF ''PARALLEL_COMPOSED_FUNCTION'' IN types\X\0A  THEN\X\0A    srcdom := expr\\parallel_composed_function.source_of_domain;\X\0A    prpfun := expr\\parallel_composed_function.prep_functions;\X\0A    finfun := expr\\parallel_composed_function.final_function;\X\0A    srcdom := substitute(srcdom, vars, vals);\X\0A    REPEAT i := 1 TO SIZEOF(prpfun);\X\0A      prpfun[i] := substitute(prpfun[i], vars, vals);\X\0A    END_REPEAT;\X\0A    IF ''MATHS_FUNCTION'' IN stripped_typeof(finfun)\X\0A    THEN\X\0A      finfun := substitute(finfun, vars, vals);\X\0A    END_IF;\X\0A    RETURN(make_parallel_composed_function(srcdom, prpfun, finfun));\X\0A  END_IF;\X\0A  IF ''MULTIPLE_ARITY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    opnds := expr\\multiple_arity_generic_expression.operands;\X\0A    REPEAT i := 1 TO SIZEOF(opnds);\X\0A      expr\\multiple_arity_generic_expression.operands[i] := substitute(opnds[i], vars, vals);\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(expr);'));
#27897=EXPRESS_CODE(#11362,('CASE pd.name OF\X\0A    ''visual appearance'', ''tactile appearance'', ''contact ratio'', ''hardness'', ''treatment result'', ''surface texture'' : RETURN(pd.name =\X\0A                                                                                                                           rep.name);\X\0A    OTHERWISE: RETURN(unknown);\X\0A  END_CASE;'));
#27900=EXPRESS_CODE(#11364,('LOCAL\X\0A  result : BOOLEAN := true;\X\0AEND_LOCAL;\X\0A  REPEAT i := 0 TO b.u_upper;\X\0A    REPEAT j := 0 TO b.v_upper;\X\0A      IF (b.weights[i][j] <= 0.0)\X\0A      THEN\X\0A        result := false;\X\0A        RETURN(result);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
