#26527=EXPRESS_CODE(#11112,('LOCAL\X\0A  result : SET OF product_definition_specified_occurrence := input.child_occurrences;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(input.child_occurrences) BY 1;\X\0A    result := result + get_descendant_occurrences(input.child_occurrences[i]);\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
#26536=EXPRESS_CODE(#11114,('LOCAL\X\0A  description_bag : BAG OF description_attribute := (USEDIN(obj,\X\0A                                                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DESCRIPTION_ATTRIBUTE.DESCRIBED_ITEM''));\X\0AEND_LOCAL;\X\0A  IF SIZEOF(description_bag) = 1\X\0A  THEN\X\0A    RETURN(description_bag[1].attribute_value);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#26553=EXPRESS_CODE(#11116,('LOCAL\X\0A  directed_link : LIST OF representation_relationship := [];\X\0AEND_LOCAL;\X\0A  IF (SIZEOF(nodes) <> SIZEOF(undirected_link) + 1) OR (VALUE_UNIQUE(nodes) = false)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO SIZEOF(undirected_link);\X\0A    CASE true OF\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_CONTEXT'' IN TYPEOF(undirected_link[i])) : BEGIN  \X\0A                                                                                                                        IF ((nodes[i]\\representation.context_of_items :=:\X\0A                                                                                                                             undirected_link[i]) AND\X\0A                                                                                                                            (nodes[i +\X\0A                                                                                                                                   1]\\representation.context_of_items :=:\X\0A                                                                                                                             undirected_link[i]))\X\0A                                                                                                                        THEN\X\0A                                                                                                                          INSERT(directed_link,\X\0A                                                                                                                                 representation_relationship('''',\X\0A                                                                                                                                                             '''',\X\0A                                                                                                                                                             nodes[i +\X\0A                                                                                                                                                                   1],\X\0A                                                                                                                                                             nodes[i]),\X\0A                                                                                                                                 (i -\X\0A                                                                                                                                  1));\X\0A                                                                                                                        ELSE\X\0A                                                                                                                          RETURN(?);\X\0A                                                                                                                        END_IF;\X\0A      END;\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_RELATIONSHIP'' IN\X\0A       TYPEOF(undirected_link[i])) : BEGIN  \X\0A                                            IF (((nodes[i] :=:\X\0A                                                  undirected_link[i]\\representation_relationship.rep_1) AND\X\0A                                                 (nodes[i + 1] :=:\X\0A                                                  undirected_link[i]\\representation_relationship.rep_2)) OR\X\0A                                                ((nodes[i] :=:\X\0A                                                  undirected_link[i]\\representation_relationship.rep_2) AND\X\0A                                                 (nodes[i + 1] :=:\X\0A                                                  undirected_link[i]\\representation_relationship.rep_1)))\X\0A                                            THEN\X\0A                                              INSERT(directed_link,\X\0A                                                     representation_relationship('''', '''', nodes[i + 1], nodes[i]),\X\0A                                                     (i - 1));\X\0A                                            ELSE\X\0A                                              RETURN(?);\X\0A                                            END_IF;\X\0A      END;\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MAPPED_ITEM'' IN TYPEOF(undirected_link[i])) : BEGIN  \X\0A                                                                                                             IF ((nodes[i] IN\X\0A                                                                                                                  using_representations(undirected_link[i])) AND\X\0A                                                                                                                 (nodes[i +\X\0A                                                                                                                        1] :=:\X\0A                                                                                                                  undirected_link[i]\\mapped_item.mapping_source\\representation_map.mapped_representation))\X\0A                                                                                                             THEN\X\0A                                                                                                               INSERT(directed_link,\X\0A                                                                                                                      representation_relationship('''',\X\0A                                                                                                                                                  '''',\X\0A                                                                                                                                                  nodes[i +\X\0A                                                                                                                                                        1],\X\0A                                                                                                                                                  nodes[i]),\X\0A                                                                                                                      (i -\X\0A                                                                                                                       1));\X\0A                                                                                                             ELSE\X\0A                                                                                                               RETURN(?);\X\0A                                                                                                             END_IF;\X\0A      END;\X\0A      OTHERWISE: RETURN(?);\X\0A    END_CASE;\X\0A  END_REPEAT;\X\0A  IF (VALUE_UNIQUE(directed_link) = false)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  RETURN(directed_link);'));
#26562=EXPRESS_CODE(#11118,('LOCAL\X\0A  id_bag : BAG OF id_attribute := (USEDIN(obj,\X\0A                                          ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ID_ATTRIBUTE.IDENTIFIED_ITEM''));\X\0AEND_LOCAL;\X\0A  IF SIZEOF(id_bag) = 1\X\0A  THEN\X\0A    RETURN(id_bag[1].attribute_value);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#26575=EXPRESS_CODE(#11120,('LOCAL\X\0A  result : SET OF oriented_joint := [];\X\0AEND_LOCAL;\X\0A  IF SIZEOF(kls) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(kls);\X\0A      result := result + kls[i].edge_list;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(get_kinematic_joints_from_oriented_joints(result));'));
#26590=EXPRESS_CODE(#11122,('LOCAL\X\0A  result : SET OF kinematic_joint := [];\X\0AEND_LOCAL;\X\0A  IF SIZEOF(ors) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(ors);\X\0A      result := result + ors[i].edge_element;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(result);'));
#26599=EXPRESS_CODE(#11124,('LOCAL\X\0A  name_bag : BAG OF name_attribute := (USEDIN(obj,\X\0A                                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.NAME_ATTRIBUTE.NAMED_ITEM''));\X\0AEND_LOCAL;\X\0A  IF SIZEOF(name_bag) = 1\X\0A  THEN\X\0A    RETURN(name_bag[1].attribute_value);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#26606=EXPRESS_CODE(#11126,('LOCAL\X\0A  sb     : sketch_basis_select := ps.sketch_basis;\X\0A  result : plane               := ?;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FACE_SURFACE'' IN TYPEOF(sb))\X\0A  THEN\X\0A    result := sb\\face_surface.face_geometry;\X\0A  ELSE\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_BOUNDED_SURFACE'' IN TYPEOF(sb))\X\0A    THEN\X\0A      result := sb\\curve_bounded_surface.basis_surface;\X\0A    ELSE\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANAR_CURVE_SELECT'' IN TYPEOF(sb))\X\0A      THEN\X\0A        BEGIN  \X\0A               IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'' IN TYPEOF(sb))\X\0A               THEN\X\0A                 result := dummy_gri || surface() || elementary_surface(sb\\conic.position) || plane();\X\0A               END_IF;\X\0A               IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TRIMMED_CURVE'' IN TYPEOF(sb))\X\0A               THEN\X\0A                 BEGIN  \X\0A                        result := get_plane_of_implicit_geometry(dummy_gri ||\X\0A                                                                 positioned_sketch(sb\\trimmed_curve.basis_curve, []));\X\0A                 END;\X\0A               END_IF;\X\0A               IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(sb))\X\0A               THEN\X\0A                 result := sb\\pcurve.basis_surface;\X\0A               END_IF;\X\0A               IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_CURVE'' IN TYPEOF(sb))\X\0A               THEN\X\0A                 BEGIN  \X\0A                        IF ((SIZEOF(sb\\surface_curve.basis_surface) = 1) AND\X\0A                            (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE'' IN\X\0A                             TYPEOF(sb\\surface_curve.basis_surface[1])))\X\0A                        THEN\X\0A                          result := sb\\surface_curve.basis_surface[1];\X\0A                        ELSE\X\0A                          IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE'' IN\X\0A                               TYPEOF(sb\\surface_curve.basis_surface[1])) AND\X\0A                              (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE'' IN\X\0A                               TYPEOF(sb\\surface_curve.basis_surface[2])))\X\0A                          THEN\X\0A                            result := ?;\X\0A                          ELSE\X\0A                            IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE'' IN\X\0A                                TYPEOF(sb\\surface_curve.basis_surface[1]))\X\0A                            THEN\X\0A                              result := sb\\surface_curve.basis_surface[1];\X\0A                            ELSE\X\0A                              result := sb\\surface_curve.basis_surface[2];\X\0A                            END_IF;\X\0A                          END_IF;\X\0A                        END_IF;\X\0A                 END;\X\0A               END_IF;\X\0A        END;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(result);'));
#26614=EXPRESS_CODE(#11128,('LOCAL\X\0A  pd_set  : SET OF property_definition                := [];\X\0A  pdr_set : SET OF property_definition_representation := [];\X\0AEND_LOCAL;\X\0A  pd_set := bag_to_set(USEDIN(c_def_instance,\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION.DEFINITION''));\X\0A  IF (SIZEOF(pd_set) < 1)\X\0A  THEN\X\0A    RETURN(pdr_set);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO HIINDEX(pd_set);\X\0A    pdr_set := pdr_set +\X\0A               bag_to_set(USEDIN(pd_set[i],\X\0A                                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION_REPRESENTATION.DEFINITION''));\X\0A  END_REPEAT;\X\0A  RETURN(pdr_set);'));
#26628=EXPRESS_CODE(#11130,('LOCAL\X\0A  d1        : REAL;\X\0A  d2        : REAL;\X\0A  d3        : REAL;\X\0A  magnitude : REAL;\X\0A  result    : direction := ?;\X\0AEND_LOCAL;\X\0A  IF ((cp1.dim <> 3) OR (cp2.dim <> 3))\X\0A  THEN\X\0A    RETURN(result);\X\0A  ELSE\X\0A    BEGIN  \X\0A           d1 := cp2.coordinates[1] - cp1.coordinates[1];\X\0A           d2 := cp2.coordinates[2] - cp1.coordinates[2];\X\0A           d3 := cp2.coordinates[3] - cp1.coordinates[3];\X\0A           magnitude := SQRT(d1 * d1 + d2 * d2 + d3 * d3);\X\0A           IF (magnitude = 0)\X\0A           THEN\X\0A             RETURN(result);\X\0A           END_IF;\X\0A           result := dummy_gri || direction([d1,d2,d3]);\X\0A    END;\X\0A  END_IF;\X\0A  RETURN(result);'));
#26642=EXPRESS_CODE(#11132,('LOCAL\X\0A  r_set : SET OF representation := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := LOINDEX(input) TO HIINDEX(input);\X\0A    r_set := r_set + using_representations(input[i]);\X\0A  END_REPEAT;\X\0A  RETURN(r_set);'));
#26651=EXPRESS_CODE(#11134,('LOCAL\X\0A  role_bag : BAG OF role_association := (USEDIN(obj,\X\0A                                                ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ROLE_ASSOCIATION.ITEM_WITH_ROLE''));\X\0AEND_LOCAL;\X\0A  IF SIZEOF(role_bag) = 1\X\0A  THEN\X\0A    RETURN(role_bag[1].role);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#26658=EXPRESS_CODE(#11136,('REPEAT WHILE (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONSTITUENT_SHAPE_ASPECT'' IN TYPEOF(current));\X\0A    current := current.parent;\X\0A  END_REPEAT;\X\0A  RETURN(current.of_shape);'));
#26664=EXPRESS_CODE(#11138,('LOCAL\X\0A  pd_set  : SET OF property_definition                := [];\X\0A  pdr_set : SET OF property_definition_representation := [];\X\0AEND_LOCAL;\X\0A  pd_set := bag_to_set(USEDIN(s_a_instance,\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION.DEFINITION''));\X\0A  IF (SIZEOF(pd_set) < 1)\X\0A  THEN\X\0A    RETURN(pdr_set);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO HIINDEX(pd_set);\X\0A    pdr_set := pdr_set +\X\0A               (QUERY(pdr\X\0A                      <* USEDIN(pd_set[i],\X\0A                                ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION_REPRESENTATION.DEFINITION'')\X\0A                      | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_DEFINITION_REPRESENTATION'' IN\X\0A                        TYPEOF(pdr)));\X\0A  END_REPEAT;\X\0A  RETURN(pdr_set);'));
#26680=EXPRESS_CODE(#11140,('LOCAL\X\0A  pd_set  : SET OF product_definition_shape := [];\X\0A  pdr_set : SET OF shape_aspect             := [];\X\0AEND_LOCAL;\X\0A  pd_set := bag_to_set(QUERY(pd\X\0A                             <* USEDIN(c_def_instance,\X\0A                                       ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION.DEFINITION'')\X\0A                             | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_SHAPE'' IN\X\0A                               TYPEOF(pd)));\X\0A  IF (SIZEOF(pd_set) < 1)\X\0A  THEN\X\0A    RETURN(pdr_set);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO HIINDEX(pd_set);\X\0A    pdr_set := pdr_set +\X\0A               bag_to_set(USEDIN(pd_set[i], ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_ASPECT.OF_SHAPE''));\X\0A  END_REPEAT;\X\0A  RETURN(pdr_set);'));
#26693=EXPRESS_CODE(#11142,('LOCAL\X\0A  typenames : SET OF STRING := stripped_typeof(expr);\X\0AEND_LOCAL;\X\0A  IF ''EXPRESSION'' IN typenames\X\0A  THEN\X\0A    RETURN(bool((''NUMERIC_EXPRESSION'' IN typenames) OR (''STRING_EXPRESSION'' IN typenames) OR\X\0A                (''BOOLEAN_EXPRESSION'' IN typenames)));\X\0A  END_IF;\X\0A  IF ''MATHS_FUNCTION'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''FUNCTION_APPLICATION'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''MATHS_SPACE'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''MATHS_VARIABLE'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''DEPENDENT_VARIABLE_DEFINITION'' IN typenames\X\0A  THEN\X\0A    RETURN(has_values_space(expr\\unary_generic_expression.operand));\X\0A  END_IF;\X\0A  IF ''COMPLEX_NUMBER_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''LOGICAL_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''BINARY_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''MATHS_ENUM_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''REAL_TUPLE_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''INTEGER_TUPLE_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''ATOM_BASED_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''MATHS_TUPLE_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''PARTIAL_DERIVATIVE_EXPRESSION'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''DEFINITE_INTEGRAL_EXPRESSION'' IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
#26701=EXPRESS_CODE(#11144,('LOCAL\X\0A  result : BOOLEAN := true;\X\0A  limit  : INTEGER := SIZEOF(values);\X\0AEND_LOCAL;\X\0A  REPEAT i := 2 TO limit;\X\0A    IF values[i] <= values[i - 1]\X\0A    THEN\X\0A      result := false;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
#26706=EXPRESS_CODE(#26705,('limit'));
#26712=EXPRESS_CODE(#11146,('LOCAL\X\0A  dqdr  : BAG OF data_quality_definition_representation_relationship := [];\X\0A  pdqdr : BAG OF product_data_and_data_quality_relationship          := [];\X\0A  pd    : BAG OF product_definition                                  := [];\X\0AEND_LOCAL;\X\0A  dqdr := USEDIN(dqir,\X\0A                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_QUALITY_DEFINITION_REPRESENTATION_RELATIONSHIP.USED_REPRESENTATION'');\X\0A  REPEAT i := 1 TO SIZEOF(dqdr);\X\0A    pdqdr := USEDIN(dqdr[i].definition,\X\0A                    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DATA_AND_DATA_QUALITY_RELATIONSHIP.DATA_QUALITY'');\X\0A    REPEAT j := 1 TO SIZEOF(pdqdr);\X\0A      pd := pd + pdqdr[j].product_data;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  RETURN(pd);'));
#26731=EXPRESS_CODE(#11148,('LOCAL\X\0A  reps : SET [1 : ?] OF representation                  := using_representations(item);\X\0A  svri : SET [1 : ?] OF variational_representation_item;\X\0A  iar  : instance_attribute_reference;\X\0A  i    : INTEGER;\X\0A  n    : INTEGER                                        := HIINDEX(reps);\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOUND_VARIATIONAL_PARAMETER'' IN TYPEOF(item))\X\0A  THEN\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.INSTANCE_ATTRIBUTE_REFERENCE'' IN\X\0A       TYPEOF(item\\generic_variable.interpretation\\environment.semantics)\X\0A    THEN\X\0A      BEGIN  \X\0A             iar := item\\generic_variable.interpretation\\environment.semantics;\X\0A             IF (reps <> using_representations(iar\\instance_attribute_reference.owning_instance))\X\0A             THEN\X\0A               RETURN(true);\X\0A             END_IF;\X\0A      END;\X\0A    ELSE\X\0A      RETURN(true);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.UNBOUND_VARIATIONAL_PARAMETER'' IN TYPEOF(item))\X\0A  THEN\X\0A    BEGIN  \X\0A           REPEAT i := 1 TO n;\X\0A             svri := QUERY(q\X\0A                           <* reps[i]\\representation.items\X\0A                           | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FREE_FORM_CONSTRAINT'' IN TYPEOF(q));\X\0A             IF SIZEOF(QUERY(r\X\0A                             <* svri\X\0A                             | item IN\X\0A                               (r\\free_form_constraint.reference_elements +\X\0A                                r\\free_form_constraint.constrained_elements))) =\X\0A                0\X\0A             THEN\X\0A               RETURN(true);\X\0A             END_IF;\X\0A           END_REPEAT;\X\0A    END;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FIXED_INSTANCE_ATTRIBUTE_SET'' IN TYPEOF(item))\X\0A  THEN\X\0A    REPEAT i := 1 TO SIZEOF(item\\fixed_instance_attribute_set.fixed_attributes);\X\0A      IF (reps <>\X\0A          using_representations(item\\fixed_instance_attribute_set.fixed_attributes[i]\\instance_attribute_reference.owning_instance))\X\0A      THEN\X\0A        RETURN(true);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EXPLICIT_CONSTRAINT'' IN TYPEOF(item))\X\0A  THEN\X\0A    IF SIZEOF(QUERY(q\X\0A                    <* (item\\explicit_constraint.reference_elements + item\\explicit_constraint.constrained_elements)\X\0A                    | reps <> using_representations(q))) >\X\0A       0\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.AUXILIARY_GEOMETRIC_REPRESENTATION_ITEM'' IN TYPEOF(item))\X\0A  THEN\X\0A    BEGIN  \X\0A           REPEAT i := 1 TO n;\X\0A             svri := QUERY(q\X\0A                           <* reps[i]\\representation.items\X\0A                           | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EXPLICIT_GEOMETRIC_CONSTRAINT'' IN\X\0A                             TYPEOF(q));\X\0A             IF SIZEOF(QUERY(r <* svri | item IN r\\explicit_geometric_constraint.reference_elements)) = 0\X\0A             THEN\X\0A               RETURN(true);\X\0A             END_IF;\X\0A           END_REPEAT;\X\0A    END;\X\0A  END_IF;\X\0A  RETURN(false);'));
