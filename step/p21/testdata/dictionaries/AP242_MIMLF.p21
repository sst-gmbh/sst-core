#28458=EXPRESS_CODE(#11466,('LOCAL\X\0A  i     : INTEGER := 0;\X\0A  j     : INTEGER := 0;\X\0A  k     : INTEGER := 0;\X\0A  dkuhr : LOGICAL := true;\X\0A  nnauo : INTEGER := 0;\X\0A  nprpc : INTEGER := 0;\X\0A  rp    : product;\X\0AEND_LOCAL;\X\0A  REPEAT i := LOINDEX(composite_assembly_sequence_definition) TO HIINDEX(composite_assembly_sequence_definition);\X\0A    nnauo := 0;\X\0A    REPEAT j := LOINDEX(next_assembly_usage_occurrence) TO HIINDEX(next_assembly_usage_occurrence);\X\0A      IF (composite_assembly_sequence_definition[i] = next_assembly_usage_occurrence[j].relating_product_definition)\X\0A      THEN\X\0A        rp := next_assembly_usage_occurrence[j].related_product_definition.formation.of_product;\X\0A        nprpc := 0;\X\0A        REPEAT k := LOINDEX(product_related_product_category) TO HIINDEX(product_related_product_category);\X\0A          IF ((rp IN product_related_product_category[k].products) AND\X\0A              (product_related_product_category[k].name IN\X\0A               [''ply'',''ply laminate'',''filament laminate'',''processed core'',''composite assembly'']))\X\0A          THEN\X\0A            nprpc := nprpc + 1;\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        IF (nprpc = 1)\X\0A        THEN\X\0A          nnauo := nnauo + 1;\X\0A        ELSE\X\0A          dkuhr := false;\X\0A          ESCAPE;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF (dkuhr = false)\X\0A    THEN\X\0A      ESCAPE;\X\0A    END_IF;\X\0A    IF (nnauo = 0)\X\0A    THEN\X\0A      dkuhr := false;\X\0A      ESCAPE;\X\0A    END_IF;\X\0A  END_REPEAT;'));
