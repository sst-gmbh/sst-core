#24906=EXPRESS_CODE(#10818,('LOCAL\X\0A  i                     : INTEGER;\X\0A  local_composite_text  : SET [0 : ?] OF composite_text;\X\0A  local_annotation_text : SET [0 : ?] OF annotation_text;\X\0A  local_children        : SET [0 : ?] OF text_or_character;\X\0AEND_LOCAL;\X\0A  local_composite_text := QUERY(child\X\0A                                <* child_text\X\0A                                | (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COMPOSITE_TEXT'' IN TYPEOF(child)));\X\0A  IF (SIZEOF(local_composite_text) > 0)\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(local_composite_text);\X\0A      IF (start_composite :=: local_composite_text[i])\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  local_children := child_text;\X\0A  IF (SIZEOF(local_composite_text)) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(local_composite_text);\X\0A      local_children := local_children + local_composite_text[i].collected_text;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  local_annotation_text := QUERY(child\X\0A                                 <* child_text\X\0A                                 | (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ANNOTATION_TEXT'' IN\X\0A                                    TYPEOF(child)));\X\0A  IF (SIZEOF(local_annotation_text) > 0)\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(local_annotation_text);\X\0A      local_children := local_children +\X\0A                        QUERY(item\X\0A                              <* local_annotation_text[i]\\mapped_item.mapping_source.mapped_representation.items\X\0A                              | SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ANNOTATION_TEXT'',\X\0A                                        ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COMPOSITE_TEXT''] *\X\0A                                       TYPEOF(item)) >\X\0A                                0);\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (local_children :<>: child_text)\X\0A  THEN\X\0A    RETURN(acyclic_composite_text(start_composite, local_children));\X\0A  ELSE\X\0A    RETURN(true);\X\0A  END_IF;'));
