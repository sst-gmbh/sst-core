#28859=EXPRESS_CODE(#11558,('LOCAL\X\0A  bss  : BAG OF STRING                    := [];\X\0A  ds   : SET OF dimensional_size          := QUERY(ds <* dimensional_size | EXISTS(ds\\dimensional_size.id));\X\0A  sa   : SET OF shape_aspect              := QUERY(sa <* shape_aspect | EXISTS(sa\\shape_aspect.id));\X\0A  sar  : SET OF shape_aspect_relationship := QUERY(sar\X\0A                                                   <* shape_aspect_relationship\X\0A                                                   | EXISTS(sar\\shape_aspect_relationship.id));\X\0A  ssa  : SET OF shape_aspect              := [];\X\0A  pass : BOOLEAN                          := true;\X\0AEND_LOCAL;\X\0A  REPEAT ii := 1 TO SIZEOF(product_definition_shape)\X\0A  WHILE pass;\X\0A    bss := [];\X\0A    ssa := bag_to_set(USEDIN(product_definition_shape[ii],\X\0A                             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_ASPECT.OF_SHAPE''));\X\0A    REPEAT i := 1 TO SIZEOF(ds);\X\0A      IF (ds[i]\\dimensional_size.applies_to IN ssa)\X\0A      THEN\X\0A        bss := bss + ds[i]\\dimensional_size.id;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    REPEAT i := 1 TO SIZEOF(sa);\X\0A      IF (sa[i] IN ssa)\X\0A      THEN\X\0A        bss := bss + sa[i]\\shape_aspect.id;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    REPEAT i := 1 TO SIZEOF(sar);\X\0A      IF (sar[i]\\shape_aspect_relationship.relating_shape_aspect IN ssa)\X\0A      THEN\X\0A        bss := bss + sar[i]\\shape_aspect_relationship.id;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF (SIZEOF(bag_to_set(bss)) <> SIZEOF(bss))\X\0A    THEN\X\0A      pass := false;\X\0A    END_IF;\X\0A  END_REPEAT;'));
#28894=EXPRESS_CODE(#28893,('pass'));
#28895=EXPRESS_CODE(#11560,('LOCAL\X\0A  design_view_contexts                                 : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.life_cycle_stage =\X\0A                                                                                                      ''design'');\X\0A  gdt_representation_view_contexts                     : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''geometrical dimensioning and tolerancing representation'');\X\0A  machining_feature_view_contexts                      : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''machining feature'');\X\0A  material_specification_view_contexts                 : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''material specification'');\X\0A  model_based_3d_annotation_presentation_view_contexts : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''model based 3D annotation presentation'');\X\0A  model_based_view_contexts                            : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''model based product geometry'');\X\0A  process_state_view_contexts                          : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''process state'');\X\0A  surface_finish_view_contexts                         : SET OF product_definition_context := QUERY(pdc\X\0A                                                                                                    <* product_definition_context\X\0A                                                                                                    | pdc.frame_of_reference.application =\X\0A                                                                                                      ''surface finish'');\X\0A  additional_view_contexts                             : SET OF product_definition_context := gdt_representation_view_contexts +\X\0A                                                                                              machining_feature_view_contexts +\X\0A                                                                                              material_specification_view_contexts +\X\0A                                                                                              model_based_3d_annotation_presentation_view_contexts +\X\0A                                                                                              process_state_view_contexts +\X\0A                                                                                              surface_finish_view_contexts;\X\0A  need_initial_model_based_view_contexts               : SET OF product_definition_context := gdt_representation_view_contexts +\X\0A                                                                                              model_based_3d_annotation_presentation_view_contexts;\X\0AEND_LOCAL;'));
