#28601=EXPRESS_CODE(#11488,('LOCAL\X\0A  i     : INTEGER;\X\0A  j     : INTEGER;\X\0A  k     : INTEGER;\X\0A  dkuhr : LOGICAL := true;\X\0A  nnauo : INTEGER;\X\0A  nprpc : INTEGER := 0;\X\0A  rp    : product;\X\0AEND_LOCAL;\X\0A  REPEAT i := LOINDEX(ply_laminate_sequence_definition) TO HIINDEX(ply_laminate_sequence_definition);\X\0A    nnauo := 0;\X\0A    REPEAT j := LOINDEX(next_assembly_usage_occurrence) TO HIINDEX(next_assembly_usage_occurrence);\X\0A      IF (ply_laminate_sequence_definition[i] = next_assembly_usage_occurrence[j].relating_product_definition)\X\0A      THEN\X\0A        rp := next_assembly_usage_occurrence[j].related_product_definition.formation.of_product;\X\0A        nprpc := 0;\X\0A        REPEAT k := LOINDEX(product_related_product_category) TO HIINDEX(product_related_product_category);\X\0A          IF ((product_related_product_category[k].name = ''ply'') AND\X\0A              (rp IN product_related_product_category[k].products))\X\0A          THEN\X\0A            nprpc := nprpc + 1;\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        IF (nprpc = 1)\X\0A        THEN\X\0A          nnauo := nnauo + 1;\X\0A        ELSE\X\0A          dkuhr := false;\X\0A          ESCAPE;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF (dkuhr = false)\X\0A    THEN\X\0A      ESCAPE;\X\0A    END_IF;\X\0A    IF (nnauo = 0)\X\0A    THEN\X\0A      dkuhr := false;\X\0A      ESCAPE;\X\0A    END_IF;\X\0A  END_REPEAT;'));
#28618=EXPRESS_CODE(#28617,('dkuhr'));
#28619=EXPRESS_CODE(#11490,('LOCAL\X\0A  i     : INTEGER;\X\0A  j     : INTEGER;\X\0A  k     : INTEGER;\X\0A  kp    : INTEGER;\X\0A  dkuhr : LOGICAL;\X\0A  nmfuo : INTEGER;\X\0A  nprpc : INTEGER := 0;\X\0A  rp    : product;\X\0AEND_LOCAL;\X\0A  dkuhr := true;\X\0A  REPEAT kp := LOINDEX(product_related_product_category) TO HIINDEX(product_related_product_category);\X\0A    IF (product_related_product_category[kp].name = ''ply'')\X\0A    THEN\X\0A      REPEAT i := LOINDEX(product_related_product_category[kp].products) TO HIINDEX(product_related_product_category[kp].products);\X\0A        nmfuo := 0;\X\0A        REPEAT j := LOINDEX(make_from_usage_option) TO HIINDEX(make_from_usage_option);\X\0A          rp := make_from_usage_option[j].related_product_definition.formation.of_product;\X\0A          IF (product_related_product_category[kp].products[i] = rp)\X\0A          THEN\X\0A            REPEAT k := LOINDEX(product_related_product_category) TO HIINDEX(product_related_product_category);\X\0A              IF ((rp IN product_related_product_category[k].products) AND\X\0A                  (product_related_product_category[k].name IN\X\0A                   [''isotropic material'',''filament assembly'',''discontinuous fiber assembly'']))\X\0A              THEN\X\0A                nprpc := nprpc + 1;\X\0A              END_IF;\X\0A            END_REPEAT;\X\0A            IF (nprpc = 1)\X\0A            THEN\X\0A              nmfuo := nmfuo + 1;\X\0A            ELSE\X\0A              dkuhr := false;\X\0A              ESCAPE;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        IF (dkuhr = false)\X\0A        THEN\X\0A          ESCAPE;\X\0A        END_IF;\X\0A        IF (nmfuo <> 1)\X\0A        THEN\X\0A          dkuhr := false;\X\0A          ESCAPE;\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A  END_REPEAT;'));
