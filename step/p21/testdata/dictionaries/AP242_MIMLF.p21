#24988=EXPRESS_CODE(#10830,('LOCAL\X\0A  rms : SET OF representation_map;\X\0A  mis : SET OF mapped_item;\X\0A  rs1 : SET OF representation;\X\0A  rs2 : SET OF representation;\X\0AEND_LOCAL;\X\0A  rs1 := using_representations(mi);\X\0A  rs2 := [];\X\0A  REPEAT WHILE SIZEOF(rs1) > 0;\X\0A    REPEAT i := 1 TO HIINDEX(rs1);\X\0A      rms := bag_to_set(USEDIN(rs1[i],\X\0A                               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_MAP.MAPPED_REPRESENTATION''));\X\0A      IF SIZEOF(rms) > 0\X\0A      THEN\X\0A        REPEAT j := 1 TO HIINDEX(rms);\X\0A          mis := bag_to_set(USEDIN(rms[i],\X\0A                                   ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MAPPED_ITEM.MAPPING_SOURCE''));\X\0A          IF SIZEOF(mis) > 0\X\0A          THEN\X\0A            REPEAT j := 1 TO HIINDEX(mis);\X\0A              IF mis[i] :=: mi\X\0A              THEN\X\0A                RETURN(false);\X\0A              END_IF;\X\0A              rs2 := rs2 + using_representations(mis[i]);\X\0A            END_REPEAT;\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    rs1 := rs2;\X\0A    rs2 := [];\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
