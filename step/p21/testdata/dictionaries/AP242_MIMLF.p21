ments);\X\0A      REPEAT k := 1 TO SIZEOF(t_type_list);\X\0A        IF (t_type_list[k] IN TYPEOF(sdiri[i].inspected_elements[j]))\X\0A        THEN\X\0A          t_type_list := t_type_list - t_type_list[k];\X\0A          ESCAPE;\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_REPEAT;\X\0A    IF (SIZEOF(t_type_list) > 0)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
