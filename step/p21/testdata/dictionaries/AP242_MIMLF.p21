N_DEFINED_FUNCTION'' IN TYPEOF(arg)) OR\X\0A     (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.STRING_DEFINED_FUNCTION'' IN TYPEOF(arg))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SIMPLE_STRING_EXPRESSION'' IN TYPEOF(arg)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.INDEX_EXPRESSION'' IN TYPEOF(arg)) OR\X\0A     (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SUBSTRING_EXPRESSION'' IN TYPEOF(arg)) OR\X\0A     (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONCAT_EXPRESSION'' IN TYPEOF(arg)) OR\X\0A     (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FORMAT_FUNCTION'' IN TYPEOF(arg))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  RETURN(false);'));
#26769=EXPRESS_CODE(#11156,('LOCAL\X\0A  y : BAG OF representation_item;\X\0AEND_LOCAL;\X\0A  IF SIZEOF(USEDIN(item, ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION.ITEMS'') *\X\0A            cntxt.representations_in_context) >\X\0A     0\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    y := QUERY(z\X\0A               <* USEDIN(item, '''')\X\0A               | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_ITEM'' IN TYPEOF(z));\X\0A    IF SIZEOF(y) > 0\X\0A    THEN\X\0A      REPEAT i := 1 TO HIINDEX(y);\X\0A        IF item_in_context(y[i], cntxt)\X\0A        THEN\X\0A          RETURN(true);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
