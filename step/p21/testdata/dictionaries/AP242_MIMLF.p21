#26828=EXPRESS_CODE(#11166,('LOCAL\X\0A  n   : INTEGER;\X\0A  res : ARRAY [low : u] OF GENERIC : T;\X\0AEND_LOCAL;\X\0A  n := SIZEOF(lis);\X\0A  IF (n <> (u - low + 1))\X\0A  THEN\X\0A    RETURN(?);\X\0A  ELSE\X\0A    res := [lis[1]:n];\X\0A    REPEAT i := 2 TO n;\X\0A      res[low + i - 1] := lis[i];\X\0A    END_REPEAT;\X\0A    RETURN(res);\X\0A  END_IF;'));
