#26356=EXPRESS_CODE(#11080,('LOCAL\X\0A  x_axis : direction;\X\0A  v      : direction;\X\0A  z      : direction;\X\0A  x_vec  : vector;\X\0AEND_LOCAL;\X\0A  IF (NOT EXISTS(z_axis))\X\0A  THEN\X\0A    RETURN(?);\X\0A  ELSE\X\0A    z := normalise(z_axis);\X\0A    IF NOT EXISTS(arg)\X\0A    THEN\X\0A      IF ((z.direction_ratios <> [1.0,0.0,0.0]) AND (z.direction_ratios <> [-1.0,0.0,0.0]))\X\0A      THEN\X\0A        v := dummy_gri || direction([1.0,0.0,0.0]);\X\0A      ELSE\X\0A        v := dummy_gri || direction([0.0,1.0,0.0]);\X\0A      END_IF;\X\0A    ELSE\X\0A      IF (arg.dim <> 3)\X\0A      THEN\X\0A        RETURN(?);\X\0A      END_IF;\X\0A      IF ((cross_product(arg, z).magnitude) = 0.0)\X\0A      THEN\X\0A        RETURN(?);\X\0A      ELSE\X\0A        v := normalise(arg);\X\0A      END_IF;\X\0A    END_IF;\X\0A    x_vec := scalar_times_vector(dot_product(v, z), z);\X\0A    x_axis := vector_difference(v, x_vec).orientation;\X\0A    x_axis := normalise(x_axis);\X\0A  END_IF;\X\0A  RETURN(x_axis);'));
#26366=EXPRESS_CODE(#11082,('LOCAL\X\0A  typenames : SET OF STRING              := stripped_typeof(expr);\X\0A  result    : SET OF generic_variable    := [];\X\0A  exprs     : LIST OF generic_expression := [];\X\0AEND_LOCAL;\X\0A  IF ''GENERIC_LITERAL'' IN typenames\X\0A  THEN\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  IF ''GENERIC_VARIABLE'' IN typenames\X\0A  THEN\X\0A    result := result + expr;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  IF ''QUANTIFIER_EXPRESSION'' IN typenames\X\0A  THEN\X\0A    exprs := QUERY(ge\X\0A                   <* expr\\multiple_arity_generic_expression.operands\X\0A                   | NOT (ge IN expr\\quantifier_expression.variables));\X\0A    REPEAT i := 1 TO SIZEOF(exprs);\X\0A      result := result + free_variables_of(exprs[i]);\X\0A    END_REPEAT;\X\0A    REPEAT i := 1 TO SIZEOF(expr\\quantifier_expression.variables);\X\0A      result := result - expr\\quantifier_expression.variables[i];\X\0A    END_REPEAT;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  IF ''UNARY_GENERIC_EXPRESSION'' IN typenames\X\0A  THEN\X\0A    RETURN(free_variables_of(expr\\unary_generic_expression.operand));\X\0A  END_IF;\X\0A  IF ''BINARY_GENERIC_EXPRESSION'' IN typenames\X\0A  THEN\X\0A    result := free_variables_of(expr\\binary_generic_expression.operands[1]);\X\0A    RETURN(result + free_variables_of(expr\\binary_generic_expression.operands[2]));\X\0A  END_IF;\X\0A  IF ''MULTIPLE_ARITY_GENERIC_EXPRESSION'' IN typenames\X\0A  THEN\X\0A    REPEAT i := 1 TO SIZEOF(expr\\multiple_arity_generic_expression.operands);\X\0A      result := result + free_variables_of(expr\\multiple_arity_generic_expression.operands[i]);\X\0A    END_REPEAT;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  RETURN(result);'));
#26389=EXPRESS_CODE(#11084,('LOCAL\X\0A  domain       : tuple_space        := convert_to_maths_function(func).domain;\X\0A  domain_types : SET OF STRING      := TYPEOF(domain);\X\0A  narg         : positive_integer   := SIZEOF(arguments);\X\0A  arg          : generic_expression;\X\0AEND_LOCAL;\X\0A  IF (schema_prefix + ''PRODUCT_SPACE'') IN domain_types\X\0A  THEN\X\0A    IF space_dimension(domain) <> narg\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  ELSE\X\0A    IF (schema_prefix + ''EXTENDED_TUPLE_SPACE'') IN domain_types\X\0A    THEN\X\0A      IF space_dimension(domain) > narg\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    ELSE\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_IF;\X\0A  REPEAT i := 1 TO narg;\X\0A    arg := convert_to_operand(arguments[i]);\X\0A    IF NOT has_values_space(arg)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF NOT compatible_spaces(factor_space(domain, i), values_space_of(arg))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
