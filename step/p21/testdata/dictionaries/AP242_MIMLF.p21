#28962=EXPRESS_CODE(#11562,('LOCAL\X\0A  number_of_input_instances : INTEGER;\X\0A  previous_in_chain         : LIST OF GENERIC := [];\X\0A  set_of_input_types        : SET OF STRING   := [];\X\0A  all_instances             : SET OF GENERIC  := [];\X\0AEND_LOCAL;\X\0A  all_instances := all_instances + aggregate_id_attribute;\X\0A  all_instances := all_instances + attribute_value_role;\X\0A  all_instances := all_instances + camera_model_d2;\X\0A  all_instances := all_instances + classification_assignment_relationship;\X\0A  all_instances := all_instances + concept_feature_relationship;\X\0A  all_instances := all_instances + concept_feature_relationship_with_condition;\X\0A  all_instances := all_instances + data_equivalence_assessment_specification;\X\0A  all_instances := all_instances + data_equivalence_criteria_representation;\X\0A  all_instances := all_instances + data_equivalence_criterion;\X\0A  all_instances := all_instances + data_equivalence_inspection_instance_report_item;\X\0A  all_instances := all_instances + data_equivalence_inspection_requirement;\X\0A  all_instances := all_instances + data_equivalence_inspection_result_representation;\X\0A  all_instances := all_instances + document_usage_constraint;\X\0A  all_instances := all_instances + edge_blended_solid;\X\0A  all_instances := all_instances + effectivity_context_role;\X\0A  all_instances := all_instances + event_occurrence_role;\X\0A  all_instances := all_instances + explicit_procedural_representation_item_relationship;\X\0A  all_instances := all_instances + founded_item;\X\0A  all_instances := all_instances + functionally_defined_transformation;\X\0A  all_instances := all_instances + indirectly_selected_elements;\X\0A  all_instances := all_instances + location_representation_role;\X\0A  all_instances := all_instances + location_role;\X\0A  all_instances := all_instances + modified_solid_with_placed_configuration;\X\0A  all_instances := all_instances + one_direction_repeat_factor;\X\0A  all_instances := all_instances + organization_type_role;\X\0A  all_instances := all_instances + procedural_representation;\X\0A  all_instances := all_instances + procedural_representation_sequence;\X\0A  all_instances := all_instances + product_definition_effectivity;\X\0A  all_instances := all_instances + product_definition_relationship_relationship;\X\0A  all_instances := all_instances + runout_zone_orientation;\X\0A  all_instances := all_instances + solid_with_depression;\X\0A  all_instances := all_instances + solid_with_hole;\X\0A  all_instances := all_instances + solid_with_pocket;\X\0A  all_instances := all_instances + solid_with_protrusion;\X\0A  all_instances := all_instances + solid_with_shape_element_pattern;\X\0A  all_instances := all_instances + solid_with_slot;\X\0A  all_instances := all_instances + swept_area_solid;\X\0A  all_instances := all_instances + symbol_target;\X\0A  all_instances := all_instances + two_direction_repeat_factor;\X\0A  all_instances := all_instances + user_selected_elements;\X\0A  ;\X\0A  number_of_input_instances := SIZEOF(all_instances);\X\0A  REPEAT i := 1 TO number_of_input_instances;\X\0A    set_of_input_types := set_of_input_types + TYPEOF(all_instances[i]);\X\0A  END_REPEAT;'));
