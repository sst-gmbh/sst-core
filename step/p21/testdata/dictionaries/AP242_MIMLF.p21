     INTERFACED_DECLARATION($)REFERENCED_DECLARATION());
#1191=(DATA_TYPE_DECLARATION()DECLARATION(#407,#1189)ENTITY_DECLARATION()
     INTERFACED_DECLARATION($)REFERENCED_DECLARATION());
#1194=(DATA_TYPE_DECLARATION()DECLARATION(#407,#1192)ENTITY_DECLARATION()
