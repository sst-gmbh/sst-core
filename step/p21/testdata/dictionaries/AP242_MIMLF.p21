#25550=EXPRESS_CODE(#10938,('REPEAT i := 1 TO s.n_u;\X\0A    REPEAT j := 1 TO s.n_v;\X\0A      IF NOT ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_SURFACE'' IN\X\0A               TYPEOF(s.segments[i][j].parent_surface)) OR\X\0A              (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.RECTANGULAR_TRIMMED_SURFACE'' IN\X\0A               TYPEOF(s.segments[i][j].parent_surface)))\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  (* Check the transition codes, omitting the last row or column *)\X\0A  REPEAT i := 1 TO s.n_u - 1;\X\0A    REPEAT j := 1 TO s.n_v;\X\0A      IF s.segments[i][j].u_transition = discontinuous\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO s.n_u;\X\0A    REPEAT j := 1 TO s.n_v - 1;\X\0A      IF s.segments[i][j].v_transition = discontinuous\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
