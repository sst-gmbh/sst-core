#28123=EXPRESS_CODE(#11404,('LOCAL\X\0A  properties                          : SET OF property_definition                := bag_to_set(QUERY(prd\X\0A                                                                                                      <* USEDIN(pd,\X\0A                                                                                                                ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION.DEFINITION'')\X\0A                                                                                                      | (prd.name =\X\0A                                                                                                         ''occurrence selection'')));\X\0A  property_definition_representations : SET OF property_definition_representation := bag_to_set(QUERY(pdr\X\0A                                                                                                      <* USEDIN(properties[1],\X\0A                                                                                                                ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION_REPRESENTATION.DEFINITION'')\X\0A                                                                                                      | (pdr.used_representation.name =\X\0A                                                                                                         ''selection criteria'')));\X\0A  selected_representation             : representation;\X\0AEND_LOCAL;\X\0A  IF (SIZEOF(properties) <> 1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF (SIZEOF(property_definition_representations) <> 1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  selected_representation := property_definition_representations[1]\\property_definition_representation.used_representation;\X\0A  IF (SIZEOF(selected_representation\\representation.items) < 1) OR\X\0A     (SIZEOF(selected_representation\\representation.items) > 2)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF (SIZEOF(QUERY(i\X\0A                   <* selected_representation\\representation.items\X\0A                   | (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MEASURE_REPRESENTATION_ITEM'',\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VALUE_RANGE''] *\X\0A                             TYPEOF(i)) =\X\0A                      1) AND\X\0A                     (i.name = ''selection quantity''))) <>\X\0A      1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF (SIZEOF(QUERY(i\X\0A                   <* selected_representation\\representation.items\X\0A                   | (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DESCRIPTIVE_REPRESENTATION_ITEM'' IN\X\0A                      TYPEOF(i)) AND\X\0A                     (i.name = ''selection control''))) >\X\0A      1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF (SIZEOF(QUERY(i\X\0A                   <* selected_representation\\representation.items\X\0A                   | (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DESCRIPTIVE_REPRESENTATION_ITEM'' IN\X\0A                      TYPEOF(i)) AND\X\0A                     (i.name = ''selection control''))) =\X\0A      0) AND\X\0A     (SIZEOF(QUERY(i\X\0A                   <* selected_representation\\representation.items\X\0A                   | (i.name = ''selection quantity'') AND\X\0A                     (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.QUALIFIED_REPRESENTATION_ITEM'',\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VALUE_RANGE''] *\X\0A                             TYPEOF(i)) =\X\0A                      0))) >\X\0A      0)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  RETURN(true);'));
