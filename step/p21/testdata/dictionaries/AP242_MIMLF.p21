#27907=EXPRESS_CODE(#27906,('b.v_upper'));
#27910=EXPRESS_CODE(#11366,('IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EDGE'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(edge_reversed(an_item));\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PATH'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(path_reversed(an_item));\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FACE_BOUND'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(face_bound_reversed(an_item));\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FACE'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(face_reversed(an_item));\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHELL'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(shell_reversed(an_item));\X\0A  END_IF;\X\0A  IF (''SET'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(set_of_topology_reversed(an_item));\X\0A  END_IF;\X\0A  IF (''LIST'' IN TYPEOF(an_item))\X\0A  THEN\X\0A    RETURN(list_of_topology_reversed(an_item));\X\0A  END_IF;\X\0A  RETURN(?);'));
#27916=EXPRESS_CODE(#11368,('IF ((NOT EXISTS(the_type)) OR (SIZEOF(sub_names) = 0))\X\0A  THEN\X\0A    RETURN(unknown);\X\0A  ELSE\X\0A    CASE criterion OF\X\0A      0 : RETURN(SIZEOF(sub_names * TYPEOF(the_type)) > 0);\X\0A      1 : RETURN(SIZEOF(sub_names * TYPEOF(the_type)) = 0);\X\0A      2 : RETURN(SIZEOF(sub_names * TYPEOF(the_type)) = 1);\X\0A      3 : RETURN(SIZEOF(sub_names * TYPEOF(the_type)) <= 1);\X\0A      OTHERWISE: RETURN(unknown);\X\0A    END_CASE;\X\0A  END_IF;'));
#27922=EXPRESS_CODE(#11370,('REPEAT i := 1 TO SIZEOF(links) - 1;\X\0A    CASE true OF\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN\X\0A       TYPEOF(links[i]\\product_definition_relationship.relating_product_definition)) AND\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN\X\0A       TYPEOF(links[i]\\product_definition_relationship.related_product_definition)) AND\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN\X\0A       TYPEOF(links[i + 1]\\product_definition_relationship.relating_product_definition)) : BEGIN  \X\0A                                                                                                  IF NOT ((links[i]\\product_definition_relationship.related_product_definition :=:\X\0A                                                                                                           links[i +\X\0A                                                                                                                 1]\\product_definition_relationship.relating_product_definition) OR\X\0A                                                                                                          ((SIZEOF(QUERY(pdr\X\0A                                                                                                                         <* USEDIN(links[i]\\product_definition_relationship.related_product_definition,\X\0A                                                                                                                                   ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_RELATIONSHIP.RELATED_PRODUCT_DEFINITION'')\X\0A                                                                                                                         | pdr\\product_definition_relationship.relating_product_definition :=:\X\0A                                                                                                                           links[i +\X\0A                                                                                                                                 1]\\product_definition_relationship.relating_product_definition)) =\X\0A                                                                                                            1) AND\X\0A                                                                                                           (links[i]\\product_definition_relationship.related_product_definition\\product_definition.formation\\product_definition_formation.of_product :=:\X\0A                                                                                                            links[i +\X\0A                                                                                                                  1]\\product_definition_relationship.relating_product_definition\\product_definition.formation\\product_definition_formation.of_product)))\X\0A                                                                                                  THEN\X\0A                                                                                                    RETURN(false);\X\0A                                                                                                  END_IF;\X\0A      END;\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_REFERENCE'' IN\X\0A       TYPEOF(links[i]\\product_definition_relationship.related_product_definition)) AND\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_REFERENCE'' IN\X\0A       TYPEOF(links[i + 1]\\product_definition_relationship.relating_product_definition)) : BEGIN  \X\0A                                                                                                  IF NOT ((links[i]\\product_definition_relationship.related_product_definition :=:\X\0A                                                                                                           links[i +\X\0A                                                                                                                 1]\\product_definition_relationship.relating_product_definition) OR\X\0A                                                                                                          ((SIZEOF(QUERY(pdr\X\0A                                                                                                                         <* USEDIN(links[i]\\product_definition_relationship.related_product_definition,\X\0A                                                                                                                                   ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_RELATIONSHIP.RELATED_PRODUCT_DEFINITION'')\X\0A                                                                                                                         | pdr\\product_definition_relationship.relating_product_definition :=:\X\0A                                                                                                                           links[i +\X\0A                                                                                                                                 1]\\product_definition_relationship.relating_product_definition)) =\X\0A                                                                                                            1) AND\X\0A                                                                                                           (links[i]\\product_definition_relationship.related_product_definition\\product_definition_reference.product_id =\X\0A                                                                                                            links[i +\X\0A                                                                                                                  1]\\product_definition_relationship.relating_product_definition\\product_definition_reference.product_id) AND\X\0A                                                                                                           (links[i]\\product_definition_relationship.related_product_definition\\product_definition_reference.id_owning_organization_name =\X\0A                                                                                                            links[i +\X\0A                                                                                                                  1]\\product_definition_relationship.relating_product_definition\\product_definition_reference.id_owning_organization_name) AND\X\0A                                                                                                           (links[i]\\product_definition_relationship.related_product_definition\\product_definition_reference.product_definition_id <>\X\0A                                                                                                            links[i +\X\0A                                                                                                                  1]\\product_definition_relationship.relating_product_definition\\product_definition_reference.product_definition_id)))\X\0A                                                                                                  THEN\X\0A                                                                                                    RETURN(false);\X\0A                                                                                                  END_IF;\X\0A      END;\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_REFERENCE'' IN\X\0A       TYPEOF(links[i]\\product_definition_relationship.relating_product_definition)) AND\X\0A      (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN\X\0A       TYPEOF(links[i]\\product_definition_relationship.related_product_definition)) : RETURN(false);\X\0A      OTHERWISE: RETURN(false);\X\0A    END_CASE;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#27927=EXPRESS_CODE(#11372,('LOCAL\X\0A  local_p_d : SET OF product_definition   := [];\X\0A  local_s_r : SET OF shape_representation := [];\X\0A  i         : INTEGER;\X\0A  j         : INTEGER;\X\0AEND_LOCAL;\X\0A  local_p_d := using_product_definition_of_shape_representation(item);\X\0A  IF (SIZEOF(local_p_d) <> 1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  ELSE\X\0A    REPEAT i := 1 TO HIINDEX(local_p_d);\X\0A      local_s_r := find_shape_representation_of_product_definition(local_p_d[i]);\X\0A      REPEAT j := 1 TO HIINDEX(local_s_r);\X\0A        IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATIVE_SHAPE_REPRESENTATION'' IN\X\0A             TYPEOF(local_s_r[j])) AND\X\0A            (local_s_r[j] :<>: item))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#27944=EXPRESS_CODE(#11374,('LOCAL\X\0A  local_s_a : SET OF shape_aspect         := [];\X\0A  local_s_r : SET OF shape_representation := [];\X\0A  i         : INTEGER;\X\0A  j         : INTEGER;\X\0AEND_LOCAL;\X\0A  local_s_a := using_shape_aspect_of_shape_representation(item);\X\0A  IF (SIZEOF(local_s_a) <> 1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  ELSE\X\0A    REPEAT i := 1 TO HIINDEX(local_s_a);\X\0A      local_s_r := find_shape_representation_of_shape_aspect(local_s_a[i]);\X\0A      REPEAT j := 1 TO HIINDEX(local_s_r);\X\0A        IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATIVE_SHAPE_REPRESENTATION'' IN\X\0A             TYPEOF(local_s_r[j])) AND\X\0A            (local_s_r[j] :<>: item))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#27964=EXPRESS_CODE(#11376,('LOCAL\X\0A  result : SET OF generic_variable := [];\X\0AEND_LOCAL;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.GENERIC_VARIABLE'' IN TYPEOF(arg)\X\0A  THEN\X\0A    RETURN([arg]);\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.UNARY_GENERIC_EXPRESSION'' IN TYPEOF(arg)\X\0A  THEN\X\0A    RETURN(used_variables(arg\\unary_generic_expression.operand));\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BINARY_GENERIC_EXPRESSION'' IN TYPEOF(arg)\X\0A  THEN\X\0A    RETURN(used_variables(arg\\binary_generic_expression.operands[1]) +\X\0A           used_variables(arg\\binary_generic_expression.operands[2]));\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MULTIPLE_ARITY_GENERIC_EXPRESSION'' IN TYPEOF(arg)\X\0A  THEN\X\0A    REPEAT i := 1 TO SIZEOF(arg\\multiple_arity_generic_expression.operands);\X\0A      result := result + used_variables(arg\\multiple_arity_generic_expression.operands[i]);\X\0A    END_REPEAT;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  RETURN([]);'));
#27980=EXPRESS_CODE(#11378,('LOCAL\X\0A  new_check_items : SET OF founded_item_select;\X\0A  result_items    : SET OF founded_item_select;\X\0A  next_items      : SET OF founded_item_select;\X\0AEND_LOCAL;\X\0A  result_items := [];\X\0A  new_check_items := checked_items + item;\X\0A  next_items := QUERY(z\X\0A                      <* bag_to_set(USEDIN(item, ''''))\X\0A                      | (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_ITEM'' IN TYPEOF(z)) OR\X\0A                        (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FOUNDED_ITEM'' IN TYPEOF(z)));\X\0A  IF SIZEOF(next_items) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(next_items);\X\0A      IF NOT (next_items[i] IN new_check_items)\X\0A      THEN\X\0A        result_items := result_items + next_items[i] + using_items(next_items[i], new_check_items);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(result_items);'));
#27997=EXPRESS_CODE(#11380,('IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN TYPEOF(item.of_shape.definition))\X\0A  THEN\X\0A    RETURN(item.of_shape.definition);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#28003=EXPRESS_CODE(#11382,('LOCAL\X\0A  local_s_d_r : SET OF shape_definition_representation := [];\X\0A  local_p_d   : SET OF product_definition              := [];\X\0A  i           : INTEGER;\X\0AEND_LOCAL;\X\0A  local_s_d_r := QUERY(i1\X\0A                       <* bag_to_set(USEDIN(item,\X\0A                                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION_REPRESENTATION.USED_REPRESENTATION''))\X\0A                       | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_DEFINITION_REPRESENTATION'' IN\X\0A                         TYPEOF(i1));\X\0A  REPEAT i := 1 TO HIINDEX(local_s_d_r);\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION'' IN\X\0A        TYPEOF(local_s_d_r[i]\\property_definition_representation.definition))\X\0A    THEN\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION'' IN\X\0A          TYPEOF(local_s_d_r[i]\\property_definition_representation.definition\\property_definition.definition))\X\0A      THEN\X\0A        local_p_d := local_p_d +\X\0A                     local_s_d_r[i]\\property_definition_representation.definition\\property_definition.definition;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(local_p_d);'));
#28020=EXPRESS_CODE(#11384,('LOCAL\X\0A  results                  : SET OF representation      := [];\X\0A  local_results            : SET OF representation      := [];\X\0A  local_representation_map : SET OF representation_map  := [];\X\0A  intermediate_items       : SET OF representation_item := [];\X\0A  i                        : INTEGER;\X\0A  j                        : INTEGER;\X\0AEND_LOCAL;\X\0A  local_results := QUERY(z\X\0A                         <* using_representations(item)\X\0A                         | SIZEOF(USEDIN(z,\X\0A                                         ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_MAP.MAPPED_REPRESENTATION'')) >\X\0A                           0);\X\0A  IF (SIZEOF(local_results) = 0)\X\0A  THEN\X\0A    RETURN([]);\X\0A  ELSE\X\0A    REPEAT i := 1 TO HIINDEX(local_results);\X\0A      local_representation_map := local_representation_map +\X\0A                                  bag_to_set(USEDIN(local_results[i],\X\0A                                                    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_MAP.MAPPED_REPRESENTATION''));\X\0A    END_REPEAT;\X\0A    REPEAT i := 1 TO HIINDEX(local_representation_map);\X\0A      intermediate_items := intermediate_items +\X\0A                            bag_to_set(USEDIN(local_representation_map[i],\X\0A                                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MAPPED_ITEM.MAPPING_SOURCE''));\X\0A    END_REPEAT;\X\0A    REPEAT j := 1 TO HIINDEX(intermediate_items);\X\0A      results := results + bag_to_set(using_representation_with_mapping(intermediate_items[j]));\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(results);'));
#28050=EXPRESS_CODE(#11386,('LOCAL\X\0A  results            : SET OF representation;\X\0A  result_bag         : BAG OF representation;\X\0A  intermediate_items : SET OF founded_item_select;\X\0AEND_LOCAL;\X\0A  results := [];\X\0A  result_bag := USEDIN(item, ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION.ITEMS'');\X\0A  IF SIZEOF(result_bag) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(result_bag);\X\0A      results := results + result_bag[i];\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  intermediate_items := using_items(item, []);\X\0A  IF SIZEOF(intermediate_items) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(intermediate_items);\X\0A      result_bag := USEDIN(intermediate_items[i],\X\0A                           ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION.ITEMS'');\X\0A      IF SIZEOF(result_bag) > 0\X\0A      THEN\X\0A        REPEAT j := 1 TO HIINDEX(result_bag);\X\0A          results := results + result_bag[j];\X\0A        END_REPEAT;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(results);'));
#28074=EXPRESS_CODE(#11388,('LOCAL\X\0A  local_s_d_r  : SET OF shape_definition_representation := [];\X\0A  local_s_d_r2 : BAG OF shape_definition_representation := [];\X\0A  local_s_a    : SET OF shape_aspect                    := [];\X\0A  i            : INTEGER;\X\0AEND_LOCAL;\X\0A  local_s_d_r2 := local_s_d_r2 +\X\0A                  QUERY(pdr\X\0A                        <* USEDIN(item,\X\0A                                  ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION_REPRESENTATION.USED_REPRESENTATION'')\X\0A                        | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_DEFINITION_REPRESENTATION'' IN\X\0A                          TYPEOF(pdr));\X\0A  local_s_d_r := bag_to_set(local_s_d_r2);\X\0A  REPEAT i := 1 TO HIINDEX(local_s_d_r);\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_ASPECT'' IN\X\0A        TYPEOF(local_s_d_r[i]\\property_definition_representation.definition\\property_definition.definition))\X\0A    THEN\X\0A      local_s_a := local_s_a +\X\0A                   local_s_d_r[i]\\property_definition_representation.definition\\property_definition.definition;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(local_s_a);'));
#28092=EXPRESS_CODE(#11390,('IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_CURVE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ELLIPSE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CIRCLE''] *\X\0A            TYPEOF(crv)) =\X\0A     1\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TRIMMED_CURVE'') IN TYPEOF(crv))\X\0A    THEN\X\0A      IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE'',\X\0A                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PARABOLA'',\X\0A                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.HYPERBOLA''] *\X\0A                TYPEOF(crv\\trimmed_curve.basis_curve)) =\X\0A         1\X\0A      THEN\X\0A        RETURN(true);\X\0A      ELSE\X\0A        RETURN(valid_basis_curve_in_2d_wireframe(crv\\trimmed_curve.basis_curve));\X\0A      END_IF;\X\0A    ELSE\X\0A      IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_2D'') IN TYPEOF(crv))\X\0A      THEN\X\0A        RETURN(valid_basis_curve_in_2d_wireframe(crv\\offset_curve_2d.basis_curve));\X\0A      ELSE\X\0A        IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'') IN TYPEOF(crv))\X\0A        THEN\X\0A          RETURN(valid_basis_curve_in_2d_wireframe(crv\\curve_replica.parent_curve));\X\0A        ELSE\X\0A          IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COMPOSITE_CURVE'') IN TYPEOF(crv))\X\0A          THEN\X\0A            RETURN(SIZEOF(QUERY(ccs\X\0A                                <* crv\\composite_curve.segments\X\0A                                | NOT (valid_basis_curve_in_2d_wireframe(ccs.parent_curve)))) =\X\0A                   0);\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
#28095=EXPRESS_CODE(#11392,('CASE date.month_component OF\X\0A    1 : RETURN({1 <= date.day_component <= 31});\X\0A    2 : BEGIN  \X\0A               IF (leap_year(date.year_component))\X\0A               THEN\X\0A                 RETURN({1 <= date.day_component <= 29});\X\0A               ELSE\X\0A                 RETURN({1 <= date.day_component <= 28});\X\0A               END_IF;\X\0A    END;\X\0A    3 : RETURN({1 <= date.day_component <= 31});\X\0A    4 : RETURN({1 <= date.day_component <= 30});\X\0A    5 : RETURN({1 <= date.day_component <= 31});\X\0A    6 : RETURN({1 <= date.day_component <= 30});\X\0A    7 : RETURN({1 <= date.day_component <= 31});\X\0A    8 : RETURN({1 <= date.day_component <= 31});\X\0A    9 : RETURN({1 <= date.day_component <= 30});\X\0A    10 : RETURN({1 <= date.day_component <= 31});\X\0A    11 : RETURN({1 <= date.day_component <= 30});\X\0A    12 : RETURN({1 <= date.day_component <= 31});\X\0A  END_CASE;\X\0A  RETURN(false);'));
