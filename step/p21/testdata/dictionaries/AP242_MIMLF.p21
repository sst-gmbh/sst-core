#26400=EXPRESS_CODE(#11086,('LOCAL\X\0A  temp : maths_space;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(func)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF space_dimension(func.domain) <> 1\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  temp := factor1(func.domain);\X\0A  IF (schema_prefix + ''PRODUCT_SPACE'') IN TYPEOF(temp)\X\0A  THEN\X\0A    IF space_dimension(temp) <> 1\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    temp := factor1(temp);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
#26404=EXPRESS_CODE(#11088,('LOCAL\X\0A  temp : maths_space;\X\0A  itvl : finite_integer_interval;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(func)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF space_dimension(func.domain) <> 1\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  temp := factor1(func.domain);\X\0A  IF (schema_prefix + ''PRODUCT_SPACE'') IN TYPEOF(temp)\X\0A  THEN\X\0A    IF space_dimension(temp) <> 1\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    temp := factor1(temp);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp)\X\0A  THEN\X\0A    itvl := temp;\X\0A    RETURN(bool((itvl.min = 0) OR (itvl.min = 1)));\X\0A  END_IF;\X\0A  RETURN(false);'));
#26409=EXPRESS_CODE(#11090,('LOCAL\X\0A  temp   : maths_space;\X\0A  pspace : product_space;\X\0A  itvl1  : finite_integer_interval;\X\0A  itvl2  : finite_integer_interval;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(func)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF space_dimension(func.domain) <> 1\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  temp := factor1(func.domain);\X\0A  IF NOT (''PRODUCT_SPACE'' IN stripped_typeof(temp))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  pspace := temp;\X\0A  IF space_dimension(pspace) <> 2\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  temp := factor1(pspace);\X\0A  IF NOT (''FINITE_INTEGER_INTERVAL'' IN stripped_typeof(temp))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  itvl1 := temp;\X\0A  temp := factor_space(pspace, 2);\X\0A  IF NOT (''FINITE_INTEGER_INTERVAL'' IN stripped_typeof(temp))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  itvl2 := temp;\X\0A  RETURN(bool((itvl1.min = itvl2.min) AND ((itvl1.min = 0) OR (itvl1.min = 1))));'));
#26416=EXPRESS_CODE(#11092,('LOCAL\X\0A  tspace : tuple_space;\X\0A  temp   : maths_space;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(func)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  tspace := func.domain;\X\0A  IF (space_dimension(tspace) = 1) AND ((schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(factor1(tspace)))\X\0A  THEN\X\0A    tspace := factor1(tspace);\X\0A  END_IF;\X\0A  IF NOT ((schema_prefix + ''PRODUCT_SPACE'') IN TYPEOF(tspace))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO space_dimension(tspace);\X\0A    temp := factor_space(tspace, i);\X\0A    IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#26421=EXPRESS_CODE(#26420,('space_dimension(tspace)'));
#26424=EXPRESS_CODE(#11094,('LOCAL\X\0A  tspace : tuple_space;\X\0A  temp   : maths_space;\X\0A  base   : INTEGER;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(func)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  tspace := func.domain;\X\0A  IF (space_dimension(tspace) = 1) AND ((schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(factor1(tspace)))\X\0A  THEN\X\0A    tspace := factor1(tspace);\X\0A  END_IF;\X\0A  IF NOT ((schema_prefix + ''PRODUCT_SPACE'') IN TYPEOF(tspace))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  temp := factor1(tspace);\X\0A  IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  base := temp\\finite_integer_interval.min;\X\0A  IF (base <> 0) AND (base <> 1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  REPEAT i := 2 TO space_dimension(tspace);\X\0A    temp := factor_space(tspace, i);\X\0A    IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF temp\\finite_integer_interval.min <> base\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#26430=EXPRESS_CODE(#26429,('space_dimension(tspace)'));
#26433=EXPRESS_CODE(#11096,('IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOUNDED_CURVE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_3D''] *\X\0A            TYPEOF(cv)) >\X\0A     1\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CIRCLE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ELLIPSE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TRIMMED_CURVE''] *\X\0A            TYPEOF(cv)) =\X\0A     1\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_CURVE'' IN TYPEOF(cv)) AND\X\0A        (cv\\b_spline_curve.self_intersect = false) OR\X\0A        (cv\\b_spline_curve.self_intersect = unknown))\X\0A    THEN\X\0A      RETURN(true);\X\0A    ELSE\X\0A      IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COMPOSITE_CURVE'' IN TYPEOF(cv)) AND\X\0A          (cv\\composite_curve.self_intersect = false) OR\X\0A          (cv\\composite_curve.self_intersect = unknown))\X\0A      THEN\X\0A        RETURN(SIZEOF(QUERY(seg <* cv\\composite_curve.segments | NOT (gbsf_check_curve(seg.parent_curve)))) = 0);\X\0A      ELSE\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'' IN TYPEOF(cv)\X\0A        THEN\X\0A          RETURN(gbsf_check_curve(cv\\curve_replica.parent_curve));\X\0A        ELSE\X\0A          IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_3D'' IN TYPEOF(cv)) AND\X\0A              ((cv\\offset_curve_3d.self_intersect = false) OR (cv\\offset_curve_3d.self_intersect = unknown)) AND\X\0A              (NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'' IN\X\0A                    TYPEOF(cv\\offset_curve_3d.basis_curve))))\X\0A          THEN\X\0A            RETURN(gbsf_check_curve(cv\\offset_curve_3d.basis_curve));\X\0A          ELSE\X\0A            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(cv)\X\0A            THEN\X\0A              RETURN((gbsf_check_curve(cv\\pcurve.reference_to_curve\\representation.items[1])) AND\X\0A                     (gbsf_check_surface(cv\\pcurve.basis_surface)));\X\0A            ELSE\X\0A              IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'' IN TYPEOF(cv)\X\0A              THEN\X\0A                IF (SIZEOF(cv\\polyline.points) >= 3)\X\0A                THEN\X\0A                  RETURN(true);\X\0A                END_IF;\X\0A              ELSE\X\0A                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_CURVE'' IN TYPEOF(cv)\X\0A                THEN\X\0A                  IF gbsf_check_curve(cv\\surface_curve.curve_3d)\X\0A                  THEN\X\0A                    REPEAT i := 1 TO SIZEOF(cv\\surface_curve.associated_geometry);\X\0A                      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE'' IN\X\0A                         TYPEOF(cv\\surface_curve.associated_geometry[i])\X\0A                      THEN\X\0A                        IF NOT gbsf_check_surface(cv\\surface_curve.associated_geometry[i])\X\0A                        THEN\X\0A                          RETURN(false);\X\0A                        END_IF;\X\0A                      ELSE\X\0A                        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN\X\0A                           TYPEOF(cv\\surface_curve.associated_geometry[i])\X\0A                        THEN\X\0A                          IF NOT gbsf_check_curve(cv\\surface_curve.associated_geometry[i])\X\0A                          THEN\X\0A                            RETURN(false);\X\0A                          END_IF;\X\0A                        END_IF;\X\0A                      END_IF;\X\0A                    END_REPEAT;\X\0A                    RETURN(true);\X\0A                  END_IF;\X\0A                END_IF;\X\0A              END_IF;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
#26438=EXPRESS_CODE(#11098,('IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CARTESIAN_POINT'' IN TYPEOF(pnt)\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_ON_CURVE'' IN TYPEOF(pnt)\X\0A    THEN\X\0A      RETURN(gbsf_check_curve(pnt\\point_on_curve.basis_curve));\X\0A    ELSE\X\0A      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_ON_SURFACE'' IN TYPEOF(pnt)\X\0A      THEN\X\0A        RETURN(gbsf_check_surface(pnt\\point_on_surface.basis_surface));\X\0A      ELSE\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DEGENERATE_PCURVE'' IN TYPEOF(pnt)\X\0A        THEN\X\0A          RETURN((gbsf_check_curve(pnt\\degenerate_pcurve.reference_to_curve\\representation.items[1])) AND\X\0A                 (gbsf_check_surface(pnt\\degenerate_pcurve.basis_surface)));\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
#26441=EXPRESS_CODE(#11100,('IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_SURFACE'' IN TYPEOF(sf)) AND\X\0A      (sf\\b_spline_surface.self_intersect = false) OR\X\0A      (sf\\b_spline_surface.self_intersect = unknown))\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SPHERICAL_SURFACE'',\X\0A               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TOROIDAL_SURFACE'',\X\0A               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_BOUNDED_SURFACE'',\X\0A               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.RECTANGULAR_TRIMMED_SURFACE''] *\X\0A              TYPEOF(sf)) =\X\0A       1\X\0A    THEN\X\0A      RETURN(true);\X\0A    ELSE\X\0A      IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_SURFACE'' IN TYPEOF(sf)) AND\X\0A          (sf\\offset_surface.self_intersect = false) OR\X\0A          (sf\\offset_surface.self_intersect = unknown))\X\0A      THEN\X\0A        RETURN(gbsf_check_surface(sf\\offset_surface.basis_surface));\X\0A      ELSE\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.RECTANGULAR_COMPOSITE_SURFACE'' IN TYPEOF(sf)\X\0A        THEN\X\0A          REPEAT i := 1 TO SIZEOF(sf\\rectangular_composite_surface.segments);\X\0A            REPEAT j := 1 TO SIZEOF(sf\\rectangular_composite_surface.segments[i]);\X\0A              IF NOT (gbsf_check_surface(sf\\rectangular_composite_surface.segments[i][j].parent_surface))\X\0A              THEN\X\0A                RETURN(false);\X\0A              END_IF;\X\0A            END_REPEAT;\X\0A          END_REPEAT;\X\0A          RETURN(true);\X\0A        ELSE\X\0A          IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_REPLICA'' IN TYPEOF(sf)\X\0A          THEN\X\0A            RETURN(gbsf_check_surface(sf\\surface_replica.parent_surface));\X\0A          ELSE\X\0A            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_OF_REVOLUTION'' IN TYPEOF(sf)\X\0A            THEN\X\0A              RETURN(gbsf_check_curve(sf\\swept_surface.swept_curve));\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
#26451=EXPRESS_CODE(#11102,('LOCAL\X\0A  grcs_1d : INTEGER := 0;\X\0A  grcs_2d : INTEGER := 0;\X\0A  grcs_3d : INTEGER := 0;\X\0AEND_LOCAL;\X\0A  IF (SIZEOF(grcs) = 1)\X\0A  THEN\X\0A    RETURN(grcs[1]\\geometric_representation_context.coordinate_space_dimension);\X\0A  ELSE\X\0A    REPEAT i := 1 TO HIINDEX(grcs);\X\0A      IF (grcs[i]\\geometric_representation_context.coordinate_space_dimension = 1)\X\0A      THEN\X\0A        grcs_1d := grcs_1d + 1;\X\0A      ELSE\X\0A        IF (grcs[i]\\geometric_representation_context.coordinate_space_dimension = 2)\X\0A        THEN\X\0A          grcs_2d := grcs_2d + 1;\X\0A        ELSE\X\0A          IF (grcs[i]\\geometric_representation_context.coordinate_space_dimension = 3)\X\0A          THEN\X\0A            grcs_3d := grcs_3d + 1;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (grcs_1d + grcs_2d = 0)\X\0A  THEN\X\0A    RETURN(3);\X\0A  ELSE\X\0A    IF (grcs_1d + grcs_3d = 0)\X\0A    THEN\X\0A      RETURN(2);\X\0A    ELSE\X\0A      IF (grcs_2d + grcs_3d = 0)\X\0A      THEN\X\0A        RETURN(1);\X\0A      ELSE\X\0A        RETURN(0);\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;'));
#26459=EXPRESS_CODE(#11104,('LOCAL\X\0A  aggregate_id_bag : BAG OF aggregate_id_attribute := (USEDIN(obj,\X\0A                                                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.AGGREGATE_ID_ATTRIBUTE.IDENTIFIED_ITEM''));\X\0AEND_LOCAL;\X\0A  IF SIZEOF(aggregate_id_bag) = 1\X\0A  THEN\X\0A    RETURN(aggregate_id_bag[1].attribute_value);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#26467=EXPRESS_CODE(#11106,('LOCAL\X\0A  result        : SET OF STRING                       := [];\X\0A  adrs_raw      : SET OF applied_document_reference   := bag_to_set(USEDIN(pdc,\X\0A                                                                           ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.APPLIED_DOCUMENT_REFERENCE.ITEMS''));\X\0A  adrs_filtered : SET OF applied_document_reference   := [];\X\0A  ras           : SET OF role_association;\X\0A  dpas          : SET OF document_product_association;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(adrs_raw);\X\0A    IF adrs_raw[i]\\document_reference.role\\object_role.name = ''mandatory''\X\0A    THEN\X\0A      adrs_filtered := adrs_filtered + adrs_raw[i];\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO HIINDEX(adrs_filtered);\X\0A    dpas := bag_to_set(USEDIN(adrs_filtered[i]\\document_reference.assigned_document,\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DOCUMENT_PRODUCT_ASSOCIATION.RELATING_DOCUMENT''));\X\0A    REPEAT j := 1 TO HIINDEX(dpas);\X\0A      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DOCUMENT_PRODUCT_EQUIVALENCE'' IN TYPEOF(dpas[j])\X\0A      THEN\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_FORMATION'' IN\X\0A           TYPEOF(dpas[j]\\document_product_association.related_product)\X\0A        THEN\X\0A          result := result +\X\0A                    dpas[j]\\document_product_association.related_product\\product_definition_formation.of_product\\product.id;\X\0A        END_IF;\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT'' IN TYPEOF(dpas[j].related_product)\X\0A        THEN\X\0A          result := result + dpas[j]\\document_product_association.related_product\\product.id;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
#26498=EXPRESS_CODE(#11108,('LOCAL\X\0A  surfs : SET [0 : 2] OF surface;\X\0A  n     : INTEGER;\X\0AEND_LOCAL;\X\0A  surfs := [];\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(c)\X\0A  THEN\X\0A    surfs := [c\\pcurve.basis_surface];\X\0A  ELSE\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_CURVE'' IN TYPEOF(c)\X\0A    THEN\X\0A      n := SIZEOF(c\\surface_curve.associated_geometry);\X\0A      REPEAT i := 1 TO n;\X\0A        surfs := surfs + associated_surface(c\\surface_curve.associated_geometry[i]);\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COMPOSITE_CURVE_ON_SURFACE'' IN TYPEOF(c)\X\0A  THEN\X\0A    n := SIZEOF(c\\composite_curve.segments);\X\0A    surfs := get_basis_surface(c\\composite_curve.segments[1].parent_curve);\X\0A    IF n > 1\X\0A    THEN\X\0A      REPEAT i := 2 TO n;\X\0A        surfs := surfs * get_basis_surface(c\\composite_curve.segments[i].parent_curve);\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(surfs);'));
#26507=EXPRESS_CODE(#26506,('n'));
