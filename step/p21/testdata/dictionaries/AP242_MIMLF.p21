#28824=EXPRESS_CODE(#11552,('LOCAL\X\0A  names : SET OF STRING := [''within a circle'',\X\0A                            ''within a cylinder'',\X\0A                            ''within a cone'',\X\0A                            ''within a single complex surface'',\X\0A                            ''within a sphere'',\X\0A                            ''between two coaxial cylinders'',\X\0A                            ''between two concentric circles'',\X\0A                            ''between two equidistant curves'',\X\0A                            ''between two equidistant complex lines or two parallel straight lines'',\X\0A                            ''between two equidistant complex surfaces or two parallel planes'',\X\0A                            ''between two equidistant surfaces'',\X\0A                            ''between two non-equidistant complex lines or two non-parallel straight lines'',\X\0A                            ''between two non-equidistant complex surfaces or two non-parallel planes'',\X\0A                            ''between two parallel circles on a conical surface'',\X\0A                            ''between two parallel circles of the same diameter'',\X\0A                            ''non uniform'',\X\0A                            ''cylindrical or circular'',\X\0A                            ''spherical'',\X\0A                            ''unknown''];\X\0A  pass  : BOOLEAN       := true;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(tolerance_zone_form)\X\0A  WHILE pass;\X\0A    pass := (tolerance_zone_form[i].name IN names);\X\0A  END_REPEAT;'));
