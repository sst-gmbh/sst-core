#26513=EXPRESS_CODE(#11110,('LOCAL\X\0A  coordinate_values : coordinates_list;\X\0A  max               : INTEGER;\X\0AEND_LOCAL;\X\0A  (* If source is of type tessellated_face its single coordinates_list is returned *)\X\0A  CASE true OF\X\0A    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_FACE'' IN\X\0A    TYPEOF(source) : BEGIN  \X\0A                            coordinate_values := source\\tessellated_face.coordinates;\X\0A                            RETURN(coordinate_values);\X\0A    END;\X\0A    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_SURFACE_SET'' IN\X\0A    TYPEOF(source) : BEGIN  \X\0A                            coordinate_values := source\\tessellated_surface_set.coordinates;\X\0A                            RETURN(coordinate_values);\X\0A    END;\X\0A    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_SOLID'' IN\X\0A    TYPEOF(source) : BEGIN  \X\0A                            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_FACE'' IN\X\0A                               TYPEOF(source\\tessellated_solid.items[1])\X\0A                            THEN\X\0A                              coordinate_values := source\\tessellated_solid.items[1]\\tessellated_face.coordinates;\X\0A                            END_IF;\X\0A                            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_EDGE'' IN\X\0A                               TYPEOF(source\\tessellated_solid.items[1])\X\0A                            THEN\X\0A                              coordinate_values := source\\tessellated_solid.items[1]\\tessellated_edge.coordinates;\X\0A                            END_IF;\X\0A                            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_VERTEX'' IN\X\0A                               TYPEOF(source\\tessellated_solid.items[1])\X\0A                            THEN\X\0A                              coordinate_values := source\\tessellated_solid.items[1]\\tessellated_vertex.coordinates;\X\0A                            END_IF;\X\0A                            max := SIZEOF(source\\tessellated_solid.items);\X\0A                            IF max = 1\X\0A                            THEN\X\0A                              RETURN(coordinate_values);\X\0A                            ELSE\X\0A                              REPEAT i := 2 TO max;\X\0A                                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_FACE'' IN\X\0A                                   TYPEOF(source\\tessellated_solid.items[i])\X\0A                                THEN\X\0A                                  IF NOT (coordinate_values :=:\X\0A                                          source\\tessellated_solid.items[i]\\tessellated_face.coordinates)\X\0A                                  THEN\X\0A                                    RETURN(?);\X\0A                                  END_IF;\X\0A                                END_IF;\X\0A                                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_EDGE'' IN\X\0A                                   TYPEOF(source\\tessellated_solid.items[i])\X\0A                                THEN\X\0A                                  IF NOT (coordinate_values :=:\X\0A                                          source\\tessellated_solid.items[i]\\tessellated_edge.coordinates)\X\0A                                  THEN\X\0A                                    RETURN(?);\X\0A                                  END_IF;\X\0A                                END_IF;\X\0A                                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_VERTEX'' IN\X\0A                                   TYPEOF(source\\tessellated_solid.items[i])\X\0A                                THEN\X\0A                                  IF NOT (coordinate_values :=:\X\0A                                          source\\tessellated_solid.items[i]\\tessellated_vertex.coordinates)\X\0A                                  THEN\X\0A                                    RETURN(?);\X\0A                                  END_IF;\X\0A                                END_IF;\X\0A                              END_REPEAT;\X\0A                              RETURN(coordinate_values);\X\0A                            END_IF;\X\0A    END;\X\0A    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_SHELL'' IN\X\0A    TYPEOF(source) : BEGIN  \X\0A                            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_FACE'' IN\X\0A                               TYPEOF(source\\tessellated_shell.items[1])\X\0A                            THEN\X\0A                              coordinate_values := source\\tessellated_shell.items[1]\\tessellated_face.coordinates;\X\0A                            END_IF;\X\0A                            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_EDGE'' IN\X\0A                               TYPEOF(source\\tessellated_shell.items[1])\X\0A                            THEN\X\0A                              coordinate_values := source\\tessellated_shell.items[1]\\tessellated_edge.coordinates;\X\0A                            END_IF;\X\0A                            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_VERTEX'' IN\X\0A                               TYPEOF(source\\tessellated_shell.items[1])\X\0A                            THEN\X\0A                              coordinate_values := source\\tessellated_shell.items[1]\\tessellated_vertex.coordinates;\X\0A                            END_IF;\X\0A                            max := SIZEOF(source\\tessellated_shell.items);\X\0A                            IF max = 1\X\0A                            THEN\X\0A                              RETURN(coordinate_values);\X\0A                            ELSE\X\0A                              REPEAT i := 2 TO max;\X\0A                                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_FACE'' IN\X\0A                                   TYPEOF(source\\tessellated_shell.items[i])\X\0A                                THEN\X\0A                                  IF NOT (coordinate_values :=:\X\0A                                          source\\tessellated_shell.items[i]\\tessellated_face.coordinates)\X\0A                                  THEN\X\0A                                    RETURN(?);\X\0A                                  END_IF;\X\0A                                END_IF;\X\0A                                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_EDGE'' IN\X\0A                                   TYPEOF(source\\tessellated_shell.items[i])\X\0A                                THEN\X\0A                                  IF NOT (coordinate_values :=:\X\0A                                          source\\tessellated_shell.items[i]\\tessellated_edge.coordinates)\X\0A                                  THEN\X\0A                                    RETURN(?);\X\0A                                  END_IF;\X\0A                                END_IF;\X\0A                                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TESSELLATED_VERTEX'' IN\X\0A                                   TYPEOF(source\\tessellated_shell.items[i])\X\0A                                THEN\X\0A                                  IF NOT (coordinate_values :=:\X\0A                                          source\\tessellated_shell.items[i]\\tessellated_vertex.coordinates)\X\0A                                  THEN\X\0A                                    RETURN(?);\X\0A                                  END_IF;\X\0A                                END_IF;\X\0A                              END_REPEAT;\X\0A                              RETURN(coordinate_values);\X\0A                            END_IF;\X\0A    END;\X\0A  END_CASE;'));
#26518=EXPRESS_CODE(#26517,('max'));
