#27082=EXPRESS_CODE(#11228,('LOCAL\X\0A  types : SET OF STRING := TYPEOF(spc);\X\0AEND_LOCAL;\X\0A  IF ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN types) OR ((schema_prefix + ''INTEGER_INTERVAL_TO_MAX'') IN types)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''FINITE_REAL_INTERVAL'') IN types)\X\0A  THEN\X\0A    RETURN(bool(spc\\finite_real_interval.max_closure = closed));\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''REAL_INTERVAL_TO_MAX'') IN types)\X\0A  THEN\X\0A    RETURN(bool(spc\\real_interval_to_max.max_closure = closed));\X\0A  END_IF;\X\0A  RETURN(false);'));
#27087=EXPRESS_CODE(#11230,('LOCAL\X\0A  pmi_role : STRING                                                    := input\\annotation_placeholder_occurrence.item\\representation_item.name;\X\0A  dmiawps  : SET OF draughting_model_item_association_with_placeholder := input\\annotation_placeholder_occurrence.the_draughting_model_item_association_with_placeholders;\X\0A  v        : SET OF STRING                                             := [];\X\0AEND_LOCAL;\X\0A  IF (SIZEOF(dmiawps) = 1)\X\0A  THEN\X\0A    v := TYPEOF(dmiawps[1]\\draughting_model_item_association_with_placeholder.definition);\X\0A  ELSE\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF NOT (pmi_role IN\X\0A          [''angular dimension'',\X\0A           ''angularity'',\X\0A           ''circular runout'',\X\0A           ''circularity'',\X\0A           ''coaxiality'',\X\0A           ''concentricity'',\X\0A           ''curve dimension'',\X\0A           ''cylindricity'',\X\0A           ''datum'',\X\0A           ''datum target'',\X\0A           ''diameter dimension'',\X\0A           ''flatness'',\X\0A           ''general dimension'',\X\0A           ''general note'',\X\0A           ''general tolerance'',\X\0A           ''label'',\X\0A           ''linear dimension'',\X\0A           ''note'',\X\0A           ''ordinate dimension'',\X\0A           ''parallelism'',\X\0A           ''perpendicularity'',\X\0A           ''position'',\X\0A           ''profile of line'',\X\0A           ''profile of surface'',\X\0A           ''radial dimension'',\X\0A           ''roundness'',\X\0A           ''runout'',\X\0A           ''straightness'',\X\0A           ''surface roughness'',\X\0A           ''symmetry'',\X\0A           ''total runout''])\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  CASE pmi_role OF\X\0A    ''angular dimension'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ANGULAR_LOCATION'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''angularity'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ANGULARITY_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''circular runout'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CIRCULAR_RUNOUT_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''circularity'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ROUNDNESS_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''coaxiality'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COAXIALITY_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''concentricity'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONCENTRICITY_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''curve dimension'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''cylindricity'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CYLINDRICITY_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''datum'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATUM'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''datum target'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATUM_TARGET'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''diameter dimension'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''flatness'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FLATNESS_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''general dimension'' : IF (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'',\X\0A                                      ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_LOCATION''] *\X\0A                                     v) =\X\0A                              1)\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''general note'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''general tolerance'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.GEOMETRIC_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''label'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''linear dimension'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''note'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''ordinate dimension'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''parallelism'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PARALLELISM_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''perpendicularity'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PERPENDICULARITY_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''position'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POSITION_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''profile of line'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE_PROFILE_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''profile of surface'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_PROFILE_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''radial dimension'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''roundness'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ROUNDNESS_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''runout'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TOTAL_RUNOUT_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''straightness'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.STRAIGHTNESS_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''surface roughness'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PROPERTY_DEFINITION'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''symmetry'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SYMMETRY_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    ''total runout'' : IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TOTAL_RUNOUT_TOLERANCE'' IN v\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    OTHERWISE: RETURN(false);\X\0A  END_CASE;'));
#27097=EXPRESS_CODE(#11232,('LOCAL\X\0A  pass       : BOOLEAN                := true;\X\0A  boxes      : BAG OF planar_box      := [];\X\0A  texts      : BAG OF annotation_text := [];\X\0A  placements : BAG OF placement       := [];\X\0A  points     : BAG OF point           := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := LOINDEX(input\\geometric_set.elements) TO HIINDEX(input\\geometric_set.elements);\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT'' IN TYPEOF(input\\geometric_set.elements[i])) AND\X\0A       NOT (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CARTESIAN_POINT'',\X\0A                    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_ON_CURVE'',\X\0A                    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_ON_SURFACE''] *\X\0A                   TYPEOF(input\\geometric_set.elements[i])) =\X\0A            1)\X\0A    THEN\X\0A      pass := false;\X\0A    ELSE\X\0A      points := points + input\\geometric_set.elements[i];\X\0A    END_IF;\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANAR_BOX'' IN TYPEOF(input\\geometric_set.elements[i])\X\0A    THEN\X\0A      boxes := boxes + input\\geometric_set.elements[i];\X\0A    END_IF;\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ANNOTATION_TEXT'' IN TYPEOF(input\\geometric_set.elements[i])\X\0A    THEN\X\0A      texts := texts + input\\geometric_set.elements[i];\X\0A    END_IF;\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLACEMENT'' IN TYPEOF(input\\geometric_set.elements[i])\X\0A    THEN\X\0A      placements := placements + input\\geometric_set.elements[i];\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  IF SIZEOF(boxes) > 1\X\0A  THEN\X\0A    pass := false;\X\0A  END_IF;\X\0A  IF SIZEOF(texts) > 1\X\0A  THEN\X\0A    pass := false;\X\0A  END_IF;\X\0A  IF SIZEOF(placements) <> 1\X\0A  THEN\X\0A    pass := false;\X\0A  END_IF;\X\0A  RETURN(pass);'));
#27120=EXPRESS_CODE(#11234,('FUNCTION fedex(val : AGGREGATE OF GENERIC : X;\X\0A               i : INTEGER) : GENERIC : X;\X\0A  RETURN(val[i]);\X\0AEND_FUNCTION;\X\0ALOCAL\X\0A  v         : maths_value            := simplify_maths_value(convert_to_maths_value(val));\X\0A  vtypes    : SET OF STRING          := stripped_typeof(v);\X\0A  s         : maths_space            := simplify_maths_space(spc);\X\0A  stypes    : SET OF STRING          := stripped_typeof(s);\X\0A  tmp_int   : INTEGER;\X\0A  tmp_real  : REAL;\X\0A  tmp_cmplx : complex_number_literal;\X\0A  lgcl      : LOGICAL;\X\0A  cum       : LOGICAL;\X\0A  vspc      : maths_space;\X\0A  sspc      : maths_space;\X\0A  smem      : SET OF maths_value;\X\0A  factors   : LIST OF maths_space;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(s)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF NOT EXISTS(v)\X\0A  THEN\X\0A    RETURN(s = the_generics);\X\0A  END_IF;\X\0A  IF (''GENERIC_EXPRESSION'' IN vtypes) AND\X\0A     NOT (''MATHS_SPACE'' IN vtypes) AND NOT (''MATHS_FUNCTION'' IN vtypes) AND NOT (''COMPLEX_NUMBER_LITERAL'' IN vtypes)\X\0A  THEN\X\0A    IF has_values_space(v)\X\0A    THEN\X\0A      vspc := values_space_of(v);\X\0A      IF subspace_of(vspc, s)\X\0A      THEN\X\0A        RETURN(true);\X\0A      END_IF;\X\0A      IF NOT compatible_spaces(vspc, s)\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      RETURN(unknown);\X\0A    END_IF;\X\0A    RETURN(unknown);\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_SPACE'' IN stypes\X\0A  THEN\X\0A    CASE s\\elementary_space.space_id OF\X\0A      es_numbers : RETURN((''NUMBER'' IN vtypes) OR (''COMPLEX_NUMBER_LITERAL'' IN vtypes));\X\0A      es_complex_numbers : RETURN(''COMPLEX_NUMBER_LITERAL'' IN vtypes);\X\0A      es_reals : RETURN((''REAL'' IN vtypes) AND NOT (''INTEGER'' IN vtypes));\X\0A      es_integers : RETURN(''INTEGER'' IN vtypes);\X\0A      es_logicals : RETURN(''LOGICAL'' IN vtypes);\X\0A      es_booleans : RETURN(''BOOLEAN'' IN vtypes);\X\0A      es_strings : RETURN(''STRING'' IN vtypes);\X\0A      es_binarys : RETURN(''BINARY'' IN vtypes);\X\0A      es_maths_spaces : RETURN(''MATHS_SPACE'' IN vtypes);\X\0A      es_maths_functions : RETURN(''MATHS_FUNCTION'' IN vtypes);\X\0A      es_generics : RETURN(true);\X\0A    END_CASE;\X\0A  END_IF;\X\0A  IF ''FINITE_INTEGER_INTERVAL'' IN stypes\X\0A  THEN\X\0A    IF ''INTEGER'' IN vtypes\X\0A    THEN\X\0A      tmp_int := v;\X\0A      RETURN({s\\finite_integer_interval.min <= tmp_int <= s\\finite_integer_interval.max});\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''INTEGER_INTERVAL_FROM_MIN'' IN stypes\X\0A  THEN\X\0A    IF ''INTEGER'' IN vtypes\X\0A    THEN\X\0A      tmp_int := v;\X\0A      RETURN(s\\integer_interval_from_min.min <= tmp_int);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''INTEGER_INTERVAL_TO_MAX'' IN stypes\X\0A  THEN\X\0A    IF ''INTEGER'' IN vtypes\X\0A    THEN\X\0A      tmp_int := v;\X\0A      RETURN(tmp_int <= s\\integer_interval_to_max.max);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FINITE_REAL_INTERVAL'' IN stypes\X\0A  THEN\X\0A    IF (''REAL'' IN vtypes) AND NOT (''INTEGER'' IN vtypes)\X\0A    THEN\X\0A      tmp_real := v;\X\0A      IF s\\finite_real_interval.min_closure = closed\X\0A      THEN\X\0A        IF s\\finite_real_interval.max_closure = closed\X\0A        THEN\X\0A          RETURN({s\\finite_real_interval.min <= tmp_real <= s\\finite_real_interval.max});\X\0A        ELSE\X\0A          RETURN({s\\finite_real_interval.min <= tmp_real < s\\finite_real_interval.max});\X\0A        END_IF;\X\0A      ELSE\X\0A        IF s\\finite_real_interval.max_closure = closed\X\0A        THEN\X\0A          RETURN({s\\finite_real_interval.min < tmp_real <= s\\finite_real_interval.max});\X\0A        ELSE\X\0A          RETURN({s\\finite_real_interval.min < tmp_real < s\\finite_real_interval.max});\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''REAL_INTERVAL_FROM_MIN'' IN stypes\X\0A  THEN\X\0A    IF (''REAL'' IN vtypes) AND NOT (''INTEGER'' IN vtypes)\X\0A    THEN\X\0A      tmp_real := v;\X\0A      IF s\\real_interval_from_min.min_closure = closed\X\0A      THEN\X\0A        RETURN(s\\real_interval_from_min.min <= tmp_real);\X\0A      ELSE\X\0A        RETURN(s\\real_interval_from_min.min < tmp_real);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''REAL_INTERVAL_TO_MAX'' IN stypes\X\0A  THEN\X\0A    IF (''REAL'' IN vtypes) AND NOT (''INTEGER'' IN vtypes)\X\0A    THEN\X\0A      tmp_real := v;\X\0A      IF s\\real_interval_to_max.max_closure = closed\X\0A      THEN\X\0A        RETURN(tmp_real <= s\\real_interval_to_max.max);\X\0A      ELSE\X\0A        RETURN(tmp_real < s\\real_interval_to_max.max);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''CARTESIAN_COMPLEX_NUMBER_REGION'' IN stypes\X\0A  THEN\X\0A    IF ''COMPLEX_NUMBER_LITERAL'' IN vtypes\X\0A    THEN\X\0A      RETURN(member_of(v\\complex_number_literal.real_part, s\\cartesian_complex_number_region.real_constraint) AND\X\0A             member_of(v\\complex_number_literal.imag_part, s\\cartesian_complex_number_region.imag_constraint));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''POLAR_COMPLEX_NUMBER_REGION'' IN stypes\X\0A  THEN\X\0A    IF ''COMPLEX_NUMBER_LITERAL'' IN vtypes\X\0A    THEN\X\0A      tmp_cmplx := v;\X\0A      tmp_cmplx.real_part := tmp_cmplx.real_part - s\\polar_complex_number_region.centre.real_part;\X\0A      tmp_cmplx.imag_part := tmp_cmplx.imag_part - s\\polar_complex_number_region.centre.imag_part;\X\0A      tmp_real := SQRT(tmp_cmplx.real_part ** 2 + tmp_cmplx.imag_part ** 2);\X\0A      IF NOT member_of(tmp_real, s\\polar_complex_number_region.distance_constraint)\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      IF tmp_real = 0.0\X\0A      THEN\X\0A        RETURN(true);\X\0A      END_IF;\X\0A      tmp_real := atan2(tmp_cmplx.imag_part, tmp_cmplx.real_part);\X\0A      RETURN(member_of(tmp_real, s\\polar_complex_number_region.direction_constraint) OR\X\0A             member_of(tmp_real + 2.0 * PI, s\\polar_complex_number_region.direction_constraint));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FINITE_SPACE'' IN stypes\X\0A  THEN\X\0A    smem := s\\finite_space.members;\X\0A    cum := false;\X\0A    REPEAT i := 1 TO SIZEOF(smem);\X\0A      cum := cum OR equal_maths_values(v, smem[i]);\X\0A      IF cum = true\X\0A      THEN\X\0A        RETURN(true);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(cum);\X\0A  END_IF;\X\0A  IF ''UNIFORM_PRODUCT_SPACE'' IN stypes\X\0A  THEN\X\0A    IF ''LIST'' IN vtypes\X\0A    THEN\X\0A      IF SIZEOF(v) = s\\uniform_product_space.exponent\X\0A      THEN\X\0A        sspc := s\\uniform_product_space.base;\X\0A        cum := true;\X\0A        REPEAT i := 1 TO SIZEOF(v);\X\0A          cum := cum AND member_of(v[i], sspc);\X\0A          IF cum = false\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        RETURN(cum);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''LISTED_PRODUCT_SPACE'' IN stypes\X\0A  THEN\X\0A    IF ''LIST'' IN vtypes\X\0A    THEN\X\0A      factors := s\\listed_product_space.factors;\X\0A      IF SIZEOF(v) = SIZEOF(factors)\X\0A      THEN\X\0A        cum := true;\X\0A        REPEAT i := 1 TO SIZEOF(v);\X\0A          cum := cum AND member_of(v[i], factors[i]);\X\0A          IF cum = false\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        RETURN(cum);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''EXTENDED_TUPLE_SPACE'' IN stypes\X\0A  THEN\X\0A    IF ''LIST'' IN vtypes\X\0A    THEN\X\0A      sspc := s\\extended_tuple_space.base;\X\0A      tmp_int := space_dimension(sspc);\X\0A      IF SIZEOF(v) >= tmp_int\X\0A      THEN\X\0A        cum := true;\X\0A        REPEAT i := 1 TO tmp_int;\X\0A          cum := cum AND member_of(v[i], factor_space(sspc, i));\X\0A          IF cum = false\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        sspc := s\\extended_tuple_space.extender;\X\0A        REPEAT i := tmp_int + 1 TO SIZEOF(v);\X\0A          cum := cum AND member_of(v[i], sspc);\X\0A          IF cum = false\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        RETURN(cum);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FUNCTION_SPACE'' IN stypes\X\0A  THEN\X\0A    IF ''MATHS_FUNCTION'' IN vtypes\X\0A    THEN\X\0A      vspc := v\\maths_function.domain;\X\0A      sspc := s\\function_space.domain_argument;\X\0A      CASE s\\function_space.domain_constraint OF\X\0A        sc_equal : cum := equal_maths_spaces(vspc, sspc);\X\0A        sc_subspace : cum := subspace_of(vspc, sspc);\X\0A        sc_member : cum := member_of(vspc, sspc);\X\0A      END_CASE;\X\0A      IF cum = false\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      vspc := v\\maths_function.range;\X\0A      sspc := s\\function_space.range_argument;\X\0A      CASE s\\function_space.range_constraint OF\X\0A        sc_equal : cum := cum AND equal_maths_spaces(vspc, sspc);\X\0A        sc_subspace : cum := cum AND subspace_of(vspc, sspc);\X\0A        sc_member : cum := cum AND member_of(vspc, sspc);\X\0A      END_CASE;\X\0A      RETURN(cum);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  RETURN(unknown);'));
#27154=EXPRESS_CODE(#27153,('tmp_int'));
#27156=EXPRESS_CODE(#27155,('tmp_int + 1'));
#27160=EXPRESS_CODE(#11238,('LOCAL\X\0A  types : SET OF STRING := TYPEOF(spc);\X\0AEND_LOCAL;\X\0A  RETURN(bool(((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN types) OR\X\0A              ((schema_prefix + ''INTEGER_INTERVAL_FROM_MIN'') IN types) OR\X\0A              ((schema_prefix + ''FINITE_REAL_INTERVAL'') IN types) OR\X\0A              ((schema_prefix + ''REAL_INTERVAL_FROM_MIN'') IN types)));'));
#27165=EXPRESS_CODE(#11240,('LOCAL\X\0A  types : SET OF STRING := TYPEOF(spc);\X\0AEND_LOCAL;\X\0A  IF ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN types) OR ((schema_prefix + ''INTEGER_INTERVAL_FROM_MIN'') IN types)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''FINITE_REAL_INTERVAL'') IN types)\X\0A  THEN\X\0A    RETURN(bool(spc\\finite_real_interval.min_closure = closed));\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''REAL_INTERVAL_FROM_MIN'') IN types)\X\0A  THEN\X\0A    RETURN(bool(spc\\real_interval_from_min.min_closure = closed));\X\0A  END_IF;\X\0A  RETURN(false);'));
#27173=EXPRESS_CODE(#11242,('LOCAL\X\0A  poly_loop_type : LOGICAL;\X\0AEND_LOCAL;\X\0A  IF (SIZEOF(l) <= 1)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  poly_loop_type := (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLY_LOOP'' IN TYPEOF(l[1]));\X\0A  REPEAT i := 2 TO SIZEOF(l);\X\0A    IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLY_LOOP'' IN TYPEOF(l[i])) <> poly_loop_type)\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(false);'));
#27182=EXPRESS_CODE(#11244,('LOCAL\X\0A  return_set : SET [1 : ?] OF closed_shell := [brep.outer];\X\0AEND_LOCAL;\X\0A  IF SIZEOF(QUERY(msbtype <* TYPEOF(brep) | msbtype LIKE ''*BREP_WITH_VOIDS'')) >= 1\X\0A  THEN\X\0A    return_set := return_set + brep\\brep_with_voids.voids;\X\0A  END_IF;\X\0A  RETURN(return_set);'));
#27189=EXPRESS_CODE(#11246,('IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOUNDED_CURVE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_3D''] *\X\0A            TYPEOF(cv)) >\X\0A     1\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  (* b_spline_curves shall not self-intersect\X\0A      *)\X\0A  IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_CURVE'' IN TYPEOF(cv)) AND\X\0A      (cv\\b_spline_curve.self_intersect = false) OR\X\0A      (cv\\b_spline_curve.self_intersect = unknown))\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'',\X\0A               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE''] *\X\0A              TYPEOF(cv)) =\X\0A       1\X\0A    THEN\X\0A      RETURN(true);\X\0A    ELSE\X\0A      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'' IN TYPEOF(cv)\X\0A      THEN\X\0A        RETURN(msf_curve_check(cv\\curve_replica.parent_curve));\X\0A      ELSE\X\0A        IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_3D'' IN TYPEOF(cv)) AND\X\0A            ((cv\\offset_curve_3d.self_intersect = false) OR (cv\\offset_curve_3d.self_intersect = unknown)) AND\X\0A            (NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'' IN\X\0A                  TYPEOF(cv\\offset_curve_3d.basis_curve))))\X\0A        THEN\X\0A          RETURN(msf_curve_check(cv\\offset_curve_3d.basis_curve));\X\0A        ELSE\X\0A          IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(cv)\X\0A          THEN\X\0A            RETURN((msf_curve_check(cv\\pcurve.reference_to_curve\\representation.items[1])) AND\X\0A                   (msf_surface_check(cv\\pcurve.basis_surface)));\X\0A          ELSE\X\0A            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_CURVE'' IN TYPEOF(cv)\X\0A            THEN\X\0A              IF msf_curve_check(cv\\surface_curve.curve_3d)\X\0A              THEN\X\0A                REPEAT i := 1 TO SIZEOF(cv\\surface_curve.associated_geometry);\X\0A                  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE'' IN\X\0A                     TYPEOF(cv\\surface_curve.associated_geometry[i])\X\0A                  THEN\X\0A                    IF NOT msf_surface_check(cv\\surface_curve.associated_geometry[i])\X\0A                    THEN\X\0A                      RETURN(false);\X\0A                    END_IF;\X\0A                  ELSE\X\0A                    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN\X\0A                       TYPEOF(cv\\surface_curve.associated_geometry[i])\X\0A                    THEN\X\0A                      IF NOT msf_curve_check(cv\\surface_curve.associated_geometry[i])\X\0A                      THEN\X\0A                        RETURN(false);\X\0A                      END_IF;\X\0A                    END_IF;\X\0A                  END_IF;\X\0A                END_REPEAT;\X\0A                RETURN(true);\X\0A              END_IF;\X\0A            ELSE\X\0A              IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'' IN TYPEOF(cv)\X\0A              THEN\X\0A                IF (SIZEOF(cv\\polyline.points) >= 3)\X\0A                THEN\X\0A                  RETURN(true);\X\0A                END_IF;\X\0A              END_IF;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  (* FALSE is returned if the input parameter cv is not a valid curve.\X\0A      *)\X\0A  RETURN(false);'));
#27194=EXPRESS_CODE(#11248,('IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ELEMENTARY_SURFACE'' IN TYPEOF(surf)\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SWEPT_SURFACE'' IN TYPEOF(surf)\X\0A    THEN\X\0A      RETURN(msf_curve_check(surf\\swept_surface.swept_curve));\X\0A    ELSE\X\0A      IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_SURFACE'' IN TYPEOF(surf)) AND\X\0A          (surf\\offset_surface.self_intersect = false) OR\X\0A          (surf\\offset_surface.self_intersect = unknown))\X\0A      THEN\X\0A        RETURN(msf_surface_check(surf\\offset_surface.basis_surface));\X\0A      ELSE\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_REPLICA'' IN TYPEOF(surf)\X\0A        THEN\X\0A          RETURN(msf_surface_check(surf\\surface_replica.parent_surface));\X\0A        ELSE\X\0A          IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_SURFACE'' IN TYPEOF(surf)) AND\X\0A              (surf\\b_spline_surface.self_intersect = false) OR\X\0A              (surf\\b_spline_surface.self_intersect = unknown))\X\0A          THEN\X\0A            RETURN(true);\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
#27197=EXPRESS_CODE(#11250,('IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOUNDED_CURVE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE'',\X\0A             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_3D''] *\X\0A            TYPEOF(cv)) >\X\0A     1\X\0A  THEN\X\0A    RETURN(false);\X\0A  ELSE\X\0A    IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_CURVE'' IN TYPEOF(cv)) AND\X\0A        (cv\\b_spline_curve.self_intersect = false) OR\X\0A        (cv\\b_spline_curve.self_intersect = unknown))\X\0A    THEN\X\0A      RETURN(true);\X\0A    ELSE\X\0A      IF SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'',\X\0A                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE''] *\X\0A                TYPEOF(cv)) =\X\0A         1\X\0A      THEN\X\0A        RETURN(true);\X\0A      ELSE\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CURVE_REPLICA'' IN TYPEOF(cv)\X\0A        THEN\X\0A          RETURN(nmsf_curve_check(cv\\curve_replica.parent_curve));\X\0A        ELSE\X\0A          IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_CURVE_3D'' IN TYPEOF(cv)) AND\X\0A              ((cv\\offset_curve_3d.self_intersect = false) OR (cv\\offset_curve_3d.self_intersect = unknown)) AND\X\0A              (NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'' IN\X\0A                    TYPEOF(cv\\offset_curve_3d.basis_curve))))\X\0A          THEN\X\0A            RETURN(nmsf_curve_check(cv\\offset_curve_3d.basis_curve));\X\0A          ELSE\X\0A            IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(cv)\X\0A            THEN\X\0A              RETURN((nmsf_curve_check(cv\\pcurve.reference_to_curve\\representation.items[1])) AND\X\0A                     (nmsf_surface_check(cv\\pcurve.basis_surface)));\X\0A            ELSE\X\0A              IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_CURVE'' IN TYPEOF(cv)\X\0A              THEN\X\0A                IF nmsf_curve_check(cv\\surface_curve.curve_3d)\X\0A                THEN\X\0A                  REPEAT i := 1 TO SIZEOF(cv\\surface_curve.associated_geometry);\X\0A                    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE'' IN\X\0A                       TYPEOF(cv\\surface_curve.associated_geometry[i])\X\0A                    THEN\X\0A                      IF NOT nmsf_surface_check(cv\\surface_curve.associated_geometry[i])\X\0A                      THEN\X\0A                        RETURN(false);\X\0A                      END_IF;\X\0A                    ELSE\X\0A                      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN\X\0A                         TYPEOF(cv\\surface_curve.associated_geometry[i])\X\0A                      THEN\X\0A                        IF NOT nmsf_curve_check(cv\\surface_curve.associated_geometry[i])\X\0A                        THEN\X\0A                          RETURN(false);\X\0A                        END_IF;\X\0A                      END_IF;\X\0A                    END_IF;\X\0A                  END_REPEAT;\X\0A                  RETURN(true);\X\0A                END_IF;\X\0A              ELSE\X\0A                IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POLYLINE'' IN TYPEOF(cv)\X\0A                THEN\X\0A                  IF (SIZEOF(cv\\polyline.points) >= 3)\X\0A                  THEN\X\0A                    RETURN(true);\X\0A                  END_IF;\X\0A                END_IF;\X\0A              END_IF;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  (* FALSE is returned if the input parameter cv is not a valid curve.\X\0A      *)\X\0A  RETURN(false);'));
#27202=EXPRESS_CODE(#11252,('IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ELEMENTARY_SURFACE'' IN TYPEOF(surf)\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SWEPT_SURFACE'' IN TYPEOF(surf)\X\0A    THEN\X\0A      RETURN(nmsf_curve_check(surf\\swept_surface.swept_curve));\X\0A    ELSE\X\0A      IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.OFFSET_SURFACE'' IN TYPEOF(surf)) AND\X\0A          (surf\\offset_surface.self_intersect = false) OR\X\0A          (surf\\offset_surface.self_intersect = unknown))\X\0A      THEN\X\0A        RETURN(nmsf_surface_check(surf\\offset_surface.basis_surface));\X\0A      ELSE\X\0A        IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_REPLICA'' IN TYPEOF(surf)\X\0A        THEN\X\0A          RETURN(nmsf_surface_check(surf\\surface_replica.parent_surface));\X\0A        ELSE\X\0A          IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.B_SPLINE_SURFACE'' IN TYPEOF(surf)) AND\X\0A              (surf\\b_spline_surface.self_intersect = false) OR\X\0A              (surf\\b_spline_surface.self_intersect = unknown))\X\0A          THEN\X\0A            RETURN(true);\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(false);'));
#27209=EXPRESS_CODE(#11254,('LOCAL\X\0A  typenames : SET OF STRING  := TYPEOF(ref);\X\0A  func      : maths_function;\X\0AEND_LOCAL;\X\0A  IF (NOT EXISTS(ref)) OR (NOT EXISTS(used))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''MATHS_SPACE'') IN typenames\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  func := ref;\X\0A  IF func IN used\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''CONSTANT_FUNCTION'') IN typenames\X\0A  THEN\X\0A    RETURN(no_cyclic_domain_reference(func\\constant_function.source_of_domain, used + [func]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''SELECTOR_FUNCTION'') IN typenames\X\0A  THEN\X\0A    RETURN(no_cyclic_domain_reference(func\\selector_function.source_of_domain, used + [func]));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''PARALLEL_COMPOSED_FUNCTION'') IN typenames\X\0A  THEN\X\0A    RETURN(no_cyclic_domain_reference(func\\parallel_composed_function.source_of_domain, used + [func]));\X\0A  END_IF;\X\0A  RETURN(true);'));
#27219=EXPRESS_CODE(#11256,('LOCAL\X\0A  types     : SET OF STRING;\X\0A  refs_plus : SET OF maths_space;\X\0AEND_LOCAL;\X\0A  IF (spc IN refs)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  types := TYPEOF(spc);\X\0A  refs_plus := refs + spc;\X\0A  IF (schema_prefix + ''FINITE_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(bool(SIZEOF(QUERY(sp\X\0A                             <* QUERY(mem <* spc\\finite_space.members | (schema_prefix + ''MATHS_SPACE'') IN TYPEOF(mem))\X\0A                             | NOT no_cyclic_space_reference(sp, refs_plus))) =\X\0A                0));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''UNIFORM_PRODUCT_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(no_cyclic_space_reference(spc\\uniform_product_space.base, refs_plus));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''LISTED_PRODUCT_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(bool(SIZEOF(QUERY(fac\X\0A                             <* spc\\listed_product_space.factors\X\0A                             | NOT no_cyclic_space_reference(fac, refs_plus))) =\X\0A                0));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''EXTENDED_TUPLE_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(no_cyclic_space_reference(spc\\extended_tuple_space.base, refs_plus) AND\X\0A           no_cyclic_space_reference(spc\\extended_tuple_space.extender, refs_plus));\X\0A  END_IF;\X\0A  RETURN(true);'));
#27231=EXPRESS_CODE(#11258,('IF NOT EXISTS(lr)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  REPEAT j := 2 TO SIZEOF(lr);\X\0A    IF lr[j] < lr[j - 1]\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#27236=EXPRESS_CODE(#11260,('LOCAL\X\0A  ndim   : INTEGER;\X\0A  v      : direction           := dummy_gri || direction([1.0,0.0,0.0]);\X\0A  result : vector_or_direction;\X\0A  vec    : vector              := dummy_gri || vector(v, 1.0);\X\0A  mag    : REAL;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(arg)\X\0A  THEN\X\0A    result := ?;\X\0A  ELSE\X\0A    ndim := arg.dim;\X\0A    IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VECTOR'' IN TYPEOF(arg)\X\0A    THEN\X\0A      BEGIN  \X\0A             v := dummy_gri || direction(arg\\vector.orientation.direction_ratios);\X\0A             IF arg\\vector.magnitude = 0.0\X\0A             THEN\X\0A               RETURN(?);\X\0A             ELSE\X\0A               vec := dummy_gri || vector(v, 1.0);\X\0A             END_IF;\X\0A      END;\X\0A    ELSE\X\0A      v := dummy_gri || direction(arg.direction_ratios);\X\0A    END_IF;\X\0A    mag := 0.0;\X\0A    REPEAT i := 1 TO ndim;\X\0A      mag := mag + v.direction_ratios[i] * v.direction_ratios[i];\X\0A    END_REPEAT;\X\0A    IF mag > 0.0\X\0A    THEN\X\0A      mag := SQRT(mag);\X\0A      REPEAT i := 1 TO ndim;\X\0A        v.direction_ratios[i] := v.direction_ratios[i] / mag;\X\0A      END_REPEAT;\X\0A      IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VECTOR'' IN TYPEOF(arg)\X\0A      THEN\X\0A        vec.orientation := v;\X\0A        result := vec;\X\0A      ELSE\X\0A        result := v;\X\0A      END_IF;\X\0A    ELSE\X\0A      RETURN(?);\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(result);'));
#27244=EXPRESS_CODE(#27243,('ndim'));
#27247=EXPRESS_CODE(#27246,('ndim'));
#27250=EXPRESS_CODE(#11262,('IF subspace_of_es(spc, es_integers)\X\0A  THEN\X\0A    RETURN(the_integers);\X\0A  END_IF;\X\0A  IF subspace_of_es(spc, es_reals)\X\0A  THEN\X\0A    RETURN(the_reals);\X\0A  END_IF;\X\0A  IF subspace_of_es(spc, es_complex_numbers)\X\0A  THEN\X\0A    RETURN(the_complex_numbers);\X\0A  END_IF;\X\0A  IF subspace_of_es(spc, es_numbers)\X\0A  THEN\X\0A    RETURN(the_numbers);\X\0A  END_IF;\X\0A  RETURN(?);'));
#27253=EXPRESS_CODE(#11264,('LOCAL\X\0A  types   : SET OF STRING       := stripped_typeof(spc);\X\0A  factors : LIST OF maths_space;\X\0A  cum     : LOGICAL             := true;\X\0AEND_LOCAL;\X\0A  IF ''UNIFORM_PRODUCT_SPACE'' IN types\X\0A  THEN\X\0A    RETURN(subspace_of_es(spc\\uniform_product_space.base, es_numbers));\X\0A  END_IF;\X\0A  IF ''LISTED_PRODUCT_SPACE'' IN types\X\0A  THEN\X\0A    factors := spc\\listed_product_space.factors;\X\0A    REPEAT i := 1 TO SIZEOF(factors);\X\0A      cum := cum AND subspace_of_es(factors[i], es_numbers);\X\0A    END_REPEAT;\X\0A    RETURN(cum);\X\0A  END_IF;\X\0A  IF ''EXTENDED_TUPLE_SPACE'' IN types\X\0A  THEN\X\0A    cum := subspace_of_es(spc\\extended_tuple_space.extender, es_numbers);\X\0A    cum := cum AND number_tuple_subspace_check(spc\\extended_tuple_space.base);\X\0A    RETURN(cum);\X\0A  END_IF;\X\0A  RETURN(false);'));
#27265=EXPRESS_CODE(#11266,('RETURN(make_uniform_product_space(spc, 1));'));
#27271=EXPRESS_CODE(#11268,('LOCAL\X\0A  pass : BOOLEAN := true;\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(input);\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PATH_AREA_WITH_PARAMETERS'' IN TYPEOF(input[i])) AND\X\0A       ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CIRCLE'' IN\X\0A         TYPEOF(input[i]\\mapped_item.mapping_source\\representation_map.mapping_origin)) OR\X\0A        ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COMPOSITE_CURVE'' IN\X\0A          TYPEOF(input[i]\\mapped_item.mapping_source\\representation_map.mapping_origin)) AND\X\0A         (input[i]\\mapped_item.mapping_source\\representation_map.mapping_origin\\composite_curve.closed_curve = true)))\X\0A    THEN\X\0A      pass := false;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(pass);'));
#27277=EXPRESS_CODE(#11270,('LOCAL\X\0A  the_reverse : oriented_open_shell;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ORIENTED_OPEN_SHELL'' IN TYPEOF(a_shell))\X\0A  THEN\X\0A    the_reverse := dummy_tri || connected_face_set(a_shell\\connected_face_set.cfs_faces) || open_shell() ||\X\0A                   oriented_open_shell(a_shell\\oriented_open_shell.open_shell_element,\X\0A                                       (NOT (a_shell\\oriented_open_shell.orientation)));\X\0A  ELSE\X\0A    the_reverse := dummy_tri || connected_face_set(a_shell\\connected_face_set.cfs_faces) || open_shell() ||\X\0A                   oriented_open_shell(a_shell, false);\X\0A  END_IF;\X\0A  RETURN(the_reverse);'));
#27281=EXPRESS_CODE(#11272,('LOCAL\X\0A  result : direction;\X\0AEND_LOCAL;\X\0A  IF (vec.dim <> 2) OR NOT EXISTS(vec)\X\0A  THEN\X\0A    RETURN(?);\X\0A  ELSE\X\0A    result := dummy_gri || direction([-vec.direction_ratios[2],vec.direction_ratios[1]]);\X\0A    RETURN(result);\X\0A  END_IF;'));
#27289=EXPRESS_CODE(#11274,('LOCAL\X\0A  tplsp  : tuple_space    := the_zero_tuple_space;\X\0A  finfun : maths_function := convert_to_maths_function(final);\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(funcs);\X\0A    tplsp := assoc_product_space(tplsp, funcs[i].range);\X\0A  END_REPEAT;\X\0A  RETURN(compatible_spaces(tplsp, finfun.domain));'));
#27300=EXPRESS_CODE(#11276,('REPEAT i := 1 TO SIZEOF(funcs);\X\0A    IF NOT (compatible_spaces(comdom, funcs[i].domain))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#27306=EXPRESS_CODE(#11278,('LOCAL\X\0A  k : positive_integer;\X\0AEND_LOCAL;\X\0A  k := i;\X\0A  IF i <= LENGTH(s)\X\0A  THEN\X\0A    IF (s[i] LIKE ''@'')\X\0A    THEN\X\0A      REPEAT UNTIL (k > LENGTH(s)) OR ((s[k] <> ''_'') AND NOT (s[k] LIKE ''@'') AND NOT (s[k] LIKE ''#''));\X\0A        k := k + 1;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(k);'));
#27314=EXPRESS_CODE(#11280,('LOCAL\X\0A  domn : tuple_space := domain;\X\0A  fspc : maths_space;\X\0A  dim  : INTEGER;\X\0A  k    : INTEGER;\X\0AEND_LOCAL;\X\0A  IF (space_dimension(domain) = 1) AND ((schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(factor1(domain)))\X\0A  THEN\X\0A    domn := factor1(domain);\X\0A  END_IF;\X\0A  dim := space_dimension(domn);\X\0A  REPEAT i := 1 TO SIZEOF(d_vars);\X\0A    k := d_vars[i];\X\0A    IF k > dim\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    fspc := factor_space(domn, k);\X\0A    IF (NOT subspace_of_es(fspc, es_reals)) AND (NOT subspace_of_es(fspc, es_complex_numbers))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#27323=EXPRESS_CODE(#11282,('LOCAL\X\0A  n : INTEGER;\X\0A  p : LOGICAL := true;\X\0AEND_LOCAL;\X\0A  n := SIZEOF(a_path.edge_list);\X\0A  REPEAT i := 2 TO n;\X\0A    p := p AND (a_path.edge_list[i - 1].edge_end :=: a_path.edge_list[i].edge_start);\X\0A  END_REPEAT;\X\0A  RETURN(p);'));
#27328=EXPRESS_CODE(#27327,('n'));
#27331=EXPRESS_CODE(#11284,('LOCAL\X\0A  the_reverse : oriented_path;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ORIENTED_PATH'' IN TYPEOF(a_path))\X\0A  THEN\X\0A    the_reverse := dummy_tri || path(list_of_topology_reversed(a_path.edge_list)) ||\X\0A                   oriented_path(a_path\\oriented_path.path_element, NOT (a_path\\oriented_path.orientation));\X\0A  ELSE\X\0A    the_reverse := dummy_tri || path(list_of_topology_reversed(a_path.edge_list)) || oriented_path(a_path, false);\X\0A  END_IF;\X\0A  RETURN(the_reverse);'));
#27336=EXPRESS_CODE(#11286,('LOCAL\X\0A  converted_angle : plane_angle_measure           := angle;\X\0A  link_rep        : kinematic_link_representation := representation_of_link(pair.joint.edge_start);\X\0A  link_cntxt      : representation_context;\X\0A  pa_units        : SET OF unit                   := [];\X\0A  pau             : unit;\X\0AEND_LOCAL;\X\0A  link_cntxt := link_rep\\representation.context_of_items;\X\0A  IF NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.GLOBAL_UNIT_ASSIGNED_CONTEXT'' IN TYPEOF(link_cntxt))\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  pa_units := QUERY(unit\X\0A                    <* link_cntxt\\global_unit_assigned_context.units\X\0A                    | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE_ANGLE_UNIT'' IN TYPEOF(unit));\X\0A  IF SIZEOF(pa_units) <> 1\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  pau := pa_units[1];\X\0A  IF (NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SI_UNIT'' IN TYPEOF(pau)) AND\X\0A          NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONVERSION_BASED_UNIT'' IN TYPEOF(pau)))\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  REPEAT WHILE (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONVERSION_BASED_UNIT'' IN TYPEOF(pau));\X\0A    converted_angle := converted_angle * pau\\conversion_based_unit.conversion_factor.value_component;\X\0A    pau := pau\\conversion_based_unit.conversion_factor.unit_component;\X\0A    IF ((NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SI_UNIT'' IN TYPEOF(pau)) AND\X\0A             NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONVERSION_BASED_UNIT'' IN TYPEOF(pau))) OR\X\0A        (NOT (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE_ANGLE_UNIT'' IN TYPEOF(pau))))\X\0A    THEN\X\0A      RETURN(?);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  IF (pau\\si_unit.name <> si_unit_name.radian)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  CASE pau\\si_unit.prefix OF\X\0A    si_prefix.exa : RETURN(1.E18 * converted_angle);\X\0A    si_prefix.peta : RETURN(1.E15 * converted_angle);\X\0A    si_prefix.tera : RETURN(1.E12 * converted_angle);\X\0A    si_prefix.giga : RETURN(1.E9 * converted_angle);\X\0A    si_prefix.mega : RETURN(1.E6 * converted_angle);\X\0A    si_prefix.kilo : RETURN(1.E3 * converted_angle);\X\0A    si_prefix.hecto : RETURN(1.E2 * converted_angle);\X\0A    si_prefix.deca : RETURN(1.E1 * converted_angle);\X\0A    si_prefix.deci : RETURN(1.E-1 * converted_angle);\X\0A    si_prefix.centi : RETURN(1.E-2 * converted_angle);\X\0A    si_prefix.milli : RETURN(1.E-3 * converted_angle);\X\0A    si_prefix.micro : RETURN(1.E-6 * converted_angle);\X\0A    si_prefix.nano : RETURN(1.E-9 * converted_angle);\X\0A    si_prefix.pico : RETURN(1.E-12 * converted_angle);\X\0A    si_prefix.femto : RETURN(1.E-15 * converted_angle);\X\0A    si_prefix.atto : RETURN(1.E-18 * converted_angle);\X\0A    OTHERWISE: RETURN(converted_angle);\X\0A  END_CASE;'));
#27347=EXPRESS_CODE(#11288,('LOCAL\X\0A  types : SET OF STRING := TYPEOF(spc);\X\0AEND_LOCAL;\X\0A  IF ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\finite_integer_interval.max);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''INTEGER_INTERVAL_TO_MAX'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\integer_interval_to_max.max);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''FINITE_REAL_INTERVAL'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\finite_real_interval.max);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''REAL_INTERVAL_TO_MAX'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\real_interval_to_max.max);\X\0A  END_IF;\X\0A  RETURN(?);'));
#27352=EXPRESS_CODE(#11290,('LOCAL\X\0A  types : SET OF STRING := TYPEOF(spc);\X\0AEND_LOCAL;\X\0A  IF ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\finite_integer_interval.min);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''INTEGER_INTERVAL_FROM_MIN'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\integer_interval_from_min.min);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''FINITE_REAL_INTERVAL'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\finite_real_interval.min);\X\0A  END_IF;\X\0A  IF ((schema_prefix + ''REAL_INTERVAL_FROM_MIN'') IN types)\X\0A  THEN\X\0A    RETURN(spc\\real_interval_from_min.min);\X\0A  END_IF;\X\0A  RETURN(?);'));
#27370=EXPRESS_CODE(#11292,('LOCAL\X\0A  k     : INTEGER;\X\0A  index : INTEGER;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(sub) OR NOT EXISTS(base) OR NOT EXISTS(shape) OR NOT EXISTS(inc) OR NOT EXISTS(first)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  IF (SIZEOF(sub) <> SIZEOF(inc)) OR (SIZEOF(sub) <> SIZEOF(shape))\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  index := first;\X\0A  REPEAT j := 1 TO SIZEOF(sub);\X\0A    IF NOT EXISTS(sub[j]) OR NOT EXISTS(inc[j])\X\0A    THEN\X\0A      RETURN(?);\X\0A    END_IF;\X\0A    k := sub[j] - base;\X\0A    IF NOT ({0 <= k < shape[j]})\X\0A    THEN\X\0A      RETURN(?);\X\0A    END_IF;\X\0A    index := index + k * inc[j];\X\0A  END_REPEAT;\X\0A  RETURN(index);'));
#27380=EXPRESS_CODE(#11294,('LOCAL\X\0A  results : SET OF shape_representation                                       := [];\X\0A  exti    : SET OF extreme_instance                                           := [];\X\0A  ii_ei   : SET OF instance_report_item_with_extreme_instances                := [];\X\0A  sdiir   : SET OF shape_data_quality_inspection_instance_report              := [];\X\0A  sdqr    : SET OF shape_data_quality_inspection_result_representation        := [];\X\0A  sdisr   : SET OF shape_data_quality_inspected_shape_and_result_relationship := [];\X\0AEND_LOCAL;\X\0A  exti := exti +\X\0A          bag_to_set(USEDIN(item,\X\0A                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EXTREME_INSTANCE.LOCATIONS_OF_EXTREME_VALUE''));\X\0A  REPEAT i := 1 TO HIINDEX(exti);\X\0A    ii_ei := ii_ei +\X\0A             bag_to_set(USEDIN(exti[i],\X\0A                               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.INSTANCE_REPORT_ITEM_WITH_EXTREME_INSTANCES.EXTREME_INSTANCES''));\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO HIINDEX(ii_ei);\X\0A    sdiir := sdiir +\X\0A             bag_to_set(USEDIN(ii_ei[i],\X\0A                               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_DATA_QUALITY_INSPECTION_INSTANCE_REPORT.INSPECTED_INSTANCES''));\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO HIINDEX(sdiir);\X\0A    sdqr := sdqr +\X\0A            QUERY(i1\X\0A                  <* bag_to_set(USEDIN(sdiir[i].inspection_result,\X\0A                                       ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION.ITEMS''))\X\0A                  | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_DATA_QUALITY_INSPECTION_RESULT_REPRESENTATION'' IN\X\0A                    TYPEOF(i1));\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO HIINDEX(sdqr);\X\0A    sdisr := sdisr +\X\0A             bag_to_set(USEDIN(sdqr[i],\X\0A                               ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_DATA_QUALITY_INSPECTED_SHAPE_AND_RESULT_RELATIONSHIP.REP_2''));\X\0A  END_REPEAT;\X\0A  REPEAT i := 1 TO HIINDEX(sdisr);\X\0A    results := results + sdisr[i].rep_1;\X\0A  END_REPEAT;\X\0A  RETURN(results);'));
#27419=EXPRESS_CODE(#11296,('LOCAL\X\0A  blist : LIST OF GENERIC : GEN := alist;\X\0AEND_LOCAL;\X\0A  IF SIZEOF(blist) > 0\X\0A  THEN\X\0A    REMOVE(blist, 1);\X\0A  END_IF;\X\0A  RETURN(blist);'));
