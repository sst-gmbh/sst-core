          str := '''';\X\0A                               END_IF;\X\0A                             END_IF;\X\0A                           END_REPEAT;\X\0A                           IF SIZEOF(vlist) = 0\X\0A                           THEN\X\0A                             RETURN(ctmv(str));\X\0A                           END_IF;\X\0A                           IF str <> ''''\X\0A                           THEN\X\0A                             INSERT(vlist, ctmv(str), 0);\X\0A                           END_IF;\X\0A                           IF SIZEOF(vlist) = 1\X\0A                           THEN\X\0A                             RETURN(vlist[1]);\X\0A                           END_IF;\X\0A      END;\X\0A      ef_size_s : IF ''STRING'' IN TYPEOF(v1)\X\0A      THEN\X\0A        str := v1;\X\0A        RETURN(ctmv(LENGTH(str)));\X\0A      END_IF;\X\0A      ef_format : IF (''NUMBER'' IN TYPEOF(v1)) AND (''STRING'' IN TYPEOF(v2))\X\0A      THEN\X\0A        RETURN(ctmv(FORMAT(v1, v2)));\X\0A      END_IF;\X\0A      ef_value : IF ''STRING'' IN TYPEOF(v1)\X\0A      THEN\X\0A        str := v1;\X\0A        RETURN(ctmv(VALUE(str)));\X\0A      END_IF;\X\0A      ef_like : IF (''STRING'' IN TYPEOF(v1)) AND (''STRING'' IN TYPEOF(v2))\X\0A      THEN\X\0A        RETURN(ctmv(v1 LIKE v2));\X\0A      END_IF;\X\0A      ef_subscript_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(bin[k]));\X\0A      END_IF;\X\0A      ef_eq_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''BINARY'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        bi2 := v2;\X\0A        RETURN(ctmv(bin = bi2));\X\0A      END_IF;\X\0A      ef_ne_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''BINARY'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        bi2 := v2;\X\0A        RETURN(ctmv(bin <> bi2));\X\0A      END_IF;\X\0A      ef_gt_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''BINARY'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        bi2 := v2;\X\0A        RETURN(ctmv(bin > bi2));\X\0A      END_IF;\X\0A      ef_lt_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''BINARY'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        bi2 := v2;\X\0A        RETURN(ctmv(bin < bi2));\X\0A      END_IF;\X\0A      ef_ge_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''BINARY'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        bi2 := v2;\X\0A        RETURN(ctmv(bin >= bi2));\X\0A      END_IF;\X\0A      ef_le_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''BINARY'' IN TYPEOF(v2))\X\0A      THEN\X\0A        bin := v1;\X\0A        bi2 := v2;\X\0A        RETURN(ctmv(bin <= bi2));\X\0A      END_IF;\X\0A      ef_subsequence_b : IF (''BINARY'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2)) AND (''INTEGER'' IN TYPEOF(v3))\X\0A      THEN\X\0A        bin := v1;\X\0A        j := v2;\X\0A        k := v3;\X\0A        RETURN(ctmv(bin[j:k]));\X\0A      END_IF;\X\0A      ef_concat_b : BEGIN  \X\0A                           boo := false;\X\0A                           REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                             IF ''BINARY'' IN TYPEOF(vlist[i])\X\0A                             THEN\X\0A                               IF boo\X\0A                               THEN\X\0A                                 bi2 := vlist[i];\X\0A                                 bin := bin + bi2;\X\0A                               ELSE\X\0A                                 bin := vlist[i];\X\0A                                 boo := true;\X\0A                               END_IF;\X\0A                               REMOVE(vlist, i);\X\0A                             ELSE\X\0A                               IF boo\X\0A                               THEN\X\0A                                 INSERT(vlist, ctmv(bin), i);\X\0A                                 boo := false;\X\0A                               END_IF;\X\0A                             END_IF;\X\0A                           END_REPEAT;\X\0A                           IF SIZEOF(vlist) = 0\X\0A                           THEN\X\0A                             RETURN(ctmv(bin));\X\0A                           END_IF;\X\0A                           IF boo\X\0A                           THEN\X\0A                             INSERT(vlist, ctmv(bin), 0);\X\0A                           END_IF;\X\0A                           IF SIZEOF(vlist) = 1\X\0A                           THEN\X\0A                             RETURN(vlist[1]);\X\0A                           END_IF;\X\0A      END;\X\0A      ef_size_b : IF ''BINARY'' IN TYPEOF(v1)\X\0A      THEN\X\0A        bin := v1;\X\0A        RETURN(ctmv(BLENGTH(bin)));\X\0A      END_IF;\X\0A      ef_subscript_t : IF (''LIST'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        tpl := v1;\X\0A        k := v2;\X\0A        RETURN(ctmv(tpl[k]));\X\0A      END_IF;\X\0A      ef_eq_t : IF (''LIST'' IN TYPEOF(v1)) AND (''LIST'' IN TYPEOF(v2))\X\0A      THEN\X\0A        lgc := equal_maths_values(v1, v2);\X\0A        IF lgc <> unknown\X\0A        THEN\X\0A          RETURN(ctmv(lgc));\X\0A        END_IF;\X\0A      END_IF;\X\0A      ef_ne_t : IF (''LIST'' IN TYPEOF(v1)) AND (''LIST'' IN TYPEOF(v2))\X\0A      THEN\X\0A        lgc := equal_maths_values(v1, v2);\X\0A        IF lgc <> unknown\X\0A        THEN\X\0A          RETURN(ctmv(NOT lgc));\X\0A        END_IF;\X\0A      END_IF;\X\0A      ef_concat_t : BEGIN  \X\0A                           tpl := [];\X\0A                           REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                             IF ''STRING'' IN TYPEOF(vlist[i])\X\0A                             THEN\X\0A                               tp2 := vlist[i];\X\0A                               tpl := tpl + tp2;\X\0A                               REMOVE(vlist, i);\X\0A                             ELSE\X\0A                               IF SIZEOF(tpl) <> 0\X\0A                               THEN\X\0A                                 INSERT(vlist, ctmv(tpl), i);\X\0A                                 tpl := [];\X\0A                               END_IF;\X\0A                             END_IF;\X\0A                           END_REPEAT;\X\0A                           IF SIZEOF(vlist) = 0\X\0A                           THEN\X\0A                             RETURN(ctmv(tpl));\X\0A                           END_IF;\X\0A                           IF SIZEOF(tpl) <> 0\X\0A                           THEN\X\0A                             INSERT(vlist, ctmv(tpl), 0);\X\0A                           END_IF;\X\0A                           IF SIZEOF(vlist) = 1\X\0A                           THEN\X\0A                             RETURN(vlist[1]);\X\0A                           END_IF;\X\0A      END;\X\0A      ef_size_t : IF ''LIST'' IN TYPEOF(v1)\X\0A      THEN\X\0A        tpl := v1;\X\0A        RETURN(ctmv(SIZEOF(tpl)));\X\0A      END_IF;\X\0A      ef_entuple : RETURN(ctmv(vlist));\X\0A      ef_detuple : IF ''LIST'' IN TYPEOF(v1)\X\0A      THEN\X\0A        tpl := v1;\X\0A        RETURN(ctmv(tpl[1]));\X\0A      END_IF;\X\0A      ef_insert : IF (''LIST'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v3))\X\0A      THEN\X\0A        tpl := v1;\X\0A        k := v3;\X\0A        INSERT(tpl, v2, k);\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_remove : IF (''LIST'' IN TYPEOF(v1)) AND (''INTEGER'' IN TYPEOF(v2))\X\0A      THEN\X\0A        tpl := v1;\X\0A        k := v2;\X\0A        REMOVE(tpl, k);\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_sum_it : IF good_t(v1, ''INTEGER'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        j := 0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          j := j + tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(j));\X\0A      END_IF;\X\0A      ef_product_it : IF good_t(v1, ''INTEGER'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        j := 1;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          j := j * tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(j));\X\0A      END_IF;\X\0A      ef_add_it : BEGIN  \X\0A                         boo := false;\X\0A                         REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                           IF good_t(vlist[i], ''INTEGER'')\X\0A                           THEN\X\0A                             IF NOT boo\X\0A                             THEN\X\0A                               tpl := vlist[i];\X\0A                               boo := true;\X\0A                             ELSE\X\0A                               tp2 := vlist[i];\X\0A                               IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A                               THEN\X\0A                                 RETURN(?);\X\0A                               END_IF;\X\0A                               REPEAT l := 1 TO SIZEOF(tpl);\X\0A                                 tpl[j] := tpl[j] + tp2[j];\X\0A                               END_REPEAT;\X\0A                             END_IF;\X\0A                             REMOVE(vlist, i);\X\0A                           END_IF;\X\0A                         END_REPEAT;\X\0A                         IF SIZEOF(vlist) = 0\X\0A                         THEN\X\0A                           RETURN(ctmv(tpl));\X\0A                         END_IF;\X\0A                         IF boo\X\0A                         THEN\X\0A                           INSERT(vlist, ctmv(tpl), 0);\X\0A                         END_IF;\X\0A                         IF SIZEOF(vlist) = 1\X\0A                         THEN\X\0A                           RETURN(vlist[1]);\X\0A                         END_IF;\X\0A      END;\X\0A      ef_subtract_it : IF good_t(v1, ''INTEGER'') AND good_t(v2, ''INTEGER'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        tp2 := v2;\X\0A        IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A        THEN\X\0A          RETURN(?);\X\0A        END_IF;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          tpl[i] := tpl[i] - tp2[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_scalar_mult_it : IF (''INTEGER'' IN TYPEOF(v1)) AND good_t(v2, ''INTEGER'')\X\0A      THEN\X\0A        j := v1;\X\0A        tpl := v2;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          tpl[i] := j * tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_dot_prod_it : IF good_t(v1, ''INTEGER'') AND good_t(v2, ''INTEGER'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        tp2 := v2;\X\0A        j := 0;\X\0A        IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A        THEN\X\0A          RETURN(?);\X\0A        END_IF;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          j := j + tpl[i] * tp2[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(j));\X\0A      END_IF;\X\0A      ef_sum_rt : IF good_t(v1, ''REAL'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        r := 0.0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          r := r + tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(r));\X\0A      END_IF;\X\0A      ef_product_rt : IF good_t(v1, ''REAL'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        r := 1.0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          r := r * tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(r));\X\0A      END_IF;\X\0A      ef_add_rt : BEGIN  \X\0A                         boo := false;\X\0A                         REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                           IF good_t(vlist[i], ''REAL'')\X\0A                           THEN\X\0A                             IF NOT boo\X\0A                             THEN\X\0A                               tpl := vlist[i];\X\0A                               boo := true;\X\0A                             ELSE\X\0A                               tp2 := vlist[i];\X\0A                               IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A                               THEN\X\0A                                 RETURN(?);\X\0A                               END_IF;\X\0A                               REPEAT l := 1 TO SIZEOF(tpl);\X\0A                                 tpl[j] := tpl[j] + tp2[j];\X\0A                               END_REPEAT;\X\0A                             END_IF;\X\0A                             REMOVE(vlist, i);\X\0A                           END_IF;\X\0A                         END_REPEAT;\X\0A                         IF SIZEOF(vlist) = 0\X\0A                         THEN\X\0A                           RETURN(ctmv(tpl));\X\0A                         END_IF;\X\0A                         IF boo\X\0A                         THEN\X\0A                           INSERT(vlist, ctmv(tpl), 0);\X\0A                         END_IF;\X\0A                         IF SIZEOF(vlist) = 1\X\0A                         THEN\X\0A                           RETURN(vlist[1]);\X\0A                         END_IF;\X\0A      END;\X\0A      ef_subtract_rt : IF good_t(v1, ''REAL'') AND good_t(v2, ''REAL'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        tp2 := v2;\X\0A        IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A        THEN\X\0A          RETURN(?);\X\0A        END_IF;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          tpl[i] := tpl[i] - tp2[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_scalar_mult_rt : IF (''REAL'' IN TYPEOF(v1)) AND good_t(v2, ''REAL'')\X\0A      THEN\X\0A        r := v1;\X\0A        tpl := v2;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          tpl[i] := r * tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_dot_prod_rt : IF good_t(v1, ''REAL'') AND good_t(v2, ''REAL'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        tp2 := v2;\X\0A        r := 0;\X\0A        IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A        THEN\X\0A          RETURN(?);\X\0A        END_IF;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          r := r + tpl[i] * tp2[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(r));\X\0A      END_IF;\X\0A      ef_norm_rt : IF good_t(v1, ''REAL'')\X\0A      THEN\X\0A        tpl := v1;\X\0A        r := 0.0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          r := r + tpl[i] * tpl[i];\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(SQRT(r)));\X\0A      END_IF;\X\0A      ef_sum_ct : IF good_t(v1, cnlit)\X\0A      THEN\X\0A        tpl := v1;\X\0A        p := 0.0;\X\0A        q := 0.0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          parts(tpl[i], r, s);\X\0A          p := p + r;\X\0A          q := q + s;\X\0A        END_REPEAT;\X\0A        RETURN(makec(p, q));\X\0A      END_IF;\X\0A      ef_product_ct : IF good_t(v1, cnlit)\X\0A      THEN\X\0A        tpl := v1;\X\0A        p := 1.0;\X\0A        q := 0.0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          parts(tpl[i], r, s);\X\0A          p := p * r - q * s;\X\0A          q := p * s + q * r;\X\0A        END_REPEAT;\X\0A        RETURN(makec(p, q));\X\0A      END_IF;\X\0A      ef_add_ct : BEGIN  \X\0A                         boo := false;\X\0A                         REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A                           IF good_t(vlist[i], cnlit)\X\0A                           THEN\X\0A                             IF NOT boo\X\0A                             THEN\X\0A                               tpl := vlist[i];\X\0A                               boo := true;\X\0A                             ELSE\X\0A                               tp2 := vlist[i];\X\0A                               IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A                               THEN\X\0A                                 RETURN(?);\X\0A                               END_IF;\X\0A                               REPEAT l := 1 TO SIZEOF(tpl);\X\0A                                 parts(tpl[j], p, q);\X\0A                                 parts(tp2[j], r, s);\X\0A                                 tpl[j] := makec(p + r, q + s);\X\0A                               END_REPEAT;\X\0A                             END_IF;\X\0A                             REMOVE(vlist, i);\X\0A                           END_IF;\X\0A                         END_REPEAT;\X\0A                         IF SIZEOF(vlist) = 0\X\0A                         THEN\X\0A                           RETURN(ctmv(tpl));\X\0A                         END_IF;\X\0A                         IF boo\X\0A                         THEN\X\0A                           INSERT(vlist, ctmv(tpl), 0);\X\0A                         END_IF;\X\0A                         IF SIZEOF(vlist) = 1\X\0A                         THEN\X\0A                           RETURN(vlist[1]);\X\0A                         END_IF;\X\0A      END;\X\0A      ef_subtract_ct : IF good_t(v1, cnlit) AND good_t(v2, cnlit)\X\0A      THEN\X\0A        tpl := v1;\X\0A        tp2 := v2;\X\0A        IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A        THEN\X\0A          RETURN(?);\X\0A        END_IF;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          parts(tpl[i], p, q);\X\0A          parts(tp2[i], r, s);\X\0A          tpl[i] := makec(p - r, q - s);\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_scalar_mult_ct : IF (cnlit IN TYPEOF(v1)) AND good_t(v2, cnlit)\X\0A      THEN\X\0A        parts(v1, p, q);\X\0A        tpl := v2;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          parts(tpl[i], r, s);\X\0A          tpl[i] := makec(p * r - q * s, p * s + q * r);\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(tpl));\X\0A      END_IF;\X\0A      ef_dot_prod_ct : IF good_t(v1, cnlit) AND good_t(v2, cnlit)\X\0A      THEN\X\0A        tpl := v1;\X\0A        tp2 := v2;\X\0A        t := 0.0;\X\0A        u := 0.0;\X\0A        IF SIZEOF(tpl) <> SIZEOF(tp2)\X\0A        THEN\X\0A          RETURN(?);\X\0A        END_IF;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          parts(tpl[i], p, q);\X\0A          parts(tp2[i], r, s);\X\0A          t := t + p * r + q * s;\X\0A          u := u + q * r - p * s;\X\0A        END_REPEAT;\X\0A        RETURN(makec(t, u));\X\0A      END_IF;\X\0A      ef_norm_ct : IF good_t(v1, cnlit)\X\0A      THEN\X\0A        tpl := v1;\X\0A        r := 0.0;\X\0A        REPEAT i := 1 TO SIZEOF(tpl);\X\0A          parts(tpl[i], p, q);\X\0A          r := r + p * p + q * q;\X\0A        END_REPEAT;\X\0A        RETURN(ctmv(SQRT(r)));\X\0A      END_IF;\X\0A      ef_if, ef_if_i, ef_if_r, ef_if_c, ef_if_s, ef_if_b, ef_if_t : IF ''LOGICAL'' IN TYPEOF(v1)\X\0A      THEN\X\0A        lgc := v1;\X\0A        IF lgc\X\0A        THEN\X\0A          RETURN(v2);\X\0A        ELSE\X\0A          RETURN(v3);\X\0A        END_IF;\X\0A      END_IF;\X\0A      ef_ensemble : RETURN(make_finite_space(mem + vlist));\X\0A      ef_member_of : IF (schema_prefix + ''MATHS_SPACE'') IN TYPEOF(v2)\X\0A      THEN\X\0A        lgc := member_of(v1, v2);\X\0A        IF lgc <> unknown\X\0A        THEN\X\0A          RETURN(ctmv(lgc));\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_CASE;\X\0A    RETURN(make_function_application(expr.func, vlist));\X\0A  END_IF;\X\0A  IF ''ABSTRACTED_EXPRESSION_FUNCTION'' IN types\X\0A  THEN\X\0A    gexpr := substitute(expr.func\\abstracted_expression_function.expr, expr.func\\quantifier_expression.variables,\X\0A                        vlist);\X\0A    RETURN(simplify_generic_expression(gexpr));\X\0A  END_IF;\X\0A  IF ''FINITE_FUNCTION'' IN types\X\0A  THEN\X\0A    pairs := expr.func\\finite_function.pairs;\X\0A    REPEAT i := 1 TO SIZEOF(pairs);\X\0A      IF equal_maths_values(vlist[1], pairs[i][1])\X\0A      THEN\X\0A        RETURN(simplify_maths_value(pairs[i][2]));\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(make_function_application(expr.func, vlist));\X\0A  END_IF;\X\0A  RETURN(expr);'));
#27507=EXPRESS_CODE(#11324,('schema_prefix + ''COMPLEX_NUMBER_LITERAL'''));
#27645=EXPRESS_CODE(#11326,('FUNCTION restore_unary(expr : unary_generic_expression;\X\0A                       opnd : generic_expression) : generic_expression;\X\0A  expr.operand := opnd;\X\0A  RETURN(expr);\X\0AEND_FUNCTION;\X\0AFUNCTION restore_binary(expr : binary_generic_expression;\X\0A                        opd1 : generic_expression;\X\0A                        opd2 : generic_expression) : generic_expression;\X\0A  expr.operands[1] := opd1;\X\0A  expr.operands[2] := opd2;\X\0A  RETURN(expr);\X\0AEND_FUNCTION;\X\0AFUNCTION restore_mulary(expr : multiple_arity_generic_expression;\X\0A                        ops : LIST OF generic_expression) : generic_expression;\X\0A  expr.operands := ops;\X\0A  RETURN(expr);\X\0AEND_FUNCTION;\X\0AFUNCTION make_number_literal(nmb : NUMBER) : generic_literal;\X\0A  IF ''INTEGER'' IN TYPEOF(nmb)\X\0A  THEN\X\0A    RETURN(make_int_literal(nmb));\X\0A  END_IF;\X\0A  RETURN(make_real_literal(nmb));\X\0AEND_FUNCTION;\X\0ALOCAL\X\0A  types  : SET OF STRING                      := stripped_typeof(expr);\X\0A  v1     : maths_value;\X\0A  v2     : maths_value;\X\0A  vlist  : LIST OF maths_value                := [];\X\0A  op1    : generic_expression;\X\0A  op2    : generic_expression;\X\0A  oplist : LIST OF generic_expression         := [];\X\0A  opnds  : LIST [2 : ?] OF generic_expression;\X\0A  n      : INTEGER;\X\0A  m      : INTEGER;\X\0A  finfun : maths_function_select;\X\0A  boo    : BOOLEAN;\X\0A  str    : STRING;\X\0A  nmb    : NUMBER;\X\0AEND_LOCAL;\X\0A  IF ''INT_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\int_literal.the_value));\X\0A  END_IF;\X\0A  IF ''REAL_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\real_literal.the_value));\X\0A  END_IF;\X\0A  IF ''BOOLEAN_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\boolean_literal.the_value));\X\0A  END_IF;\X\0A  IF ''STRING_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\string_literal.the_value));\X\0A  END_IF;\X\0A  IF ''COMPLEX_NUMBER_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(expr);\X\0A  END_IF;\X\0A  IF ''LOGICAL_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\logical_literal.lit_value));\X\0A  END_IF;\X\0A  IF ''BINARY_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\binary_literal.lit_value));\X\0A  END_IF;\X\0A  IF ''MATHS_ENUM_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(expr\\maths_enum_literal.lit_value);\X\0A  END_IF;\X\0A  IF ''REAL_TUPLE_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\real_tuple_literal.lit_value));\X\0A  END_IF;\X\0A  IF ''INTEGER_TUPLE_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\integer_tuple_literal.lit_value));\X\0A  END_IF;\X\0A  IF ''ATOM_BASED_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(expr\\atom_based_literal.lit_value);\X\0A  END_IF;\X\0A  IF ''MATHS_TUPLE_LITERAL'' IN types\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(expr\\maths_tuple_literal.lit_value));\X\0A  END_IF;\X\0A  IF ''MATHS_SPACE'' IN types\X\0A  THEN\X\0A    RETURN(simplify_maths_space(expr));\X\0A  END_IF;\X\0A  IF ''FUNCTION_APPLICATION'' IN types\X\0A  THEN\X\0A    RETURN(simplify_function_application(expr));\X\0A  END_IF;\X\0A  IF ''UNARY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    v1 := simplify_generic_expression(expr\\unary_generic_expression.operand);\X\0A    op1 := convert_to_operand(v1);\X\0A  END_IF;\X\0A  IF ''BINARY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    v1 := simplify_generic_expression(expr\\binary_generic_expression.operands[1]);\X\0A    op1 := convert_to_operand(v1);\X\0A    v2 := simplify_generic_expression(expr\\binary_generic_expression.operands[2]);\X\0A    op2 := convert_to_operand(v2);\X\0A  END_IF;\X\0A  IF ''MULTIPLE_ARITY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    opnds := expr\\multiple_arity_generic_expression.operands;\X\0A    REPEAT i := 1 TO SIZEOF(opnds);\X\0A      v1 := simplify_generic_expression(opnds[i]);\X\0A      INSERT(vlist, v1, i - 1);\X\0A      INSERT(oplist, convert_to_operand(v1), i - 1);\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF ''PARALLEL_COMPOSED_FUNCTION'' IN types\X\0A  THEN\X\0A    v1 := vlist[1];\X\0A    n := SIZEOF(vlist);\X\0A    finfun := vlist[n];\X\0A    REMOVE(vlist, n);\X\0A    REMOVE(vlist, 1);\X\0A    RETURN(make_parallel_composed_function(v1, vlist, finfun));\X\0A  END_IF;\X\0A  IF (''ABS_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(ABS(v1)));\X\0A  END_IF;\X\0A  IF (''ACOS_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(ACOS(v1)));\X\0A  END_IF;\X\0A  IF ''AND_EXPRESSION'' IN types\X\0A  THEN\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''BOOLEAN'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        boo := vlist[i];\X\0A        IF NOT boo\X\0A        THEN\X\0A          RETURN(convert_to_maths_value(false));\X\0A        END_IF;\X\0A        REMOVE(oplist, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(true));\X\0A    END_IF;\X\0A    IF SIZEOF(oplist) = 1\X\0A    THEN\X\0A      RETURN(oplist[1]);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''ASIN_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(ASIN(v1)));\X\0A  END_IF;\X\0A  IF (''ATAN_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(ATAN(v1, v2)));\X\0A  END_IF;\X\0A  IF (''COMPARISON_EXPRESSION'' IN types) AND\X\0A     (((''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))) OR\X\0A      ((''STRING'' IN TYPEOF(v1)) AND (''STRING'' IN TYPEOF(v2))) OR\X\0A      ((''BOOLEAN'' IN TYPEOF(v1)) AND (''BOOLEAN'' IN TYPEOF(v2))))\X\0A  THEN\X\0A    IF ''COMPARISON_EQUAL'' IN types\X\0A    THEN\X\0A      boo := bool(v1 = v2);\X\0A    ELSE\X\0A      IF ''COMPARISON_GREATER'' IN types\X\0A      THEN\X\0A        boo := bool(v1 > v2);\X\0A      ELSE\X\0A        IF ''COMPARISON_GREATER_EQUAL'' IN types\X\0A        THEN\X\0A          boo := bool(v1 >= v2);\X\0A        ELSE\X\0A          IF ''COMPARISON_LESS'' IN types\X\0A          THEN\X\0A            boo := bool(v1 < v2);\X\0A          ELSE\X\0A            IF ''COMPARISON_LESS_EQUAL'' IN types\X\0A            THEN\X\0A              boo := bool(v1 <= v2);\X\0A            ELSE\X\0A              IF ''COMPARISON_NOT_EQUAL'' IN types\X\0A              THEN\X\0A                boo := bool(v1 <> v2);\X\0A              ELSE\X\0A                IF ''LIKE_EXPRESSION'' IN types\X\0A                THEN\X\0A                  boo := bool(v1 LIKE v2);\X\0A                ELSE\X\0A                  RETURN(?);\X\0A                END_IF;\X\0A              END_IF;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(convert_to_maths_value(boo));\X\0A  END_IF;\X\0A  IF ''CONCAT_EXPRESSION'' IN types\X\0A  THEN\X\0A    str := '''';\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''STRING'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        str := vlist[i] + str;\X\0A        REMOVE(oplist, i);\X\0A      ELSE\X\0A        IF LENGTH(str) > 0\X\0A        THEN\X\0A          INSERT(oplist, make_string_literal(str), i);\X\0A          str := '''';\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(str));\X\0A    END_IF;\X\0A    IF LENGTH(str) > 0\X\0A    THEN\X\0A      INSERT(oplist, make_string_literal(str), 0);\X\0A    END_IF;\X\0A    IF SIZEOF(oplist) = 1\X\0A    THEN\X\0A      RETURN(oplist[1]);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''COS_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(COS(v1)));\X\0A  END_IF;\X\0A  IF (''DIV_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(v1 DIV v2));\X\0A  END_IF;\X\0A  IF ''EQUALS_EXPRESSION'' IN types\X\0A  THEN\X\0A    opnds := expr\\binary_generic_expression.operands;\X\0A    RETURN(convert_to_maths_value(opnds[1] :=: opnds[2]));\X\0A  END_IF;\X\0A  IF (''EXP_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(EXP(v1)));\X\0A  END_IF;\X\0A  IF (''FORMAT_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''STRING'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(FORMAT(v1, v2)));\X\0A  END_IF;\X\0A  IF (''INDEX_EXPRESSION'' IN types) AND (''STRING'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    str := v1;\X\0A    n := v2;\X\0A    RETURN(convert_to_maths_value(str[n]));\X\0A  END_IF;\X\0A  IF (''INT_VALUE_EXPRESSION'' IN types) AND (''STRING'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(VALUE(v1)));\X\0A  END_IF;\X\0A  IF ''INTERVAL_EXPRESSION'' IN types\X\0A  THEN\X\0A    str := '''';\X\0A    IF ''NUMBER'' IN TYPEOF(vlist[1])\X\0A    THEN\X\0A      str := ''NUMBER'';\X\0A    END_IF;\X\0A    IF ''STRING'' IN TYPEOF(vlist[1])\X\0A    THEN\X\0A      str := ''STRING'';\X\0A    END_IF;\X\0A    IF ''BOOLEAN'' IN TYPEOF(vlist[1])\X\0A    THEN\X\0A      str := ''BOOLEAN'';\X\0A    END_IF;\X\0A    IF (LENGTH(str) > 0) AND (str IN TYPEOF(vlist[2])) AND (str IN TYPEOF(vlist[3]))\X\0A    THEN\X\0A      RETURN(convert_to_maths_value({vlist[1] <= vlist[2] <= vlist[3]}));\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''LENGTH_EXPRESSION'' IN types) AND (''STRING'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(LENGTH(v1)));\X\0A  END_IF;\X\0A  IF (''LOG_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(LOG(v1)));\X\0A  END_IF;\X\0A  IF (''LOG10_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(LOG10(v1)));\X\0A  END_IF;\X\0A  IF (''LOG2_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(LOG2(v1)));\X\0A  END_IF;\X\0A  IF ''MAXIMUM_EXPRESSION'' IN types\X\0A  THEN\X\0A    boo := false;\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''NUMBER'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        IF boo\X\0A        THEN\X\0A          IF nmb < vlist[i]\X\0A          THEN\X\0A            nmb := vlist[i];\X\0A          END_IF;\X\0A        ELSE\X\0A          nmb := vlist[i];\X\0A          boo := true;\X\0A        END_IF;\X\0A        REMOVE(oplist, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(nmb));\X\0A    END_IF;\X\0A    IF boo\X\0A    THEN\X\0A      INSERT(oplist, make_number_literal(nmb), 0);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF ''MINIMUM_EXPRESSION'' IN types\X\0A  THEN\X\0A    boo := false;\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''NUMBER'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        IF boo\X\0A        THEN\X\0A          IF nmb > vlist[i]\X\0A          THEN\X\0A            nmb := vlist[i];\X\0A          END_IF;\X\0A        ELSE\X\0A          nmb := vlist[i];\X\0A          boo := true;\X\0A        END_IF;\X\0A        REMOVE(oplist, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(nmb));\X\0A    END_IF;\X\0A    IF boo\X\0A    THEN\X\0A      INSERT(oplist, make_number_literal(nmb), 0);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''MINUS_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(v1 - v2));\X\0A  END_IF;\X\0A  IF (''MOD_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(v1 MOD v2));\X\0A  END_IF;\X\0A  IF ''MULT_EXPRESSION'' IN types\X\0A  THEN\X\0A    nmb := 1;\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''NUMBER'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        nmb := nmb * vlist[i];\X\0A        REMOVE(oplist, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(nmb));\X\0A    END_IF;\X\0A    IF nmb <> 1\X\0A    THEN\X\0A      INSERT(oplist, make_number_literal(nmb), 0);\X\0A    END_IF;\X\0A    IF SIZEOF(oplist) = 1\X\0A    THEN\X\0A      RETURN(oplist[1]);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''NOT_EXPRESSION'' IN types) AND (''BOOLEAN'' IN TYPEOF(v1))\X\0A  THEN\X\0A    boo := v1;\X\0A    RETURN(convert_to_maths_value(NOT (boo)));\X\0A  END_IF;\X\0A  IF (''ODD_EXPRESSION'' IN types) AND (''INTEGER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(ODD(v1)));\X\0A  END_IF;\X\0A  IF ''OR_EXPRESSION'' IN types\X\0A  THEN\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''BOOLEAN'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        boo := vlist[i];\X\0A        IF boo\X\0A        THEN\X\0A          RETURN(convert_to_maths_value(true));\X\0A        END_IF;\X\0A        REMOVE(oplist, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(false));\X\0A    END_IF;\X\0A    IF SIZEOF(oplist) = 1\X\0A    THEN\X\0A      RETURN(oplist[1]);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF ''PLUS_EXPRESSION'' IN types\X\0A  THEN\X\0A    nmb := 0;\X\0A    REPEAT i := SIZEOF(vlist) TO 1 BY -1;\X\0A      IF ''NUMBER'' IN TYPEOF(vlist[i])\X\0A      THEN\X\0A        nmb := nmb + vlist[i];\X\0A        REMOVE(oplist, i);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF SIZEOF(oplist) = 0\X\0A    THEN\X\0A      RETURN(convert_to_maths_value(nmb));\X\0A    END_IF;\X\0A    IF nmb <> 0\X\0A    THEN\X\0A      INSERT(oplist, make_number_literal(nmb), 0);\X\0A    END_IF;\X\0A    IF SIZEOF(oplist) = 1\X\0A    THEN\X\0A      RETURN(oplist[1]);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (''POWER_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(v1 ** v2));\X\0A  END_IF;\X\0A  IF (''SIN_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(SIN(v1)));\X\0A  END_IF;\X\0A  IF (''SLASH_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1)) AND (''NUMBER'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(v1 / v2));\X\0A  END_IF;\X\0A  IF (''SQUARE_ROOT_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(SQRT(v1)));\X\0A  END_IF;\X\0A  IF (''SUBSTRING_EXPRESSION'' IN types) AND (''STRING'' IN TYPEOF(vlist[1])) AND (''NUMBER'' IN TYPEOF(vlist[2])) AND\X\0A     (''NUMBER'' IN TYPEOF(vlist[3]))\X\0A  THEN\X\0A    str := vlist[1];\X\0A    n := vlist[2];\X\0A    m := vlist[3];\X\0A    RETURN(convert_to_maths_value(str[n:m]));\X\0A  END_IF;\X\0A  IF (''TAN_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(TAN(v1)));\X\0A  END_IF;\X\0A  IF (''UNARY_MINUS_EXPRESSION'' IN types) AND (''NUMBER'' IN TYPEOF(v1))\X\0A  THEN\X\0A    nmb := v1;\X\0A    RETURN(convert_to_maths_value(-nmb));\X\0A  END_IF;\X\0A  IF (''VALUE_EXPRESSION'' IN types) AND (''STRING'' IN TYPEOF(v1))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(VALUE(v1)));\X\0A  END_IF;\X\0A  IF (''XOR_EXPRESSION'' IN types) AND (''BOOLEAN'' IN TYPEOF(v1)) AND (''BOOLEAN'' IN TYPEOF(v2))\X\0A  THEN\X\0A    RETURN(convert_to_maths_value(v1 XOR v2));\X\0A  END_IF;\X\0A  IF ''UNARY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    RETURN(restore_unary(expr, op1));\X\0A  END_IF;\X\0A  IF ''BINARY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    RETURN(restore_binary(expr, op1, op2));\X\0A  END_IF;\X\0A  IF ''MULTIPLE_ARITY_GENERIC_EXPRESSION'' IN types\X\0A  THEN\X\0A    RETURN(restore_mulary(expr, oplist));\X\0A  END_IF;\X\0A  RETURN(expr);'));
#27703=EXPRESS_CODE(#11336,('LOCAL\X\0A  stypes   : SET OF STRING       := stripped_typeof(spc);\X\0A  sset     : SET OF maths_value;\X\0A  zset     : SET OF maths_value  := [];\X\0A  zval     : maths_value;\X\0A  zspc     : maths_space;\X\0A  zallint  : BOOLEAN             := true;\X\0A  zint     : INTEGER;\X\0A  zmin     : INTEGER;\X\0A  zmax     : INTEGER;\X\0A  factors  : LIST OF maths_space;\X\0A  zfactors : LIST OF maths_space := [];\X\0A  rspc     : maths_space;\X\0AEND_LOCAL;\X\0A  IF ''FINITE_SPACE'' IN stypes\X\0A  THEN\X\0A    sset := spc\\finite_space.members;\X\0A    REPEAT i := 1 TO SIZEOF(sset);\X\0A      zval := simplify_maths_value(sset[i]);\X\0A      zset := zset + [zval];\X\0A      IF zallint AND (''INTEGER'' IN TYPEOF(zval))\X\0A      THEN\X\0A        zint := zval;\X\0A        IF i = 1\X\0A        THEN\X\0A          zmin := zint;\X\0A          zmax := zint;\X\0A        ELSE\X\0A          IF zint < zmin\X\0A          THEN\X\0A            zmin := zint;\X\0A          END_IF;\X\0A          IF zint > zmax\X\0A          THEN\X\0A            zmax := zint;\X\0A          END_IF;\X\0A        END_IF;\X\0A      ELSE\X\0A        zallint := false;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF zallint AND (SIZEOF(zset) = zmax - zmin + 1)\X\0A    THEN\X\0A      RETURN(make_finite_integer_interval(zmin, zmax));\X\0A    END_IF;\X\0A    RETURN(make_finite_space(zset));\X\0A  END_IF;\X\0A  IF ''UNIFORM_PRODUCT_SPACE'' IN stypes\X\0A  THEN\X\0A    zspc := simplify_maths_space(spc\\uniform_product_space.base);\X\0A    RETURN(make_uniform_product_space(zspc, spc\\uniform_product_space.exponent));\X\0A  END_IF;\X\0A  IF ''LISTED_PRODUCT_SPACE'' IN stypes\X\0A  THEN\X\0A    factors := spc\\listed_product_space.factors;\X\0A    REPEAT i := 1 TO SIZEOF(factors);\X\0A      INSERT(zfactors, simplify_maths_space(factors[i]), i - 1);\X\0A    END_REPEAT;\X\0A    RETURN(make_listed_product_space(zfactors));\X\0A  END_IF;\X\0A  IF ''EXTENDED_TUPLE_SPACE'' IN stypes\X\0A  THEN\X\0A    zspc := simplify_maths_space(spc\\extended_tuple_space.base);\X\0A    rspc := simplify_maths_space(spc\\extended_tuple_space.extender);\X\0A    RETURN(make_extended_tuple_space(zspc, rspc));\X\0A  END_IF;\X\0A  IF ''FUNCTION_SPACE'' IN stypes\X\0A  THEN\X\0A    zspc := simplify_maths_space(spc\\function_space.domain_argument);\X\0A    rspc := simplify_maths_space(spc\\function_space.range_argument);\X\0A    RETURN(make_function_space(spc\\function_space.domain_constraint, zspc, spc\\function_space.range_constraint, rspc));\X\0A  END_IF;\X\0A  RETURN(spc);'));
#27735=EXPRESS_CODE(#11338,('LOCAL\X\0A  vtypes : SET OF STRING       := stripped_typeof(val);\X\0A  vlist  : LIST OF maths_value;\X\0A  nlist  : LIST OF maths_value := [];\X\0AEND_LOCAL;\X\0A  IF ''GENERIC_EXPRESSION'' IN vtypes\X\0A  THEN\X\0A    RETURN(simplify_generic_expression(val));\X\0A  END_IF;\X\0A  IF ''LIST'' IN vtypes\X\0A  THEN\X\0A    vlist := val;\X\0A    REPEAT i := 1 TO SIZEOF(vlist);\X\0A      INSERT(nlist, simplify_maths_value(vlist[i]), i - 1);\X\0A    END_REPEAT;\X\0A    RETURN(convert_to_maths_value(nlist));\X\0A  END_IF;\X\0A  RETURN(val);'));
#27750=EXPRESS_CODE(#11340,('LOCAL\X\0A  types : SET OF STRING := stripped_typeof(spc);\X\0AEND_LOCAL;\X\0A  IF ''FINITE_SPACE'' IN types\X\0A  THEN\X\0A    IF SIZEOF(spc\\finite_space.members) = 1\X\0A    THEN\X\0A      RETURN(spc\\finite_space.members[1]);\X\0A    END_IF;\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  IF ''FINITE_INTEGER_INTERVAL'' IN types\X\0A  THEN\X\0A    IF spc\\finite_integer_interval.size = 1\X\0A    THEN\X\0A      RETURN(spc\\finite_integer_interval.min);\X\0A    END_IF;\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  RETURN(?);'));
#27762=EXPRESS_CODE(#11342,('LOCAL\X\0A  result : SET OF kinematic_link_representation := [];\X\0AEND_LOCAL;\X\0A  IF one_not_two\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(aprr);\X\0A      result := result + aprr[i].rep_1;\X\0A    END_REPEAT;\X\0A  ELSE\X\0A    REPEAT i := 1 TO HIINDEX(aprr);\X\0A      result := result + aprr[i].rep_2;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(result);'));
#27773=EXPRESS_CODE(#11344,('LOCAL\X\0A  types : SET OF STRING := TYPEOF(tspace);\X\0AEND_LOCAL;\X\0A  IF (schema_prefix + ''UNIFORM_PRODUCT_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(tspace\\uniform_product_space.exponent);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''LISTED_PRODUCT_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(SIZEOF(tspace\\listed_product_space.factors));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''EXTENDED_TUPLE_SPACE'') IN types\X\0A  THEN\X\0A    RETURN(space_dimension(tspace\\extended_tuple_space.base));\X\0A  END_IF;\X\0A  RETURN(?);'));
#27778=EXPRESS_CODE(#11346,('LOCAL\X\0A  typenames : SET OF STRING       := TYPEOF(space);\X\0A  factors   : LIST OF maths_space;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(space)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF subspace_of_es(space, es_reals) OR subspace_of_es(space, es_complex_numbers)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF (schema_prefix + ''UNIFORM_PRODUCT_SPACE'') IN typenames\X\0A  THEN\X\0A    RETURN(space_is_continuum(space\\uniform_product_space.base));\X\0A  END_IF;\X\0A  IF (schema_prefix + ''LISTED_PRODUCT_SPACE'') IN typenames\X\0A  THEN\X\0A    factors := space\\listed_product_space.factors;\X\0A    IF SIZEOF(factors) = 0\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    REPEAT i := 1 TO SIZEOF(factors);\X\0A      IF NOT space_is_continuum(factors[i])\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
#27789=EXPRESS_CODE(#11348,('LOCAL\X\0A  types : SET OF STRING := stripped_typeof(spc);\X\0AEND_LOCAL;\X\0A  IF ''FINITE_SPACE'' IN types\X\0A  THEN\X\0A    RETURN(bool(SIZEOF(spc\\finite_space.members) = 1));\X\0A  END_IF;\X\0A  IF ''FINITE_INTEGER_INTERVAL'' IN types\X\0A  THEN\X\0A    RETURN(bool(spc\\finite_integer_interval.size = 1));\X\0A  END_IF;\X\0A  RETURN(false);'));
#27795=EXPRESS_CODE(#11350,('LOCAL\X\0A  types  : SET OF STRING := TYPEOF(arg);\X\0A  stypes : SET OF STRING := [];\X\0A  n      : INTEGER       := LENGTH(schema_prefix);\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(types);\X\0A    IF types[i][1:n] = schema_prefix\X\0A    THEN\X\0A      stypes := stypes + types[i][n + 1:LENGTH(types[i])];\X\0A    ELSE\X\0A      stypes := stypes + types[i];\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(stypes);'));
#27805=EXPRESS_CODE(#11352,('LOCAL\X\0A  general_datum_reference_bag : BAG OF general_datum_reference := (USEDIN(input,\X\0A                                                                          ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.GENERAL_DATUM_REFERENCE.BASE''));\X\0AEND_LOCAL;\X\0A  IF SIZEOF(general_datum_reference_bag) = 1\X\0A  THEN\X\0A    RETURN(general_datum_reference_bag[1]);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#27812=EXPRESS_CODE(#11354,('CASE true OF\X\0A    (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_LOCATION'' IN\X\0A     TYPEOF(input)) : RETURN(input\\shape_aspect_relationship.relating_shape_aspect\\shape_aspect.of_shape);\X\0A    (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DIMENSIONAL_SIZE'' IN\X\0A     TYPEOF(input)) : RETURN(input\\dimensional_size.applies_to\\shape_aspect.of_shape);\X\0A    (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_SHAPE'' IN TYPEOF(input)) : RETURN(input);\X\0A    (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_ASPECT'' IN\X\0A     TYPEOF(input)) : RETURN(input\\shape_aspect.of_shape);\X\0A    OTHERWISE: RETURN(?);\X\0A  END_CASE;'));
#27816=EXPRESS_CODE(#11356,('LOCAL\X\0A  spc1   : maths_space                  := simplify_maths_space(space1);\X\0A  spc2   : maths_space                  := simplify_maths_space(space2);\X\0A  types1 : SET OF STRING                := stripped_typeof(spc1);\X\0A  types2 : SET OF STRING                := stripped_typeof(spc2);\X\0A  lgcl   : LOGICAL;\X\0A  cum    : LOGICAL;\X\0A  es_val : elementary_space_enumerators;\X\0A  bnd1   : REAL;\X\0A  bnd2   : REAL;\X\0A  n      : INTEGER;\X\0A  sp1    : maths_space;\X\0A  sp2    : maths_space;\X\0A  prgn1  : polar_complex_number_region;\X\0A  prgn2  : polar_complex_number_region;\X\0A  aitv   : finite_real_interval;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(spc1) OR NOT EXISTS(spc2)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF spc2 = the_generics\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_SPACE'' IN types1\X\0A  THEN\X\0A    IF NOT (''ELEMENTARY_SPACE'' IN types2)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    es_val := spc2\\elementary_space.space_id;\X\0A    IF spc1\\elementary_space.space_id = es_val\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    CASE spc1\\elementary_space.space_id OF\X\0A      es_numbers : RETURN(false);\X\0A      es_complex_numbers : RETURN(es_val = es_numbers);\X\0A      es_reals : RETURN(es_val = es_numbers);\X\0A      es_integers : RETURN(es_val = es_numbers);\X\0A      es_logicals : RETURN(false);\X\0A      es_booleans : RETURN(es_val = es_logicals);\X\0A      es_strings : RETURN(false);\X\0A      es_binarys : RETURN(false);\X\0A      es_maths_spaces : RETURN(false);\X\0A      es_maths_functions : RETURN(false);\X\0A      es_generics : RETURN(false);\X\0A    END_CASE;\X\0A    RETURN(unknown);\X\0A  END_IF;\X\0A  IF ''FINITE_INTEGER_INTERVAL'' IN types1\X\0A  THEN\X\0A    cum := true;\X\0A    REPEAT i := spc1\\finite_integer_interval.min TO spc1\\finite_integer_interval.max;\X\0A      cum := cum AND member_of(i, spc2);\X\0A      IF cum = false\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(cum);\X\0A  END_IF;\X\0A  IF ''INTEGER_INTERVAL_FROM_MIN'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_integers));\X\0A    END_IF;\X\0A    IF ''INTEGER_INTERVAL_FROM_MIN'' IN types2\X\0A    THEN\X\0A      RETURN(spc1\\integer_interval_from_min.min >= spc2\\integer_interval_from_min.min);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''INTEGER_INTERVAL_TO_MAX'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_integers));\X\0A    END_IF;\X\0A    IF ''INTEGER_INTERVAL_TO_MAX'' IN types2\X\0A    THEN\X\0A      RETURN(spc1\\integer_interval_to_max.max <= spc2\\integer_interval_to_max.max);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FINITE_REAL_INTERVAL'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_reals));\X\0A    END_IF;\X\0A    IF (''FINITE_REAL_INTERVAL'' IN types2) OR (''REAL_INTERVAL_FROM_MIN'' IN types2) OR (''REAL_INTERVAL_TO_MAX'' IN types2)\X\0A    THEN\X\0A      IF min_exists(spc2)\X\0A      THEN\X\0A        bnd1 := spc1\\finite_real_interval.min;\X\0A        bnd2 := real_min(spc2);\X\0A        IF (bnd1 < bnd2) OR ((bnd1 = bnd2) AND min_included(spc1) AND NOT min_included(spc2))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A      IF max_exists(spc2)\X\0A      THEN\X\0A        bnd1 := spc1\\finite_real_interval.max;\X\0A        bnd2 := real_max(spc2);\X\0A        IF (bnd1 > bnd2) OR ((bnd1 = bnd2) AND max_included(spc1) AND NOT max_included(spc2))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''REAL_INTERVAL_FROM_MIN'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_reals));\X\0A    END_IF;\X\0A    IF ''REAL_INTERVAL_FROM_MIN'' IN types2\X\0A    THEN\X\0A      bnd1 := spc1\\real_interval_from_min.min;\X\0A      bnd2 := spc2\\real_interval_from_min.min;\X\0A      RETURN((bnd2 < bnd1) OR ((bnd2 = bnd1) AND (min_included(spc2) OR NOT min_included(spc1))));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''REAL_INTERVAL_TO_MAX'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_reals));\X\0A    END_IF;\X\0A    IF ''REAL_INTERVAL_TO_MAX'' IN types2\X\0A    THEN\X\0A      bnd1 := spc1\\real_interval_to_max.max;\X\0A      bnd2 := spc2\\real_interval_to_max.max;\X\0A      RETURN((bnd2 > bnd1) OR ((bnd2 = bnd1) AND (max_included(spc2) OR NOT max_included(spc1))));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_complex_numbers));\X\0A    END_IF;\X\0A    IF ''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types2\X\0A    THEN\X\0A      RETURN(subspace_of(spc1\\cartesian_complex_number_region.real_constraint,\X\0A                         spc2\\cartesian_complex_number_region.real_constraint) AND\X\0A             subspace_of(spc1\\cartesian_complex_number_region.imag_constraint,\X\0A                         spc2\\cartesian_complex_number_region.imag_constraint));\X\0A    END_IF;\X\0A    IF ''POLAR_COMPLEX_NUMBER_REGION'' IN types2\X\0A    THEN\X\0A      RETURN(subspace_of(enclose_cregion_in_pregion(spc1, spc2\\polar_complex_number_region.centre), spc2));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''POLAR_COMPLEX_NUMBER_REGION'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      es_val := spc2\\elementary_space.space_id;\X\0A      RETURN((es_val = es_numbers) OR (es_val = es_complex_numbers));\X\0A    END_IF;\X\0A    IF ''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types2\X\0A    THEN\X\0A      RETURN(subspace_of(enclose_pregion_in_cregion(spc1), spc2));\X\0A    END_IF;\X\0A    IF ''POLAR_COMPLEX_NUMBER_REGION'' IN types2\X\0A    THEN\X\0A      prgn1 := spc1;\X\0A      prgn2 := spc2;\X\0A      IF prgn1.centre = prgn2.centre\X\0A      THEN\X\0A        IF prgn2.direction_constraint.max > PI\X\0A        THEN\X\0A          aitv := make_finite_real_interval(-PI, open, prgn2.direction_constraint.max - 2.0 * PI,\X\0A                                            prgn2.direction_constraint.max_closure);\X\0A          RETURN(subspace_of(prgn1.distance_constraint, prgn2.distance_constraint) AND\X\0A                 (subspace_of(prgn1.direction_constraint, prgn2.direction_constraint) OR\X\0A                  subspace_of(prgn1.direction_constraint, aitv)));\X\0A        ELSE\X\0A          RETURN(subspace_of(prgn1.distance_constraint, prgn2.distance_constraint) AND\X\0A                 subspace_of(prgn1.direction_constraint, prgn2.direction_constraint));\X\0A        END_IF;\X\0A      END_IF;\X\0A      RETURN(subspace_of(enclose_pregion_in_pregion(prgn1, prgn2.centre), prgn2));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FINITE_SPACE'' IN types1\X\0A  THEN\X\0A    cum := true;\X\0A    REPEAT i := 1 TO SIZEOF(spc1\\finite_space.members);\X\0A      cum := cum AND member_of(spc1\\finite_space.members[i], spc2);\X\0A      IF cum = false\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(cum);\X\0A  END_IF;\X\0A  IF ''PRODUCT_SPACE'' IN types1\X\0A  THEN\X\0A    IF ''PRODUCT_SPACE'' IN types2\X\0A    THEN\X\0A      IF space_dimension(spc1) = space_dimension(spc2)\X\0A      THEN\X\0A        cum := true;\X\0A        REPEAT i := 1 TO space_dimension(spc1);\X\0A          cum := cum AND subspace_of(factor_space(spc1, i), factor_space(spc2, i));\X\0A          IF cum = false\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        RETURN(cum);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF ''EXTENDED_TUPLE_SPACE'' IN types2\X\0A    THEN\X\0A      IF space_dimension(spc1) >= space_dimension(spc2)\X\0A      THEN\X\0A        cum := true;\X\0A        REPEAT i := 1 TO space_dimension(spc1);\X\0A          cum := cum AND subspace_of(factor_space(spc1, i), factor_space(spc2, i));\X\0A          IF cum = false\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A        RETURN(cum);\X\0A      END_IF;\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''EXTENDED_TUPLE_SPACE'' IN types1\X\0A  THEN\X\0A    IF ''EXTENDED_TUPLE_SPACE'' IN types2\X\0A    THEN\X\0A      n := space_dimension(spc1);\X\0A      IF n < space_dimension(spc2)\X\0A      THEN\X\0A        n := space_dimension(spc2);\X\0A      END_IF;\X\0A      cum := true;\X\0A      REPEAT i := 1 TO n + 1;\X\0A        cum := cum AND subspace_of(factor_space(spc1, i), factor_space(spc2, i));\X\0A        IF cum = false\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A      RETURN(cum);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FUNCTION_SPACE'' IN types1\X\0A  THEN\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      RETURN(spc2\\elementary_space.space_id = es_maths_functions);\X\0A    END_IF;\X\0A    IF ''FUNCTION_SPACE'' IN types2\X\0A    THEN\X\0A      cum := true;\X\0A      sp1 := spc1\\function_space.domain_argument;\X\0A      sp2 := spc2\\function_space.domain_argument;\X\0A      CASE spc1\\function_space.domain_constraint OF\X\0A        sc_equal : BEGIN  \X\0A                          CASE spc2\\function_space.domain_constraint OF\X\0A                            sc_equal : cum := cum AND equal_maths_spaces(sp1, sp2);\X\0A                            sc_subspace : cum := cum AND subspace_of(sp1, sp2);\X\0A                            sc_member : cum := cum AND member_of(sp1, sp2);\X\0A                          END_CASE;\X\0A        END;\X\0A        sc_subspace : BEGIN  \X\0A                             CASE spc2\\function_space.domain_constraint OF\X\0A                               sc_equal : RETURN(false);\X\0A                               sc_subspace : cum := cum AND subspace_of(sp1, sp2);\X\0A                               sc_member : BEGIN  \X\0A                                                  IF NOT member_of(sp1, sp2)\X\0A                                                  THEN\X\0A                                                    RETURN(false);\X\0A                                                  END_IF;\X\0A                                                  cum := unknown;\X\0A                               END;\X\0A                             END_CASE;\X\0A        END;\X\0A        sc_member : BEGIN  \X\0A                           CASE spc2\\function_space.domain_constraint OF\X\0A                             sc_equal : cum := cum AND space_is_singleton(sp1) AND\X\0A                                               equal_maths_spaces(singleton_member_of(sp1), sp2);\X\0A                             sc_subspace : BEGIN  \X\0A                                                  IF NOT member_of(sp2, sp1)\X\0A                                                  THEN\X\0A                                                    RETURN(false);\X\0A                                                  END_IF;\X\0A                                                  cum := unknown;\X\0A                             END;\X\0A                             sc_member : cum := cum AND (subspace_of(sp1, sp2));\X\0A                           END_CASE;\X\0A        END;\X\0A      END_CASE;\X\0A      IF cum = false\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      sp1 := spc1\\function_space.range_argument;\X\0A      sp2 := spc2\\function_space.range_argument;\X\0A      CASE spc1\\function_space.range_constraint OF\X\0A        sc_equal : BEGIN  \X\0A                          CASE spc2\\function_space.range_constraint OF\X\0A                            sc_equal : cum := cum AND equal_maths_spaces(sp1, sp2);\X\0A                            sc_subspace : cum := cum AND subspace_of(sp1, sp2);\X\0A                            sc_member : cum := cum AND member_of(sp1, sp2);\X\0A                          END_CASE;\X\0A        END;\X\0A        sc_subspace : BEGIN  \X\0A                             CASE spc2\\function_space.domain_constraint OF\X\0A                               sc_equal : RETURN(false);\X\0A                               sc_subspace : cum := cum AND subspace_of(sp1, sp2);\X\0A                               sc_member : BEGIN  \X\0A                                                  IF NOT member_of(sp1, sp2)\X\0A                                                  THEN\X\0A                                                    RETURN(false);\X\0A                                                  END_IF;\X\0A                                                  cum := unknown;\X\0A                               END;\X\0A                             END_CASE;\X\0A        END;\X\0A        sc_member : BEGIN  \X\0A                           CASE spc2\\function_space.domain_constraint OF\X\0A                             sc_equal : cum := cum AND space_is_singleton(sp1) AND\X\0A                                               equal_maths_spaces(singleton_member_of(sp1), sp2);\X\0A                             sc_subspace : BEGIN  \X\0A                                                  IF NOT member_of(sp2, sp1)\X\0A                                                  THEN\X\0A                                                    RETURN(false);\X\0A                                                  END_IF;\X\0A                                                  cum := unknown;\X\0A                             END;\X\0A                             sc_member : cum := cum AND subspace_of(sp1, sp2);\X\0A                           END_CASE;\X\0A        END;\X\0A      END_CASE;\X\0A      RETURN(cum);\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  RETURN(unknown);'));
#27835=EXPRESS_CODE(#27834,('spc1\\finite_integer_interval.min'));
