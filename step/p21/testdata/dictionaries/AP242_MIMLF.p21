DATA('_DOCUMENTATION_MAPPING_SCHEMA',('EXTENDED_DICTIONARY_SCHEMA'));
#1232=DOCUMENTATION(#1231,('\X\0AThe sdai_mapping_schema defines a model mapping between a source express-schema and a target express-schema.\X\0AIt is suitable for the ARM (source) to AIM (target) mapping used in STEP Application Protocolls.\X\0AIt includes schema to schema mapping\X\0Aentity to entity mapping\X\0Aattribute to attribute mapping\X\0Aconstraints of various kinds and variations of the above.\X\0A'));
#1235=DOCUMENTATION(#1233,(' \X\0A\X\09An attribute_mapping_path_select type specifies the elements that may be in attribute mapping path.\X\0A'));
#1238=DOCUMENTATION(#1236,('\X\0A\X\09An entity_or_attribute type defines selection between attribute or entity definitions. It is used as target for entity mapping.\X\0A'));
#1243=DOCUMENTATION(#1241,('\X\0AEntity_mapping defines how a source entity is mapped to a target entity or target attribute.\X\0AFor one source entity there may be zero, one or several alternative entity_mappings.\X\0A'));
#1245=DOCUMENTATION(#1244,('\X\0A\X\09The source entity to be mapped.\X\0A\X\09'));
#1247=DOCUMENTATION(#1246,('\X\0A\X\09The target entity or attribute to which the source entity is mapped.\X\0A\X\09'));
#1249=DOCUMENTATION(#1248,('\X\0A\X\09This entity_mapping may require additional constraints to be valid.\X\0A\X\09 The root of a constraint tree is given here.\X\0AThe constraints are restrictions that must be met for target to be a valid mapping.\X\0A\X\09'));
#1251=DOCUMENTATION(#1250,('\X\0A\X\09Defines if the entity is an entry point for wave algorithm.\X\0A\X\09'));
#1253=DOCUMENTATION(#1252,('\X\0A\X\09Defines if the entity mapping is valid only when there is at least one ARM user of this entity.\X\0A\X\09'));
#1256=DOCUMENTATION(#1254,('\X\0AA schema mapping relates a source EXPRESS schema with a target EXPRESS schema.\X\0A'));
#1258=DOCUMENTATION(#1257,('\X\0A\X\09A source is a schema of source entities and attributes definitions.\X\0A\X\09'));
#1260=DOCUMENTATION(#1259,('\X\0A\X\09A target is a schema of target entities and attributes definitions.\X\0A\X\09'));
#1262=DOCUMENTATION(#1261,('\X\0A\X\09An uofs is a collection of mappings of units of functionality.\X\0A\X\09'));
#1264=DOCUMENTATION(#1263,('\X\0A\X\09An id is identifier of mapping. It may be used to store name, version number or any other useful information about mapping.\X\0A\X\09'));
#1266=DOCUMENTATION(#1265,('\X\0A\X\09The components is the set of schema mappings which are included into this schema.\X\0A\X\09Since v25.\X\0A\X\09'));
#1269=DOCUMENTATION(#1267,('\X\0AAn uof_mapping gropes mappings by units of functionality.\X\0AMaybe to add short names of UOFs. e.g. "S1" = product_identification\X\0A'));
#1271=DOCUMENTATION(#1270,('\X\0A\X\09A name is name of unit of functionality.\X\0A\X\09'));
#1273=DOCUMENTATION(#1272,('\X\0A\X\09The mappings are a collection of mappings of source entities.\X\0A\X\09An entity_mapping may participate in more than one uof_mapping.\X\0A\X\09'));
#1276=DOCUMENTATION(#1274,('\X\0AAn aggregate_member_consttraint_select type specifies elements that may be constrained by aggregate_member_constraint.\X\0A'));
#1279=DOCUMENTATION(#1277,('\X\0AAn attribute_select type specifies elements that may be of entity type.\X\0A'));
#1282=DOCUMENTATION(#1280,('\X\0AAn attribute_value_constraint_select type specifies elements that may be constraint to some simple value (e.g. to some string value).\X\0A'));
#1285=DOCUMENTATION(#1283,('\X\0AThe constraint_select is the top element to build higher level constraints from lower level concstraints, to represent the resulting constraints for a attribute_mapping_alternative or the constraint for an entity_mapping_alternative.\X\0A'));
#1288=DOCUMENTATION(#1286,('\X\0AAn inverse_attribute_constraint specifies elements that may be as attribute in inverse_attribute_constraint. \X\0A'));
#1291=DOCUMENTATION(#1289,('\X\0AA path_constraint_select type specifies elements that may be as element1 in path_constraint. They all defines how to make step from one entity instance to other.\X\0A'));
#1294=DOCUMENTATION(#1292,('\X\0AA select_constraint_select type specifies elements that may be constrained to some defined type.\X\0A'));
#1297=DOCUMENTATION(#1295,('\X\0AAn aggregate_member_constraint is a constraint that constraint aggregates. It selects one specific or arbitrary element from aggregate. The attribute must point to an attribute of type aggregate.\X\0A'));
#1299=DOCUMENTATION(#1298,('\X\0A\X\09If set, defines element in aggregate that must meet requirement, e.g. [1], only valid for LIST and ARRAY but misused by APs.\X\0A\X\09If unset, there shall be at least one member. Notation [i]\X\0A\X\09'));
#1301=DOCUMENTATION(#1300,('\X\0A\X\09An attribute must be of aggregate type. One element of is this aggregate is selected using aggregate_member_constraint.\X\0A\X\09'));
#1304=DOCUMENTATION(#1302,('\X\0AAn and_constraint_relationship is relationship of two constraints and both these constraints must be met to fulfil and_constraint_relationship.\X\0A'));
#1307=DOCUMENTATION(#1305,('\X\0AAn attirubute_value_constraint is constraint that is used to restrict attributes or elements of aggregates to some specific simple value.\X\0A'));
#1309=DOCUMENTATION(#1308,('\X\0A\X\09An attribute is definition of attribute or aggregate that is constraint to some value.\X\0A\X\09'));
#1312=DOCUMENTATION(#1310,('\X\0AA booleant_constraint specifies a constraint on boolean value. Attribute must point to attribute definition or aggregate or select element (in this case select element that is defined type) that is of type boolean.\X\0A'));
#1314=DOCUMENTATION(#1313,('\X\0A\X\09A constraint_value is value to which the attribute is constraint.\X\0A\X\09'));
#1317=DOCUMENTATION(#1315,(' Abstract supertype for all constraints except attribute because it is taken from dictionary '));
#1320=DOCUMENTATION(#1318,('\X\0ANEGATION_CONSTRAINT is used to specify that result of constraint has to be taken negated.\X\0AIt can be used only in the addition constraint but never in the main path.\X\0A'));
#1322=DOCUMENTATION(#1321,('\X\0A\X\09constraints result of whose has to negated.\X\0A\X\09'));
#1325=DOCUMENTATION(#1323,('\X\0AThe constraint_attribute further constrains an Express-attribute, an inverse_attribute_constraint or another constraint_attribute.\X\0A'));
#1328=DOCUMENTATION(#1326,('\X\0AA constraint_relationship defines pair of constraints. It does not specify the meaning of relationship nor a direction to go.\X\0A'));
#1330=DOCUMENTATION(#1329,('\X\0A\X\09An element2 is a second constraint that is related by this constraint relationship.\X\0A\X\09'));
#1333=DOCUMENTATION(#1331,('\X\0AAn entity_constraint specifies a constraint on entity type. The attribute must point to an attribute or constraint definition that is of an entity type. This constraint restricts to subtypes or select types (maybe to complex types).\X\0A'));
#1335=DOCUMENTATION(#1334,('\X\0A\X\09A domain defines an entity type. The value of constraint attribute (it also may be element of aggregate) must by of this type.\X\0A\X\09'));
#1337=DOCUMENTATION(#1336,('\X\0A\X\09An attribute is a definition of attribute that is constraint to some entity type.\X\0A\X\09'));
#1340=DOCUMENTATION(#1338,('\X\0AAn enumeration_constraint specifies a constraint on enumeration value. Attribute must point to attribute that is of type enumeration.\X\0A'));
#1342=DOCUMENTATION(#1341,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#1345=DOCUMENTATION(#1343,('\X\0AAn exact_entity_constraint is entity constraint that constraints the attribute to be of some specific entity type, excluding subtypes of it.\X\0A'));
#1348=DOCUMENTATION(#1346,('\X\0AAn instance_equal is instance_constraint that requires to constraints to end with the same instance.\X\0A'));
#1351=DOCUMENTATION(#1349,('\X\0AAn integer_constraint specifies a constraint on integer value. Attribute must point to attribute that is of type integer.\X\0A'));
#1353=DOCUMENTATION(#1352,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#1356=DOCUMENTATION(#1354,('\X\0AAn inverse_attribute_constraint defines a needed inverse attribute that is missing in the target schema.\X\0AThis is needed to travel reverse to attribute definition.\X\0A\X\0A\X\09NOTE 1 - In the case that the AIM express already contains the proper inverse attribute this should be used.\X\0A'));
#1358=DOCUMENTATION(#1357,('\X\0A\X\09An inverted_attribute is a definition of attribute that is inverted.\X\0A\X\09'));
#1361=DOCUMENTATION(#1359,('\X\0AA logical_constraint specifies a constraint on logical value. Attribute must point to attribute that is of type logical.\X\0A'));
#1363=DOCUMENTATION(#1362,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#1366=DOCUMENTATION(#1364,('\X\0AA non_optional_constraint restricts optional attribute of entity to be non-optional.\X\0A'));
#1369=DOCUMENTATION(#1367,('\X\0AAn instances_constraint is a consraint_relationship that defined constraints on instances of one type.\X\0A'));
#1371=DOCUMENTATION(#1370,('\X\0A\X\09An element1 is first constraint that is related by this constraint relationship.\X\0A\X\09'));
#1374=DOCUMENTATION(#1372,('\X\0AAn or_constraint_relationship is an instance_constraint where it is enough, that requirements of at least one constraint are meet.\X\0A'));
#1377=DOCUMENTATION(#1375,('\X\0AA path_constraint is a constraint_relationship that does following: requires make step using element1 and meet requirements of element2. The element1 shall be a constraint on an attribute of an entity-type. The element2 defines a constraint on the entity reached by following element1.\X\0A'));
#1379=DOCUMENTATION(#1378,('\X\0A\X\09An element1 is attribute or other element that allows to make step from one entity instance to instance of other entity.\X\0A\X\09'));
#1382=DOCUMENTATION(#1380,('\X\0AEnd_of_path_constraint is intended as a replacement for\X\0Aattribute_constraint.path list. It allows to identify end of the main path\X\0Acondition. See comments at attribute_constraint.path<br>\X\0AEnd_of_path_constraint is used as value of path_constraint.element2 or at the top of\X\0Aconstraint tree.<br>\X\0AIntroduced in version 31.1.\X\0A'));
#1384=DOCUMENTATION(#1383,('\X\0A\X\09The remaining part of constraint tree which doesn''t belong to the main path.\X\0A\X\09'));
#1387=DOCUMENTATION(#1385,('\X\0AA real_constraint specifies a constraint on real value. Attribute must point to attribute that is of type real.\X\0A'));
#1389=DOCUMENTATION(#1388,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#1392=DOCUMENTATION(#1390,('\X\0AA select_constraint specifies a constraint on select type. Attribute must point to attribute that is of select type.\X\0A\X\0AComplex instances may exist with logical_, boolean_, string_, enumeration_, integer_ and real_constraint.\X\0A'));
#1394=DOCUMENTATION(#1393,('\X\0A\X\09A data_type defines a path to go throw select.\X\0A\X\09'));
#1396=DOCUMENTATION(#1395,('\X\0A\X\09An attribute is definition of attribute or other element that is of select type and is constraint to some specific selection.\X\0A\X\09'));
#1399=DOCUMENTATION(#1397,('\X\0AA String_constraint specifies a constraint on string value. Attribute must point to attribute that is of type string.\X\0A'));
#1401=DOCUMENTATION(#1400,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#1404=DOCUMENTATION(#1402,('\X\0AAn aggregate_member_constraint is a constraint that constraint how many elements may be in aggregate. It selects one specific or arbitrary element from aggregate. The attribute must point to an attribute of type aggregate.\X\0ASince v25.\X\0AThis constraint may introduce some changes in selects where valind constraints for other constraints are listed.\X\0A'));
#1406=DOCUMENTATION(#1405,('\X\0A\X\09Defines size of aggregate.\X\0A\X\09'));
#1408=DOCUMENTATION(#1407,('\X\0A\X\09An attribute must be of aggregate type. One element of is this aggregate is selected using aggregate_member_constraint.\X\0A\X\09'));
#1411=DOCUMENTATION(#1409,('\X\0AA conformance_class_mapping is a schema_mapping that defines only the mappings of entities that are required by some conformance class.\X\0A'));
#1414=DOCUMENTATION(#1412,('\X\0AA module_mapping is a schema_mapping that defines only the mappings of entities that are defined in some module.\X\0A'));
#1417=DOCUMENTATION(#1415,('\X\0AA application_protocol_mapping is a schema_mapping that defines all the mappings of entities that are defined by this application protocol.\X\0A'));
#1420=DOCUMENTATION(#1418,('\X\0AAn attribute_mapping is a generic_attribute_mapping for the case when the target is an EXPRESS data type.\X\0A'));
#1423=DOCUMENTATION(#1422,('\X\0A\X\09A domain identifies the data type of the source attribute in the case it is a named_type. \X\0A\X\09If the source attribute leads to entity data types the corresponding entity_mapping is given here.\X\0A\X\09If the source attribute is a select type of one or several defined types, \X\0A\X\09the particular defined type this attribute mapping belongs to is specified here.\X\0A\X\09In other cases this attribute is UNSET.\X\0A\X\09'));
#1427=DOCUMENTATION(#1425,('\X\0AA generic_attribute_mapping specifies one of possible more alternatives\X\0Ahow an entity attribute on the source side maps to the target side.\X\0AA generic_attribute_mapping is either a attribute_mapping_value if it\X\0Amaps to a specific value or an attribute_mapping if it maps to some\X\0AEXPRESS data type.\X\0A\X\0AFor each source attribute one or several alternative\X\0Ageneric_attribute_mapping for a given entity_mapping shall be available.\X\0AIn the case that the source entity of the parent_entity is a subtype\X\0Aof one or several entities, generic_attribute_mapping shall be available\X\0Afor all inherited attributes. If an inherited attribute is redeclared in\X\0Athe subtype generic_attribute_mapping shall reflect changes in the mapping.\X\0A\X\0AGeneric_attribute_mappings shall be available for explicit source\X\0Aattributes. For derived and inverse attributes it is optional and depends\X\0Aon specific application.\X\0A'));
#1429=DOCUMENTATION(#1428,('\X\0A\X\09Specifies for which alternative entity_mapping this mapping of attribute exist.\X\0A\X\09source:  The entity attribute of the source side.\X\0A\X\09'));
#1431=DOCUMENTATION(#1430,('\X\0A\X\09A source is a definition of source attribute.\X\0A\X\09'));
#1433=DOCUMENTATION(#1432,('\X\0A\X\09If the attribute mapping is restricted in some way, the root constraint is defined here.\X\0A\X\09In addition the constraints includes the REFERENCE PATH as well as the target data type.\X\0A\X\09It can be unset only in case of IDENTICAL MAPPING if there are no further constraints.\X\0A\X\09(See guidelines for the development of mapping specifications, ISO TC 184/SC4 N1029)\X\0A\X\09'));
#1435=DOCUMENTATION(#1434,('\X\0A\X\09In the case that the target is of a select data type and the target value is not an entity\X\0A\X\09the select path is defined here.\X\0A\X\09The select path lists all defined types which are not select types,\X\0A\X\09needed to characterize a simple type.\X\0A\X\09The usage is the same as for select_type in dictionary schema (ISO 10303-22)\X\0A\X\09and correspond to the encoding of values of select data types in ISO\X\0A\X\0910303-21 and -27 (late and early binding attribute access).\X\0A\X\09'));
#1437=DOCUMENTATION(#1436,('\X\0A\X\09If TRUE the constraints of this generic_attribute_mapping\X\0A\X\09shall be fulfilled in addition to the constraints of the parent\X\0A\X\09entity_mapping.\X\0A\X\09'));
#1440=DOCUMENTATION(#1438,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#1442=DOCUMENTATION(#1441,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#1445=DOCUMENTATION(#1443,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#1447=DOCUMENTATION(#1446,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified. \X\0A\X\09\X\09It is an Express id of enumeration item.\X\0A\X\09'));
#1450=DOCUMENTATION(#1448,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#1452=DOCUMENTATION(#1451,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#1455=DOCUMENTATION(#1453,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#1457=DOCUMENTATION(#1456,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#1460=DOCUMENTATION(#1458,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#1462=DOCUMENTATION(#1461,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#1465=DOCUMENTATION(#1463,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#1467=DOCUMENTATION(#1466,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#1470=DOCUMENTATION(#1468,('\X\0AA mapping of attribute to some specific simple value.\X\0A'));
#1473=DOCUMENTATION(#1471,('\X\0ADefines relationships between entity mappings.\X\0A'));
#1475=DOCUMENTATION(#1474,('\X\0A\X\09Master entity mapping.\X\0A\X\09'));
#1477=DOCUMENTATION(#1476,('\X\0A\X\09Dependant entity mapping.\X\0A\X\09'));
#1479=DOCUMENTATION(#1478,('\X\0A\X\09Optional constraints can define the path to walk from relating mapping to related mapping.\X\0A\X\09'));
#1481=DOCUMENTATION(#1480,('\X\0A\X\09Optional path to walk from relating mapping to related mapping.<br>\X\0A\X\09OBSOLETE SINCE VERSION 30.1 - will be removed soon\X\0A\X\09'));
#1484=DOCUMENTATION(#1482,('\X\0ARelationship between two entity mappings.\X\0AThese entities must have the same sub-supertype relationship in source schema.\X\0AIf path defined in constraints is empty, then subtype mapping constraints must include \X\0Aall constraints from supertype mapping (i.e. to be the same or more restrictive).\X\0A<br>\X\0ARelating is supertype (more restrictive mapping), related is subtype (mapping of more general entity).\X\0A'));
#1487=DOCUMENTATION(#1485,('\X\0ADefines path from one entity mapping (relating) to other entity mapping (related).\X\0AThe latter is considered to be derived variant of relating entity mapping.\X\0AIt is used in attribute mappings when attribute mapping path points only to relating entity mapping.\X\0A'));
#1490=DOCUMENTATION(#1488,('\X\0ATYPE_CONSTRAINT requires that starting AIM instance is of type defined in domain attribute.\X\0A'));
#1492=DOCUMENTATION(#1491,(' Required type of AIM instance. '));
#1494=DOCUMENTATION(#1493,(' The remaining constraints in a similar way as path.element2 attribute. '));
#1497=DOCUMENTATION(#1495,('\X\0AEXACT_TYPE_CONSTRAINT requires that starting AIM instance is of specific type but not it''s subtype.\X\0A'));
#1500=DOCUMENTATION(#1498,('\X\0AINTERSECTION_CONSTRAINT allows to get only common (intersecting) instances \X\0Afrom subpaths specified by this instance. This can be used in particularly when\X\0Aseveral AND paths point to same instance. It effectively outdates \X\0Ainstance_equal entity.\X\0AIntroduced in version 31.0.\X\0A'));
#1502=DOCUMENTATION(#1501,('\X\0A\X\09Subpaths to be intersected.\X\0A\X\09'));
ENDSEC;
DATA('_DOCUMENTATION_SDAI_MAPPING_SCHEMA',('EXTENDED_DICTIONARY_SCHEMA'));
#408=DOCUMENTATION(#407,('\X\0AThe sdai_mapping_schema defines a model mapping between a source express-schema and a target express-schema.\X\0AIt is suitable for the ARM (source) to AIM (target) mapping used in STEP Application Protocolls.\X\0AIt includes schema to schema mapping\X\0Aentity to entity mapping\X\0Aattribute to attribute mapping\X\0Aconstraints of various kinds and variations of the above.\X\0A'));
#411=DOCUMENTATION(#409,(' \X\0A\X\09An attribute_mapping_path_select type specifies the elements that may be in attribute mapping path.\X\0A'));
#414=DOCUMENTATION(#412,('\X\0A\X\09An entity_or_attribute type defines selection between attribute or entity definitions. It is used as target for entity mapping.\X\0A'));
#419=DOCUMENTATION(#417,('\X\0AEntity_mapping defines how a source entity is mapped to a target entity or target attribute.\X\0AFor one source entity there may be zero, one or several alternative entity_mappings.\X\0A'));
#421=DOCUMENTATION(#420,('\X\0A\X\09The source entity to be mapped.\X\0A\X\09'));
#423=DOCUMENTATION(#422,('\X\0A\X\09The target entity or attribute to which the source entity is mapped.\X\0A\X\09'));
#425=DOCUMENTATION(#424,('\X\0A\X\09This entity_mapping may require additional constraints to be valid.\X\0A\X\09 The root of a constraint tree is given here.\X\0AThe constraints are restrictions that must be met for target to be a valid mapping.\X\0A\X\09'));
#427=DOCUMENTATION(#426,('\X\0A\X\09Defines if the entity is an entry point for wave algorithm.\X\0A\X\09'));
#429=DOCUMENTATION(#428,('\X\0A\X\09Defines if the entity mapping is valid only when there is at least one ARM user of this entity.\X\0A\X\09'));
#432=DOCUMENTATION(#430,('\X\0AA schema mapping relates a source EXPRESS schema with a target EXPRESS schema.\X\0A'));
#434=DOCUMENTATION(#433,('\X\0A\X\09A source is a schema of source entities and attributes definitions.\X\0A\X\09'));
#436=DOCUMENTATION(#435,('\X\0A\X\09A target is a schema of target entities and attributes definitions.\X\0A\X\09'));
#438=DOCUMENTATION(#437,('\X\0A\X\09An uofs is a collection of mappings of units of functionality.\X\0A\X\09'));
#440=DOCUMENTATION(#439,('\X\0A\X\09An id is identifier of mapping. It may be used to store name, version number or any other useful information about mapping.\X\0A\X\09'));
#442=DOCUMENTATION(#441,('\X\0A\X\09The components is the set of schema mappings which are included into this schema.\X\0A\X\09Since v25.\X\0A\X\09'));
#445=DOCUMENTATION(#443,('\X\0AAn uof_mapping gropes mappings by units of functionality.\X\0AMaybe to add short names of UOFs. e.g. "S1" = product_identification\X\0A'));
#447=DOCUMENTATION(#446,('\X\0A\X\09A name is name of unit of functionality.\X\0A\X\09'));
#449=DOCUMENTATION(#448,('\X\0A\X\09The mappings are a collection of mappings of source entities.\X\0A\X\09An entity_mapping may participate in more than one uof_mapping.\X\0A\X\09'));
#452=DOCUMENTATION(#450,('\X\0AAn aggregate_member_consttraint_select type specifies elements that may be constrained by aggregate_member_constraint.\X\0A'));
#455=DOCUMENTATION(#453,('\X\0AAn attribute_select type specifies elements that may be of entity type.\X\0A'));
#458=DOCUMENTATION(#456,('\X\0AAn attribute_value_constraint_select type specifies elements that may be constraint to some simple value (e.g. to some string value).\X\0A'));
#461=DOCUMENTATION(#459,('\X\0AThe constraint_select is the top element to build higher level constraints from lower level concstraints, to represent the resulting constraints for a attribute_mapping_alternative or the constraint for an entity_mapping_alternative.\X\0A'));
#464=DOCUMENTATION(#462,('\X\0AAn inverse_attribute_constraint specifies elements that may be as attribute in inverse_attribute_constraint. \X\0A'));
#467=DOCUMENTATION(#465,('\X\0AA path_constraint_select type specifies elements that may be as element1 in path_constraint. They all defines how to make step from one entity instance to other.\X\0A'));
#470=DOCUMENTATION(#468,('\X\0AA select_constraint_select type specifies elements that may be constrained to some defined type.\X\0A'));
#473=DOCUMENTATION(#471,('\X\0AAn aggregate_member_constraint is a constraint that constraint aggregates. It selects one specific or arbitrary element from aggregate. The attribute must point to an attribute of type aggregate.\X\0A'));
#475=DOCUMENTATION(#474,('\X\0A\X\09If set, defines element in aggregate that must meet requirement, e.g. [1], only valid for LIST and ARRAY but misused by APs.\X\0A\X\09If unset, there shall be at least one member. Notation [i]\X\0A\X\09'));
#477=DOCUMENTATION(#476,('\X\0A\X\09An attribute must be of aggregate type. One element of is this aggregate is selected using aggregate_member_constraint.\X\0A\X\09'));
#480=DOCUMENTATION(#478,('\X\0AAn and_constraint_relationship is relationship of two constraints and both these constraints must be met to fulfil and_constraint_relationship.\X\0A'));
#483=DOCUMENTATION(#481,('\X\0AAn attirubute_value_constraint is constraint that is used to restrict attributes or elements of aggregates to some specific simple value.\X\0A'));
#485=DOCUMENTATION(#484,('\X\0A\X\09An attribute is definition of attribute or aggregate that is constraint to some value.\X\0A\X\09'));
#488=DOCUMENTATION(#486,('\X\0AA booleant_constraint specifies a constraint on boolean value. Attribute must point to attribute definition or aggregate or select element (in this case select element that is defined type) that is of type boolean.\X\0A'));
#490=DOCUMENTATION(#489,('\X\0A\X\09A constraint_value is value to which the attribute is constraint.\X\0A\X\09'));
#493=DOCUMENTATION(#491,(' Abstract supertype for all constraints except attribute because it is taken from dictionary '));
#496=DOCUMENTATION(#494,('\X\0ANEGATION_CONSTRAINT is used to specify that result of constraint has to be taken negated.\X\0AIt can be used only in the addition constraint but never in the main path.\X\0A'));
#498=DOCUMENTATION(#497,('\X\0A\X\09constraints result of whose has to negated.\X\0A\X\09'));
#501=DOCUMENTATION(#499,('\X\0AThe constraint_attribute further constrains an Express-attribute, an inverse_attribute_constraint or another constraint_attribute.\X\0A'));
#504=DOCUMENTATION(#502,('\X\0AA constraint_relationship defines pair of constraints. It does not specify the meaning of relationship nor a direction to go.\X\0A'));
#506=DOCUMENTATION(#505,('\X\0A\X\09An element2 is a second constraint that is related by this constraint relationship.\X\0A\X\09'));
#509=DOCUMENTATION(#507,('\X\0AAn entity_constraint specifies a constraint on entity type. The attribute must point to an attribute or constraint definition that is of an entity type. This constraint restricts to subtypes or select types (maybe to complex types).\X\0A'));
#511=DOCUMENTATION(#510,('\X\0A\X\09A domain defines an entity type. The value of constraint attribute (it also may be element of aggregate) must by of this type.\X\0A\X\09'));
#513=DOCUMENTATION(#512,('\X\0A\X\09An attribute is a definition of attribute that is constraint to some entity type.\X\0A\X\09'));
#516=DOCUMENTATION(#514,('\X\0AAn enumeration_constraint specifies a constraint on enumeration value. Attribute must point to attribute that is of type enumeration.\X\0A'));
#518=DOCUMENTATION(#517,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#521=DOCUMENTATION(#519,('\X\0AAn exact_entity_constraint is entity constraint that constraints the attribute to be of some specific entity type, excluding subtypes of it.\X\0A'));
#524=DOCUMENTATION(#522,('\X\0AAn instance_equal is instance_constraint that requires to constraints to end with the same instance.\X\0A'));
#527=DOCUMENTATION(#525,('\X\0AAn integer_constraint specifies a constraint on integer value. Attribute must point to attribute that is of type integer.\X\0A'));
#529=DOCUMENTATION(#528,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#532=DOCUMENTATION(#530,('\X\0AAn inverse_attribute_constraint defines a needed inverse attribute that is missing in the target schema.\X\0AThis is needed to travel reverse to attribute definition.\X\0A\X\0A\X\09NOTE 1 - In the case that the AIM express already contains the proper inverse attribute this should be used.\X\0A'));
#534=DOCUMENTATION(#533,('\X\0A\X\09An inverted_attribute is a definition of attribute that is inverted.\X\0A\X\09'));
#537=DOCUMENTATION(#535,('\X\0AA logical_constraint specifies a constraint on logical value. Attribute must point to attribute that is of type logical.\X\0A'));
#539=DOCUMENTATION(#538,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#542=DOCUMENTATION(#540,('\X\0AA non_optional_constraint restricts optional attribute of entity to be non-optional.\X\0A'));
#545=DOCUMENTATION(#543,('\X\0AAn instances_constraint is a consraint_relationship that defined constraints on instances of one type.\X\0A'));
#547=DOCUMENTATION(#546,('\X\0A\X\09An element1 is first constraint that is related by this constraint relationship.\X\0A\X\09'));
#550=DOCUMENTATION(#548,('\X\0AAn or_constraint_relationship is an instance_constraint where it is enough, that requirements of at least one constraint are meet.\X\0A'));
#553=DOCUMENTATION(#551,('\X\0AA path_constraint is a constraint_relationship that does following: requires make step using element1 and meet requirements of element2. The element1 shall be a constraint on an attribute of an entity-type. The element2 defines a constraint on the entity reached by following element1.\X\0A'));
#555=DOCUMENTATION(#554,('\X\0A\X\09An element1 is attribute or other element that allows to make step from one entity instance to instance of other entity.\X\0A\X\09'));
#558=DOCUMENTATION(#556,('\X\0AEnd_of_path_constraint is intended as a replacement for\X\0Aattribute_constraint.path list. It allows to identify end of the main path\X\0Acondition. See comments at attribute_constraint.path<br>\X\0AEnd_of_path_constraint is used as value of path_constraint.element2 or at the top of\X\0Aconstraint tree.<br>\X\0AIntroduced in version 31.1.\X\0A'));
#560=DOCUMENTATION(#559,('\X\0A\X\09The remaining part of constraint tree which doesn''t belong to the main path.\X\0A\X\09'));
#563=DOCUMENTATION(#561,('\X\0AA real_constraint specifies a constraint on real value. Attribute must point to attribute that is of type real.\X\0A'));
#565=DOCUMENTATION(#564,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#568=DOCUMENTATION(#566,('\X\0AA select_constraint specifies a constraint on select type. Attribute must point to attribute that is of select type.\X\0A\X\0AComplex instances may exist with logical_, boolean_, string_, enumeration_, integer_ and real_constraint.\X\0A'));
#570=DOCUMENTATION(#569,('\X\0A\X\09A data_type defines a path to go throw select.\X\0A\X\09'));
#572=DOCUMENTATION(#571,('\X\0A\X\09An attribute is definition of attribute or other element that is of select type and is constraint to some specific selection.\X\0A\X\09'));
#575=DOCUMENTATION(#573,('\X\0AA String_constraint specifies a constraint on string value. Attribute must point to attribute that is of type string.\X\0A'));
#577=DOCUMENTATION(#576,('\X\0A\X\09A constraint_value defines a constant to which constraint attribute must be equal.\X\0A\X\09'));
#580=DOCUMENTATION(#578,('\X\0AAn aggregate_member_constraint is a constraint that constraint how many elements may be in aggregate. It selects one specific or arbitrary element from aggregate. The attribute must point to an attribute of type aggregate.\X\0ASince v25.\X\0AThis constraint may introduce some changes in selects where valind constraints for other constraints are listed.\X\0A'));
#582=DOCUMENTATION(#581,('\X\0A\X\09Defines size of aggregate.\X\0A\X\09'));
#584=DOCUMENTATION(#583,('\X\0A\X\09An attribute must be of aggregate type. One element of is this aggregate is selected using aggregate_member_constraint.\X\0A\X\09'));
#587=DOCUMENTATION(#585,('\X\0AA conformance_class_mapping is a schema_mapping that defines only the mappings of entities that are required by some conformance class.\X\0A'));
#590=DOCUMENTATION(#588,('\X\0AA module_mapping is a schema_mapping that defines only the mappings of entities that are defined in some module.\X\0A'));
#593=DOCUMENTATION(#591,('\X\0AA application_protocol_mapping is a schema_mapping that defines all the mappings of entities that are defined by this application protocol.\X\0A'));
#596=DOCUMENTATION(#594,('\X\0AAn attribute_mapping is a generic_attribute_mapping for the case when the target is an EXPRESS data type.\X\0A'));
#599=DOCUMENTATION(#598,('\X\0A\X\09A domain identifies the data type of the source attribute in the case it is a named_type. \X\0A\X\09If the source attribute leads to entity data types the corresponding entity_mapping is given here.\X\0A\X\09If the source attribute is a select type of one or several defined types, \X\0A\X\09the particular defined type this attribute mapping belongs to is specified here.\X\0A\X\09In other cases this attribute is UNSET.\X\0A\X\09'));
#603=DOCUMENTATION(#601,('\X\0AA generic_attribute_mapping specifies one of possible more alternatives\X\0Ahow an entity attribute on the source side maps to the target side.\X\0AA generic_attribute_mapping is either a attribute_mapping_value if it\X\0Amaps to a specific value or an attribute_mapping if it maps to some\X\0AEXPRESS data type.\X\0A\X\0AFor each source attribute one or several alternative\X\0Ageneric_attribute_mapping for a given entity_mapping shall be available.\X\0AIn the case that the source entity of the parent_entity is a subtype\X\0Aof one or several entities, generic_attribute_mapping shall be available\X\0Afor all inherited attributes. If an inherited attribute is redeclared in\X\0Athe subtype generic_attribute_mapping shall reflect changes in the mapping.\X\0A\X\0AGeneric_attribute_mappings shall be available for explicit source\X\0Aattributes. For derived and inverse attributes it is optional and depends\X\0Aon specific application.\X\0A'));
#605=DOCUMENTATION(#604,('\X\0A\X\09Specifies for which alternative entity_mapping this mapping of attribute exist.\X\0A\X\09source:  The entity attribute of the source side.\X\0A\X\09'));
#607=DOCUMENTATION(#606,('\X\0A\X\09A source is a definition of source attribute.\X\0A\X\09'));
#609=DOCUMENTATION(#608,('\X\0A\X\09If the attribute mapping is restricted in some way, the root constraint is defined here.\X\0A\X\09In addition the constraints includes the REFERENCE PATH as well as the target data type.\X\0A\X\09It can be unset only in case of IDENTICAL MAPPING if there are no further constraints.\X\0A\X\09(See guidelines for the development of mapping specifications, ISO TC 184/SC4 N1029)\X\0A\X\09'));
#611=DOCUMENTATION(#610,('\X\0A\X\09In the case that the target is of a select data type and the target value is not an entity\X\0A\X\09the select path is defined here.\X\0A\X\09The select path lists all defined types which are not select types,\X\0A\X\09needed to characterize a simple type.\X\0A\X\09The usage is the same as for select_type in dictionary schema (ISO 10303-22)\X\0A\X\09and correspond to the encoding of values of select data types in ISO\X\0A\X\0910303-21 and -27 (late and early binding attribute access).\X\0A\X\09'));
#613=DOCUMENTATION(#612,('\X\0A\X\09If TRUE the constraints of this generic_attribute_mapping\X\0A\X\09shall be fulfilled in addition to the constraints of the parent\X\0A\X\09entity_mapping.\X\0A\X\09'));
#616=DOCUMENTATION(#614,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#618=DOCUMENTATION(#617,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#621=DOCUMENTATION(#619,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#623=DOCUMENTATION(#622,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified. \X\0A\X\09\X\09It is an Express id of enumeration item.\X\0A\X\09'));
#626=DOCUMENTATION(#624,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#628=DOCUMENTATION(#627,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#631=DOCUMENTATION(#629,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#633=DOCUMENTATION(#632,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#636=DOCUMENTATION(#634,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#638=DOCUMENTATION(#637,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#641=DOCUMENTATION(#639,('\X\0A\X\09An attribute mapping to specify the mapping for the specific value of attribute.\X\0A'));
#643=DOCUMENTATION(#642,('\X\0A\X\09\X\09The value of source attribute for which the mapping is specified.\X\0A\X\09'));
#646=DOCUMENTATION(#644,('\X\0AA mapping of attribute to some specific simple value.\X\0A'));
#649=DOCUMENTATION(#647,('\X\0ADefines relationships between entity mappings.\X\0A'));
#651=DOCUMENTATION(#650,('\X\0A\X\09Master entity mapping.\X\0A\X\09'));
#653=DOCUMENTATION(#652,('\X\0A\X\09Dependant entity mapping.\X\0A\X\09'));
#655=DOCUMENTATION(#654,('\X\0A\X\09Optional constraints can define the path to walk from relating mapping to related mapping.\X\0A\X\09'));
#657=DOCUMENTATION(#656,('\X\0A\X\09Optional path to walk from relating mapping to related mapping.<br>\X\0A\X\09OBSOLETE SINCE VERSION 30.1 - will be removed soon\X\0A\X\09'));
#660=DOCUMENTATION(#658,('\X\0ARelationship between two entity mappings.\X\0AThese entities must have the same sub-supertype relationship in source schema.\X\0AIf path defined in constraints is empty, then subtype mapping constraints must include \X\0Aall constraints from supertype mapping (i.e. to be the same or more restrictive).\X\0A<br>\X\0ARelating is supertype (more restrictive mapping), related is subtype (mapping of more general entity).\X\0A'));
#663=DOCUMENTATION(#661,('\X\0ADefines path from one entity mapping (relating) to other entity mapping (related).\X\0AThe latter is considered to be derived variant of relating entity mapping.\X\0AIt is used in attribute mappings when attribute mapping path points only to relating entity mapping.\X\0A'));
#666=DOCUMENTATION(#664,('\X\0ATYPE_CONSTRAINT requires that starting AIM instance is of type defined in domain attribute.\X\0A'));
#668=DOCUMENTATION(#667,(' Required type of AIM instance. '));
#670=DOCUMENTATION(#669,(' The remaining constraints in a similar way as path.element2 attribute. '));
#673=DOCUMENTATION(#671,('\X\0AEXACT_TYPE_CONSTRAINT requires that starting AIM instance is of specific type but not it''s subtype.\X\0A'));
#676=DOCUMENTATION(#674,('\X\0AINTERSECTION_CONSTRAINT allows to get only common (intersecting) instances \X\0Afrom subpaths specified by this instance. This can be used in particularly when\X\0Aseveral AND paths point to same instance. It effectively outdates \X\0Ainstance_equal entity.\X\0AIntroduced in version 31.0.\X\0A'));
#678=DOCUMENTATION(#677,('\X\0A\X\09Subpaths to be intersected.\X\0A\X\09'));
ENDSEC;
