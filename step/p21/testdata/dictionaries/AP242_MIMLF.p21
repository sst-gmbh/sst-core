#25115=EXPRESS_CODE(#10854,('CONSTANT\X\0A  base_types : SET OF STRING :=\X\0A               [''NUMBER'',\X\0A                ''COMPLEX_NUMBER_LITERAL'',\X\0A                ''REAL'',\X\0A                ''INTEGER'',\X\0A                ''LOGICAL'',\X\0A                ''BOOLEAN'',\X\0A                ''STRING'',\X\0A                ''BINARY'',\X\0A                ''MATHS_SPACE'',\X\0A                ''MATHS_FUNCTION'',\X\0A                ''LIST'',\X\0A                ''ELEMENTARY_SPACE_ENUMERATORS'',\X\0A                ''ORDERING_TYPE'',\X\0A                ''LOWER_UPPER'',\X\0A                ''SYMMETRY_TYPE'',\X\0A                ''ELEMENTARY_FUNCTION_ENUMERATORS'',\X\0A                ''OPEN_CLOSED'',\X\0A                ''SPACE_CONSTRAINT_TYPE'',\X\0A                ''REPACKAGE_OPTIONS'',\X\0A                ''EXTENSION_OPTIONS''];\X\0AEND_CONSTANT;\X\0ALOCAL\X\0A  v        : maths_value;\X\0A  key_type : STRING             := '''';\X\0A  types    : SET OF STRING;\X\0A  ge       : generic_expression;\X\0A  cum      : LOGICAL            := true;\X\0A  vspc     : maths_space;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(sv) OR NOT EXISTS(es)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  CASE es OF\X\0A    es_numbers : key_type := ''NUMBER'';\X\0A    es_complex_numbers : key_type := ''COMPLEX_NUMBER_LITERAL'';\X\0A    es_reals : key_type := ''REAL'';\X\0A    es_integers : key_type := ''INTEGER'';\X\0A    es_logicals : key_type := ''LOGICAL'';\X\0A    es_booleans : key_type := ''BOOLEAN'';\X\0A    es_strings : key_type := ''STRING'';\X\0A    es_binarys : key_type := ''BINARY'';\X\0A    es_maths_spaces : key_type := ''MATHS_SPACE'';\X\0A    es_maths_functions : key_type := ''MATHS_FUNCTION'';\X\0A    es_generics : RETURN(true);\X\0A  END_CASE;\X\0A  REPEAT i := 1 TO SIZEOF(sv);\X\0A    IF NOT EXISTS(sv[i])\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    v := simplify_maths_value(sv[i]);\X\0A    types := stripped_typeof(v);\X\0A    IF key_type IN types\X\0A    THEN\X\0A      SKIP;\X\0A    END_IF;\X\0A    IF (es = es_numbers) AND (''COMPLEX_NUMBER_LITERAL'' IN types)\X\0A    THEN\X\0A      SKIP;\X\0A    END_IF;\X\0A    IF SIZEOF(base_types * types) > 0\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ge := v;\X\0A    IF has_values_space(ge)\X\0A    THEN\X\0A      vspc := values_space_of(ge);\X\0A      IF NOT subspace_of_es(vspc, es)\X\0A      THEN\X\0A        IF NOT compatible_spaces(vspc, make_elementary_space(es))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A        cum := unknown;\X\0A      END_IF;\X\0A    ELSE\X\0A      cum := unknown;\X\0A    END_IF;\X\0A    IF cum = false\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(cum);'));
#25117=EXPRESS_CODE(#10856,('[''NUMBER'',\X\0A                ''COMPLEX_NUMBER_LITERAL'',\X\0A                ''REAL'',\X\0A                ''INTEGER'',\X\0A                ''LOGICAL'',\X\0A                ''BOOLEAN'',\X\0A                ''STRING'',\X\0A                ''BINARY'',\X\0A                ''MATHS_SPACE'',\X\0A                ''MATHS_FUNCTION'',\X\0A                ''LIST'',\X\0A                ''ELEMENTARY_SPACE_ENUMERATORS'',\X\0A                ''ORDERING_TYPE'',\X\0A                ''LOWER_UPPER'',\X\0A                ''SYMMETRY_TYPE'',\X\0A                ''ELEMENTARY_FUNCTION_ENUMERATORS'',\X\0A                ''OPEN_CLOSED'',\X\0A                ''SPACE_CONSTRAINT_TYPE'',\X\0A                ''REPACKAGE_OPTIONS'',\X\0A                ''EXTENSION_OPTIONS'']'));
#25130=EXPRESS_CODE(#10858,('LOCAL\X\0A  spc_id : elementary_space_enumerators;\X\0AEND_LOCAL;\X\0A  IF (sc = sc_equal) OR NOT (''ELEMENTARY_SPACE'' IN stripped_typeof(spc))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  spc_id := spc\\elementary_space.space_id;\X\0A  IF sc = sc_subspace\X\0A  THEN\X\0A    RETURN(bool(spc_id = es_generics));\X\0A  END_IF;\X\0A  IF sc = sc_member\X\0A  THEN\X\0A    RETURN(bool((spc_id = es_generics) OR (spc_id = es_maths_spaces)));\X\0A  END_IF;\X\0A  RETURN(?);'));
#25134=EXPRESS_CODE(#10860,('IF (p.size_in_x > 0.) AND (p.size_in_y > 0.)\X\0A  THEN\X\0A    RETURN(p.size_in_x / p.size_in_y);\X\0A  ELSE\X\0A    RETURN(?);\X\0A  END_IF;'));
#25137=EXPRESS_CODE(#10862,('LOCAL\X\0A  local_relation  : SET OF assembly_component_usage := [];\X\0A  local_relation2 : BAG OF assembly_component_usage := [];\X\0AEND_LOCAL;\X\0A  local_relation2 := local_relation2 +\X\0A                     QUERY(pdr\X\0A                           <* USEDIN(item,\X\0A                                     ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_RELATIONSHIP.RELATING_PRODUCT_DEFINITION'')\X\0A                           | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ASSEMBLY_COMPONENT_USAGE'' IN TYPEOF(pdr));\X\0A  local_relation := bag_to_set(local_relation2);\X\0A  IF (SIZEOF(local_relation) = 0)\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    RETURN(false);\X\0A  END_IF;'));
#25148=EXPRESS_CODE(#10864,('IF (SIZEOF(QUERY(pdr\X\0A                   <* USEDIN(item,\X\0A                             ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_RELATIONSHIP.RELATED_PRODUCT_DEFINITION'')\X\0A                   | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ASSEMBLY_COMPONENT_USAGE'' IN TYPEOF(pdr))) =\X\0A      0)\X\0A  THEN\X\0A    RETURN(true);\X\0A  ELSE\X\0A    RETURN(false);\X\0A  END_IF;'));
#25152=EXPRESS_CODE(#10866,('LOCAL\X\0A  types1  : SET OF STRING         := stripped_typeof(ts1);\X\0A  types2  : SET OF STRING         := stripped_typeof(ts2);\X\0A  up1     : uniform_product_space := make_uniform_product_space(the_reals, 1);\X\0A  up2     : uniform_product_space := make_uniform_product_space(the_reals, 1);\X\0A  lp1     : listed_product_space  := the_zero_tuple_space;\X\0A  lp2     : listed_product_space  := the_zero_tuple_space;\X\0A  lps     : listed_product_space  := the_zero_tuple_space;\X\0A  et1     : extended_tuple_space  := the_tuples;\X\0A  et2     : extended_tuple_space  := the_tuples;\X\0A  ets     : extended_tuple_space  := the_tuples;\X\0A  use_up1 : BOOLEAN;\X\0A  use_up2 : BOOLEAN;\X\0A  use_lp1 : BOOLEAN;\X\0A  use_lp2 : BOOLEAN;\X\0A  factors : LIST OF maths_space   := [];\X\0A  tspace  : tuple_space;\X\0AEND_LOCAL;\X\0A  IF ''UNIFORM_PRODUCT_SPACE'' IN types1\X\0A  THEN\X\0A    up1 := ts1;\X\0A    use_up1 := true;\X\0A    use_lp1 := false;\X\0A  ELSE\X\0A    IF ''LISTED_PRODUCT_SPACE'' IN types1\X\0A    THEN\X\0A      lp1 := ts1;\X\0A      use_up1 := false;\X\0A      use_lp1 := true;\X\0A    ELSE\X\0A      IF NOT (''EXTENDED_TUPLE_SPACE'' IN types1)\X\0A      THEN\X\0A        RETURN(?);\X\0A      END_IF;\X\0A      et1 := ts1;\X\0A      use_up1 := false;\X\0A      use_lp1 := false;\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF ''UNIFORM_PRODUCT_SPACE'' IN types2\X\0A  THEN\X\0A    up2 := ts2;\X\0A    use_up2 := true;\X\0A    use_lp2 := false;\X\0A  ELSE\X\0A    IF ''LISTED_PRODUCT_SPACE'' IN types2\X\0A    THEN\X\0A      lp2 := ts2;\X\0A      use_up2 := false;\X\0A      use_lp2 := true;\X\0A    ELSE\X\0A      IF NOT (''EXTENDED_TUPLE_SPACE'' IN types2)\X\0A      THEN\X\0A        RETURN(?);\X\0A      END_IF;\X\0A      et2 := ts2;\X\0A      use_up2 := false;\X\0A      use_lp2 := false;\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF use_up1\X\0A  THEN\X\0A    IF use_up2\X\0A    THEN\X\0A      IF up1.base = up2.base\X\0A      THEN\X\0A        tspace := make_uniform_product_space(up1.base, up1.exponent + up2.exponent);\X\0A      ELSE\X\0A        factors := [up1.base:up1.exponent,up2.base:up2.exponent];\X\0A        tspace := make_listed_product_space(factors);\X\0A      END_IF;\X\0A    ELSE\X\0A      IF use_lp2\X\0A      THEN\X\0A        factors := [up1.base:up1.exponent];\X\0A        factors := factors + lp2.factors;\X\0A        tspace := make_listed_product_space(factors);\X\0A      ELSE\X\0A        tspace := assoc_product_space(up1, et2.base);\X\0A        tspace := make_extended_tuple_space(tspace, et2.extender);\X\0A      END_IF;\X\0A    END_IF;\X\0A  ELSE\X\0A    IF use_lp1\X\0A    THEN\X\0A      IF use_up2\X\0A      THEN\X\0A        factors := [up2.base:up2.exponent];\X\0A        factors := lp1.factors + factors;\X\0A        tspace := make_listed_product_space(factors);\X\0A      ELSE\X\0A        IF use_lp2\X\0A        THEN\X\0A          tspace := make_listed_product_space(lp1.factors + lp2.factors);\X\0A        ELSE\X\0A          tspace := assoc_product_space(lp1, et2.base);\X\0A          tspace := make_extended_tuple_space(tspace, et2.extender);\X\0A        END_IF;\X\0A      END_IF;\X\0A    ELSE\X\0A      IF use_up2\X\0A      THEN\X\0A        IF et1.extender = up2.base\X\0A        THEN\X\0A          tspace := assoc_product_space(et1.base, up2);\X\0A          tspace := make_extended_tuple_space(tspace, et1.extender);\X\0A        ELSE\X\0A          RETURN(?);\X\0A        END_IF;\X\0A      ELSE\X\0A        IF use_lp2\X\0A        THEN\X\0A          factors := lp2.factors;\X\0A          REPEAT i := 1 TO SIZEOF(factors);\X\0A            IF et1.extender <> factors[i]\X\0A            THEN\X\0A              RETURN(?);\X\0A            END_IF;\X\0A          END_REPEAT;\X\0A          tspace := assoc_product_space(et1.base, lp2);\X\0A          tspace := make_extended_tuple_space(tspace, et1.extender);\X\0A        ELSE\X\0A          IF et1.extender = et2.extender\X\0A          THEN\X\0A            tspace := assoc_product_space(et1, et2.base);\X\0A          ELSE\X\0A            RETURN(?);\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(tspace);'));
#25178=EXPRESS_CODE(#10868,('LOCAL\X\0A  surf : surface;\X\0AEND_LOCAL;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(arg)\X\0A  THEN\X\0A    surf := arg\\pcurve.basis_surface;\X\0A  ELSE\X\0A    surf := arg;\X\0A  END_IF;\X\0A  RETURN(surf);'));
#25183=EXPRESS_CODE(#10870,('LOCAL\X\0A  r : REAL;\X\0AEND_LOCAL;\X\0A  IF (y = 0.0) AND (x = 0.0)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  r := ATAN(y, x);\X\0A  IF x < 0.0\X\0A  THEN\X\0A    IF y < 0.0\X\0A    THEN\X\0A      r := r - PI;\X\0A    ELSE\X\0A      r := r + PI;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(r);'));
#25193=EXPRESS_CODE(#10872,('LOCAL\X\0A  the_set : SET OF GENERIC : INTYPE := [];\X\0AEND_LOCAL;\X\0A  IF SIZEOF(the_bag) > 0\X\0A  THEN\X\0A    REPEAT i := 1 TO HIINDEX(the_bag);\X\0A      the_set := the_set + the_bag[i];\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(the_set);'));
#25209=EXPRESS_CODE(#10874,('LOCAL\X\0A  u      : LIST [2 : 3] OF direction;\X\0A  factor : REAL;\X\0A  d1     : direction;\X\0A  d2     : direction;\X\0AEND_LOCAL;\X\0A  IF (dim = 3)\X\0A  THEN\X\0A    d1 := NVL(normalise(axis3), dummy_gri || direction([0.0,0.0,1.0]));\X\0A    d2 := first_proj_axis(d1, axis1);\X\0A    u := [d2,second_proj_axis(d1, d2, axis2),d1];\X\0A  ELSE\X\0A    IF EXISTS(axis1)\X\0A    THEN\X\0A      d1 := normalise(axis1);\X\0A      u := [d1,orthogonal_complement(d1)];\X\0A      IF EXISTS(axis2)\X\0A      THEN\X\0A        factor := dot_product(axis2, u[2]);\X\0A        IF (factor < 0.0)\X\0A        THEN\X\0A          u[2].direction_ratios[1] := -u[2].direction_ratios[1];\X\0A          u[2].direction_ratios[2] := -u[2].direction_ratios[2];\X\0A        END_IF;\X\0A      END_IF;\X\0A    ELSE\X\0A      IF EXISTS(axis2)\X\0A      THEN\X\0A        d1 := normalise(axis2);\X\0A        u := [orthogonal_complement(d1),d1];\X\0A        u[1].direction_ratios[1] := -u[1].direction_ratios[1];\X\0A        u[1].direction_ratios[2] := -u[1].direction_ratios[2];\X\0A      ELSE\X\0A        u := [dummy_gri || direction([1.0,0.0]),dummy_gri || direction([0.0,1.0])];\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(u);'));
#25220=EXPRESS_CODE(#10876,('IF NOT EXISTS(lgcl)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF lgcl <> true\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  RETURN(true);'));
#25225=EXPRESS_CODE(#10878,('IF b\X\0A  THEN\X\0A    RETURN(choice1);\X\0A  ELSE\X\0A    RETURN(choice2);\X\0A  END_IF;'));
#25232=EXPRESS_CODE(#10880,('LOCAL\X\0A  d : direction := NVL(normalise(ref_direction), dummy_gri || direction([1.0,0.0]));\X\0AEND_LOCAL;\X\0A  RETURN([d,orthogonal_complement(d)]);'));
#25241=EXPRESS_CODE(#10882,('LOCAL\X\0A  d1 : direction;\X\0A  d2 : direction;\X\0AEND_LOCAL;\X\0A  d1 := NVL(normalise(axis), dummy_gri || direction([0.0,0.0,1.0]));\X\0A  d2 := first_proj_axis(d1, ref_direction);\X\0A  RETURN([d2,normalise(cross_product(d1, d2))\\vector.orientation,d1]);'));
#25247=EXPRESS_CODE(#10884,('LOCAL\X\0A  category_assignments : BAG OF product_category;\X\0A  categories           : SET OF STRING           := [];\X\0AEND_LOCAL;\X\0A  category_assignments := USEDIN(obj,\X\0A                                 ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_RELATED_PRODUCT_CATEGORY.PRODUCTS'');\X\0A  REPEAT i := LOINDEX(category_assignments) TO HIINDEX(category_assignments) BY 1;\X\0A    categories := categories + category_assignments[i].name;\X\0A  END_REPEAT;\X\0A  RETURN(categories);'));
#25258=EXPRESS_CODE(#10886,('LOCAL\X\0A  po_role : STRING;\X\0AEND_LOCAL;\X\0A  po_role := e\\person_and_organization_assignment.role.name;\X\0A  CASE po_role OF\X\0A    ''request_recipient'' : IF SIZEOF(e.items) <>\X\0A                             SIZEOF(QUERY(x\X\0A                                          <* e.items\X\0A                                          | SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CHANGE_REQUEST'',\X\0A                                                    ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.START_REQUEST''] *\X\0A                                                   TYPEOF(x)) =\X\0A                                            1))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''initiator'' : IF SIZEOF(e.items) <>\X\0A                     SIZEOF(QUERY(x\X\0A                                  <* e.items\X\0A                                  | SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CHANGE_REQUEST'',\X\0A                                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.START_REQUEST'',\X\0A                                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.START_WORK'',\X\0A                                            ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CHANGE''] *\X\0A                                           TYPEOF(x)) =\X\0A                                    1))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''creator'' : IF SIZEOF(e.items) <>\X\0A                   SIZEOF(QUERY(x\X\0A                                <* e.items\X\0A                                | SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_FORMATION'',\X\0A                                          ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION''] *\X\0A                                         TYPEOF(x)) =\X\0A                                  1))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''part_supplier'' : IF SIZEOF(e.items) <>\X\0A                         SIZEOF(QUERY(x\X\0A                                      <* e.items\X\0A                                      | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_FORMATION'' IN\X\0A                                        TYPEOF(x)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''design_supplier'' : IF SIZEOF(e.items) <>\X\0A                           SIZEOF(QUERY(x\X\0A                                        <* e.items\X\0A                                        | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_FORMATION'' IN\X\0A                                          TYPEOF(x)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''design_owner'' : IF SIZEOF(e.items) <>\X\0A                        SIZEOF(QUERY(x\X\0A                                     <* e.items\X\0A                                     | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT'' IN TYPEOF(x)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''configuration_manager'' : IF SIZEOF(e.items) <>\X\0A                                 SIZEOF(QUERY(x\X\0A                                              <* e.items\X\0A                                              | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONFIGURATION_ITEM'' IN\X\0A                                                TYPEOF(x)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''contractor'' : IF SIZEOF(e.items) <>\X\0A                      SIZEOF(QUERY(x\X\0A                                   <* e.items\X\0A                                   | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONTRACT'' IN TYPEOF(x)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    ''classification_officer'' : IF SIZEOF(e.items) <>\X\0A                                  SIZEOF(QUERY(x\X\0A                                               <* e.items\X\0A                                               | ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SECURITY_CLASSIFICATION'' IN\X\0A                                                 TYPEOF(x)))\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    OTHERWISE: RETURN(true);\X\0A  END_CASE;\X\0A  RETURN(true);'));
#25265=EXPRESS_CODE(#10888,('LOCAL\X\0A  i           : INTEGER;\X\0A  next_vertex : vertex;\X\0AEND_LOCAL;\X\0A  IF (SIZEOF(edges) = 1)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ((edges[2].edge_start :=: edges[1].edge_end) XOR (edges[2].edge_start :=: edges[1].edge_start))\X\0A  THEN\X\0A    next_vertex := edges[2].edge_end;\X\0A  ELSE\X\0A    IF ((edges[2].edge_end :=: edges[1].edge_end) XOR (edges[2].edge_end :=: edges[1].edge_start))\X\0A    THEN\X\0A      next_vertex := edges[2].edge_start;\X\0A    ELSE\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF (SIZEOF(edges) = 2)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  REPEAT i := 3 TO HIINDEX(edges);\X\0A    IF (edges[i].edge_start :=: next_vertex)\X\0A    THEN\X\0A      next_vertex := edges[i].edge_end;\X\0A    ELSE\X\0A      IF (edges[i].edge_end :=: next_vertex)\X\0A      THEN\X\0A        next_vertex := edges[i].edge_start;\X\0A      ELSE\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#25272=EXPRESS_CODE(#10890,('LOCAL\X\0A  crv    : curve   := checked_curve;\X\0A  i      : INTEGER;\X\0A  j      : INTEGER;\X\0A  result : BOOLEAN := false;\X\0AEND_LOCAL;\X\0A  IF (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONIC'',\X\0A              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LINE''] *\X\0A             TYPEOF(crv)) >\X\0A      0)\X\0A  THEN\X\0A    result := true;\X\0A  ELSE\X\0A    IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.TRIMMED_CURVE'' IN TYPEOF(crv)) AND\X\0A        check_curve_planarity(crv\\trimmed_curve.basis_curve))\X\0A    THEN\X\0A      result := true;\X\0A    ELSE\X\0A      IF ((''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PCURVE'' IN TYPEOF(crv)) AND\X\0A          (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE'' IN TYPEOF(crv\\pcurve.basis_surface)))\X\0A      THEN\X\0A        result := true;\X\0A      ELSE\X\0A        IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SURFACE_CURVE'' IN TYPEOF(crv))\X\0A        THEN\X\0A          BEGIN  \X\0A                 REPEAT j := 1 TO HIINDEX(crv\\surface_curve.basis_surface);\X\0A                   IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE'' IN\X\0A                       TYPEOF(crv\\surface_curve.basis_surface[j]))\X\0A                   THEN\X\0A                     result := true;\X\0A                   END_IF;\X\0A                 END_REPEAT;\X\0A          END;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(result);'));
#25292=EXPRESS_CODE(#10892,('LOCAL\X\0A  globaldim : INTEGER                       := 0;\X\0A  reps      : SET [0 : ?] OF representation := [];\X\0A  result    : BOOLEAN                       := true;\X\0AEND_LOCAL;\X\0A  globaldim := geometric_dimensionalities_in_contexts(grc);\X\0A  IF (globaldim > 0)\X\0A  THEN\X\0A    IF (SIZEOF(capt) > 0)\X\0A    THEN\X\0A      REPEAT i := 1 TO HIINDEX(capt);\X\0A        IF (HIINDEX(capt[i].coordinates) <> globaldim)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A    IF (SIZEOF(dir) > 0)\X\0A    THEN\X\0A      REPEAT i := 1 TO HIINDEX(dir);\X\0A        IF (HIINDEX(dir[i].direction_ratios) <> globaldim)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A    RETURN(result);\X\0A  ELSE\X\0A    IF (SIZEOF(capt) > 0)\X\0A    THEN\X\0A      REPEAT i := 1 TO HIINDEX(capt);\X\0A        reps := using_representations(capt[i]);\X\0A        IF (SIZEOF(reps) > 0)\X\0A        THEN\X\0A          REPEAT j := 1 TO HIINDEX(reps);\X\0A            IF (HIINDEX(capt[i].coordinates) <>\X\0A                reps[j].context_of_items\\geometric_representation_context.coordinate_space_dimension)\X\0A            THEN\X\0A              RETURN(false);\X\0A            END_IF;\X\0A          END_REPEAT;\X\0A        ELSE\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A    IF (SIZEOF(dir) > 0)\X\0A    THEN\X\0A      REPEAT i := 1 TO HIINDEX(dir);\X\0A        reps := using_representations(dir[i]);\X\0A        IF (SIZEOF(reps) > 0)\X\0A        THEN\X\0A          REPEAT j := 1 TO HIINDEX(reps);\X\0A            IF (HIINDEX(dir[i].direction_ratios) <>\X\0A                reps[j].context_of_items\\geometric_representation_context.coordinate_space_dimension)\X\0A            THEN\X\0A              RETURN(false);\X\0A            END_IF;\X\0A          END_REPEAT;\X\0A        ELSE\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(result);'));
#25319=EXPRESS_CODE(#10894,('LOCAL\X\0A  mthspc   : maths_space;\X\0A  interval : finite_integer_interval;\X\0A  i        : INTEGER;\X\0AEND_LOCAL;\X\0A  mthspc := factor1(idxdom);\X\0A  interval := mthspc;\X\0A  IF order = by_rows\X\0A  THEN\X\0A    i := 1;\X\0A  ELSE\X\0A    i := 2;\X\0A  END_IF;\X\0A  RETURN(bool((interval.min <= base) AND (interval.max >= base + shape[i])));'));
#25326=EXPRESS_CODE(#10896,('LOCAL\X\0A  temp         : maths_space;\X\0A  idx_rng_itvl : finite_integer_interval;\X\0A  loc_dmn_itvl : finite_integer_interval;\X\0AEND_LOCAL;\X\0A  temp := factor1(index_range);\X\0A  IF (schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(temp)\X\0A  THEN\X\0A    temp := factor1(temp);\X\0A  END_IF;\X\0A  IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  idx_rng_itvl := temp;\X\0A  temp := factor1(loc_domain);\X\0A  IF (schema_prefix + ''TUPLE_SPACE'') IN TYPEOF(temp)\X\0A  THEN\X\0A    temp := factor1(temp);\X\0A  END_IF;\X\0A  IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(temp))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  loc_dmn_itvl := temp;\X\0A  RETURN(bool((loc_dmn_itvl.min <= idx_rng_itvl.min) AND (idx_rng_itvl.max <= loc_dmn_itvl.max + 1)));'));
#25338=EXPRESS_CODE(#10898,('LOCAL\X\0A  mthspc   : maths_space;\X\0A  interval : finite_integer_interval;\X\0A  i        : INTEGER;\X\0AEND_LOCAL;\X\0A  IF space_dimension(locrng) <> 1\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  mthspc := factor1(locrng);\X\0A  IF NOT ((schema_prefix + ''FINITE_INTEGER_INTERVAL'') IN TYPEOF(mthspc))\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  interval := mthspc;\X\0A  IF order = by_rows\X\0A  THEN\X\0A    i := 2;\X\0A  ELSE\X\0A    i := 1;\X\0A  END_IF;\X\0A  RETURN(bool((interval.min >= base) AND (interval.max <= base + shape[i] - 1)));'));
#25344=EXPRESS_CODE(#10900,('LOCAL\X\0A  a : SET OF text_alignment := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(ct.collected_text);\X\0A    a := a + [ct.collected_text[i]\\text_literal.alignment];\X\0A  END_REPEAT;\X\0A  RETURN(SIZEOF(a) = 1);'));
#25353=EXPRESS_CODE(#10902,('LOCAL\X\0A  f : SET OF font_select := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(ct.collected_text);\X\0A    f := f + [ct.collected_text[i]\\text_literal.font];\X\0A  END_REPEAT;\X\0A  RETURN(SIZEOF(f) <= 1);'));
#25362=EXPRESS_CODE(#10904,('LOCAL\X\0A  item : classification_item;\X\0A  role : classification_role;\X\0AEND_LOCAL;\X\0A  role := aia\\classification_assignment.role;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CLASS_SYSTEM'' IN\X\0A      TYPEOF(aia\\classification_assignment.assigned_class))\X\0A  THEN\X\0A    IF (role\\classification_role.name <> ''class system membership'')\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    REPEAT i := LOINDEX(aia\\applied_classification_assignment.items) TO HIINDEX(aia\\applied_classification_assignment.items);\X\0A      item := aia\\applied_classification_assignment.items[i];\X\0A      IF (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CHARACTERIZED_CLASS''] * TYPEOF(item)) = 0)\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CHARACTERIZED_CLASS'' IN\X\0A      TYPEOF(aia\\classification_assignment.assigned_class))\X\0A  THEN\X\0A    IF NOT (role\\classification_role.name IN [''definitional'',''non-definitional'',''''])\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    REPEAT i := LOINDEX(aia\\applied_classification_assignment.items) TO HIINDEX(aia\\applied_classification_assignment.items);\X\0A      item := aia\\applied_classification_assignment.items[i];\X\0A      IF (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CLASSIFIED_ITEM''] * TYPEOF(item)) = 0)\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (role\\classification_role.name = ''definitional'')\X\0A  THEN\X\0A    IF NOT (SIZEOF(QUERY(it\X\0A                         <* aia\\applied_classification_assignment.items\X\0A                         | NOT (SIZEOF([''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT'',\X\0A                                        ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_FORMATION'',\X\0A                                        ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION''] *\X\0A                                       TYPEOF(it)) =\X\0A                                1))) =\X\0A            0)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(true);'));
#25371=EXPRESS_CODE(#10906,('LOCAL\X\0A  the_reverse : oriented_closed_shell;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ORIENTED_CLOSED_SHELL'' IN TYPEOF(a_shell))\X\0A  THEN\X\0A    the_reverse := dummy_tri || connected_face_set(a_shell\\connected_face_set.cfs_faces) || closed_shell() ||\X\0A                   oriented_closed_shell(a_shell\\oriented_closed_shell.closed_shell_element,\X\0A                                         NOT (a_shell\\oriented_closed_shell.orientation));\X\0A  ELSE\X\0A    the_reverse := dummy_tri || connected_face_set(a_shell\\connected_face_set.cfs_faces) || closed_shell() ||\X\0A                   oriented_closed_shell(a_shell, false);\X\0A  END_IF;\X\0A  RETURN(the_reverse);'));
#25381=EXPRESS_CODE(#10908,('LOCAL\X\0A  result : SET OF kinematic_joint := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO HIINDEX(items);\X\0A    result := result + items[i].transformation_operator.joint;\X\0A  END_REPEAT;\X\0A  RETURN(result);'));
#25394=EXPRESS_CODE(#10910,('LOCAL\X\0A  shape : LIST OF positive_integer;\X\0AEND_LOCAL;\X\0A  IF NOT EXISTS(basis) OR NOT EXISTS(coef)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  shape := shape_of_array(coef);\X\0A  IF NOT EXISTS(shape)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF SIZEOF(shape) < SIZEOF(basis)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO SIZEOF(basis);\X\0A    IF (basis[i].num_basis = shape[i]) <> true\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#25404=EXPRESS_CODE(#10912,('LOCAL\X\0A  typenames   : SET OF STRING                   := stripped_typeof(sp1);\X\0A  crgn1       : cartesian_complex_number_region;\X\0A  crgn2       : cartesian_complex_number_region;\X\0A  prgn1       : polar_complex_number_region;\X\0A  prgn2       : polar_complex_number_region;\X\0A  prgn1c2     : polar_complex_number_region;\X\0A  prgn2c1     : polar_complex_number_region;\X\0A  sp1_is_crgn : BOOLEAN;\X\0A  sp2_is_crgn : BOOLEAN;\X\0AEND_LOCAL;\X\0A  IF ''CARTESIAN_COMPLEX_NUMBER_REGION'' IN typenames\X\0A  THEN\X\0A    sp1_is_crgn := true;\X\0A    crgn1 := sp1;\X\0A  ELSE\X\0A    IF ''POLAR_COMPLEX_NUMBER_REGION'' IN typenames\X\0A    THEN\X\0A      sp1_is_crgn := false;\X\0A      prgn1 := sp1;\X\0A    ELSE\X\0A      RETURN(true);\X\0A    END_IF;\X\0A  END_IF;\X\0A  typenames := stripped_typeof(sp2);\X\0A  IF ''CARTESIAN_COMPLEX_NUMBER_REGION'' IN typenames\X\0A  THEN\X\0A    sp2_is_crgn := true;\X\0A    crgn2 := sp2;\X\0A  ELSE\X\0A    IF ''POLAR_COMPLEX_NUMBER_REGION'' IN typenames\X\0A    THEN\X\0A      sp2_is_crgn := false;\X\0A      prgn2 := sp2;\X\0A    ELSE\X\0A      RETURN(true);\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF sp1_is_crgn AND sp2_is_crgn\X\0A  THEN\X\0A    RETURN(compatible_intervals(crgn1.real_constraint, crgn2.real_constraint) AND\X\0A           compatible_intervals(crgn1.imag_constraint, crgn2.imag_constraint));\X\0A  END_IF;\X\0A  IF NOT sp1_is_crgn AND\X\0A         NOT sp2_is_crgn AND (prgn1.centre.real_part = prgn2.centre.real_part) AND\X\0A             (prgn1.centre.imag_part = prgn2.centre.imag_part)\X\0A  THEN\X\0A    IF NOT compatible_intervals(prgn1.distance_constraint, prgn2.distance_constraint)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF compatible_intervals(prgn1.direction_constraint, prgn2.direction_constraint)\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    IF (prgn1.direction_constraint.max > PI) AND (prgn2.direction_constraint.max < PI)\X\0A    THEN\X\0A      RETURN(compatible_intervals(prgn2.direction_constraint,\X\0A                                  make_finite_real_interval(-PI, open, prgn1.direction_constraint.max - 2.0 * PI,\X\0A                                                            prgn1.direction_constraint.max_closure)));\X\0A    END_IF;\X\0A    IF (prgn2.direction_constraint.max > PI) AND (prgn1.direction_constraint.max < PI)\X\0A    THEN\X\0A      RETURN(compatible_intervals(prgn1.direction_constraint,\X\0A                                  make_finite_real_interval(-PI, open, prgn2.direction_constraint.max - 2.0 * PI,\X\0A                                                            prgn2.direction_constraint.max_closure)));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF sp1_is_crgn AND NOT sp2_is_crgn\X\0A  THEN\X\0A    crgn2 := enclose_pregion_in_cregion(prgn2);\X\0A    prgn1 := enclose_cregion_in_pregion(crgn1, prgn2.centre);\X\0A    RETURN(compatible_complex_number_regions(crgn1, crgn2) AND compatible_complex_number_regions(prgn1, prgn2));\X\0A  END_IF;\X\0A  IF NOT sp1_is_crgn AND sp2_is_crgn\X\0A  THEN\X\0A    crgn1 := enclose_pregion_in_cregion(prgn1);\X\0A    prgn2 := enclose_cregion_in_pregion(crgn2, prgn1.centre);\X\0A    RETURN(compatible_complex_number_regions(crgn1, crgn2) AND compatible_complex_number_regions(prgn1, prgn2));\X\0A  END_IF;\X\0A  prgn1c2 := enclose_pregion_in_pregion(prgn1, prgn2.centre);\X\0A  prgn2c1 := enclose_pregion_in_pregion(prgn2, prgn1.centre);\X\0A  RETURN(compatible_complex_number_regions(prgn1, prgn2c1) AND compatible_complex_number_regions(prgn1c2, prgn2));'));
#25418=EXPRESS_CODE(#10914,('LOCAL\X\0A  esval1_is_numeric : LOGICAL;\X\0A  esval2_is_numeric : LOGICAL;\X\0AEND_LOCAL;\X\0A  IF (esval1 = esval2) OR (esval1 = es_generics) OR (esval2 = es_generics)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  esval1_is_numeric := (esval1 >= es_numbers) AND (esval1 <= es_integers);\X\0A  esval2_is_numeric := (esval2 >= es_numbers) AND (esval2 <= es_integers);\X\0A  IF (esval1_is_numeric AND (esval2 = es_numbers)) OR (esval2_is_numeric AND (esval1 = es_numbers))\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF esval1_is_numeric XOR esval2_is_numeric\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ((esval1 = es_logicals) AND (esval2 = es_booleans)) OR ((esval1 = es_booleans) AND (esval2 = es_logicals))\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
#25424=EXPRESS_CODE(#10916,('LOCAL\X\0A  amin : REAL;\X\0A  amax : REAL;\X\0AEND_LOCAL;\X\0A  IF min_exists(sp1) AND max_exists(sp2)\X\0A  THEN\X\0A    amin := real_min(sp1);\X\0A    amax := real_max(sp2);\X\0A    IF amin > amax\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF amin = amax\X\0A    THEN\X\0A      RETURN(min_included(sp1) AND max_included(sp2));\X\0A    END_IF;\X\0A  END_IF;\X\0A  IF min_exists(sp2) AND max_exists(sp1)\X\0A  THEN\X\0A    amin := real_min(sp2);\X\0A    amax := real_max(sp1);\X\0A    IF amin > amax\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF amin = amax\X\0A    THEN\X\0A      RETURN(min_included(sp2) AND max_included(sp1));\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(true);'));
#25430=EXPRESS_CODE(#10918,('LOCAL\X\0A  types1 : SET OF STRING := stripped_typeof(sp1);\X\0A  types2 : SET OF STRING := stripped_typeof(sp2);\X\0A  lgcl   : LOGICAL       := unknown;\X\0A  m      : INTEGER;\X\0A  n      : INTEGER;\X\0A  s1     : maths_space;\X\0A  s2     : maths_space;\X\0AEND_LOCAL;\X\0A  IF ''FINITE_SPACE'' IN types1\X\0A  THEN\X\0A    REPEAT i := 1 TO SIZEOF(sp1\\finite_space.members);\X\0A      lgcl := member_of(sp1\\finite_space.members[i], sp2);\X\0A      IF lgcl <> false\X\0A      THEN\X\0A        RETURN(true);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''FINITE_SPACE'' IN types2\X\0A  THEN\X\0A    REPEAT i := 1 TO SIZEOF(sp2\\finite_space.members);\X\0A      lgcl := member_of(sp2\\finite_space.members[i], sp1);\X\0A      IF lgcl <> false\X\0A      THEN\X\0A        RETURN(true);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_SPACE'' IN types1\X\0A  THEN\X\0A    IF sp1\\elementary_space.space_id = es_generics\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    IF ''ELEMENTARY_SPACE'' IN types2\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp1\\elementary_space.space_id, sp2\\elementary_space.space_id));\X\0A    END_IF;\X\0A    IF (''FINITE_INTEGER_INTERVAL'' IN types2) OR (''INTEGER_INTERVAL_FROM_MIN'' IN types2) OR\X\0A       (''INTEGER_INTERVAL_TO_MAX'' IN types2)\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp1\\elementary_space.space_id, es_integers));\X\0A    END_IF;\X\0A    IF (''FINITE_REAL_INTERVAL'' IN types2) OR (''REAL_INTERVAL_FROM_MIN'' IN types2) OR (''REAL_INTERVAL_TO_MAX'' IN types2)\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp1\\elementary_space.space_id, es_reals));\X\0A    END_IF;\X\0A    IF (''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types2) OR (''POLAR_COMPLEX_NUMBER_REGION'' IN types2)\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp1\\elementary_space.space_id, es_complex_numbers));\X\0A    END_IF;\X\0A    IF ''TUPLE_SPACE'' IN types2\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF ''FUNCTION_SPACE'' IN types2\X\0A    THEN\X\0A      RETURN(bool(sp1\\elementary_space.space_id = es_maths_functions));\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''ELEMENTARY_SPACE'' IN types2\X\0A  THEN\X\0A    IF sp2\\elementary_space.space_id = es_generics\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    IF (''FINITE_INTEGER_INTERVAL'' IN types1) OR (''INTEGER_INTERVAL_FROM_MIN'' IN types1) OR\X\0A       (''INTEGER_INTERVAL_TO_MAX'' IN types1)\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp2\\elementary_space.space_id, es_integers));\X\0A    END_IF;\X\0A    IF (''FINITE_REAL_INTERVAL'' IN types1) OR (''REAL_INTERVAL_FROM_MIN'' IN types1) OR (''REAL_INTERVAL_TO_MAX'' IN types1)\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp2\\elementary_space.space_id, es_reals));\X\0A    END_IF;\X\0A    IF (''CARTESIAN_COMPLEX_NUMBER_REGION'' IN types1) OR (''POLAR_COMPLEX_NUMBER_REGION'' IN types1)\X\0A    THEN\X\0A      RETURN(compatible_es_values(sp2\\elementary_space.space_id, es_complex_numbers));\X\0A    END_IF;\X\0A    IF ''TUPLE_SPACE'' IN types1\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    IF ''FUNCTION_SPACE'' IN types1\X\0A    THEN\X\0A      RETURN(bool(sp2\\elementary_space.space_id = es_maths_functions));\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF subspace_of_es(sp1, es_integers)\X\0A  THEN\X\0A    IF subspace_of_es(sp2, es_integers)\X\0A    THEN\X\0A      RETURN(compatible_intervals(sp1, sp2));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF subspace_of_es(sp2, es_integers)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF subspace_of_es(sp1, es_reals)\X\0A  THEN\X\0A    IF subspace_of_es(sp2, es_reals)\X\0A    THEN\X\0A      RETURN(compatible_intervals(sp1, sp2));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF subspace_of_es(sp2, es_reals)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF subspace_of_es(sp1, es_complex_numbers)\X\0A  THEN\X\0A    IF subspace_of_es(sp2, es_complex_numbers)\X\0A    THEN\X\0A      RETURN(compatible_complex_number_regions(sp1, sp2));\X\0A    END_IF;\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF subspace_of_es(sp2, es_complex_numbers)\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''UNIFORM_PRODUCT_SPACE'' IN types1\X\0A  THEN\X\0A    IF ''UNIFORM_PRODUCT_SPACE'' IN types2\X\0A    THEN\X\0A      IF sp1\\uniform_product_space.exponent <> sp2\\uniform_product_space.exponent\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      RETURN(compatible_spaces(sp1\\uniform_product_space.base, sp2\\uniform_product_space.base));\X\0A    END_IF;\X\0A    IF ''LISTED_PRODUCT_SPACE'' IN types2\X\0A    THEN\X\0A      n := SIZEOF(sp2\\listed_product_space.factors);\X\0A      IF sp1\\uniform_product_space.exponent <> n\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      REPEAT i := 1 TO n;\X\0A        IF NOT compatible_spaces(sp1\\uniform_product_space.base, sp2\\listed_product_space.factors[i])\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    IF ''EXTENDED_TUPLE_SPACE'' IN types2\X\0A    THEN\X\0A      m := sp1\\uniform_product_space.exponent;\X\0A      n := space_dimension(sp2\\extended_tuple_space.base);\X\0A      IF m < n\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      IF m = n\X\0A      THEN\X\0A        RETURN(compatible_spaces(sp1, sp2\\extended_tuple_space.base));\X\0A      END_IF;\X\0A      RETURN(compatible_spaces(sp1,\X\0A                               assoc_product_space(sp2\\extended_tuple_space.base,\X\0A                                                   make_uniform_product_space(sp2\\extended_tuple_space.extender,\X\0A                                                                              m - n))));\X\0A    END_IF;\X\0A    IF ''FUNCTION_SPACE'' IN types2\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''LISTED_PRODUCT_SPACE'' IN types1\X\0A  THEN\X\0A    n := SIZEOF(sp1\\listed_product_space.factors);\X\0A    IF ''UNIFORM_PRODUCT_SPACE'' IN types2\X\0A    THEN\X\0A      IF n <> sp2\\uniform_product_space.exponent\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      REPEAT i := 1 TO n;\X\0A        IF NOT compatible_spaces(sp2\\uniform_product_space.base, sp1\\listed_product_space.factors[i])\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    IF ''LISTED_PRODUCT_SPACE'' IN types2\X\0A    THEN\X\0A      IF n <> SIZEOF(sp2\\listed_product_space.factors)\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      REPEAT i := 1 TO n;\X\0A        IF NOT compatible_spaces(sp1\\listed_product_space.factors[i], sp2\\listed_product_space.factors[i])\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_REPEAT;\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    IF ''EXTENDED_TUPLE_SPACE'' IN types2\X\0A    THEN\X\0A      m := space_dimension(sp2\\extended_tuple_space.base);\X\0A      IF n < m\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      IF n = m\X\0A      THEN\X\0A        RETURN(compatible_spaces(sp1, sp2\\extended_tuple_space.base));\X\0A      END_IF;\X\0A      RETURN(compatible_spaces(sp1,\X\0A                               assoc_product_space(sp2\\extended_tuple_space.base,\X\0A                                                   make_uniform_product_space(sp2\\extended_tuple_space.extender,\X\0A                                                                              n - m))));\X\0A    END_IF;\X\0A    IF (schema_prefix + ''FUNCTION_SPACE'') IN types2\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''EXTENDED_TUPLE_SPACE'' IN types1\X\0A  THEN\X\0A    IF (''UNIFORM_PRODUCT_SPACE'' IN types2) OR (''LISTED_PRODUCT_SPACE'' IN types2)\X\0A    THEN\X\0A      RETURN(compatible_spaces(sp2, sp1));\X\0A    END_IF;\X\0A    IF ''EXTENDED_TUPLE_SPACE'' IN types2\X\0A    THEN\X\0A      IF NOT compatible_spaces(sp1\\extended_tuple_space.extender, sp2\\extended_tuple_space.extender)\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      n := space_dimension(sp1\\extended_tuple_space.base);\X\0A      m := space_dimension(sp2\\extended_tuple_space.base);\X\0A      IF n < m\X\0A      THEN\X\0A        RETURN(compatible_spaces(assoc_product_space(sp1\\extended_tuple_space.base,\X\0A                                                     make_uniform_product_space(sp1\\extended_tuple_space.extender,\X\0A                                                                                m - n)),\X\0A                                 sp2\\extended_tuple_space.base));\X\0A      END_IF;\X\0A      IF n = m\X\0A      THEN\X\0A        RETURN(compatible_spaces(sp1\\extended_tuple_space.base, sp2\\extended_tuple_space.base));\X\0A      END_IF;\X\0A      IF n > m\X\0A      THEN\X\0A        RETURN(compatible_spaces(sp1\\extended_tuple_space.base,\X\0A                                 assoc_product_space(sp2\\extended_tuple_space.base,\X\0A                                                     make_uniform_product_space(sp2\\extended_tuple_space.extender,\X\0A                                                                                n - m))));\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF ''FUNCTION_SPACE'' IN types2\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF ''FUNCTION_SPACE'' IN types1\X\0A  THEN\X\0A    IF ''FUNCTION_SPACE'' IN types2\X\0A    THEN\X\0A      s1 := sp1\\function_space.domain_argument;\X\0A      s2 := sp2\\function_space.domain_argument;\X\0A      CASE sp1\\function_space.domain_constraint OF\X\0A        sc_equal : BEGIN  \X\0A                          CASE sp2\\function_space.domain_constraint OF\X\0A                            sc_equal : lgcl := subspace_of(s1, s2) AND subspace_of(s2, s1);\X\0A                            sc_subspace : lgcl := subspace_of(s1, s2);\X\0A                            sc_member : lgcl := member_of(s1, s2);\X\0A                          END_CASE;\X\0A        END;\X\0A        sc_subspace : BEGIN  \X\0A                             CASE sp2\\function_space.domain_constraint OF\X\0A                               sc_equal : lgcl := subspace_of(s2, s1);\X\0A                               sc_subspace : lgcl := compatible_spaces(s1, s2);\X\0A                               sc_member : lgcl := unknown;\X\0A                             END_CASE;\X\0A        END;\X\0A        sc_member : BEGIN  \X\0A                           CASE sp2\\function_space.domain_constraint OF\X\0A                             sc_equal : lgcl := member_of(s2, s1);\X\0A                             sc_subspace : lgcl := unknown;\X\0A                             sc_member : lgcl := compatible_spaces(s1, s2);\X\0A                           END_CASE;\X\0A        END;\X\0A      END_CASE;\X\0A      IF lgcl = false\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      s1 := sp1\\function_space.range_argument;\X\0A      s2 := sp2\\function_space.range_argument;\X\0A      CASE sp1\\function_space.range_constraint OF\X\0A        sc_equal : BEGIN  \X\0A                          CASE sp2\\function_space.range_constraint OF\X\0A                            sc_equal : lgcl := subspace_of(s1, s2) AND subspace_of(s2, s1);\X\0A                            sc_subspace : lgcl := subspace_of(s1, s2);\X\0A                            sc_member : lgcl := member_of(s1, s2);\X\0A                          END_CASE;\X\0A        END;\X\0A        sc_subspace : BEGIN  \X\0A                             CASE sp2\\function_space.range_constraint OF\X\0A                               sc_equal : lgcl := subspace_of(s2, s1);\X\0A                               sc_subspace : lgcl := compatible_spaces(s1, s2);\X\0A                               sc_member : lgcl := unknown;\X\0A                             END_CASE;\X\0A        END;\X\0A        sc_member : BEGIN  \X\0A                           CASE sp2\\function_space.range_constraint OF\X\0A                             sc_equal : lgcl := member_of(s2, s1);\X\0A                             sc_subspace : lgcl := unknown;\X\0A                             sc_member : lgcl := compatible_spaces(s1, s2);\X\0A                           END_CASE;\X\0A        END;\X\0A      END_CASE;\X\0A      IF lgcl = false\X\0A      THEN\X\0A        RETURN(false);\X\0A      END_IF;\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(true);'));
