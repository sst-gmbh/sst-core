#24638=EXPRESS_CODE(#10772,('LOCAL\X\0A  type_out : SET OF STRING;\X\0A  sizeei   : INTEGER;\X\0AEND_LOCAL;\X\0A  sizeei := SIZEOF(ei);\X\0A  IF (sizeei = 0)\X\0A  THEN\X\0A    RETURN(ddna_no_element);\X\0A  END_IF;\X\0A  type_out := TYPEOF(ei[1]);\X\0A  IF (SIZEOF(ei) > 1)\X\0A  THEN\X\0A    RETURN(ddna_others);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ASSEMBLY_COMPONENT_USAGE'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_assembly_component_usage);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BINARY_ASSEMBLY_CONSTRAINT'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_binary_assembly_constraint);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CARTESIAN_POINT'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_cartesian_point);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONTEXT_DEPENDENT_SHAPE_REPRESENTATION'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_context_dependent_shape_representation);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COUNT_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_count_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MULTI_LEVEL_REFERENCE_DESIGNATOR'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_multi_level_reference_designator);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VOLUME_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_volume_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3MS_INSPECTED_EQUIVALENCE_ELEMENT_SELECT'' IN type_out)\X\0A  THEN\X\0A    RETURN(ddna_a3ms_inspected_equivalence_element_select);\X\0A  END_IF;\X\0A  RETURN(ddna_others);'));
#24647=EXPRESS_CODE(#10774,('LOCAL\X\0A  type_out : SET OF STRING;\X\0AEND_LOCAL;\X\0A  type_out := TYPEOF(ei[1]);\X\0A  IF (SIZEOF(ei) > 1)\X\0A  THEN\X\0A    RETURN(etna_others);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_OR_REFERENCE'' IN type_out)\X\0A  THEN\X\0A    RETURN(etna_product_definition_or_reference);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHAPE_REPRESENTATION'' IN type_out)\X\0A  THEN\X\0A    RETURN(etna_shape_representation);\X\0A  END_IF;\X\0A  RETURN(etna_others);'));
#24652=EXPRESS_CODE(#10776,('LOCAL\X\0A  type_out : SET OF STRING;\X\0AEND_LOCAL;\X\0A  type_out := TYPEOF(ei);\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOOLEAN_VALUE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_boolean_value);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONTEXT_DEPENDENT_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_context_dependent_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_length_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3MA_LENGTH_MEASURE_AND_CONTEXT_DEPENDENT_MEASURE_PAIR'' IN\X\0A      type_out)\X\0A  THEN\X\0A    RETURN(mdna_length_measure_and_context_dependent_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE_ANGLE_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_plane_angle_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VOLUME_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_volume_measure);\X\0A  END_IF;\X\0A  RETURN(mdna_others);'));
#24657=EXPRESS_CODE(#10778,('LOCAL\X\0A  type_out : SET OF STRING;\X\0AEND_LOCAL;\X\0A  type_out := value_limit_type(ei);\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONTEXT_DEPENDENT_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_context_dependent_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_length_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE_ANGLE_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_plane_angle_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VOLUME_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdna_volume_measure);\X\0A  END_IF;\X\0A  RETURN(mdna_others);'));
#24663=EXPRESS_CODE(#10780,('LOCAL\X\0A  aeaa : SET OF a3m_equivalence_accuracy_association;\X\0A  rp   : SET OF representation;\X\0A  tp   : SET OF a3ma_accuracy_type_name              := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(cr.accuracy_types);\X\0A    tp := tp + [cr.accuracy_types[i]];\X\0A  END_REPEAT;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_ITEM'' IN TYPEOF(ei))\X\0A  THEN\X\0A    aeaa := bag_to_set(USEDIN(ei,\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_ACCURACY_ASSOCIATION.EQUIVALENCE_TARGET''));\X\0A    IF (SIZEOF(cr.accuracy_types) = 0)\X\0A    THEN\X\0A      IF (SIZEOF(aeaa) = 0)\X\0A      THEN\X\0A        RETURN(true);\X\0A      ELSE\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (a3ma_get_accuracy_types(aeaa) = tp)\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    rp := bag_to_set(USEDIN(ei, ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION.ITEMS''));\X\0A  ELSE\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION'' IN TYPEOF(ei))\X\0A    THEN\X\0A      rp := [ei];\X\0A    ELSE\X\0A      rp := [];\X\0A    END_IF;\X\0A  END_IF;\X\0A  aeaa := [];\X\0A  REPEAT i := 1 TO SIZEOF(rp);\X\0A    aeaa := aeaa +\X\0A            bag_to_set(USEDIN(rp[i],\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_ACCURACY_ASSOCIATION.EQUIVALENCE_TARGET''));\X\0A  END_REPEAT;\X\0A  IF (a3ma_get_accuracy_types(aeaa) >= tp)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
#24683=EXPRESS_CODE(#10782,('LOCAL\X\0A  deiir   : data_equivalence_inspection_instance_report;\X\0A  eiriwei : equivalence_instance_report_item_with_notable_instances;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_INSTANCE_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deiir := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deiir.inspected_instances);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EQUIVALENCE_INSTANCE_REPORT_ITEM_WITH_NOTABLE_INSTANCES'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        eiriwei := deiir.inspected_instances[i];\X\0A        REPEAT j := 1 TO SIZEOF(eiriwei.notable_instances);\X\0A          IF (NOT (a3ma_get_detected_difference_type(eiriwei.notable_instances[j].comparing_elements) IN\X\0A                   cr.detected_difference_types))\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A          IF (NOT (a3ma_get_detected_difference_type(eiriwei.notable_instances[j].compared_elements) IN\X\0A                   cr.detected_difference_types))\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#24693=EXPRESS_CODE(#10784,('LOCAL\X\0A  compared_et  : a3ma_element_type_name;\X\0A  comparing_et : a3ma_element_type_name;\X\0A  deiir        : data_equivalence_inspection_instance_report;\X\0A  aeiiri       : a3m_equivalence_inspection_instance_report_item;\X\0A  deiep        : data_equivalence_inspected_element_pair;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_INSTANCE_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deiir := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deiir.inspected_instances);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_INSPECTION_INSTANCE_REPORT_ITEM'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        aeiiri := deiir.inspected_instances[i];\X\0A        deiep := aeiiri.inspected_element;\X\0A        compared_et := a3ma_get_element_type(deiep.compared_elements);\X\0A        comparing_et := a3ma_get_element_type(deiep.comparing_elements);\X\0A        IF (NOT (compared_et IN cr.compared_element_types) OR NOT (comparing_et IN cr.comparing_element_types))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A        IF (compared_et <> comparing_et)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#24704=EXPRESS_CODE(#10786,('LOCAL\X\0A  amdtn   : a3ma_measured_data_type_name;\X\0A  deicr   : data_equivalence_inspection_criterion_report;\X\0A  acriwmv : a3m_equivalence_criterion_report_item_with_measured_value;\X\0A  deiir   : data_equivalence_inspection_instance_report;\X\0A  aeiiri  : a3m_equivalence_inspection_instance_report_item;\X\0A  eiriwei : equivalence_instance_report_item_with_notable_instances;\X\0AEND_LOCAL;\X\0A  amdtn := cr.measured_data_type;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_CRITERION_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deicr := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deicr.statistical_values);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_CRITERION_REPORT_ITEM_WITH_MEASURED_VALUE'' IN\X\0A          TYPEOF(deicr.statistical_values[i]))\X\0A      THEN\X\0A        acriwmv := deicr.statistical_values[i];\X\0A        IF (a3ma_get_measured_type(acriwmv.representative_measured_value) <> amdtn)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_INSTANCE_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deiir := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deiir.inspected_instances);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_INSPECTION_INSTANCE_REPORT_ITEM'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        aeiiri := deiir.inspected_instances[i];\X\0A        IF (a3ma_get_measured_type(aeiiri.measured_value_for_inspected_element) <> amdtn)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EQUIVALENCE_INSTANCE_REPORT_ITEM_WITH_NOTABLE_INSTANCES'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        eiriwei := deiir.inspected_instances[i];\X\0A        REPEAT j := 1 TO SIZEOF(eiriwei.notable_instances);\X\0A          IF (a3ma_get_measured_type(eiriwei.notable_instances[j].measured_value) <> amdtn)\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#24725=EXPRESS_CODE(#10788,('LOCAL\X\0A  type_out : a3ms_measured_data_type_name;\X\0A  retval   : SET OF a3ms_accuracy_type_name := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(ei);\X\0A    type_out := a3ms_get_value_limit_type(ei[i].specific_accuracy.range);\X\0A    IF (type_out = mdns_area_measure)\X\0A    THEN\X\0A      retval := retval + [atns_area_measure];\X\0A    ELSE\X\0A      IF (type_out = mdns_length_measure)\X\0A      THEN\X\0A        retval := retval + [atns_length_measure];\X\0A      ELSE\X\0A        IF (type_out = mdns_plane_angle_measure)\X\0A        THEN\X\0A          retval := retval + [atns_plane_angle_measure];\X\0A        ELSE\X\0A          IF (type_out = mdns_volume_measure)\X\0A          THEN\X\0A            retval := retval + [atns_volume_measure];\X\0A          ELSE\X\0A            retval := retval + [atns_others];\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(retval);'));
#24738=EXPRESS_CODE(#10790,('LOCAL\X\0A  type_out : SET OF STRING;\X\0A  sizeei   : INTEGER;\X\0AEND_LOCAL;\X\0A  sizeei := SIZEOF(ei);\X\0A  IF (sizeei = 0)\X\0A  THEN\X\0A    RETURN(ddns_no_element);\X\0A  ELSE\X\0A    type_out := TYPEOF(ei[1]);\X\0A    REPEAT i := 2 TO sizeei;\X\0A      IF (TYPEOF(ei[i]) <> type_out)\X\0A      THEN\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.AREA_MEASURE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_area_measure);\X\0A      ELSE\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CARTESIAN_POINT'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_cartesian_point);\X\0A      ELSE\X\0A        IF (sizeei = 2)\X\0A        THEN\X\0A          RETURN(ddns_two_cartesian_points);\X\0A        ELSE\X\0A          RETURN(ddns_others);\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONNECTED_FACE_SET'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_connected_face_set);\X\0A      ELSE\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.COUNT_MEASURE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_count_measure);\X\0A      ELSE\X\0A        IF (sizeei = 2)\X\0A        THEN\X\0A          RETURN(ddns_two_count_measure);\X\0A        ELSE\X\0A          IF (sizeei = 3)\X\0A          THEN\X\0A            RETURN(ddns_three_count_measure);\X\0A          ELSE\X\0A            IF (sizeei = 4)\X\0A            THEN\X\0A              RETURN(ddns_four_count_measure);\X\0A            ELSE\X\0A              IF (sizeei = 5)\X\0A              THEN\X\0A                RETURN(ddns_five_count_measure);\X\0A              ELSE\X\0A                RETURN(ddns_others);\X\0A              END_IF;\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EDGE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_edge);\X\0A      ELSE\X\0A        RETURN(ddns_several_edges);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.FACE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_face);\X\0A      ELSE\X\0A        RETURN(ddns_several_faces);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_length_measure);\X\0A      ELSE\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_ON_CURVE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_point_on_curve);\X\0A      ELSE\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_ON_SURFACE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_point_on_surface);\X\0A      ELSE\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VOLUME_MEASURE'' IN type_out)\X\0A    THEN\X\0A      IF (sizeei = 1)\X\0A      THEN\X\0A        RETURN(ddns_volume_measure);\X\0A      ELSE\X\0A        RETURN(ddns_others);\X\0A      END_IF;\X\0A    END_IF;\X\0A  END_IF;\X\0A  RETURN(ddns_others);'));
#24744=EXPRESS_CODE(#24743,('sizeei'));
#24750=EXPRESS_CODE(#10792,('LOCAL\X\0A  type_out : SET OF STRING;\X\0AEND_LOCAL;\X\0A  type_out := TYPEOF(ei[1]);\X\0A  IF (SIZEOF(ei) > 1)\X\0A  THEN\X\0A    RETURN(etns_others);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONNECTED_EDGE_SET'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_connected_edge_set);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.CONNECTED_FACE_SET'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_connected_face_set);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MANIFOLD_SOLID_BREP'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_manifold_solid_brep);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.POINT_CLOUD_DATASET'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_point_cloud_dataset);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHELL_BASED_SURFACE_MODEL'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_shell_based_surface_model);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SHELL_BASED_WIREFRAME_MODEL'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_shell_based_wireframe_model);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VERTEX_POINT'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_vertex_point);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EXTERNALLY_DEFINED_REPRESENTATION_ITEM'' IN type_out)\X\0A  THEN\X\0A    RETURN(etns_external_representation_item);\X\0A  END_IF;\X\0A  RETURN(etns_others);'));
#24755=EXPRESS_CODE(#10794,('LOCAL\X\0A  type_out : SET OF STRING;\X\0AEND_LOCAL;\X\0A  type_out := TYPEOF(ei);\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.AREA_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_area_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOOLEAN_VALUE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_boolean_value);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_length_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE_ANGLE_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_plane_angle_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VOLUME_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_volume_measure);\X\0A  END_IF;\X\0A  RETURN(mdns_others);'));
#24760=EXPRESS_CODE(#10796,('LOCAL\X\0A  type_out : SET OF STRING;\X\0AEND_LOCAL;\X\0A  type_out := value_limit_type(ei);\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.AREA_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_area_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BOOLEAN_VALUE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_boolean_value);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.LENGTH_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_length_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PLANE_ANGLE_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_plane_angle_measure);\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.VOLUME_MEASURE'' IN type_out)\X\0A  THEN\X\0A    RETURN(mdns_volume_measure);\X\0A  END_IF;\X\0A  RETURN(mdns_others);'));
#24766=EXPRESS_CODE(#10798,('LOCAL\X\0A  aeaa : SET OF a3m_equivalence_accuracy_association;\X\0A  rp   : SET OF representation;\X\0A  tp   : SET OF a3ms_accuracy_type_name              := [];\X\0AEND_LOCAL;\X\0A  REPEAT i := 1 TO SIZEOF(cr.accuracy_types);\X\0A    tp := tp + [cr.accuracy_types[i]];\X\0A  END_REPEAT;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION_ITEM'' IN TYPEOF(ei))\X\0A  THEN\X\0A    aeaa := bag_to_set(USEDIN(ei,\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_ACCURACY_ASSOCIATION.EQUIVALENCE_TARGET''));\X\0A    IF (SIZEOF(cr.accuracy_types) = 0)\X\0A    THEN\X\0A      IF (SIZEOF(aeaa) = 0)\X\0A      THEN\X\0A        RETURN(true);\X\0A      ELSE\X\0A        RETURN(false);\X\0A      END_IF;\X\0A    END_IF;\X\0A    IF (a3ms_get_accuracy_types(aeaa) = tp)\X\0A    THEN\X\0A      RETURN(true);\X\0A    END_IF;\X\0A    rp := bag_to_set(USEDIN(ei, ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION.ITEMS''));\X\0A  ELSE\X\0A    IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.REPRESENTATION'' IN TYPEOF(ei))\X\0A    THEN\X\0A      rp := [ei];\X\0A    ELSE\X\0A      rp := [];\X\0A    END_IF;\X\0A  END_IF;\X\0A  aeaa := [];\X\0A  REPEAT i := 1 TO SIZEOF(rp);\X\0A    aeaa := aeaa +\X\0A            bag_to_set(USEDIN(rp[i],\X\0A                              ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_ACCURACY_ASSOCIATION.EQUIVALENCE_TARGET''));\X\0A  END_REPEAT;\X\0A  IF (a3ms_get_accuracy_types(aeaa) >= tp)\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  RETURN(false);'));
#24786=EXPRESS_CODE(#10800,('LOCAL\X\0A  deiir   : data_equivalence_inspection_instance_report;\X\0A  eiriwei : equivalence_instance_report_item_with_notable_instances;\X\0A  addtn   : a3ms_detected_difference_type_name;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_INSTANCE_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deiir := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deiir.inspected_instances);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EQUIVALENCE_INSTANCE_REPORT_ITEM_WITH_NOTABLE_INSTANCES'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        eiriwei := deiir.inspected_instances[i];\X\0A        REPEAT j := 1 TO SIZEOF(eiriwei.notable_instances);\X\0A          IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MISMATCH_OF_POINT_CLOUD_AND_RELATED_GEOMETRY'' IN\X\0A              TYPEOF(cr))\X\0A          THEN\X\0A            addtn := a3ms_get_detected_difference_type(eiriwei.notable_instances[j].comparing_elements);\X\0A            IF (a3ms_get_element_type(eiriwei.inspected_element.comparing_elements) = etns_connected_edge_set)\X\0A            THEN\X\0A              IF (addtn <> ddns_point_on_curve)\X\0A              THEN\X\0A                RETURN(false);\X\0A              END_IF;\X\0A            ELSE\X\0A              IF (a3ms_get_element_type(eiriwei.inspected_element.comparing_elements) = etns_connected_face_set)\X\0A              THEN\X\0A                IF (addtn <> ddns_point_on_surface)\X\0A                THEN\X\0A                  RETURN(false);\X\0A                END_IF;\X\0A              ELSE\X\0A                IF (a3ms_get_element_type(eiriwei.inspected_element.comparing_elements) <>\X\0A                    etns_external_representation_item)\X\0A                THEN\X\0A                  RETURN(false);\X\0A                END_IF;\X\0A              END_IF;\X\0A            END_IF;\X\0A            IF (NOT (a3ms_get_detected_difference_type(eiriwei.notable_instances[j].compared_elements) IN\X\0A                     cr.detected_difference_types))\X\0A            THEN\X\0A              RETURN(false);\X\0A            END_IF;\X\0A          ELSE\X\0A            IF (NOT (a3ms_get_detected_difference_type(eiriwei.notable_instances[j].comparing_elements) IN\X\0A                     cr.detected_difference_types))\X\0A            THEN\X\0A              RETURN(false);\X\0A            END_IF;\X\0A            IF (NOT (a3ms_get_detected_difference_type(eiriwei.notable_instances[j].compared_elements) IN\X\0A                     cr.detected_difference_types))\X\0A            THEN\X\0A              RETURN(false);\X\0A            END_IF;\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#24797=EXPRESS_CODE(#10802,('LOCAL\X\0A  compared_et  : a3ms_element_type_name;\X\0A  comparing_et : a3ms_element_type_name;\X\0A  deiir        : data_equivalence_inspection_instance_report;\X\0A  aeiiri       : a3m_equivalence_inspection_instance_report_item;\X\0A  deiep        : data_equivalence_inspected_element_pair;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_INSTANCE_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deiir := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deiir.inspected_instances);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_INSPECTION_INSTANCE_REPORT_ITEM'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        aeiiri := deiir.inspected_instances[i];\X\0A        deiep := aeiiri.inspected_element;\X\0A        compared_et := a3ms_get_element_type(deiep.compared_elements);\X\0A        comparing_et := a3ms_get_element_type(deiep.comparing_elements);\X\0A        IF ((NOT (compared_et IN cr.compared_element_types) AND (compared_et <> etns_external_representation_item)) OR\X\0A            (NOT (comparing_et IN cr.comparing_element_types) AND (comparing_et <> etns_external_representation_item)))\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A        IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MISMATCH_OF_POINT_CLOUD_AND_RELATED_GEOMETRY'' IN\X\0A            TYPEOF(cr))\X\0A        THEN\X\0A          IF (((comparing_et <> etns_external_representation_item) AND\X\0A               (compared_et <> etns_external_representation_item)) AND\X\0A              (compared_et = comparing_et))\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        ELSE\X\0A          IF (((comparing_et <> etns_external_representation_item) AND\X\0A               (compared_et <> etns_external_representation_item)) AND\X\0A              (compared_et <> comparing_et))\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#24808=EXPRESS_CODE(#10804,('LOCAL\X\0A  amdtn   : a3ms_measured_data_type_name;\X\0A  deicr   : data_equivalence_inspection_criterion_report;\X\0A  acriwmv : a3m_equivalence_criterion_report_item_with_measured_value;\X\0A  deiir   : data_equivalence_inspection_instance_report;\X\0A  aeiiri  : a3m_equivalence_inspection_instance_report_item;\X\0A  eiriwei : equivalence_instance_report_item_with_notable_instances;\X\0AEND_LOCAL;\X\0A  amdtn := cr.measured_data_type;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_CRITERION_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deicr := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deicr.statistical_values);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_CRITERION_REPORT_ITEM_WITH_MEASURED_VALUE'' IN\X\0A          TYPEOF(deicr.statistical_values[i]))\X\0A      THEN\X\0A        acriwmv := deicr.statistical_values[i];\X\0A        IF (a3ms_get_measured_type(acriwmv.representative_measured_value) <> amdtn)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DATA_EQUIVALENCE_INSPECTION_INSTANCE_REPORT'' IN TYPEOF(ei))\X\0A  THEN\X\0A    deiir := ei;\X\0A    REPEAT i := 1 TO SIZEOF(deiir.inspected_instances);\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.A3M_EQUIVALENCE_INSPECTION_INSTANCE_REPORT_ITEM'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        aeiiri := deiir.inspected_instances[i];\X\0A        IF (a3ms_get_measured_type(aeiiri.measured_value_for_inspected_element) <> amdtn)\X\0A        THEN\X\0A          RETURN(false);\X\0A        END_IF;\X\0A      END_IF;\X\0A      IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.EQUIVALENCE_INSTANCE_REPORT_ITEM_WITH_NOTABLE_INSTANCES'' IN\X\0A          TYPEOF(deiir.inspected_instances[i]))\X\0A      THEN\X\0A        eiriwei := deiir.inspected_instances[i];\X\0A        REPEAT j := 1 TO SIZEOF(eiriwei.notable_instances);\X\0A          IF (a3ms_get_measured_type(eiriwei.notable_instances[j].measured_value) <> amdtn)\X\0A          THEN\X\0A            RETURN(false);\X\0A          END_IF;\X\0A        END_REPEAT;\X\0A      END_IF;\X\0A    END_REPEAT;\X\0A  END_IF;\X\0A  RETURN(true);'));
#24826=EXPRESS_CODE(#10806,('LOCAL\X\0A  dir2 : direction := dummy_gri || direction([1.0,0.0,0.0]);\X\0A  dir3 : direction := dummy_gri || direction([1.0,0.0,0.0]);\X\0A  dir4 : direction := dummy_gri || direction([1.0,0.0,0.0]);\X\0A  val  : REAL;\X\0A  mag  : REAL;\X\0AEND_LOCAL;\X\0A  IF (p1.dim <> 3)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  REPEAT i := 1 TO 3;\X\0A    dir2.direction_ratios[i] := p2.coordinates[i] - p1.coordinates[i];\X\0A    dir3.direction_ratios[i] := p3.coordinates[i] - p1.coordinates[i];\X\0A    dir4.direction_ratios[i] := p4.coordinates[i] - p1.coordinates[i];\X\0A    mag := dir4.direction_ratios[i] * dir4.direction_ratios[i];\X\0A  END_REPEAT;\X\0A  mag := SQRT(mag);\X\0A  val := mag * dot_product(dir4, cross_product(dir2, dir3).orientation);\X\0A  RETURN(val);'));
#24840=EXPRESS_CODE(#10808,('LOCAL\X\0A  result : BOOLEAN := true;\X\0AEND_LOCAL;\X\0A  IF (''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.SIMPLE_GENERIC_EXPRESSION'' IN TYPEOF(arg1))\X\0A  THEN\X\0A    RETURN(true);\X\0A  END_IF;\X\0A  IF arg1 IN arg2\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.UNARY_GENERIC_EXPRESSION'' IN TYPEOF(arg1)\X\0A  THEN\X\0A    RETURN(acyclic(arg1\\unary_generic_expression.operand, arg2 + [arg1]));\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.BINARY_GENERIC_EXPRESSION'' IN TYPEOF(arg1)\X\0A  THEN\X\0A    RETURN(acyclic(arg1\\binary_generic_expression.operands[1], arg2 + [arg1]) AND\X\0A           acyclic(arg1\\binary_generic_expression.operands[2], arg2 + [arg1]));\X\0A  END_IF;\X\0A  IF ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.MULTIPLE_ARITY_GENERIC_EXPRESSION'' IN TYPEOF(arg1)\X\0A  THEN\X\0A    result := true;\X\0A    REPEAT i := 1 TO SIZEOF(arg1\\multiple_arity_generic_expression.operands);\X\0A      result := result AND acyclic(arg1\\multiple_arity_generic_expression.operands[i], arg2 + [arg1]);\X\0A    END_REPEAT;\X\0A    RETURN(result);\X\0A  END_IF;\X\0A  RETURN(result);'));
#24851=EXPRESS_CODE(#10810,('LOCAL\X\0A  x : SET OF action_directive_relationship;\X\0AEND_LOCAL;\X\0A  IF relation.relating IN relatives\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  x := QUERY(adr\X\0A             <* bag_to_set(USEDIN(relation.relating,\X\0A                                  ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ACTION_DIRECTIVE_RELATIONSHIP.RELATED''))\X\0A             | specific_relation IN TYPEOF(adr));\X\0A  REPEAT i := 1 TO HIINDEX(x);\X\0A    IF NOT acyclic_action_directive_relationship(x[i], relatives + relation.relating, specific_relation)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#24865=EXPRESS_CODE(#10812,('LOCAL\X\0A  x : SET OF alternative_solution_relationship;\X\0AEND_LOCAL;\X\0A  IF relation.relating_product_definition_formation IN relatives\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  x := QUERY(asr\X\0A             <* bag_to_set(USEDIN(relation.relating_product_definition_formation,\X\0A                                  ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ALTERNATIVE_SOLUTION_RELATIONSHIP.RELATED_PRODUCT_DEFINITION_FORMATION''))\X\0A             | specific_relation IN TYPEOF(asr));\X\0A  REPEAT i := 1 TO HIINDEX(x);\X\0A    IF NOT acyclic_alternative_solution_relationship(x[i], relatives + relation.relating_product_definition_formation,\X\0A                                                     specific_relation)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
#24879=EXPRESS_CODE(#10814,('LOCAL\X\0A  x : SET OF assignment_object_relationship;\X\0AEND_LOCAL;\X\0A  IF relation.relating IN relatives\X\0A  THEN\X\0A    RETURN(false);\X\0A  END_IF;\X\0A  x := QUERY(aor\X\0A             <* bag_to_set(USEDIN(relation.relating,\X\0A                                  ''AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ASSIGNMENT_OBJECT_RELATIONSHIP.RELATED''))\X\0A             | specific_relation IN TYPEOF(aor));\X\0A  REPEAT i := 1 TO HIINDEX(x);\X\0A    IF NOT acyclic_assignment_object_relationship(x[i], relatives + relation.relating, specific_relation)\X\0A    THEN\X\0A      RETURN(false);\X\0A    END_IF;\X\0A  END_REPEAT;\X\0A  RETURN(true);'));
