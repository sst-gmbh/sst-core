#26878=EXPRESS_CODE(#11170,('LOCAL\X\0A  res : ARRAY [low1 : u1] OF ARRAY [low2 : u2] OF GENERIC : T;\X\0AEND_LOCAL;\X\0A  (* Check input dimensions for consistency *)\X\0A  IF (u1 - low1 + 1) <> SIZEOF(lis)\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  IF (u2 - low2 + 1) <> SIZEOF(lis[1])\X\0A  THEN\X\0A    RETURN(?);\X\0A  END_IF;\X\0A  (* Initialise res with values from lis[1] *)\X\0A  res := [list_to_array(lis[1], low2, u2):(u1 - low1 + 1)];\X\0A  REPEAT i := 2 TO HIINDEX(lis);\X\0A    IF (u2 - low2 + 1) <> SIZEOF(lis[i])\X\0A    THEN\X\0A      RETURN(?);\X\0A    END_IF;\X\0A    res[low1 + i - 1] := list_to_array(lis[i], low2, u2);\X\0A  END_REPEAT;\X\0A  RETURN(res);'));
