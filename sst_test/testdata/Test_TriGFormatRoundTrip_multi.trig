@prefix lci:	<http://ontology.semanticstep.net/lci#> .
@prefix rdf:	<http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:	<http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:	<http://www.w3.org/2001/XMLSchema#> .
@prefix owl:	<http://www.w3.org/2002/07/owl#> .

<urn:uuid:bbbbbbbb-1111-1111-1111-111111111111> {
@prefix ns1:	<urn:uuid:bbbbbbbb-1111-1111-1111-111111111111#> .

<urn:uuid:bbbbbbbb-1111-1111-1111-111111111111>	a	owl:Ontology .
ns1:Jane	a	lci:Person ;
	rdfs:label	"Jane Doe" .
}

<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222> {
@prefix ns2:	<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222#> .

<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222>	a	owl:Ontology .
ns2:CompanyA	a	lci:Organization ;
	rdfs:label	"Company A" .
}
