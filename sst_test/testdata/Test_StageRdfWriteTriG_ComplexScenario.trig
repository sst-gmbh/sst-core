@prefix countrycodes:	<http://ontology.semanticstep.net/countrycodes#> .
@prefix lci:	<http://ontology.semanticstep.net/lci#> .
@prefix rdf:	<http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:	<http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:	<http://www.w3.org/2001/XMLSchema#> .
@prefix owl:	<http://www.w3.org/2002/07/owl#> .

<urn:uuid:dddddddd-4444-4444-4444-444444444444> {
@prefix ns3:	<urn:uuid:dddddddd-4444-4444-4444-444444444444#> .

<urn:uuid:dddddddd-4444-4444-4444-444444444444>	a	owl:Ontology .
ns3:Jane	lci:partOf	countrycodes:de .
ns3:John	lci:partOf	countrycodes:cn .
}

<urn:uuid:aaaaaaaa-1111-1111-1111-111111111111> {
@prefix ns4:	<urn:uuid:aaaaaaaa-1111-1111-1111-111111111111#> .

<urn:uuid:aaaaaaaa-1111-1111-1111-111111111111>	a	owl:Ontology .
ns4:Adam	a	lci:Person ;
	rdfs:label	"Adam Smith" .
ns4:Jane	a	lci:Person ;
	rdfs:label	"Jane Doe" .
ns4:John	a	lci:Person ;
	rdfs:label	"John Doe" .
}

<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222> {
@prefix ns1:	<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222#> .

<urn:uuid:bbbbbbbb-2222-2222-2222-222222222222>	a	owl:Ontology .
ns1:CompanyA	a	lci:Organization ;
	rdfs:label	"Company A" .
ns1:CompanyB	a	lci:Organization ;
	rdfs:label	"Company B" .
_:b0	a	lci:Organization ;
	rdfs:label	"Stealth Startup" .
}

<urn:uuid:cccccccc-3333-3333-3333-333333333333> {
@prefix ns2:	<urn:uuid:cccccccc-3333-3333-3333-333333333333#> .

<urn:uuid:cccccccc-3333-3333-3333-333333333333>	a	owl:Ontology .
ns2:John	ns2:hasFriends	( ns4:Jane ns4:Adam ) ;
	ns2:worksAt	ns2:CompanyA ;
	ns2:hasSkill	( "Go" "Python" "RDF" ) .
ns2:hasFriends	a	rdf:Property .
ns2:hasSkill	a	rdf:Property .
ns2:worksAt	a	rdf:Property .
}
