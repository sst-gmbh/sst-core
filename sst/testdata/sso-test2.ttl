@prefix lci:   <http://ontology.semanticstep.net/lci#> .
@prefix sso:   <http://ontology.semanticstep.net/sso#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://ontology.semanticstep.net/sso>
    rdf:type     owl:Ontology ;
    owl:imports   <http://ontology.semanticstep.net/lci> ;
    owl:versionInfo "0.01" .

sso:AssemblyDesign
    rdf:type owl:Class ;
    rdfs:subClassOf lci:ArrangedIndividual ;
    owl:disjointUnionOf (lci:Individual sso:AbstractPart) ;
    sso:ownedBy <http://ontology.semanticstep.net/sso>.
