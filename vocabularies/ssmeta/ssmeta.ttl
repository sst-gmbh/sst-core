@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ssmeta:   <http://ontology.semanticstep.net/ssmeta#> .

<http://ontology.semanticstep.net/ssmeta>
    rdf:type     owl:Ontology ;
    owl:versionInfo "0.01" .

# THIS ONTOLOGY IS SPECIFIC FOR SST TO ENABLE HIGH PERFORMANCE AND DATA EXCHANGE WITH STEP AND OTHER FORMATS
# THIS ONTOLOGY IS PRIMARILY BE USED BY OTHER HIGHER LEVEL ONTOLOGIES THAT ARE THE BASIS OF SST

# on object type that can be used by it's own; in Express this means non-abstract
ssmeta:MainClass
    rdf:type owl:Class ;
    owl:disjointUnionOf (ssmeta:OptionClass ssmeta:AbstractClass ssmeta:SelectClass) .

# an object type that can only be used in combination with another ssmeta:mainClass
ssmeta:OptionClass
    rdf:type owl:Class .

# an object type that can not directly be used but only one of it's sub-classes
ssmeta:AbstractClass
    rdf:type owl:Class .

ssmeta:ConnotationalClass
    rdf:type owl:Class .

ssmeta:EnumerationClass
    rdf:type owl:Class .

# an property that can not directly be used in application data; but one of its sub-properties can be used
ssmeta:AbstractProperty
    rdf:type rdfs:Class ;
    rdfs:subPropertyOf rdf:Property .

# member type of a collection/List
ssmeta:ofType rdf:type owl:ObjectProperty ;
    rdfs:domain rdf:List ;
    rdfs:label "of member type"@en .

# to indicate that a class is not intended to have direct members, but only through sub-classes
ssmeta:isAbstract
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

# to indicate that an IRI is pre-defined for an SST application and must not be changed by a user
ssmeta:isSystem
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

# indicates if the subject is available for an application
ssmeta:isActive
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .



##########################  Express & STEP Part21 related ###################

# emulate entity selects in Express
ssmeta:SelectClass
    rdf:type owl:Class ;
    owl:disjointUnionOf (ssmeta:MainClass ssmeta:OptionClass ssmeta:AbstractClass) .

ssmeta:externalMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

# ssmeta:stepImEntityMap indicates that the subject has a direct mapping
# to an entity of STEP integrated models (IM) of ISO 10303, including IR, AIC, AIM, MIM
ssmeta:stepImEntityMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

# ssmeta:stepImAttributeMap indicates that the subject has a direct mapping
# to an entity attribute of STEP integrated models (IM) of ISO 10303, including IR, AIC, AIM, MIM
ssmeta:stepImAttributeMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

ssmeta:stepImSelectMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

ssmeta:stepImEnumerationMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

ssmeta:stepImDefinedTypeMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

# ssmeta:stepImMapAttributeOrder provides the identification/mapping order of explicit attributes
# of a STEP entity, excluding the attributes of possible supertypes.
# This order is needed to map values of entity attributes from STEP p21 files
ssmeta:stepImMapAttributeOrder
    rdf:type owl:ObjectProperty ;
    rdfs:domain ssmeta:MainClass ;
    rdfs:range rdf:List .

# This individual is used within a ssmeta:stepImMapAttributeOrder that a particular STEP attribute 
# has no direct mapping to the SST ontology and thus requires special handling
ssmeta:StepImMapAttributeSpecial
    rdf:type owl:NamedIndividual .

# ssmeta:stepImMapSupertypeOrder identifies the supertypes of a STEP entity in the specifiy order.
# This order is needed to map values of entity attributes from STEP p21 files
ssmeta:stepImMapSupertypeOrder
    rdf:type owl:ObjectProperty ;
    rdfs:domain ssmeta:MainClass ;
    rdfs:range rdf:List .


# mapping for STEP Modules Application Reference Model ARM of ISO 10303-1000 and -400 series
ssmeta:stepArmMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

# mapping for STEP domain model of ISO 10303, primarily the one defined in part 4442 and predecessor 3001
ssmeta:stepDmMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

# mapping of enumeration values for STEP domain model of ISO 10303
ssmeta:stepDmEnumerationMap
    rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf rdfs:label ;
    rdfs:range xsd:string .

# An ssmeta:Schema represents an Express Schema as defined in ISO 10303-11
# in which the declarations (direct or indirect) for ssmeta:Entity and ssmeta:DefinedType are valid.
ssmeta:Schema
	rdfs:label "Schema" ;
    rdf:type owl:Class , ssmeta:MainClass .

# An ssmeta:EntityInstance represents either:
# (1) a single EntityInstance where the entity has no supertype,
# (2) a single-leave complex EntityInstance where the entity has one or more supertypes,
# (3) a multi-leave complex entity instance.
# The cases (1) and (2) are encoded by a ssmeta:EntityInstance 
#   with a single ssmeta:entityInstanceType and a single ssmeta:propertyValues
#   that list the values in the order as they show up in a p21 file.
# The cases (1) and (2) differs in the way that 
#   for (1) the collection of ssmeta:propertyValues contains only ths value of the reference entity
#   for (2) the collection of ssmeta:propertyValues contains all value of the reference entity and it's supertype.
# The order of the attributes in (2) is as defined in p21: first the highest supertype, then the 2nd supertype, etc. .
# The case (3) is encoded by a ssmeta:EntityInstance that contains no ssmeta:entityInstanceType, 
#   but contains 2 or more ssmeta:complexInstanceValue(s).
ssmeta:EntityInstance
	rdfs:label "EntityInstance" ;
    rdf:type owl:Class , ssmeta:MainClass .

# An ssmeta:Entity represents an Express Entity as defined in ISO 10303-11.
# Depending on its usage it may denote a single entity (case 1 and 3) or a single-leave complex EntityInstance (case 2).
ssmeta:Entity
	rdfs:label "Entity" ;
    rdf:type owl:Class , ssmeta:MainClass .

# An ssmeta:DefinedType represents an Express DefinedType as defined in ISO 10303-11.
ssmeta:DefinedType
	rdfs:label "DefinedType" ;
    rdf:type owl:Class , ssmeta:MainClass .

# An ssmeta:EnumerationValue represents a value of the Express types BOOLEAN, LOGICAL or ENUMERATION
ssmeta:EnumerationValue
	rdfs:label "EnumerationValue" ;
    rdf:type owl:Class , ssmeta:MainClass .

# An ssmeta:entityInstanceType defines the Entity type of an EntityInstance for the cases (1) and (2).
ssmeta:entityInstanceType
    rdf:type owl:ObjectProperty ;
    rdfs:domain ssmeta:EntityInstance ;
    rdfs:range ssmeta:Entity .

# range is a collection of any stuff
ssmeta:simpleInstanceValue
    rdf:type rdf:Property ;
    rdfs:domain ssmeta:EntityInstance .

# A ComplexEntityInstance is composed by 2 or more SingleEntityValues
ssmeta:complexInstanceValue
    rdf:type owl:ObjectProperty ;
    rdfs:domain ssmeta:EntityInstance ;
    rdfs:range ssmeta:SingleEntityValue .

# A SingleEntityValue is a part of a ComplexEntityInstance
ssmeta:SingleEntityValue
	rdfs:label "SingleEntityValue" ;
    rdf:type owl:Class , ssmeta:MainClass .

# A ssmeta:singleEntityValueType defines the Entity type of a ssmeta:SingleEntityValue for the cases (3).
ssmeta:singleEntityValueType
    rdf:type owl:ObjectProperty ;
    rdfs:domain ssmeta:SingleEntityValue ;
    rdfs:range ssmeta:Entity .

# An ssmeta:attributeValues represents the attribute values of an ssmeta:EntityInstance
# or of a ssmeta:SingleEntityValue by a collection in the order as they show up in a p21 file.
ssmeta:attributeValues
    rdf:type owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ;
                  owl:unionOf  ( ssmeta:EntityInstance ssmeta:SingleEntityValue )
                ] ;
    rdfs:range rdf:List .

# The class ssmeta:SpecialPropertyValue contains special attribute values used in a p21 file.
ssmeta:SpecialPropertyValue
	rdfs:label "SpecialPropertyValue" ;
    rdf:type owl:Class , ssmeta:MainClass .

# A ssmeta:derivedValue is a ssmeta:SpecialPropertyValue that is represented by "*" in a p21 file.
# It indicates an explicit attribute in a supertype entity that is re-declared as derived in a subtpye.
ssmeta:derivedValue
    rdf:type ssmeta:SpecialPropertyValue .

# An ssmeta:indeterminateValue is a ssmeta:SpecialPropertyValue that is represented by "$" in a p21 file.
# It indicates an explicit attribute for which no value is provided.
ssmeta:indeterminateValue
    rdf:type ssmeta:SpecialPropertyValue .

# An ssmeta:emptyAgggregateValue is is a ssmeta:SpecialPropertyValue that is represented by empty parentheses "()" in a p21 file.
# It indicates an explicit attribute of an aggregate type that contains no members.
ssmeta:emptyAgggregateValue
    rdf:type ssmeta:SpecialPropertyValue .


##########################  Others ###################

# Experimental to identify the source system, dataset and revision for a whole NamedGraph
# Example usage:
# <urn:uuid:7c8bfb47-6a2e-428a-bd69-8cf6854dd854>	a	l:Ontology ;
#   ssmeta:sourceSystem "EDWin Library" ;
#   ssmeta:sourceDataset "ADC804..." ;
#   ssmeta:sourceDatasetDateTime "2001-10-26T19:32:52Z"
#   ssmeta:ssmeta:sourceDatasetHash256 "73jfjejhfh4474747" .

# This is to specify the source system from where the SST NamedGraph was generated
ssmeta:sourceSystem
    rdf:type owl:AnnotationProperty ;
    rdfs:range xsd:string .

# This is to identify the source system; e.g. the file name
ssmeta:sourceDataset
    rdf:type owl:AnnotationProperty ;
    rdfs:range xsd:string .

# this is to record the time stamp that is associated to the source dataset (e.g. a file)
ssmeta:sourceDatasetDateTime
    rdf:type owl:AnnotationProperty ;
    rdfs:range xsd:dateTime .

# this is to record the exact revision of the source dataset (e.g. a file) as a Hash256
ssmeta:sourceDatasetHash256
    rdf:type owl:AnnotationProperty ;
    rdfs:range xsd:string .

# this is to record arbitrary data for any kind of object
# the string should be in the form "tool-name:value"; e.g. "SST-EDM:symbol-master"
ssmeta:directive
    rdf:type owl:AnnotationProperty ;
    rdfs:range xsd:string .

##########################  Generic tabular / CSV interface support ###################

