##########################  ClassSystem support ###################


# to specifiy the list of Properties for all the lci:ClassOfIndividual(s) of a sso:ClassSystem
ssmeta:formClassProperties
    rdf:type owl:ObjectProperty, owl:FunctionalProperty ;
	rdfs:domain owl:Class ; # should be sso:ClassSystem ;
	rdfs:range ssmeta:ListOfProperties .

# to specifiy the list of Properties for all the members of all the lci:ClassOfIndividual(s) of a sso:ClassSystem
ssmeta:formIndividualProperties
    rdf:type owl:ObjectProperty, owl:FunctionalProperty ;
	rdfs:domain owl:Class ; # should be sso:ClassSystem ;
	rdfs:range ssmeta:ListOfProperties .

# to specifiy the list of Properties for all the direct and indirect members of a lci:ClassOfIndividual
ssmeta:formProperties
    rdf:type owl:ObjectProperty, owl:FunctionalProperty ;
	rdfs:domain owl:Class ; # should be lci:ClassOfIndividual ;
	rdfs:range ssmeta:ListOfProperties .

# to defined the ordered list of Fields as a Collection
ssmeta:ListOfProperties
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of fields" ;
	ssmeta:ofType rdf:Property .  # in fact some usage of sso:PropertyDefinition

ssmeta:PropertyAssignment
 	a rdfs:Class .

# field is displayed in speficied order in user dialogs for the object of the selected class
# even if we edit an object for a given class 
# rdfs:label, rdfs:description and other string literal properties might be used to overide PropertyDefinitions
ssmeta:assignedProperty 
    rdf:type owl:ObjectProperty , ssmeta:AbstractProperty ;
    rdfs:domain ssmeta:PropertyAssignment ;
    rdfs:range rdf:Property .  # sso:PropertyDefinition
# mandatory field: field is displayed and user must enter a value
ssmeta:assignedPropertyMandatory 
    rdf:type owl:ObjectProperty  ;
    rdfs:subClassOf ssmeta:assignedProperty .
# optional field: field is displayed and user may or may not enter a value
ssmeta:assignedPropertyOptional 
    rdf:type owl:ObjectProperty  ;
    rdfs:subClassOf ssmeta:assignedProperty .
# mandatory set field: field is displayed and user must enter at least one value, might enter more with "+"
ssmeta:assignedPropertyMandatorySet
    rdf:type owl:ObjectProperty  ;
    rdfs:subClassOf ssmeta:assignedProperty .
# optional set field: field is displayed and user may or may not enter one value, might enter more with "+"
ssmeta:assignedPropertyOptionalSet 
    rdf:type owl:ObjectProperty  ;
    rdfs:subClassOf ssmeta:assignedProperty .


# to define a particular Field. A Field might be shared by several Forms
# DEPRECATED
ssmeta:Field
	rdfs:label "Field" ;
    rdf:type owl:Class , ssmeta:MainClass ;
    rdfs:subClassOf rdf:Property .

ssmeta:goAlias
    a owl:DatatypeProperty ;
	rdfs:label "Go Alias" ;
	rdfs:comment "Alias for Golang used by SST early binding; needed when there is a upper/lower case conflict" ;
	rdfs:domain rdfs:Resource ;
	rdfs:range rdfs:Literal .

