	lci:identificationByLiteral "g" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Mass ;
	:kilogram "0.001"^^xsd:double .
# 4-1.b tonne
:tonne
	rdfs:label "tonne"@en ;
	lci:identificationByLiteral "t" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Mass ;
	:kilogram "1000.0"^^xsd:double .
# 4-1.B.a pound
:pound
	rdfs:label "pound"@en ;
	lci:identificationByLiteral "lb" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Mass ;
	:kilogram "0.45359237"^^xsd:double .
# 4-1.B.b grain
:grain
	rdfs:label "grain"@en ;
	lci:identificationByLiteral "gr" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Mass ;
	:kilogram "0.00006479891"^^xsd:double .
# 4-1.B.c ounce
:ounce
	rdfs:label "ounce"@en ;
	lci:identificationByLiteral "oz" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Mass ;
	:kilogram "0.02834952"^^xsd:double .
