# 3-5 angle
:Angle
	rdfs:label "angle"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 3-5.a radian
:radian
	rdfs:label "radian"@en ;
	lci:identificationByLiteral "rad" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue .
#	rdfs:domain :Angle ;
# 3-5.b degree
:angleDegree
	rdfs:label "degree"@en ;
	lci:identificationByLiteral "⁰" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	:radian "0.01745329251994329576923690768489"^^xsd:double ;
	rdfs:domain :Angle .
# 3-5.c minute
:angleMinute
	rdfs:label "minute"@en ;
	lci:identificationByLiteral "'" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	:radian "2.9088820866572159615394846141477e-4"^^xsd:double ;
	rdfs:domain :Angle .
