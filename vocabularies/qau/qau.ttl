# Copyright Semantic STEP Technology GmbH, Germany & DCT Co., Ltd. Tianjin, China

# This is an ontology to wrap up the quantities and units as defined in the ISO 80000 series of standards

@prefix :      <http://ontology.semanticstep.net/qau#> .
@prefix lci:   <http://ontology.semanticstep.net/lci#> .
@prefix ssmeta:   <http://ontology.semanticstep.net/ssmeta#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

<http://ontology.semanticstep.net/qau>
	rdf:type     owl:Ontology ;
    owl:imports  <http://ontology.semanticstep.net/lci> ; .

:symbol
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf lci:identificationByLiteral .

:multiplicityFactor
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:double .

:reciprocalQuantity
	rdfs:label "reciprocal quantity"@en ;
	rdf:type owl:ObjectProperty , owl:SymmetricProperty ;
	rdfs:domain lci:PhysicalQuantity ;
	rdfs:range lci:PhysicalQuantity .

:multipliedlQuantities
	rdfs:label "multiplied quantity"@en ;
	rdf:type owl:ObjectProperty ;
	rdfs:domain lci:PhysicalQuantity ;
	rdfs:range :ListOfPhysicalQuantities .

:ListOfPhysicalQuantities
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of orientations" ;
	ssmeta:ofType lci:PhysicalQuantity .

:SiPrefix
 	a rdfs:Class .

# ===== ISO 80000-1:2009 Quantities and units — Part 1: General =====

# 6.5.4 SI prefixes
# 10e24 yotta Y
:Yotta
	rdf:type :SiPrefix ;
	rdfs:label "yotta"@en ;
	lci:identificationByLiteral "Y" ;
	:multiplicityFactor "10e24"^^xsd:double .
# 10e21 zetta Z
:Zetta
	rdf:type :SiPrefix ;
	rdfs:label "zetta"@en ;
	lci:identificationByLiteral "Z" ;
	:multiplicityFactor "10e21"^^xsd:double .
# 10e18 exa E
:Exa
	rdf:type :SiPrefix ;
	rdfs:label "exa"@en ;
	lci:identificationByLiteral "E" ;
	:multiplicityFactor "10e18"^^xsd:double .
# 10e15 peta P
:Peta
	rdf:type :SiPrefix ;
	rdfs:label "peta"@en ;
	lci:identificationByLiteral "P" ;
	:multiplicityFactor "10e15"^^xsd:double .
# 10e12 tera T
:Tera
	rdf:type :SiPrefix ;
	rdfs:label "tera"@en ;
	lci:identificationByLiteral "T" ;
	:multiplicityFactor "10e12"^^xsd:double .
# 10e9 giga G
:Giga
	rdf:type :SiPrefix ;
	rdfs:label "giga"@en ;
	lci:identificationByLiteral "G" ;
	:multiplicityFactor "10e9"^^xsd:double .
# 10e6 mega M
:Mega
	rdf:type :SiPrefix ;
	rdfs:label "mega"@en ;
	lci:identificationByLiteral "M" ;
	:multiplicityFactor "10e6"^^xsd:double .
# 10e3 kilo k
:Kilo
	rdf:type :SiPrefix ;
	rdfs:label "kilo"@en ;
	lci:identificationByLiteral "k" ;
	:multiplicityFactor "10e3"^^xsd:double .
# 10e2 hecto h
:Hecto
	rdf:type :SiPrefix ;
	rdfs:label "hecto"@en ;
	lci:identificationByLiteral "h" ;
	:multiplicityFactor "10e2"^^xsd:double .
# 10e1 deca da
:Deca
	rdf:type :SiPrefix ;
	rdfs:label "deca"@en ;
	lci:identificationByLiteral "da" ;
	:multiplicityFactor "10e1"^^xsd:double .
# 10e–1 deci d
:Deci
	rdf:type :SiPrefix ;
	rdfs:label "deci"@en ;
	lci:identificationByLiteral "d" ;
	:multiplicityFactor "10e-1"^^xsd:double .
# 10e–2 centi c
:Centi
	rdf:type :SiPrefix ;
	rdfs:label "centi"@en ;
	lci:identificationByLiteral "c" ;
	:multiplicityFactor "10e-2"^^xsd:double .
# 10e–3 milli m
:Milli
	rdf:type :SiPrefix ;
	rdfs:label "milli"@en ;
	lci:identificationByLiteral "m" ;
	:multiplicityFactor "10e-3"^^xsd:double .
# 10e–6 micro µ
:Micro
	rdf:type :SiPrefix ;
	rdfs:label "micro"@en ;
	lci:identificationByLiteral "μ" ;
	:multiplicityFactor "10e-6"^^xsd:double .
# 10e–9 nano n
:Nano
	rdf:type :SiPrefix ;
	rdfs:label "nano"@en ;
	lci:identificationByLiteral "n" ;
	:multiplicityFactor "10e-9"^^xsd:double .
# 10e–12 pico p
:Pico
	rdf:type :SiPrefix ;
	rdfs:label "pico"@en ;
	lci:identificationByLiteral "p" ;
	:multiplicityFactor "10e-12"^^xsd:double .
# 10e–15 femto f
:Femto
	rdf:type :SiPrefix ;
	rdfs:label "femto"@en ;
	lci:identificationByLiteral "f" ;
	:multiplicityFactor "10e-15"^^xsd:double .
# 10e–18 atto a
:Atto
	rdf:type :SiPrefix ;
	rdfs:label "atto"@en ;
	lci:identificationByLiteral "a" ;
	:multiplicityFactor "10e-18"^^xsd:double .
# 10e–21 zepto z
:Zepto
	rdf:type :SiPrefix ;
	rdfs:label "zepto"@en ;
	lci:identificationByLiteral "z" ;
	:multiplicityFactor "10e-21"^^xsd:double .
# 10e–24 yocto y
:Yocto
	rdf:type :SiPrefix ;
	rdfs:label "yocto"@en ;
	lci:identificationByLiteral "y" ;
	:multiplicityFactor "10e-24"^^xsd:double .


# === not part of ISO 80000 ===
# derived from count_measure in ISO 10303-41
:CountQuantity
	rdfs:label "count quantity"@en ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Quantity .

:CurrencyQuantity
	rdfs:label "currency quantity"@en ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :CountQuantity .


# ===== ISO 80000-2:2009 Quantities and units — Part 1: Mathematical signs and symbols to be used in the natural sciences and technology =====
# - out of scope

# ===== ISO 80000-3:2006 Quantities and units — Part 3: Space and time =====

# 3-1.1 length
:Length
	rdfs:label "length"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 3-1.2 breadth
:Breadth
	rdfs:label "breadth"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.3 height
:Height
	rdfs:label "height"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.4 thickness
:Thickness
	rdfs:label "thickness"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.5 radius
:Radius
	rdfs:label "radius"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.6 radial distance
:RadialDistance
	rdfs:label "radial distance"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.7 diameter
:Diameter
	rdfs:label "diameter"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.8 length of path
:LengthOfPath
	rdfs:label "length of path"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.9 distance
:Distance
	rdfs:label "distance"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.10 cartesian coordinates
:CartesianCoordinates
	rdfs:label "cartesian coordinates"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.11 position vector
:PositionVector
	rdfs:label "position vector"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.12 displacement
:Displacement
	rdfs:label "displacement"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.13 radius of curvature
:RadiusOfCurvature
	rdfs:label "radius of curvature"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf :Length .
# 3-1.a metre
:metre
	rdfs:label "metre"@en ;
	lci:identificationByLiteral "m" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length .
:kiloMetre
	rdfs:label "kilo metre"@en ;
	lci:identificationByLiteral "km" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1.0e3"^^xsd:double .
:milliMetre
	rdfs:label "milli metre"@en ;
	lci:identificationByLiteral "mm" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1.0e-3"^^xsd:double .
:microMetre
	rdfs:label "micro metre"@en ;
	lci:identificationByLiteral "μm" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1.0e-6"^^xsd:double .
:nanoMetre
	rdfs:label "nano metre"@en ;
	lci:identificationByLiteral "nm" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1.0e-9"^^xsd:double .
:picoMetre
	rdfs:label "pico metre"@en ;
	lci:identificationByLiteral "om" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1.0e-12"^^xsd:double .
# 3-1.B.a inch
:inch
	rdfs:label "inch"@en ;
	lci:identificationByLiteral "in" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "0.0254"^^xsd:double .
:milliInch
	rdfs:label "mil / milli inch"@en ;
	lci:identificationByLiteral "mil" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:inch "1.0e-3"^^xsd:double .
# 3-1.B.b foot
:foot
	rdfs:label "foot"@en ;
	lci:identificationByLiteral "ft" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "0.3048"^^xsd:double .
# 3-1.B.c yard
:yard
	rdfs:label "yard"@en ;
	lci:identificationByLiteral "yd" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "0.9144"^^xsd:double .
# 3-1.B.d mile
:mile
	rdfs:label "mile"@en ;
	lci:identificationByLiteral "mi" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1609.344"^^xsd:double .
# 3-1.C.a light year
:lightYear
	rdfs:label "light year"@en ;
	lci:identificationByLiteral "l.y." ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "9.460730e15"^^xsd:double .
# 3-1.C.b astronomical unit
:astronomicalUnit
	rdfs:label "astronomical unit"@en ;
	lci:identificationByLiteral "ua" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "1.49597870691e11"^^xsd:double .
# 3-1.C.c parsec
:parsec
	rdfs:label "parsec"@en ;
	lci:identificationByLiteral "pc" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Length ;
	:metre "30.85678e15"^^xsd:double .

# 3-2 curvature
:Curvature
	rdfs:label "curvature"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 3-2.a metre to the power minus one
:metreToThePowerMinusOne
	rdfs:label "metre to the power minus one"@en ;
	lci:identificationByLiteral "m⁻¹" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue .
#	rdfs:domain :Curvature ;

# 3-3 area
:Area
	rdfs:label "area"@en ;
	rdf:type owl:Class , ssmeta:MainClass, lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
