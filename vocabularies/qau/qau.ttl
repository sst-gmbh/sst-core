# ===== ISO 80000-10: Quantities and units — Part 10: Atomic and nuclear physics =====

# 10-1.1 atomic number // proton number
:atomicNumber
	rdfs:label "atomic number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:domain lci:ChemicalElement ;
	rdfs:range xsd:int .
# 10-1.2 neutron number
:neutronNumber
	rdfs:label "neutron number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-1.3 nucleon number
:nucleonNumber
	rdfs:label "nucleon number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-1.a one

# 10-2 rest mass
:RestMass
	rdfs:label "rest mass"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-2.a kilogram
# 10-2.b dalton,
#        unified atomic mass unit

# 10-3 rest energy
:RestEnergy
	rdfs:label "rest energy"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-3.a joulc mass constant
# 10-4.a kilogram
# 10-4.b daltssOf lci:PhysicalQuantity .
# 3-1.13 radius of con, unified atomic mass unit

# 10-5.1 elementary charge
# => see 9-49 elementary charge
# 10-5.2 charge number
:ChargeNumber
	rdfs:label "charge number"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-5.a coulomb

# 10-6.1 Planck constant
# 10-6.2 reduced Planck constant
# 10-6.a joule second

# 10-7 Bohr radius
#:BohrRadius
#	rdfs:label "Bohr radius"@en ;
#	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
#	rdfs:subClassOf lci:PhysicalQuantity .
# 10-7.a metre

# 10-8 Rydberg constant
# 10-8.a metre to the power minus one

# 10-9 Hartree energy
# 10-9.a joule

# 10-10.1 magnetic dipole moment
# => see 6-30 magnetic dipole moment
# 10-10.2 Bohr magneton
:BohrMagneton
	rdfs:label "Bohr magneton"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-10.3 nuclear magneton
:NuclearMagneton
	rdfs:label "nuclear magneton"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-10.a amper asquare metre

# 10-11 spin
:Spin
	rdfs:label "spin"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-11.a kilogram metre squared per second

# 10-12 total angular momentum
:TotalAngularMomentum
	rdfs:label "total angular momentum"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-12.a joule second

# 10-13.1 gyromagnetic ratio for electron
:GyromagneticRatioForElectron
	rdfs:label "gyromagnetic ratio for electron"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-13.2 gyromagnetic ratio
:GyromagneticRatio
	rdfs:label "gyromagnetic ratio"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-13.a ampere square metre per joule second

# 10-14.1 quantum number
:QuantumNumber
	rdfs:label "quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.2 principal quantum number
:PrincipalQuantumNumber
	rdfs:label "principal quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.3 orbital angular momentum quantum number
:OrbitalAngularMomentumQuantumNumber
	rdfs:label "orbital angular momentum quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.4 magnetic quantum number
:MagneticQuantumNumber
	rdfs:label "magnetic quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.5 spin quantum number 
:SpinQuantumNumber
	rdfs:label "spin quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.6 total angular momentum quantum number
:TotalAngularMomentumQuantumNumber
	rdfs:label "total angular momentum quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.7 nuclear spin quantum number
:NuclearSpinQuantumNumber
	rdfs:label "nuclear spin quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.8 hyperfine structure quantum number
:HyperfineStructureQuantumNumber
	rdfs:label "hyperfine structure quantum number"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-14.a one

# 10-15.1 Landé factor of atom or electron // g-factor of atom or electron
:LandeFactorOfAtomOrElectron
	rdfs:label "Landé factor of atom or electron"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-15.2 g-factor of nucleus or nuclear particle
:GFactorOfNucleusOrNuclearParticle
	rdfs:label "g-factor of nucleus or nuclear particle"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:range xsd:int .
# 10-15.a one

# 10-16.1 Larmor angular frequency
:LarmorAngularFrequency
	rdfs:label "Larmor angular frequency"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-16.2 nuclear precession angular frequency
:NuclearPrecessionAngularFrequency
	rdfs:label "nuclear precession angular frequency"@en ;
	rdf:type owl:Class , ssmeta:MainClass , lci:PhysicalQuantityKind ;
	rdfs:subClassOf lci:PhysicalQuantity .
# 10-16.a radian per second
# 10-16.b second to the power minus one

