	:second "3600.0"^^xsd:double .
# 3-7.d day
:day
	rdfs:label "day"@en ;
	lci:identificationByLiteral "d" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Time ;
	:second "86400.0"^^xsd:double .
# 3-7.d year
:year
	rdfs:label "year"@en ;
	lci:identificationByLiteral "a" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Time ;
	:second "31556926.0"^^xsd:double .   # tropical year, 365,242 20 d

# Note: ISO 80000 does not define units for month and week defined; likely because there these can not exactly recalculated to the other units
# SST defines a month as 1/12 of a tropical year
:month
	rdfs:label "month"@en ;
#	lci:identificationByLiteral "" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Time ;
	:second "2629743.8333333333333333333333333"^^xsd:double .
## SST defines a week as 7 days
:week
	rdfs:label "day"@en ;
#	lci:identificationByLiteral "" ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:subPropertyOf lci:numericQuantityValue ;
	rdfs:domain :Time ;
	:second "604800.0"^^xsd:double .


