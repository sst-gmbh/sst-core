lci:ChemicalSolution
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:HomogeneousChemicalMixture ;
	skos:definition "TBD" ;
	skos:prefLabel "chemical solution" ;
	skos:scopeNote "TBD" .

