# ISO 15926-2: 5.2.26.4 multidimensional_property 
# The name has been changed to use more common mathematical terminology.
lci:ListOfPhysicalQuantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:ListOfQuantity ;
	skos:definition "<List> that has <PhysicalQuantity> as its range" ;
	skos:prefLabel "list of physical quantity" .

# ISO 15926-2: no
lci:ListOfQuantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:List ;
	skos:definition "<List> that has <Quantity> as its range" ;
	skos:prefLabel "list of quantity" ;
	skos:scopeNote "This class is defined in the ontology solely to provide structure." .

# ISO 15926-2:  MISSING ???
lci:OrderedPairOfPhysicalQuantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:OrderedPairOfQuantity ;
	skos:definition "<OrderedPairOfQuantity> that is an ordered pair of <PhysicalQuantity>" ;
	skos:example "('50 hours', '200 hours') is an <OrderedPairOfPhysicalQuantity>." ;
	skos:prefLabel "ordered pair of physical quantity" .

# ISO 15926-2: no, This class is a useful special case of the class multidimensional_object which is defined in ISO 15926-2.
lci:OrderedPairOfQuantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:OrderedPair ;
	skos:definition "<OrderedPair> that is an order pair of <Quantity>" ;
	skos:example "('50 hours', '200 hours') is an <OrderedPairOfQuantity>." ;
	skos:prefLabel "ordered pair of quantity" .

# ISO 15926-2: no, This class is a useful special case of the class multidimensional_object which is defined in ISO 15926-2.
lci:OrderedPairOfTimeDuration
	rdf:type owl:Class ;
	rdfs:subClassOf lci:OrderedPairOfPhysicalQuantity ;
	skos:definition "<OrderedPairOfPhysicalQuantity> that is an ordered pair of <TimeDuration>" ;
	skos:example "('50 hours', '200 hours') is an <OrderedPairOfTimeDuration>." ;
	skos:prefLabel "ordered pair of time duration" .

# ISO 15926-2: 5.2.26.1 class_of_indirect_property 
# The name has been changed to make it more intuitive.
lci:PhysicalProperty
	rdf:type owl:Class ;
	rdfs:subClassOf lci:Mapping ;
	skos:definition "<QuantityMeasure> that has a <PhysicalQuantitySpace> as its range" ;
	skos:example "'Maximum allowable working temperature' is a <PhysicalProperty>. The relationship between stream S-101 and its maximum allowable working temperature of 300 degrees Celsius is not a classification of the stream. Instead it is a classification of a hypothetical limit state. 'Internal pressure' is a <PhysicalProperty>. The relationship between vessel V-101 at 2016-03-09T12:30Z and its internal pressure of 1.5 bar is not a classification of the vessel at 2016-03-09T12:30Z. Instead it is a classification of the fluid within vessel V-101 at 2016-03-09T12:30Z." ;
	skos:prefLabel "physical property" ;
	skos:scopeNote "A member of <PhysicalProperty> is implemented in this part of ISO 15926 as an owl:ObjectProperty with the range <PhysicalQuantity>." .

# ISO 15926-2: property # This class has been renamed to be consistent with ISO 80000.
lci:PhysicalQuantity
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> that is measurable or observable" ;
	skos:example "The mass 10 kilograms is a <Quantity>." ;
	skos:prefLabel "physical quantity" .

## ISO 15926-2: 5.2.27.8 single_property_dimension 
# This class has been renamed to be consistent with ISO 80000.
lci:PhysicalQuantityKind
	rdf:type owl:Class ;
	rdfs:subClassOf lci:QuantityKind , lci:PhysicalQuantitySpace ;
	skos:definition "<PhysicalQuantitySpace> and a <QuantityKind>" ;
	skos:example "mass is a <PhysicalQuantityKind>." ;
	skos:prefLabel "physical quantity kind" .

## ISO 15926-2: 5.2.27.6 property_range 
# This class has been renamed to be consistent with ISO 80000.
# => for SST see instead optional subclasses of lci:Quantity to use together with lci:PhysicalQuantity
# lci:PhysicalQuantityRange
# 	rdf:type owl:Class ;
# 	rdfs:subClassOf lci:PhysicalQuantitySpace , lci:QuantityRange ;
# 	skos:definition "<PhysicalQuantitySpace> and <QuantityRange>" ;
# 	skos:example "The instances of mass that are greater than 10 kilograms and less than 15 kilograms is a <PhysicalQuantityRange>" ;
# 	skos:prefLabel "physical quantity range" .

## ISO 15926-2:  MISSING ???
#lci:PhysicalQuantityRatio
#	rdf:type owl:Class ;
#	rdfs:subClassOf lci:QuantityRatio , lci:ClassOfOrderedPairOfPhysicalQuantity ;
#	skos:definition "<QuantityRatio> that is a <ClassOfOrderedPairOfPhysicalQuantity>" ;
#	skos:prefLabel "physical quantity ratio" .

## ISO 15926-2: 5.2.27.7 property_space 
# This class has been renamed to be consistent with ISO 80000.
lci:PhysicalQuantitySpace
	rdf:type owl:Class ;
	rdfs:subClassOf lci:ClassOfPhysicalQuantity , lci:QuantitySpace ;
	skos:definition "<ClassOfPhysicalQuantity> that is a subspace of, or all of, a <PhysicalQuantityKind>" ;
	skos:example "mass is a <PhysicalQuantitySpace>." ;
	skos:prefLabel "physical quantity space" .

# ISO 15926-2: no, This is a proposed extension to support monetary amount and other non-physical quantities.
lci:Quantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:ClassOfIndividual ;
	skos:definition "<ClassOfIndividual> that has the degree or magnitude of a quality or characteristic as the criterion for membership" ;
	skos:example "The mass 10 kilograms is a <Quantity>.The monetary amount 10 euro is a <Quantity>." ;
	skos:prefLabel "quantity" .
lci:TheoreticalExactQuantity
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> that is theoretical exact in meaning of a <theoretically exact dimension> defined in ISO 5459." ;
#	skos:example "" ;
	skos:prefLabel "theoretical exact quantity" .
# SST specific, to separate from Min and Max
lci:NominalQuantity
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> that is used to identify a characteristic of a product." ;
#	skos:example "" ;
	skos:prefLabel "nominal quantity" .
lci:MinQuantity
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> in the range down to the spcified minimm value" ;
#	skos:example "" ;
	skos:prefLabel "min quantity" .
lci:MaxQuantity
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> in the range up to the spcified maximum value" ;
#	skos:example "" ;
	skos:prefLabel "max quantity" .
lci:MinMaxQuantity
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> in the range within a minimum and maximum value" ;
#	skos:example "" ;
	skos:prefLabel "min-max quantity" .
lci:MinNomMaxQuantity
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:Quantity ;
	skos:definition "<Quantity> defined by a nominal value with a minimum and maximum range that can be defined either absolute or relative and might be symmetric or unsymmetric" ;
#	skos:example "" ;
	skos:prefLabel "min-nom-max quantity" .

lci:numericQuantityValue
	rdfs:label "numeric quantity value"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:domain lci:Quantity ;
	rdfs:range xsd:double ;
	skos:definition "property that defines the numerical value for a quantity" .
# derived from descriptive_measure in ISO 10303-41
lci:descriptiveQuantityValue
	rdfs:label "descriptive quantity value"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:domain lci:Quantity ;
	rdfs:range xsd:string ;
	skos:definition "property that defines the textual descriptive value for a quantity" .

lci:significantDecimalDigits
	rdfs:label "digits"@en ;
	rdf:type owl:DatatypeProperty ;
	rdfs:domain lci:Quantity;
	rdfs:range xsd:positiveInteger ;
	skos:definition "property that defines the number of significant decimal digits of the nominal value" ;
#	skos:example "" ;
	skos:prefLabel "significant decimal digits" .
lci:minOffsetFromNominalValue
	rdfs:label "min"@en ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:domain lci:MinNomMaxQuantity;
	rdfs:range xsd:double ;
	skos:definition "property that defines the offset from the nominal value for the minimum boundary in the same unit as the nominal value; typically a negative value" ;
#	skos:example "" ;
	skos:prefLabel "minimum offset from nominal value" .
lci:maxOffsetFromNominalValue
	rdfs:label "max"@en ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:domain lci:MinNomMaxQuantity;
	rdfs:range xsd:double ;
	skos:definition "property that defines the offset from the nominal value for the maximum boundary in the same unit as the nominal value; typically a positive value" ;
#	skos:example "" ;
	skos:prefLabel "maximum offset from nominal value" .
lci:minMaxOffsetFromNominalValue
	rdfs:label "min-max"@en ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:domain lci:MinNomMaxQuantity;
	rdfs:range xsd:double ;
	skos:definition "property that defines the offset from the nominal value in the same unit as the nominal value for the minimum and maximum boundary; must be a positve value" ;
#	skos:example "" ;
	skos:prefLabel "minimum and maximum offset from nominal value" .
lci:minRelativeOffsetFromNominalValue
	rdfs:label "min%"@en ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:domain lci:MinNomMaxQuantity;
	rdfs:range xsd:double ;
	skos:definition "property that defines the relative offset in percent from the nominal value for the minimum boundary; typically a negaive value" ;
#	skos:example "" ;
	skos:prefLabel "minimum relative offset from nominal value in %" .
lci:maxRelativeOffsetFromNominalValue
	rdfs:label "max%"@en ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:domain lci:MinNomMaxQuantity;
	rdfs:range xsd:double ;
	skos:definition "property that defines the relative offset in percent from the nominal value for the maximum boundary; typically a negaive value" ;
#	skos:example "" ;
	skos:prefLabel "maximum relative offset from nominal value in %" .
lci:minMaxRelativeOffsetFromNominalValue
	rdfs:label "min-max%"@en ;
	rdf:type owl:DatatypeProperty , lci:LinearScale ;
	rdfs:domain lci:MinNomMaxQuantity;
	rdfs:range xsd:double ;
	skos:definition "property that defines the relative offset in percent from the nominal value for the minimum and maximum boundary; must be a positive value" ;
#	skos:example "" ;
	skos:prefLabel "minimum and maximum offset from nominal value" .

## ISO 15926-2: no, This is a proposed extension to support monetary amount and other non-physical quantities.
lci:QuantityKind
	rdf:type owl:Class ;
	rdfs:subClassOf lci:QuantitySpace ;
	skos:definition "<ClassOfQuantity> that is all instances of <Quantity> of the same kind" ;
	skos:example "The class 'monetary amount' is subclass of <QuantityKind>. The class 'euro amount' is a member of 'monetary amount' and <QuantityKind>." ;
	skos:prefLabel "quantity kind" ;
	skos:scopeNote "The different currencies with codes defined in ISO 3166 are all members of 'monetary amount' and <QuantityKind>." .

## ISO 15926-2: no, This is a proposed extension to support monetary amount and other non-physical quantities.
