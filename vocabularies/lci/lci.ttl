## ISO 15926-2: no, An extension that supports subspaces of <span class="id">PhysicalQuantitySpace</span>.
lci:subPhysicalQuantitySpaceOf
	rdf:type owl:ObjectProperty ;
	rdfs:domain lci:PhysicalQuantitySpace ;
	rdfs:range lci:PhysicalQuantitySpace ;
	skos:definition "<PhysicalQuantitySpace> that is a subspace" ;
	skos:prefLabel "sub physical quantity space of" .

