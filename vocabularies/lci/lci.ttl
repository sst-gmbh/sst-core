# Copyright Semantic STEP Technology GmbH, Germany & DCT Co., Ltd. Tianjin, China

# This file is a highly modifed version of the lci ontology as defined in ISO/TS 15926-12:2018.
# Major changes are:
# * use of a different base URL
# * merged all relevant lci concepts into this single Ontology
# * removal of many higher level abstraction concepts that are not needed for SST
# * adding lci:isDefinedBy and lci:PropertyDefinition
#
# As much as possible the original definitions from ISO/TS 15926-12:2018 are preserved.

@prefix lci:   <http://ontology.semanticstep.net/lci#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ssmeta:   <http://ontology.semanticstep.net/ssmeta#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

<http://ontology.semanticstep.net/lci>
	rdf:type     owl:Ontology ;
	owl:versionInfo "0.01" .

#############  SST management, not part of ISO/TS 15926-12:2018 ###################

# need to state which objects are defined 

# Meaning is that everything that is stated for the object applies also for the subject
# It works similar like making a copy. 
# A subject can have at most one lci:isDefinedBy triple.
lci:isDefinedBy
	rdf:type owl:ObjectProperty , owl:FunctionalProperty , owl:IrreflexiveProperty ;
	rdfs:subPropertyOf rdfs:isDefinedBy ;
	rdfs:domain lci:SpaceTimeIndividual ;
	rdfs:range lci:SpaceTimeIndividual .
lci:isDefinitionFor 
	owl:inverseOf lci:isDefinedBy .

# derived from STEP PropertyDefinition
lci:PropertyDefinition
	ssmeta:stepDmMap "PropertyDefinition" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf rdf:Property .


#############  Top Level ###################

## ISO 15926-2: no
lci:powerClassOf
	rdf:type owl:ObjectProperty , owl:FunctionalProperty , owl:InverseFunctionalProperty ;
	rdfs:domain owl:Class ;
	rdfs:range owl:Class ;
	skos:definition "<Class> that the power class is obtained from" ;
	skos:prefLabel "power class of" ;
	skos:scopeNote "The power class 'Class of A' of the class 'A' is set of all subclasses of A, including A itself. The use of power class relationships in an ontology is not supported by inferencing, but is an aid to to rigorous structuring of an ontology. A powerclass can be defined as an OWL Restriction class on the property rdfs:subClassOf." .

## ISO 15926-2: 5.2.25.4 union_of_set_of_class
#lci:unionOfAllMembersOf
#	rdf:type owl:ObjectProperty , owl:InverseFunctionalProperty ;
#	rdfs:domain lci:Class ;
#	rdfs:range lci:ClassOfClass ;
#	skos:definition "<Class> that is the union of all members" ;
#	skos:example "The <RangePhysicalQuantity> that is all instances of <Individual> with a mass greater than 10 kilograms and less than 15 kilograms is the <unionOfAllMembersOf> the <RangePhysicalQuantity> that is all instances of mass greater than 10 kilograms and less than 15 kilograms." ;
#	skos:prefLabel "union of all members of" ;
#	skos:scopeNote "For an enumerated set of classes the union of all members can be defined using owl:unionOf. However the <unionOfAllMembersOf> relationship is required where the members of the set are not enumerated." .

# OK ISO 15926-2: 5.2.1.2 thing
lci:Thing
	rdf:type owl:Class , ssmeta:AbstractClass;
	rdfs:subClassOf owl:Thing ;
	owl:disjointUnionOf (
		lci:Individual 
		# ... more to add
		lci:AbstractObject) ;
	skos:definition "an <Individual> or <AbstractObject>" ;
	skos:prefLabel "thing" ;
	skos:scopeNote "An owl:Thing can be something other than an <Individual> or <AbstractObject>. Therefore <Thing> is a subclass of owl:Thing." .

# 5.2.6 Possible individuals
lci:Individual
	rdf:type owl:Class , ssmeta:MainClass ;
	owl:disjointUnionOf (
		lci:SpaceTimeIndividual 
		lci:OmnipresentIndividual
	) ;
	skos:definition "The class of individuals that do not exist in space and time and that and that have no variations defined in 4D" ;
	skos:prefLabel "individual" .

# SST only
lci:OmnipresentIndividual
	rdf:type owl:Class , ssmeta:MainClass ;
#	owl:disjointUnionOf (
#		lci:State
#		lci:OmnipresentIndividualEnumeration
#		rdfs:Literal) ;
	skos:definition "The class of individuals that do not exist in space and time and that and that have no variations defined in 4D" ;
	skos:prefLabel "other individual" .

# OK ISO 15926-2: 5.2.6.11 possible_individual 
# Name has been changed from "possible individual" because the class includes actual individuals as well as possible, but not actual ones.
lci:SpaceTimeIndividual
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Individual ;
	owl:disjointUnionOf (
		lci:PhysicalObject 
		lci:Activity
		lci:Event
		lci:InformationObject
#		lci:PointOrRegionInSpaceAndTime   # is treated as a PhysicalObject
	) ;
	skos:definition "The class of SpaceTimeIndividuals that exists in space and time and that may have variations defined in 4D" ;
	skos:prefLabel "space-time individual" ;
	skos:scopeNote "This class includes: things where any of the space-time dimensions are vanishingly small; things that are either all space for a period of time, or all time for a region of space; the entirety of all space-time; things that actually exist, or have existed; things that are fictional or conjectured and possibly exist in the past, present or future; temporal parts (states) of other SpaceTimeIndividuals; things that have a specific position, but zero extent in one or more dimensions, such as points, lines, and surfaces." .

# ISO 15926-2: 5.2.1.1 abstract_object 
lci:AbstractObject  
	rdf:type owl:Class , ssmeta:AbstractClass ;
	rdfs:subClassOf lci:Thing ;
	skos:definition "<Thing> that does not exist in space and time" ;
	skos:prefLabel "abstract object" ;
	skos:scopeNote "An <AbstractObject> does not exist in space and time, and does not have properties or relationships that change. Most instances of <AbstractObject> are classes, but there are a few mostly to do with mathematics that are not." .

#############  Top SpaceTimeIndividuals ###################

# OK ISO 15926-2: 5.2.6.2 arranged_individual
lci:ArrangedIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	owl:disjointWith lci:Non-arrangedIndividual ;
	skos:definition "<Individual> that has parts with a particular organization or arrangement" ;
	skos:prefLabel "arranged space-time individual" ;
	skos:scopeNote "The properties, characteristics and behaviours of an <ArrangedIndividual> are different from those of its individual parts." .
lci:Non-arrangedIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	skos:definition "<Individual> that is not an <ArrangedIndividual>" ;
	skos:example "The 2015 production run of pump model 'WBX-456A' a <PhysicalObject> and a <Non-arrangedIndividual>. A particular pump within the production run is an <ArrangedIndividual>." ;
	skos:prefLabel "non-arranged space-time individual" .

lci:SpecificIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	owl:disjointWith lci:TypicalIndividual ;
	skos:definition "<SpaceTimeIndividual> that exist or may exist at a specific space and time" ;
	skos:example "my bycicle that is of a specific model and has a specific serial number" ;
	skos:prefLabel "specific space-time individual" .
lci:TypicalIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	skos:definition "<SpaceTimeIndividual> that does not exist at a specifc space and time and that can therefore be used for several other SpaceTimeIndividuals as definition" ;
	skos:example "A particular model of a bycicle of which many SpecificIndividuals exist" ;
	skos:prefLabel "typical space-time individual" .

# ISO 15926-2: 5.2.6.1 actual_individual
lci:ActualIndividual
	rdf:type owl:Class , ssmeta:OptionClass;
	rdfs:subClassOf lci:SpecificIndividual ;
	owl:disjointWith lci:Non-actualIndividual ;
	skos:definition "<SpaceTimeIndividual> that actually exists in the real world" ;
	skos:example "The 25 gallon per minute pump that was required for the Omega production system from 21 March 1998 is a <Individual>. The pump manufactured in July of 1998 that has a capacity of 28 gallon per minute is an <ActualIndividual>." ;
	skos:prefLabel "actual space-time individual" .
lci:Non-actualIndividual
	rdf:type owl:Class, ssmeta:OptionClass;
	rdfs:subClassOf lci:SpecificIndividual ;
	skos:definition "<SpaceTimeIndividual> that is not an <ActualIndividual>" ;
	skos:example "The planned 'Hinkley Point C' power station is a <PhysicalObject> and a <Non-actualIndividual>" ;
	skos:prefLabel "non-actual space-time individual" .

# OK ISO 15926-2: 5.2.6.15 whole_life_individual
lci:WholeLifeIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	owl:disjointWith lci:Non-wholeLifeIndividual ;
	skos:definition "<Individual> that is a that is an entire lifetime as defined by its basis for identity" ;
	skos:example "The plastic cup on the desk of Fred Bloggs (bounded by its creation and destruction events) is a <WholeLifeIndividual>. The cup whilst it stands on that desk is a temporal part of the <WholeLifeIndividual>." ;
	skos:prefLabel "whole life space-time individual" .
lci:Non-wholeLifeIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	skos:definition "<Individual> that is not an <WholeLifeIndividual>" ;
	skos:example "The temporal part of the pump with serial number 'P-98/1234' that is installed as pump tag '20-P-101' is a <MaterializedPhysicalObject> and a <Non-wholeLifeIndividual>. The temporal part of pump tag '20-P-101' that has the pump with serial number 'P-98/1234' installed is a <FunctionalPhysicalObject> and a <Non-wholeLifeIndividual>." ;
	skos:prefLabel "non-whole life space-time individual" .

# ISO 15926-2: 5.2.6.10 physical_object
lci:PhysicalObject
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	owl:disjointUnionOf (
		lci:Matter 
#		lci:PhysicalField 
#		lci:PhysicalRadiation
		lci:PointOrRegionInSpaceAndTime
	) ;
	skos:definition "<Individual> that is a distribution of energy, matter or both" ;
	skos:example "Pump P_101 is a <PhysicalObject>." ;
	skos:prefLabel "physical object" .

# ISO 15926-2: 5.2.9.1 activity
lci:Activity
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	skos:definition "<Individual> that is something happening or changing" ;
	skos:prefLabel "activity" ;
	skos:scopeNote "An <Activity> is a space-time extension in which other instances of <Individual> and <Event> participate." .

# ISO 15926-2: 5.2.9.5 event     ?? Difference to PointInTime
lci:Event
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	skos:definition "<Individual> that has zero extent in time" ;
	skos:example "The connection of power to pump P_101 is an <Event>. This event that marks the beginning of a temporal part of pump P_101." ;
	skos:prefLabel "event" ;
	skos:scopeNote "An <Event> is the temporal boundary of one or more instances of <Individual> although there may be no knowledge of them." .

# added by SST
lci:PointOrRegionInSpaceAndTime
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject .

# ISO 15926-2: no
lci:PointOrPeriodInTime
	rdf:type owl:Class , ssmeta:MainClass ;
	owl:disjointWith lci:PointOrRegionInSpace ;
	rdfs:subClassOf lci:PointOrRegionInSpaceAndTime .

# ISO 15926-2: 5.2.9.8 point_in_time
lci:PointInTime
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PointOrPeriodInTime ;
	owl:disjointWith lci:PeriodInTime ;
	skos:definition "<Individual> that is all that exists in space at an instant in time" ;
	skos:example "1999-05-13T16:31:23.56Z' is an identification of a <PointInTime>, which is defined by ISO 8601." ;
	skos:prefLabel "point in time" ;
	skos:scopeNote "A <PointInTime> can be regarded as an unbounded 3D 'plane' within 4D space-time that has a zero temporal extent." .
# ISO 15926-2: 5.2.6.9 period_in_time    MODIFIED ??
lci:PeriodInTime
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PointOrPeriodInTime ;
	skos:definition "<Individual> that is all that exists in space for a period in time" ;
	skos:example "From 2000-11-21T06:00Z to 2000-11-21T11:53Z is a <PeriodInTime>." ;
	skos:prefLabel "period in time" ;
	skos:scopeNote "A <PeriodInTime> is bounded by a start <PointInTime> and an end <PointInTime>." .

# ISO 15926-2:  ???, Modified
lci:PointOrRegionInSpace
	rdf:type owl:Class , ssmeta:AbstractClass ;
	rdfs:subClassOf lci:PointOrRegionInSpaceAndTime .
# ISO 15926-2: 5.2.6.12 spatial_location
# The class defined in ISO 15926-2 has been split into <span class="id">PointInSpace</span> and <span class="id">RegionInSpace</span> in order to be consistent with <span class="id">PointInTime</span> and <span class="id">PeriodInTime</span>.</p><p>The two spatial classes are subclasses of  <span class="id">Individual</span>, rather than  <span class="id">PhysicalObject</span> in ISO 15926-2, to be consistent with the two temporal classes.</p>
# ???, Modified 
lci:PointInSpace
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PointOrRegionInSpace ;
	owl:disjointWith lci:RegionInSpace ;
	skos:definition "<Individual> that is all that exists in time at a point in space" ;
	skos:prefLabel "point in space" ;
	skos:scopeNote "A <PointInSpace> can be defined in any spatial frame. It can be defined with respect to a moving or moveable object, such as a ship or an equipment item." .
# ISO 15926-2: 5.2.6.12 spatial_location	
# The class defined in ISO 15926-2 has been split into <span class="id">PointInSpace</span> and <span class="id">RegionInSpace</span> in order to be consistent with <span class="id">PointInTime</span> and <span class="id">PeriodInTime</span>.</p><p>The two spatial classes are subclasses of  <span class="id">Individual</span>, rather than  <span class="id">PhysicalObject</span> in ISO 15926-2, to be consistent with the two temporal classes.</p>
lci:RegionInSpace
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PointOrRegionInSpace ;
	skos:definition "<Individual> that is all that exists in time for a region in space" ;
	skos:prefLabel "region in space" ;
	skos:scopeNote "A <RegionInSpace> can be defined in any spatial frame. It can be defined with respect to a moving or moveable object, such as a ship or an equipment item. License block, construction area, country, air corridor, maritime traffic zone, and hazard control zone are subclasses of <RegionInSpace>." .



#############  Top PhysicalObjects  ###################

# OK ISO 15926-2: 5.2.8.6 class_of_feature
lci:Feature
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject , lci:ArrangedIndividual ;
	skos:definition "<PhysicalObject> that is a contiguous, non-separable part of a <Individual> and that has an incompletely defined separating bound" ;
    skos:prefLabel "feature" ;
    skos:scopeNote "Mountain, groove, rim, nozzle, nose, and raised face are subclasses of <Feature>." .

# ISO 15926-2: 5.2.6.7 functional_physical_object
lci:FunctionalPhysicalObject
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:PhysicalObject ;
	skos:definition "<PhysicalObject> that has functional continuity as its basis of identity" ;
	skos:example "The heat exchanger system known as tag E-4507 is a <FunctionalPhysicalObject>." ;
	skos:prefLabel "functional physical object" ;
	skos:scopeNote "A <FunctionalPhysicalObject> has functional, rather than material, continuity as its basis for identity. Adjacent temporal parts of a <FunctionalPhysicalObject> need not have common matter or energy, provided the matter or energy of each temporal part fulfils the same function" .

# ISO 15926-2: 5.2.8.8 class_of_inanimate_physical_object 
# This class has been derived from the power class defined in ISO 15926-2.
lci:InanimateIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	owl:disjointWith lci:AnimateIndividual ;
	skos:definition "TBD" ;
	skos:prefLabel "inanimate space-time individual" ;
	skos:scopeNote "TBD" .
lci:AnimateIndividual
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	skos:definition "TBD" ;
	skos:prefLabel "animate space-time individual" ;
	skos:scopeNote "TBD" .

# skip? ISO 15926-2: 5.2.6.8 materialised_physical_object
lci:MaterializedPhysicalObject
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf lci:PhysicalObject ;
	skos:definition "<PhysicalObject> that has matter continuity, energy continuity of both as its basis of identity" ;
	skos:example "The shell and tube heat exchanger with manufacture's serial number ES/1234 is a <MaterializedPhysicalObject>." ;
	skos:prefLabel "materialized physical object" ;
	skos:scopeNote "A <MaterializedPhysicalObject> has some continuity of matter or energy between adjacent temporal parts. However, the eeplacement of some components from time to time does not create a new identity." .

# ISO 15926-2: 5.2.8.13 class_of_organization
# This class has been derived from the power class defined in ISO 15926-2.
lci:Organization
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject , lci:ArrangedIndividual ;
	skos:definition "<PhysicalObject> that consists of people and other assets and that is organized with a particular purpose" ;
	skos:example "POSC Caesar Association, Fiatech, Bechtel and TopQuadrant are instances of <Organization>." ;
	skos:prefLabel "organization" ;
	skos:scopeNote "Company, government, and project team are subclasses of <Organization>." .

# ISO 15926-2: 5.2.6.13 stream
# TBD; see also sso:PartTransportFeature, and isn't it an activity
lci:Stream
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject ;
	skos:definition "<PhysicalObject> where continuity of flow path is the basis of identity" ;
	skos:prefLabel "stream" .

# added by SST
lci:Matter
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject ;
	owl:disjointUnionOf (
		lci:SubAtomicParticle 
		lci:ChemicalSubstance
		lci:ChemicalMixture
		lci:ParticulateMaterial
		lci:SolidBody
#		lci:AstronomicObject
		) ;
	skos:definition "TBD" ;
	skos:prefLabel "matter" .

# ISO 15926-2: 5.2.8.16 class_of_sub_atomic_particle
# This class has been derived from the power class defined in ISO 15926-2.
lci:SubAtomicParticle
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Matter ;
	skos:definition "<PhysicalObject> that is or can be a part of an atom" ;
	skos:prefLabel "subatomic particle" ;
	skos:scopeNote "Proton, electron, meson, neutron, positron, muon, quark, and neutrino are subclasses of <SubAtomicParticle>." .

# added by SST
lci:ChemicalSubstance
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Matter ;
	skos:definition "TBD" ;
	skos:prefLabel "chemical substance" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Chemical_substance" .

# ISO 15926-2: 5.2.8.2 class_of_atom
# derived from power class
lci:ChemicalElement
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalSubstance ;
	skos:definition "<ChemicalSubstance> that is an atom" ;
	skos:prefLabel "chemical element" ;
	skos:scopeNote "An atom is the basic unit of matter that consists of a dense central nucleus surrounded by a cloud of negatively charged electrons (wikipedia).All entries in the periodic table of elements are subclasses of <Atom>." .

# ISO 15926-2: 5.2.8.11 class_of_molecule
# This class has been derived from the power class defined in ISO 15926-2.
lci:ChemicalCompound
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalSubstance ;
	skos:definition "<ChemicalSubstance> that is a molecule" ;
	skos:prefLabel "chemical compund" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Chemical_compound" .

lci:MolecularCompound
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalCompound ;
	skos:definition "<ChemicalCompound> that held together by covalent bonds" ;
	skos:prefLabel "molecular compund" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Molecule" .

lci:IonicCompound
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalCompound ;
	skos:definition "<ChemicalCompound> that held together by ionic bonds" ;
	skos:prefLabel "ionic compund" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Salt_(chemistry)" .

lci:IntermetallicCompound
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalCompound ;
	skos:definition "<ChemicalCompound> that held together by metallic bonds" ;
	skos:prefLabel "intermetallic compund" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Intermetallic" .

lci:CoordinationComplex
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalCompound ;
	skos:definition "<ChemicalCompound> that held together by coordinate covalent bonds" ;
	skos:prefLabel "coordination complex" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Coordination_complex" .

# added by SST
lci:OrganicCompound
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalCompound ;
	skos:definition "<ChemicalCompound> that is condidered to be of an organic nature" ;
	skos:prefLabel "organic compound" ;
	skos:scopeNote "https://en.wikipedia.org/wiki/Organic_compound" .

# PaticularMatter, TBD
# https://en.wikipedia.org/wiki/Particulate_matter

# ISO 15926-2: 5.2.8.14 class_of_particulate_material
# This class has been derived from the power class defined in ISO 15926-2.
lci:ParticulateMaterial
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Matter ;
#	skos:definition "<Matter> that is an amount of super-molecular sized objects" ;
	skos:definition "Any solid material composed of distinct particles or pieces, regardless of size, shape, or chemical composition. Particulate materials include dusts, fibers, fines, chips, chunks, flakes, or mixtures of these." ;
	skos:example "The load of sand delivered on 2014-03-31 is a <ParticulateMaterial>." ;
	skos:prefLabel "particulate material" ;
#	skos:scopeNote "The super-molecular sized objects can be of the same or different types." ;
	skos:scopeNote "A sieve is a device for separating particulate materials into various desired particle size ranges through woven screens, such as meshes or nets, or by mechanical forces, such as shaking, tapping, or vacuum." ;
	skos:scopeNote "https://www.aiche.org/ccps/resources/glossary/process-safety-glossary/particulate-material" ;
 	skos:scopeNote "https://www.sciencedirect.com/topics/engineering/particulate-material" .

# added by SST
# https://www.quora.com/What-is-the-main-difference-between-a-rigid-body-and-a-solid-body
lci:SolidBody
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Matter ;
	skos:definition "<matter> with a defined boundary that may undergo elastic or plastic deformation." ;
	skos:prefLabel "solid body" ;
	skos:scopeNote "https://www.sciencedirect.com/topics/mathematics/solid-body" .

# added by SST
lci:RigidBody
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "idealized <SolidBody> that does not deform under the influence of forces" ;
	skos:prefLabel "rigid body" ;
	skos:scopeNote "https://www.sciencedirect.com/topics/mathematics/solid-body" .

lci:FlexibleBody
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "<SolidBody> whose purpose is to undergo elastic deformations." ;
	skos:prefLabel "flexible body" ;
	skos:example "coil spring, gasket and rubber band are examples of <FlexibleBody>" ;
	skos:scopeNote "" .

lci:FlexRigidBody
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "<SolidBody> that is composed of different regions with rigid and flexible characteristics" ;
	skos:prefLabel "flex-rigid body" ;
	skos:example "A hose consisting of a flexible hollow tube and rigid house couplings at the end is an examples of <FlexRigidBody>" ;
	skos:scopeNote "" .

lci:KinematicBody
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "<SolidBody> whose rigid regions move according to defined kinematic joints relative to each other." ;
	skos:prefLabel "kinematic body" ;
	skos:example "Scissor, gear, and excavator are typical examples of <KinematicBody>" ;
	skos:scopeNote "" .

lci:FlexRigidKinematicBody
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "<SolidBody> whose rigid regions move according to defined kinematic joints relative to each other combined with flexible regions." ;
	skos:prefLabel "flex-rigid kinematic body" ;
	skos:example "Human body consisting of bons, skin, muscels and more is an example of <FlexRigidKinematicBody>" ;
	skos:scopeNote "TBD" .

# ISO 15926-2: 5.2.8.12 class_of_organism 
# This class has been derived from the power class defined in ISO 15926-2.
lci:Organism
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject , lci:ArrangedIndividual ;
	skos:definition "<PhysicalObject> that is a single living organism" ;
	skos:prefLabel "organism" .

# ISO 15926-2: 5.2.8.15 class_of_person 
# This class has been derived from the power class defined in ISO 15926-2.
lci:Person
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Organism ;
	skos:definition "<Organism> that is a person" ;
	skos:example "Nils Sandsmark, Tim Berners-Lee and Ian Horrocks instances of <Person>." ;
	skos:prefLabel "person" ;
	skos:scopeNote "Engineer, plant manager, student, male, female, senior citizen, adult, girl, and boy are subclasses of <Person>." .


# ISO 15926-2: 5.2.8.3 class_of_biological_matter
# derived from power class
lci:BiologicalMatter
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "<lci:SolidBody> that consists of all or part of one or more biological cells alive or dead" ;
	skos:prefLabel "biological matter" ;
	skos:scopeNote "Blood, enzyme and plazma are subclasses of <BiologicalMatter>." .

# ISO 15926-2: 5.2.8.4 class_of_composite_material
lci:CompositeMaterial
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SolidBody ;
	skos:definition "<lci:SolidBody> that is an arrangement of separable compounds" ;
	skos:prefLabel "composite material" ;
	skos:scopeNote "Plywood and glass reinforced plastic are subclasses of <CompositeMaterial>." .

# ISO 15926-2: 5.2.8.5 class_of_compound
# This class has been derived from the power class defined in ISO 15926-2.
lci:ChemicalMixture
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:Matter ;
	skos:definition "<ChemicalMixture> that is an arrangement of molecules of the same or different types bound together by intermolecular forces" ;
	skos:prefLabel "compound" ;
	skos:scopeNote "Water, sulphuric acid, sand, limestone and steel are subclasses of <Compound>." .

# added by SST
lci:HeterogeneousChemicalMixture
	rdf:type owl:Class , ssmeta:MainClass ;
