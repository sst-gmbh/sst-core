lci:HomogeneousChemicalMixture
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ChemicalMixture ;
	skos:definition "TBD" ;
	skos:prefLabel "homogeneous chemical mixture" ;
	skos:scopeNote "TBD" .

