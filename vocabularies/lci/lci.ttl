## ISO 15926-2:  MISSING ???
#lci:QuantityRatio
#	rdf:type owl:Class ;
#	rdfs:subClassOf lci:Ratio , lci:ClassOfOrderedPairOfQuantity ;
#	skos:definition "<Ratio> that is a <ClassOfOrderedPairOfQuantity>" ;
#	skos:prefLabel "quantity ratio" .

## ISO 15926-2: no, This is a proposed extension to support monetary amount and other non-physical quantities.
lci:QuantitySpace
	rdf:type owl:Class ;
	rdfs:subClassOf lci:ClassOfQuantity ;
	skos:definition "<ClassOfQuantity> that is a subspace of, or all of, a <QuantityKind>" ;
	skos:example "Monetary amount is a <QuantitySpace>. Mass is a <QuantitySpace>." ;
	skos:prefLabel "quantity space" .

# ISO 15926-2: no, This is a proposed exension to support a physical quantity range as a class of individual.
lci:RangePhysicalQuantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:RangeQuantity ;
	skos:definition "<RangeQuantity> that is all members of all instances of <PhysicalQuantity> within a <PhysicalQuantityRange>" ;
	skos:example "The instances of <Individual> with a mass greater than 10 kilograms and less than 15 kilograms is a <RangePhysicalQuantity>." ;
	skos:prefLabel "range physical quantity" .

# ISO 15926-2:  ??? not indicated in table
lci:RangeQuantity
	rdf:type owl:Class ;
	rdfs:subClassOf lci:ClassOfIndividual ;
	skos:definition "<ClassOfIndividual> that is all members of all instances of <Quantity> within a <QuantityRange>" ;
	skos:example "The instances of <Individual> with a mass greater than 10 kilograms and less than 15 kilograms is a <RangeQuantity>. The instances of <Individual> costing a monetary amount greater than 10 euro and less than 15 euro is a <RangeQuantity>." ;
	skos:prefLabel "range quantity" .

# ISO 15926-2:  MISSING ???
lci:RangeTimeDuration
	rdf:type owl:Class ;
	rdfs:subClassOf lci:RangePhysicalQuantity ;
	skos:definition "<RangePhysicalQuantity> that is all members of all instances of <TimeDuration> within a range" ;
	skos:example "The instances of <PeriodInTime> with a duration greater than 1 hour is a <RangeTimeDuration>." ;
	skos:prefLabel "range time duration" .

# ISO 15926-2: 5.2.28.4 scale
lci:Scale
	rdf:type owl:Class ;
	rdfs:subClassOf lci:Isomorphism ;
	skos:definition "<Isomorphism> between a <PhysicalQuantitySpace> and a <NumberSpace>" ;
	skos:example "Celsius is a <Scale> that is an isomorphism between the <PhysicalQuantitySpace> thermodynamic temperature and the <NumberRange> that is reals greater than -273.15." ;
	skos:prefLabel "scale" ;
	skos:scopeNote "A member of <Scale> is implemented in this part of ISO 15926 as an owl:DatatypeProperty with domain <PhysicalQuantity>." .

lci:LinearScale
	rdf:type owl:Class ;
	rdfs:subClassOf lci:Scale .

lci:LogarithmicScale
	rdf:type owl:Class ;
	rdfs:subClassOf lci:Scale .

## ISO 15926-2: no, Added to distinguish between a <span class="id">CartesianProductOfQuantityKind</span> and a subspace of it.
