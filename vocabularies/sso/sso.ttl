# END_ENTITY;
sso:MatingDefinition
	ssmeta:stepDmMap "MatingDefinition" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:AssemblyDesign .
sso:Part_MatingDefinition
 	rdf:type owl:Class , ssmeta:MainClass ;
    rdfs:subClassOf sso:Part , sso:MatingDefinition .

# ENTITY CollectionDefinition
# 	SUBTYPE OF(PartView);
# 	Purpose : OPTIONAL MultiLingualStringSelect;
# INVERSE
# 	CollectedParts : SET[2:?] OF CollectedPartRelationship FOR Relating;
# END_ENTITY;
sso:CollectionDefinition
	ssmeta:stepDmMap "CollectionDefinition" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:PartDefinition .

sso:Part_CollectionDefinition
 	rdf:type owl:Class , ssmeta:MainClass ;
    rdfs:subClassOf sso:Part , sso:CollectionDefinition .

# ENTITY ViewOccurrenceRelationship
# 	SUPERTYPE OF (ONEOF(AssemblyOccurrenceRelationship, CollectedPartRelationship));
# 	Id : OPTIONAL IdentifierSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	RelationType : ClassSelect;
# 	Relating : PartView;
# 	Related : DefinitionBasedOccurrence;
# END_ENTITY;
#
# Decided to remove these, because they are only structural without any semantic
# Corresponding ARM entity Product_occurrence_definition_relationship is abstract
# 
# sso:occurrenceViewRelationship
# 	rdf:type owl:ObjectProperty ;
# 	rdfs:subPropertyOf lci:arrangedPartOf ;
# 	rdfs:domain sso:ProductOccurrence ;
# 	rdfs:range sso:PartDefinition .
# sso:viewOccurrenceRelationship 
# 	owl:inverseOf sso:occurrenceViewRelationship .

# ENTITY CollectedPartRelationship
# 	SUBTYPE OF(ViewOccurrenceRelationship);
# 	SELF\ViewOccurrenceRelationship.Relating : CollectionDefinition;
# DERIVE
# 	SELF\ViewOccurrenceRelationship.RelationType : STRING := 'collected part view';
# END_ENTITY;
sso:partCollectionRelationship
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:arrangedPartOf ;
	rdfs:range sso:CollectionDefinition .
sso:collectedPartRelationship  
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:partCollectionRelationship .

# ENTITY AssemblyOccurrenceRelationship
# 	ABSTRACT
# 	SUPERTYPE OF (ONEOF(NextAssemblyOccurrenceUsage, PromissoryAssemblyOccurrenceUsage))
# 	SUBTYPE OF(ViewOccurrenceRelationship);
# 	SELF\ViewOccurrenceRelationship.Relating : AssemblyDefinition;
# 	Placement : OPTIONAL SET[1:?] OF TransformationAndAssociationSelect; => rep::contextDependentShapeRepresentation
# WHERE
# WR1: NOT('GEOMETRICREPRESENTATIONRELATIONSHIPWITHPLACEMENTTRANSFORMATION' IN TYPEOF(Placement)) OR (SIZEOF(QUERY(ix <* Placement | ix\RepresentationRelationship.Definitional = TRUE)) = 0);
# END_ENTITY;
# 
# Decided to remove as this is already covered by: lci:hasAssembledPart <-> lci:assembledPartOf
# Corresponding ARM entity ENTITY Assembly_component_relationship is abstract
#
# sso:occurrenceAssemblyRelationship
# 	rdf:type owl:ObjectProperty ;
# 	rdfs:subPropertyOf sso:occurrenceViewRelationship ;
# 	rdfs:range sso:AssemblyDesign .
# sso:assemblyOccurrenceRelationship 
# 	owl:inverseOf sso:occurrenceAssemblyRelationship .

# ENTITY NextAssemblyOccurrenceUsage
# 	SUPERTYPE OF (MatedPartAssociation)
# 	SUBTYPE OF(AssemblyOccurrenceRelationship);
# DERIVE
# 	SELF\ViewOccurrenceRelationship.RelationType : STRING := 'next assembly occurrence';
# END_ENTITY;
sso:occurrenceNextAssemblyUsage
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:hasAssembledPart ;
	rdfs:domain sso:ProductOccurrence ;  # but not a sso:SpecifiedOccurrence
	rdfs:range sso:AssemblyDesign .
sso:nextAssemblyOccurrenceUsage 
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:occurrenceNextAssemblyUsage .
#	rdfs:subPropertyOf lci:assembledPartOf
#	rdfs:domain sso:AssemblyDesign .

# ENTITY MatedPartAssociation
#	SUBTYPE OF(NextAssemblyOccurrenceUsage);
#	SELF\AssemblyOccurrenceRelationship.Relating : MatingDefinition;
# END_ENTITY;
sso:occurrenceMatedUsage
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf sso:occurrenceNextAssemblyUsage ;
	rdfs:range sso:AssemblyDesign .
sso:matedPartAssociation 
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:occurrenceMatedUsage .

# TYPE MatingTypeEnum = ENUMERATION OF(
# 	bolted_joint, => sso:MatingType_Bolting
# 	brazing, => sso:MatingType_Brazing
# 	clasping, => sso:MatingType_Clasping
# 	clinching, => sso:MatingType_Clinching
# 	clipping, => sso:MatingType_Clipping
# 	doweling, => sso:MatingType_Doweling
# 	flanging, => sso:MatingType_Flanging
# 	foam_injection, => sso:MatingType_FoamInjection
# 	friction_welding, => sso:MatingType_FrictionWelding
# 	gluing, => sso:MatingType_Gluing
# 	laser_welding, => sso:MatingType_LaserWelding
# 	press_fit, => sso:MatingType_PressFit
# 	riveting, => sso:MatingType_Riveting
# 	sewing, => sso:MatingType_Sewing
# 	soldering, => sso:MatingType_Soldering
# 	spot_welding, => sso:MatingType_SpotWelding
# 	stapling, => sso:MatingType_Stapling
# 	welding => sso:MatingType_Welding
# );
# END_TYPE;
sso:MatingType
	ssmeta:stepDmMap "MatedPartRelationship.MatingType" ;
	rdf:type lci:ClassOfIndividual ;
	rdfs:subClassOf ssmeta:OptionClass .
sso:MatingType_Bolting
	skos:prefLabel "bolted joint" ;
	skos:definition "an attachment of two or more items that are screwed together using screws, bolt nuts, and washers" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Brazing
	skos:prefLabel "brazing" ;
	skos:definition "an attachment of two or more items established by soldering or brazing" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Clasping
	skos:prefLabel "clasping" ;
	skos:definition "an attachment of two or more items established by using a clamp at one common outer border" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Clinching
	skos:prefLabel "clinching" ;
	skos:definition "an attachment of two or more items established by pressing these items together and stamping texture at the point of contact" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Clipping
	skos:prefLabel "clipping" ;
	skos:definition "an attachment of two or more items established by a clip (such as fixing the inner door panel at the inner door plate)" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Doweling
	skos:prefLabel "doweling" ;
	skos:definition "an attachment of two or more items using a pin that is fit into each of each part by pressing" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Flanging
	skos:prefLabel "flanging" ;
	skos:definition "an attachment of two or more items by crimping a projected length of one part over the edge of the other part" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_FoamInjection
	skos:prefLabel "foam_injection" ;
	skos:definition "an attachment of two or more items where foam is injected into a cavity to establish the connection" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_FrictionWelding
	skos:prefLabel "friction welding" ;
	skos:definition "an attachment of two or more items by welding together using friction" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Gluing
	skos:prefLabel "gluing" ;
	skos:definition "an attachment of two items established by adhesion material" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_LaserWelding
	skos:prefLabel "laser welding" ;
	skos:definition "an attachment of two or more items that are welded together using a laser technique" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_PressFit
	skos:prefLabel "press fit" ;
	skos:definition "an attachment of two or more items obtained by forces resulting from the selected size tolerances" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Riveting
	skos:prefLabel "riveting" ;
	skos:definition "an attachment of two or more items that are riveted together at a certain spot using a rivet" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Sewing
	skos:prefLabel "sewing" ;
	skos:definition "an attachment of two or more items that are sewn together" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Soldering
	skos:prefLabel "soldering" ;
	skos:definition "an attachment of two or more items by soldering together with one solder bead" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_SpotWelding
	skos:prefLabel "spot welding" ;
	skos:definition "an attachment of two or more items that are welded together at a certain welding spot" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Stapling
	skos:prefLabel "stapling" ;
	skos:definition "an attachment of two or more items at a certain spot using a nail or a wire stitch to establish the connection" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .
sso:MatingType_Welding
	skos:prefLabel "welding" ;
	skos:definition "an attachment of two or more items by welding together with one weld bead" ;
	rdfs:subClassOf  sso:MatingConnection ;
	rdf:type owl:Class , sso:MatingType .

# ENTITY PromissoryAssemblyOccurrenceUsage
