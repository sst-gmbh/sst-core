# ENTITY RepresentationRelationship
# 	ABSTRACT
# 	SUPERTYPE OF (ONEOF(GeometricRepresentationRelationship, GeometryToTopologyModelAssociation, PlyOrientationAngle, TopologyToGeometryModelAssociation));
# 	Id : OPTIONAL IdentifierSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	Relating : Representation;
# 	Related : Representation;
# 	Definitional : BOOLEAN;
# END_ENTITY;
# => rep::representationRelationship
# 
# ENTITY GeometryToTopologyModelAssociation
# 	SUBTYPE OF(RepresentationRelationship);
# 	Origin : SET[1:?] OF GeometryAssociationItemSelect;
# 	Target : SET[1:?] OF TopologyAssociationItemSelect;
# INVERSE
# 	AssemblyContext : SET[0:?] OF AssemblyOccurrenceRelationship FOR Placement;
# WHERE
# WR1: SIZEOF(Origin) = SIZEOF(Target);
# WR2: SIZEOF(QUERY( ac <* AssemblyContext | NOT ('WiringHarnessAssemblyDesign' IN TYPEOF(ac\AssemblyOccurrenceRelationship.Relating)))) = 0;
# WR3: SELF\RepresentationRelationship.Definitional = FALSE;
