# ENTITY master_port
#      ABSTRACT SUPERTYPE OF (ONEOF(input_master_port, 
#                                   output_master_port,
#                                   bidirectional_master_port, 
#                                   unspecified_direction_master_port)); 
# :MasterPort is not abstract, same as unspecified_direction_master_port
:MasterPort
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual .

# ENTITY input_master_port
#      SUBTYPE OF (master_port);                                     
#    dc_fanout_load : OPTIONAL load_value;
#    dc_max_fanin   : OPTIONAL load_value;
:InputMasterPort
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :MasterPort .

# ENTITY output_master_port
#      SUBTYPE OF (master_port);                                     
#    dc_fanin_load : OPTIONAL load_value;
#    dc_max_fanout : OPTIONAL load_value;
:OutputMasterPort
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :MasterPort .

