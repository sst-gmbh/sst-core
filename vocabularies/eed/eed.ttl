@prefix sso:   <http://ontology.semanticstep.net/sso#> .
@prefix lci:   <http://ontology.semanticstep.net/lci#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ssmeta:   <http://ontology.semanticstep.net/ssmeta#> .
@prefix rep:   <http://ontology.semanticstep.net/rep#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
# @prefix ssqau:      <http://ontology.semanticstep.net/ssqau#> .


<http://ontology.semanticstep.net/eed>
        rdf:type     owl:Ontology ;
        owl:imports   <http://ontology.semanticstep.net/lci> ;
        owl:versionInfo "0.01" .


:FunctionalDefinition
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual .

:FunctionalDefinitionElement
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:Aspect .

:FunctionalDefinitionTerminal
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FunctionalDefinitionElement .

:FunctionalNetworkDefinition
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FunctionalDefinitionElement .

:FunctionalOccurrence
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual .

:FunctionalOccurrenceTerminal
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:Aspect .

# FunctionalNode to be used for internal node
# supports Kirchhoff's current law
:FunctionalNode
	rdf:type owl:Class , ssmeta:AbstractClass ;
	rdfs:subClassOf :FunctionalDefinitionElement .

# A FunctionalInternallNode is not visible to the outside
:FunctionalInternallNode
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FunctionalNode .

# A FunctionalTerminalNode is a FunctionalNode that is visible to the outside by it's FunctionalDefinitionTerminal
:FunctionalTerminalNode
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FunctionalNode , :FunctionalDefinitionTerminal .

:connectedTerminal
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:directlyConnectedTo ;
	rdfs:domain sso:PartConnectivityDefinition ;
	rdfs:range :FunctionalOccurrenceTerminal . 

############################################################
# from EDIF library_model
############################################################
# The library_model schema describes what information can be found in an EDIF library. 
# An EDIF library is a grouping of reusable objects. 
# A library contains cell definitions, geometry_macro_templates and various types of instantiatable templates for schematic views. 
# It also includes definitions of figure_groups which are common to all reusable objects in a library. 

# ENTITY library
# :=: not explicitly / fully covered with way in SST, an EDIF library is primarily a ClassOfIndividuals


############################################################
# from EDIF hierarchy_model
############################################################
# The hierarchy_model schema describes the hierarchical information of a cell 
# which is the basic unit of design. 
# A cell can have multiple views of the same type. 
# Views and symbols which share the same interface are grouped into a cluster. 
# Views and symbols may also be grouped into a view_group to indicate 
# a particularly close relationship to each other. 

# ENTITY cell
#      ABSTRACT SUPERTYPE OF (ONEOF(internal_cell,  external_cell));
#    clusters            : OPTIONAL SET [1:?] OF cluster; => only one, included
#    document            : OPTIONAL SET [1:?] OF documentation; => skip
#    name                : OPTIONAL name_information;  => rdfs:label
#    properties          : OPTIONAL SET [1:?] OF property; => default SST properties
#    status_of_copyright : OPTIONAL SET [1:?] OF copyright; => skip
#    status_of_written   : OPTIONAL SET [1:?] OF written;  => skip
#    view_groups         : OPTIONAL SET [1:?] OF view_group; => TBD       
# => :FunctionalOccurrence

# ENTITY internal_cell
# => to skip
# ENTITY external_cell
# => to skip

# ENTITY Cluster
#      ABSTRACT SUPERTYPE OF (ONEOF(internal_cluster,
#                                   external_cluster));
#    cell_representations   : OPTIONAL SET [1:?] OF cell_representation;
#    cluster_configurations : OPTIONAL SET [1:?] OF cluster_configuration; => TBD
#    document               : OPTIONAL SET [1:?] OF documentation; => skip
#    name                   : OPTIONAL name_information;  => skip
#    interface              : cluster_interface; => exactly one, included 
#    properties             : OPTIONAL SET [1:?] OF property; => default SST properties
#    status_of_copyright    : OPTIONAL SET [1:?] OF copyright; => skip
#    status_of_written      : OPTIONAL SET [1:?] OF written; => skip
# => covered in :FunctionalUnit

# ENTITY internal_cluster
# => to skip
# ENTITY external_cluster
# => to skip

