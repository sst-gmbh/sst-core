@prefix :      <http://ontology.semanticstep.net/aic_geometrically_bounded_surface#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

:GeometricallyBoundedSurfaceShapeRepresentation
        a                owl:Class ;
        rdfs:subClassOf  :ShapeRepresentation .

base:aic_geometrically_bounded_surface
        a            owl:Ontology ;
        owl:imports  base:support_resource_schema , base:representation_schema , base:product_property_representation_schema , base:measure_schema , base:geometry_schema , base:geometric_model_schema .
