:FixedReferenceSweptSurface
        a                owl:Class ;
        rdfs:subClassOf  :SweptSurface .

:TransitionCodeContSameGradient
        a       :TransitionCode .

:generalisedMajorRadius
        a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :DupinCyclideSurface ;
