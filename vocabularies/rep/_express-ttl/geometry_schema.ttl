@prefix base:  <http://ontology.semanticstep.net/> .

:directrix  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :SurfaceCurveSweptSurface :FixedReferenceSweptSurface )
                     ] ;
        rdfs:range   :Curve .

:ratio  a            owl:DatatypeProperty ;
        rdfs:domain  :EccentricConicalVolume ;
        rdfs:range   xsd:double .

:equivalentPoint  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :EvaluatedDegeneratePcurve ;
        rdfs:range   :CartesianPoint .

:DimensionCount  a       owl:Class ;
