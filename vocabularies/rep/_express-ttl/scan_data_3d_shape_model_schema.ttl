@prefix :      <http://ontology.semanticstep.net/scan_data_3d_shape_model_schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

:ptsPerSublist  a    owl:DatatypeProperty ;
        rdfs:domain  :PointCloudSuperdataset ;
        rdfs:range   xsd:int .

:scannerUncertainty  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ScannerBasicProperties ;
        rdfs:range   :PositiveLengthMeasure .

:colourIndices  a    owl:DatatypeProperty ;
        rdfs:domain  :PointCloudDatasetWithColours ;
        rdfs:range   xsd:int .

:PointCloudDatasetWithColours
        a                owl:Class ;
        rdfs:subClassOf  :PointCloudDataset .

:ScanDataShapeRepresentation
        a                owl:Class ;
        rdfs:subClassOf  :ShapeRepresentation .

:intensities  a      owl:DatatypeProperty ;
        rdfs:domain  :PointCloudDatasetWithIntensities ;
        rdfs:range   xsd:double .

:pointCoordinates  a  owl:DatatypeProperty ;
        rdfs:domain  :PointCloudDataset ;
        rdfs:range   xsd:double .

:ScannerBasicProperties
        a                owl:Class ;
        rdfs:subClassOf  :ScannerProperty .

:PointCloudDatasetWithNormals
        a                owl:Class ;
        rdfs:subClassOf  :PointCloudDataset .

:PointCloudSetOrSuperset
        a       owl:Class .

:sublists  a         owl:ObjectProperty ;
        rdfs:domain  :PointCloudSuperdataset ;
        rdfs:range   :PointCloudDataset .

base:scan_data_3d_shape_model_schema
        a            owl:Ontology ;
        owl:imports  base:support_resource_schema , base:representation_schema , base:product_property_representation_schema , base:measure_schema , base:geometry_schema .

:ScannerProperty  a      owl:Class ;
        rdfs:subClassOf  :RepresentationItem .

:PointCloudDatasetWithIntensities
        a                owl:Class ;
        rdfs:subClassOf  :PointCloudDataset .

:PointCloudSuperdataset
        a                owl:Class ;
        rdfs:subClassOf  :PointCloudSetOrSuperset , :ScannedDataItem .

:scannerIdentification
        a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ScannerBasicProperties ;
        rdfs:range   :Label .

:normals  a          owl:DatatypeProperty ;
        rdfs:domain  :PointCloudDatasetWithNormals ;
        rdfs:range   xsd:double .

:scannerInfo  a      owl:ObjectProperty ;
        rdfs:domain  :Scan3dModel ;
        rdfs:range   :ScannerProperty .

:TriangulatedPointCloudDataset
        a                owl:Class ;
        rdfs:subClassOf  :ScannedDataItem .

:triangles  a        owl:DatatypeProperty ;
        rdfs:domain  :TriangulatedPointCloudDataset ;
        rdfs:range   xsd:int .

:Scan3dModel  a          owl:Class ;
        rdfs:subClassOf  :ScannedDataItem .

:ScannedDataItem  a      owl:Class ;
        rdfs:subClassOf  :GeometricRepresentationItem .

:scannedPoints  a    owl:ObjectProperty ;
        rdfs:domain  :Scan3dModel ;
        rdfs:range   :ScannedDataItem .

:PointCloudDataset  a    owl:Class ;
        rdfs:subClassOf  :PointCloudSetOrSuperset , :ScannedDataItem .

:points  a           owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TriangulatedPointCloudDataset ;
        rdfs:range   :PointCloudSetOrSuperset .

:scannerLocation  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ScannerBasicProperties ;
        rdfs:range   :Axis2Placement3d .
