@prefix :      <http://ontology.semanticstep.net/geometric_model_schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

:ExtrudedAreaSolid  a    owl:Class ;
        rdfs:subClassOf  :SweptAreaSolid .

:ctriangles  a       owl:DatatypeProperty ;
        rdfs:domain  :CubicBezierTriangulatedFace ;
        rdfs:range   xsd:int .

:crossSections  a    owl:ObjectProperty ;
        rdfs:domain  :SectionedSpine ;
        rdfs:range   :Curve .

:baseSurface  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :HalfSpaceSolid ;
        rdfs:range   :Surface .

:TessellatedCurveSet  a  owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:items  a            owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedSolid :TessellatedShell :TessellatedWire )
                     ] ;
        rdfs:range   :TessellatedEdgeOrVertex , :TessellatedStructuredItem .

:EdgeCurve  rdfs:subClassOf  :EdgeOrCurve .

:secondOperand  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :BooleanResult ;
        rdfs:range   :BooleanOperand .

:FaceSurface  rdfs:subClassOf  :FaceOrSurface .

:height  a           owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :RectangularPyramid :RightCircularCone :RightCircularCylinder :EccentricCone )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:SweptDiskSolid  a       owl:Class ;
        rdfs:subClassOf  :SolidModel .

:parentSolid  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :SolidReplica ;
        rdfs:range   :SolidModel .

:HalfSpaceSolid  a       owl:Class ;
        rdfs:subClassOf  :BooleanOperand , :GeometricRepresentationItem .

:enclosure  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :BoxedHalfSpace :RectangledHalfSpace )
                     ] ;
        rdfs:range   :RectangleDomain , :BoxDomain .

:EdgeOrCurve  a  owl:Class .

:CircularArea  a         owl:Class ;
        rdfs:subClassOf  :BoundedPrimitive2d , :Primitive2d .

:w2     a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :ParameterValue .

:corner  a           owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :BoxDomain :RectangleDomain )
                     ] ;
        rdfs:range   :CartesianPoint .

:RightCircularCone  a    owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:ShellBasedWireframeModel
        a                owl:Class ;
        rdfs:subClassOf  :WireframeModel , :GeometricRepresentationItem .

:elements  a         owl:ObjectProperty ;
        rdfs:domain  :GeometricSet ;
        rdfs:range   :GeometricSetSelect .

:RectangledHalfSpace  a  owl:Class ;
        rdfs:subClassOf  :HalfSpace2d .

:AngularDeviation  a     owl:Class ;
        rdfs:subClassOf  :TessellationAccuracyParameterItem , :PositivePlaneAngleMeasure .

:TessellatedShapeRepresentation
        a                owl:Class ;
        rdfs:subClassOf  :ShapeRepresentation .

:Tetrahedron  a          owl:Class ;
        rdfs:subClassOf  :FacetedPrimitive .

:BooleanOperator  a  owl:Class ;
        owl:oneOf  ( :BooleanOperatorUnion :BooleanOperatorIntersection :BooleanOperatorDifference ) .

:TessellatedWire  a      owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:AreaWithOuterBoundary
        a                owl:Class ;
        rdfs:subClassOf  :BoundedPrimitive2d , :HalfSpace2d .

:TessellatedConnectingEdge
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedEdge .

:Brep2d  a               owl:Class ;
        rdfs:subClassOf  :SolidModel .

:coneAngle1  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :CyclideSegmentSolid ;
        rdfs:range   :PlaneAngleMeasure .

:EccentricCone  a        owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:RectangleDomain  a      owl:Class ;
        rdfs:subClassOf  :FoundedItem .

:turnAngle  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :CyclideSegmentSolid ;
        rdfs:range   :PlaneAngleMeasure .

:face1  a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedConnectingEdge :CubicTessellatedConnectingEdge )
                     ] ;
        rdfs:range   :CubicBezierTriangulatedFace , :TessellatedFace .

:voids  a            owl:ObjectProperty ;
        rdfs:domain  :BrepWithVoids ;
        rdfs:range   :OrientedClosedShell .

:FaceOrSurface  a  owl:Class .

:pointList  a        owl:DatatypeProperty ;
        rdfs:domain  :TessellatedPointSet ;
        rdfs:range   xsd:int .

:lineStripFace2  a   owl:DatatypeProperty ;
        rdfs:domain  :TessellatedConnectingEdge ;
        rdfs:range   xsd:int .

:points  a           owl:ObjectProperty ;
        rdfs:domain  :FacetedPrimitive ;
        rdfs:range   :CartesianPoint .

:BooleanOperatorIntersection
        a       :BooleanOperator .

:sweptArea  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :SweptAreaSolid ;
        rdfs:range   :CurveBoundedSurface .

:zlength  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :BoxDomain ;
        rdfs:range   :PositiveLengthMeasure .

:RightAngularWedge  a    owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:TessellatedStructuredItem
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:extent  a           owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Brep2d ;
        rdfs:range   :Face .

:Torus  a                owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:v1     a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :ParameterValue .

:TessellatedFacetLongShortEdgeRatio
        a                owl:Class ;
        rdfs:subClassOf  :TessellationAccuracyParameterItem , :RatioMeasure .

:TessellatedEdgeOrVertex
        a       owl:Class .

:Ellipsoid  a            owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:geometricModelLink  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TessellatedWire ;
        rdfs:range   :PathOrCompositeCurve .

:geometricLink  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedEdge :TessellatedFace :TessellatedSolid )
                     ] ;
        rdfs:range   :ManifoldSolidBrep , :FaceOrSurface , :EdgeOrCurve .

:fbsmFaces  a        owl:ObjectProperty ;
        rdfs:domain  :FaceBasedSurfaceModel ;
        rdfs:range   :ConnectedFaceSet .

:transformation  a   owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :SolidReplica :GeometricSetReplica )
                     ] ;
        rdfs:range   :CartesianTransformationOperator , :CartesianTransformationOperator3d .

:ChordalDeviation  a     owl:Class ;
        rdfs:subClassOf  :TessellationAccuracyParameterItem , :PositiveLengthMeasure .

:radius  a           owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :Sphere :RightCircularCone :RightCircularCylinder :CircularArea :SweptDiskSolid )
                     ] ;
        rdfs:range   :LengthMeasure , :PositiveLengthMeasure .

:TessellatedShell  a     owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:RectangularPyramid  a   owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:TessellatedPointSet  a  owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:BoundedPrimitive2d  a   owl:Class ;
        rdfs:subClassOf  :CsgPrimitive .

:SurfaceModel  a  owl:Class .

:BooleanOperatorUnion
        a       :BooleanOperator .

:yOffset  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :EccentricCone ;
        rdfs:range   :LengthMeasure .

:RightCircularCylinder
        a                owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:CsgSolid  a             owl:Class ;
        rdfs:subClassOf  :SolidModel .

:PolygonalArea  a        owl:Class ;
        rdfs:subClassOf  :BoundedPrimitive2d , :Primitive2d .

:directrix  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :SurfaceCurveSweptFaceSolid :SurfaceCurveSweptAreaSolid :SweptDiskSolid )
                     ] ;
        rdfs:range   :Curve .

:coneAngle2  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :CyclideSegmentSolid ;
        rdfs:range   :PlaneAngleMeasure .

:normals  a          owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedFace :TessellatedSurfaceSet )
                     ] ;
        rdfs:range   xsd:double .

:face2  a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedConnectingEdge :CubicTessellatedConnectingEdge )
                     ] ;
        rdfs:range   :CubicBezierTriangulatedFace , :TessellatedFace .

:parentSet  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :GeometricSetReplica ;
        rdfs:range   :GeometricSet .

:PathOrCompositeCurve
        a       owl:Class .

:pnindex  a          owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TriangulatedFace :ComplexTriangulatedFace :TriangulatedSurfaceSet :ComplexTriangulatedSurfaceSet )
                     ] ;
        rdfs:range   xsd:int .

:RepositionedTessellatedItem
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:ManifoldSolidBrep  a    owl:Class ;
        rdfs:subClassOf  :SolidModel .

:FacetedBrep  a          owl:Class ;
        rdfs:subClassOf  :ManifoldSolidBrep .

:firstOperand  a     owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :BooleanResult ;
        rdfs:range   :BooleanOperand .

:BrepWithVoids  a        owl:Class ;
        rdfs:subClassOf  :ManifoldSolidBrep .

:BoxedHalfSpace  a       owl:Class ;
        rdfs:subClassOf  :HalfSpaceSolid .

:position  a         owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :Block :RightAngularWedge :RectangularPyramid :RightCircularCone :RightCircularCylinder :EccentricCone :Torus :Ellipsoid :CyclideSegmentSolid :EllipticArea :RectangularArea )
                     ] ;
        rdfs:range   :Axis2Placement2d , :Axis1Placement , :Axis2Placement3d .

:TessellatedVertex  a    owl:Class ;
        rdfs:subClassOf  :TessellatedEdgeOrVertex , :TessellatedStructuredItem .

:extrudedDirection  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :ExtrudedFaceSolid :ExtrudedAreaSolid )
                     ] ;
        rdfs:range   :Direction .

:sbsmBoundary  a     owl:ObjectProperty ;
        rdfs:domain  :ShellBasedSurfaceModel ;
        rdfs:range   :Shell .

:v2     a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :ParameterValue .

:Point  rdfs:subClassOf  :GeometricSetSelect .

:majorRadius  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Torus ;
        rdfs:range   :PositiveLengthMeasure .

:TessellatedFace  a      owl:Class ;
        rdfs:subClassOf  :TessellatedStructuredItem .

:triangles  a        owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TriangulatedFace :TriangulatedSurfaceSet )
                     ] ;
        rdfs:range   xsd:int .

:depth  a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :ExtrudedFaceSolid :ExtrudedAreaSolid )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:ratio  a            owl:DatatypeProperty ;
        rdfs:domain  :EccentricCone ;
        rdfs:range   xsd:double .

:WireframeModel  a  owl:Class .

:semiAxis1  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :EccentricCone :Ellipsoid :EllipticArea )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:location  a         owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepositionedTessellatedItem ;
        rdfs:range   :Axis2Placement3d .

:BooleanOperatorDifference
        a       :BooleanOperator .

:GeometricSetReplica  a  owl:Class ;
        rdfs:subClassOf  :GeometricSet .

:ylength  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :RectangularPyramid :BoxDomain :RectangleDomain )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:radius1  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :CyclideSegmentSolid ;
        rdfs:range   :PositiveLengthMeasure .

:CubicBezierTriangulatedFace
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedFace .

:Block  a                owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:Path   rdfs:subClassOf  :PathOrCompositeCurve .

:SweptAreaSolid  a       owl:Class ;
        rdfs:subClassOf  :SolidModel .

:CubicTessellatedConnectingEdge
        a                owl:Class ;
        rdfs:subClassOf  :CubicBezierTessellatedEdge .

:HalfSpace2d  a          owl:Class ;
        rdfs:subClassOf  :BooleanOperand , :Primitive2d .

:BoxDomain  a            owl:Class ;
        rdfs:subClassOf  :FoundedItem .

:operator  a         owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :BooleanResult ;
        rdfs:range   :BooleanOperator .

:ShellBasedSurfaceModel
        a                owl:Class ;
        rdfs:subClassOf  :SurfaceModel , :GeometricRepresentationItem .

:pointIndex  a       owl:DatatypeProperty ;
        rdfs:domain  :TessellatedVertex ;
        rdfs:range   xsd:int .

:coordinates  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedVertex :TessellatedEdge :TessellatedFace :TessellatedSurfaceSet :TessellatedCurveSet :TessellatedPointSet )
                     ] ;
        rdfs:range   :CoordinatesList .

:minorRadius  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Torus ;
        rdfs:range   :PositiveLengthMeasure .

:agreementFlag  a    owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :HalfSpaceSolid :HalfSpace2d )
                     ] ;
        rdfs:range   xsd:boolean .

:RevolvedAreaSolid  a    owl:Class ;
        rdfs:subClassOf  :SweptAreaSolid .

:Sphere  a               owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:xOffset  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :EccentricCone ;
        rdfs:range   :LengthMeasure .

:RectangularArea  a      owl:Class ;
        rdfs:subClassOf  :BoundedPrimitive2d , :Primitive2d .

:CubicBezierTessellatedEdge
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedEdge .

:u1     a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :ParameterValue .

:axis   a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :RevolvedFaceSolid :RevolvedAreaSolid )
                     ] ;
        rdfs:range   :Axis1Placement .

:LengthToHeightRatio  a  owl:Class ;
        rdfs:subClassOf  :TessellationAccuracyParameterItem , :RatioMeasure .

:x      a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :Block :RightAngularWedge :RectangularArea )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:TessellatedItem  a      owl:Class ;
        rdfs:subClassOf  :GeometricRepresentationItem .

:npoints  a          owl:DatatypeProperty ;
        rdfs:domain  :CoordinatesList ;
        rdfs:range   xsd:int .

:CoordinatesList  a      owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:spinePoints  a      owl:ObjectProperty ;
        rdfs:domain  :SectionedSpine ;
        rdfs:range   :Point .

:triangleStrips  a   owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :ComplexTriangulatedFace :ComplexTriangulatedSurfaceSet )
                     ] ;
        rdfs:range   xsd:int .

:TessellatedShapeRepresentationWithAccuracyParameters
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedShapeRepresentation .

:EllipticArea  a         owl:Class ;
        rdfs:subClassOf  :BoundedPrimitive2d , :Primitive2d .

:baseCurve  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :HalfSpace2d ;
        rdfs:range   :Curve .

:SweptFaceSolid  a       owl:Class ;
        rdfs:subClassOf  :SolidModel .

:GeometricCurveSet  a    owl:Class ;
        rdfs:subClassOf  :GeometricSet .

:outer  a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ManifoldSolidBrep ;
        rdfs:range   :ClosedShell .

:Primitive2d  a          owl:Class ;
        rdfs:subClassOf  :GeometricRepresentationItem .

:semiAxis2  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :EccentricCone :Ellipsoid :EllipticArea )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:smooth  a           owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedConnectingEdge :CubicTessellatedConnectingEdge )
                     ] ;
        rdfs:range   xsd:NMTOKEN .

:CyclideSegmentSolid  a  owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:ebwmBoundary  a     owl:ObjectProperty ;
        rdfs:domain  :EdgeBasedWireframeModel ;
        rdfs:range   :ConnectedEdgeSet .

:radius2  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :CyclideSegmentSolid ;
        rdfs:range   :PositiveLengthMeasure .

:topologicalLink  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedVertex :TessellatedShell )
                     ] ;
        rdfs:range   :ConnectedFaceSet , :VertexPoint .

:EdgeBasedWireframeModel
        a                owl:Class ;
        rdfs:subClassOf  :WireframeModel , :GeometricRepresentationItem .

:referenceSurface  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :SurfaceCurveSweptFaceSolid :SurfaceCurveSweptAreaSolid )
                     ] ;
        rdfs:range   :Surface .

:RevolvedFaceSolid  a    owl:Class ;
        rdfs:subClassOf  :SweptFaceSolid .

:centre  a           owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :Sphere :CircularArea )
                     ] ;
        rdfs:range   :CartesianPoint , :Point .

:SolidReplica  a         owl:Class ;
        rdfs:subClassOf  :SolidModel .

:GeometricSet  a         owl:Class ;
        rdfs:subClassOf  :GeometricRepresentationItem .

:angle  a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :RevolvedFaceSolid :RevolvedAreaSolid )
                     ] ;
        rdfs:range   :PlaneAngleMeasure .

:BooleanResult  a        owl:Class ;
        rdfs:subClassOf  :CsgSelect , :BooleanOperand , :GeometricRepresentationItem .

:startParam  a       owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :SurfaceCurveSweptFaceSolid :SurfaceCurveSweptAreaSolid :SweptDiskSolid )
                     ] ;
        rdfs:range   xsd:double .

:xlength  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :RectangularPyramid :BoxDomain :RectangleDomain )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:Surface  rdfs:subClassOf  :GeometricSetSelect , :FaceOrSurface .

:children  a         owl:ObjectProperty ;
        rdfs:domain  :TessellatedGeometricSet ;
        rdfs:range   :TessellatedItem .

:SolidModel  a           owl:Class ;
        rdfs:subClassOf  :BooleanOperand , :GeometricRepresentationItem .

:u2     a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :ParameterValue .

:SurfaceCurveSweptAreaSolid
        a                owl:Class ;
        rdfs:subClassOf  :SweptAreaSolid .

:y      a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :Block :RightAngularWedge :RectangularArea )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:FaceBasedSurfaceModel
        a                owl:Class ;
        rdfs:subClassOf  :SurfaceModel , :GeometricRepresentationItem .

:TriangulatedFace  a     owl:Class ;
        rdfs:subClassOf  :TessellatedFace .

:treeRootExpression  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :CsgSolid ;
        rdfs:range   :CsgSelect .

base:geometric_model_schema
        a            owl:Ontology ;
        owl:imports  base:topology_schema , base:support_resource_schema , base:representation_schema , base:product_property_representation_schema , base:measure_schema , base:geometry_schema .

:lineStrip  a        owl:DatatypeProperty ;
        rdfs:domain  :TessellatedEdge ;
        rdfs:range   xsd:int .

:TessellatedGeometricSet
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:BooleanOperand  a  owl:Class .

:tessellationAccuracyParameters
        a            owl:ObjectProperty ;
        rdfs:domain  :TessellatedShapeRepresentationWithAccuracyParameters ;
        rdfs:range   :TessellationAccuracyParameterItem .

:TessellatedSolid  a     owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:semiAxis3  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Ellipsoid ;
        rdfs:range   :PositiveLengthMeasure .

:GeometricSetSelect  a  owl:Class .

:SectionedSpine  a       owl:Class ;
        rdfs:subClassOf  :GeometricCurveSet .

:ConvexHexahedron  a     owl:Class ;
        rdfs:subClassOf  :FacetedPrimitive .

:SurfaceCurveSweptFaceSolid
        a                owl:Class ;
        rdfs:subClassOf  :SweptFaceSolid .

:innerRadius  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :SweptDiskSolid ;
        rdfs:range   :PositiveLengthMeasure .

:positionCoords  a   owl:DatatypeProperty ;
        rdfs:domain  :CoordinatesList ;
        rdfs:range   xsd:double .

:ExtrudedFaceSolid  a    owl:Class ;
        rdfs:subClassOf  :SweptFaceSolid .

:lineStrips  a       owl:DatatypeProperty ;
        rdfs:domain  :TessellatedCurveSet ;
        rdfs:range   xsd:int .

:w1     a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :ParameterValue .

:CsgPrimitive  a         owl:Class ;
        rdfs:subClassOf  :CsgSelect , :BooleanOperand .

:CompositeCurve  rdfs:subClassOf  :PathOrCompositeCurve .

:CsgSelect  a   owl:Class .

:TessellatedSurfaceSet
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedItem .

:sweptFace  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :SweptFaceSolid ;
        rdfs:range   :FaceSurface .

:pnmax  a            owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedFace :TessellatedSurfaceSet )
                     ] ;
        rdfs:range   xsd:int .

:FacetedPrimitive  a     owl:Class ;
        rdfs:subClassOf  :CsgPrimitive , :GeometricRepresentationItem .

:Curve  rdfs:subClassOf  :GeometricSetSelect , :EdgeOrCurve .

:TriangulatedSurfaceSet
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedSurfaceSet .

:MaximumEdgeLength  a    owl:Class ;
        rdfs:subClassOf  :TessellationAccuracyParameterItem , :PositiveLengthMeasure .

:sbwmBoundary  a     owl:ObjectProperty ;
        rdfs:domain  :ShellBasedWireframeModel ;
        rdfs:range   :Shell .

:z      a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :Block :RightAngularWedge )
                     ] ;
        rdfs:range   :PositiveLengthMeasure .

:ltx    a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RightAngularWedge ;
        rdfs:range   :LengthMeasure .

:endParam  a         owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :SurfaceCurveSweptFaceSolid :SurfaceCurveSweptAreaSolid :SweptDiskSolid )
                     ] ;
        rdfs:range   xsd:double .

:TessellatedEdge  a      owl:Class ;
        rdfs:subClassOf  :TessellatedEdgeOrVertex , :TessellatedStructuredItem .

:semiAngle  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RightCircularCone ;
        rdfs:range   :PlaneAngleMeasure .

:TessellationAccuracyParameterItem
        a       owl:Class .

:bounds  a           owl:ObjectProperty ;
        rdfs:domain  :PolygonalArea ;
        rdfs:range   :CartesianPoint .

:ComplexTriangulatedSurfaceSet
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedSurfaceSet .

:TrimmedVolume  a        owl:Class ;
        rdfs:subClassOf  :SolidModel .

:basisVolume  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :TrimmedVolume ;
        rdfs:range   :Volume .

:triangleFans  a     owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :ComplexTriangulatedFace :ComplexTriangulatedSurfaceSet )
                     ] ;
        rdfs:range   xsd:int .

:ComplexTriangulatedFace
        a                owl:Class ;
        rdfs:subClassOf  :TessellatedFace .

:lineStripFace1  a   owl:DatatypeProperty ;
        rdfs:domain  :TessellatedConnectingEdge ;
        rdfs:range   xsd:int .
