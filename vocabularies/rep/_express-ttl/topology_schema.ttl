@prefix :      <http://ontology.semanticstep.net/topology_schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

:bounds  a           owl:ObjectProperty ;
        rdfs:domain  :Face ;
        rdfs:range   :FaceBound .

:VolumeWithParametricBoundary
        a                owl:Class ;
        rdfs:subClassOf  :VolumeWithFaces .

:pcurveReference  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :SeamEdge ;
        rdfs:range   :Pcurve .

:edgeElement  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :OrientedEdge ;
        rdfs:range   :Edge .

:FaceOuterBound  a       owl:Class ;
        rdfs:subClassOf  :FaceBound .

:ReversibleTopologyItem
        a                owl:Class ;
        rdfs:subClassOf  :ReversibleTopology .

:volumeGeometry  a   owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :VolumeWithFaces ;
        rdfs:range   :Volume .

:parentFace  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Subface ;
        rdfs:range   :Face .

:cvsVolumes  a       owl:ObjectProperty ;
        rdfs:domain  :ConnectedVolumeSet ;
        rdfs:range   :VolumeWithFaces .

:OpenShell  a            owl:Class ;
        rdfs:subClassOf  :Shell , :ReversibleTopologyItem , :ConnectedFaceSet .

:ConnectedEdgeSubSet  a  owl:Class ;
        rdfs:subClassOf  :ConnectedEdgeSet .

:faceGeometry  a     owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :FaceSurface ;
        rdfs:range   :Surface .

:Path   a                owl:Class ;
        rdfs:subClassOf  :ReversibleTopologyItem , :TopologicalRepresentationItem .

:OrientedPath  a         owl:Class ;
        rdfs:subClassOf  :Path .

:outerBound  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :VolumeWithParametricBoundary :VolumeWithShell )
                     ] ;
        rdfs:range   :ClosedShell , :Face .

:vertexGeometry  a   owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :VertexPoint ;
        rdfs:range   :Point .

:Face   a                owl:Class ;
        rdfs:subClassOf  :ReversibleTopologyItem , :TopologicalRepresentationItem .

:VertexLoop  a           owl:Class ;
        rdfs:subClassOf  :Loop .

:edgeEnd  a          owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Edge ;
        rdfs:range   :Vertex .

:OrientedOpenShell  a    owl:Class ;
        rdfs:subClassOf  :OpenShell .

:cfsFaces  a         owl:ObjectProperty ;
        rdfs:domain  :ConnectedFaceSet ;
        rdfs:range   :Face .

:parentEdge  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Subedge ;
        rdfs:range   :Edge .

:WireShell  a            owl:Class ;
        rdfs:subClassOf  :Shell , :TopologicalRepresentationItem .

:VolumeWithShell  a      owl:Class ;
        rdfs:subClassOf  :VolumeWithFaces .

:ConnectedVolumeSet  a   owl:Class ;
        rdfs:subClassOf  :TopologicalRepresentationItem .

:vertexShellExtent  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :VertexShell ;
        rdfs:range   :VertexLoop .

:bound  a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :FaceBound ;
        rdfs:range   :Loop .

:edgeList  a         owl:ObjectProperty ;
        rdfs:domain  :Path ;
        rdfs:range   :OrientedEdge .

:OrientedClosedShell  a  owl:Class ;
        rdfs:subClassOf  :ClosedShell .

:parentEdgeSet  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ConnectedEdgeSubSet ;
        rdfs:range   :ConnectedEdgeSet .

:cesEdges  a         owl:ObjectProperty ;
        rdfs:domain  :ConnectedEdgeSet ;
        rdfs:range   :Edge .

:ConnectedEdgeSet  a     owl:Class ;
        rdfs:subClassOf  :TopologicalRepresentationItem .

:Edge   a                owl:Class ;
        rdfs:subClassOf  :ReversibleTopologyItem , :TopologicalRepresentationItem .

:loopVertex  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :VertexLoop ;
        rdfs:range   :Vertex .

:Subpath  a              owl:Class ;
        rdfs:subClassOf  :Path .

:ClosedShell  a          owl:Class ;
        rdfs:subClassOf  :Shell , :ReversibleTopologyItem , :ConnectedFaceSet .

:ReversibleTopology  a  owl:Class .

:OrientedFace  a         owl:Class ;
        rdfs:subClassOf  :Face .

:FaceBound  a            owl:Class ;
        rdfs:subClassOf  :ReversibleTopologyItem , :TopologicalRepresentationItem .

:parentVolumeSet  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ConnectedVolumeSubSet ;
        rdfs:range   :ConnectedVolumeSet .

:sameSense  a        owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :EdgeCurve :FaceSurface )
                     ] ;
        rdfs:range   xsd:boolean .

:VertexShell  a          owl:Class ;
        rdfs:subClassOf  :Shell , :TopologicalRepresentationItem .

:parentFaceSet  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ConnectedFaceSubSet ;
        rdfs:range   :ConnectedFaceSet .

base:topology_schema  a  owl:Ontology ;
        owl:imports  base:support_resource_schema , base:representation_schema , base:measure_schema , base:geometry_schema .

:ConnectedFaceSet  a     owl:Class ;
        rdfs:subClassOf  :TopologicalRepresentationItem .

:closedShellElement  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :OrientedClosedShell ;
        rdfs:range   :ClosedShell .

:faceElement  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :OrientedFace ;
        rdfs:range   :Face .

:VertexPoint  a      owl:Class ;
        owl:unionOf  ( :Vertex :GeometricRepresentationItem ) .

:TopologicalRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationItem ;
        owl:oneOf        ( :dummy_tri ) .

:FaceSurface  a      owl:Class ;
        owl:unionOf  ( :Face :GeometricRepresentationItem ) .

:wireShellExtent  a  owl:ObjectProperty ;
        rdfs:domain  :WireShell ;
        rdfs:range   :Loop .

:OrientedEdge  a         owl:Class ;
        rdfs:subClassOf  :Edge .

:EdgeCurve  a        owl:Class ;
        owl:unionOf  ( :Edge :GeometricRepresentationItem ) .

:Subedge  a              owl:Class ;
        rdfs:subClassOf  :Edge .

:OpenPath  a             owl:Class ;
        rdfs:subClassOf  :Path .

:SetOfReversibleTopologyItem
        a                owl:Class ;
        rdfs:subClassOf  :ReversibleTopologyItem , :ReversibleTopology .

:parentPath  a       owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Subpath ;
        rdfs:range   :Path .

:pathElement  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :OrientedPath ;
        rdfs:range   :Path .

:edgeGeometry  a     owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :EdgeCurve ;
        rdfs:range   :Curve .

:Vertex  a               owl:Class ;
        rdfs:subClassOf  :TopologicalRepresentationItem .

:openShellElement  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :OrientedOpenShell ;
        rdfs:range   :OpenShell .

:VolumeWithFaces  a  owl:Class ;
        owl:unionOf  ( :GeometricRepresentationItem :TopologicalRepresentationItem ) .

:Subface  a              owl:Class ;
        rdfs:subClassOf  :Face .

:polygon  a          owl:ObjectProperty ;
        rdfs:domain  :PolyLoop ;
        rdfs:range   :CartesianPoint .

:ConnectedFaceSubSet  a  owl:Class ;
        rdfs:subClassOf  :ConnectedFaceSet .

:EdgeLoop  a         owl:Class ;
        owl:unionOf  ( :Loop :Path ) .

:orientation  a      owl:DatatypeProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :FaceBound :OrientedClosedShell :OrientedEdge :OrientedFace :OrientedOpenShell :OrientedPath )
                     ] ;
        rdfs:range   xsd:boolean .

:edgeStart  a        owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Edge ;
        rdfs:range   :Vertex .

:ConnectedVolumeSubSet
        a                owl:Class ;
        rdfs:subClassOf  :ConnectedVolumeSet .

:Loop   a                owl:Class ;
        rdfs:subClassOf  :TopologicalRepresentationItem .

:SeamEdge  a             owl:Class ;
        rdfs:subClassOf  :OrientedEdge .

:PolyLoop  a         owl:Class ;
        owl:unionOf  ( :Loop :GeometricRepresentationItem ) .

:ListOfReversibleTopologyItem
        a                owl:Class ;
        rdfs:subClassOf  :ReversibleTopology , :ReversibleTopologyItem .

:Shell  a       owl:Class .
