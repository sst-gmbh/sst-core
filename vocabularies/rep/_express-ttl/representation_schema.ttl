@prefix :      <http://ontology.semanticstep.net/representation_schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

:rep2   a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationRelationship ;
        rdfs:range   :RepresentationOrRepresentationReference .

:CompoundItemDefinition
        a       owl:Class .

:DefinitionalRepresentationRelationship
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationRelationship .

:binaryValue  a      owl:DatatypeProperty ;
        rdfs:domain  :BinaryRepresentationItem ;
        rdfs:range   xsd:hexBinary .

:RepresentationContext
        a       owl:Class .

:transformItem1  a   owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ItemDefinedTransformation ;
        rdfs:range   :RepresentationItem .

:mappingSource  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :MappedItem ;
        rdfs:range   :RepresentationMap .

:BinaryRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationItem .

:mapUsage  a           owl:ObjectProperty ;
        rdfs:domain    :RepresentationMap ;
        rdfs:range     :MappedItem ;
        owl:inverseOf  :mappingSource .

:relatingRepresentationItem
        a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationItemRelationship ;
        rdfs:range   :RepresentationItem .

:RepresentationRelationship
        a       owl:Class .

:rep1   a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationRelationship ;
        rdfs:range   :RepresentationOrRepresentationReference .

:mappingOrigin  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationMap ;
        rdfs:range   :RepresentationItem .

:ItemDefinedTransformation
        a                owl:Class ;
        rdfs:subClassOf  :Transformation .

:FoundedItem  a          owl:Class ;
        rdfs:subClassOf  :FoundedItemSelect .

:contextIdentifier  a  owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationContext ;
        rdfs:range   :Identifier .

:contextType  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationContext ;
        rdfs:range   :Text .

:transformationOperator
        a            owl:ObjectProperty ;
        rdfs:domain  :RepresentationRelationshipWithTransformation ;
        rdfs:range   :Transformation .

:SetRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :CompoundItemDefinition .

:RepresentationItemRelationship
        a       owl:Class .

:mappingTarget  a    owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :MappedItem ;
        rdfs:range   :RepresentationItem .

:ParametricRepresentationContext
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationContext .

:SetItemDefinedTransformation
        a                owl:Class ;
        rdfs:subClassOf  :Transformation .

:description  a      owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :FunctionallyDefinedTransformation :ItemDefinedTransformation :RepresentationItemRelationship :RepresentationRelationship )
                     ] ;
        rdfs:range   :Text .

:contextOfItems  a   owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :Representation ;
        rdfs:range   :RepresentationContext .

base:representation_schema
        a            owl:Ontology ;
        owl:imports  base:support_resource_schema .

:CompoundRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationItem .

:itemElement  a      owl:ObjectProperty ;
        rdfs:domain  :CompoundRepresentationItem ;
        rdfs:range   :CompoundItemDefinition .

:ValueRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationItem .

:RepresentationItem  a   owl:Class ;
        rdfs:subClassOf  :FoundedItemSelect .

:RepresentationMap  a  owl:Class .

:mappedRepresentation
        a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationMap ;
        rdfs:range   :Representation .

:relatedRepresentationItem
        a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :RepresentationItemRelationship ;
        rdfs:range   :RepresentationItem .

:name   a            owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  [ a            owl:Class ;
                       owl:unionOf  ( :FunctionallyDefinedTransformation :ItemDefinedTransformation :Representation :RepresentationItem :RepresentationItemRelationship :RepresentationRelationship )
                     ] ;
        rdfs:range   :Label .

:representationsInContext
        a              owl:ObjectProperty ;
        rdfs:domain    :RepresentationContext ;
        rdfs:range     :Representation ;
        owl:inverseOf  :contextOfItems .

:ListRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :CompoundItemDefinition .

:DefinitionalRepresentation
        a                owl:Class ;
        rdfs:subClassOf  :Representation .

:RepresentationOrRepresentationReference
        a       owl:Class .

:Transformation  a  owl:Class .

:BytesRepresentationItem
        a                owl:Class ;
        rdfs:subClassOf  :BinaryRepresentationItem .

:DefinitionalRepresentationRelationshipWithSameContext
        a                owl:Class ;
        rdfs:subClassOf  :DefinitionalRepresentationRelationship .

:items  a            owl:ObjectProperty ;
        rdfs:domain  :Representation ;
        rdfs:range   :RepresentationItem .

:transformItem2  a   owl:FunctionalProperty , owl:ObjectProperty ;
        rdfs:domain  :ItemDefinedTransformation ;
        rdfs:range   :RepresentationItem .

:FunctionallyDefinedTransformation
        a                owl:Class ;
        rdfs:subClassOf  :Transformation .

:RepresentationRelationshipWithTransformation
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationRelationship .

:FoundedItemSelect  a  owl:Class .

:Representation  a       owl:Class ;
        rdfs:subClassOf  :RepresentationOrRepresentationReference .

:MappedItem  a           owl:Class ;
        rdfs:subClassOf  :RepresentationItem .
