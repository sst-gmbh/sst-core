@prefix :      <http://ontology.semanticstep.net/measure_schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

:VolumeMeasure  a        owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:MassMeasure  a          owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ForceMeasure  a         owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:NonNegativeLengthMeasure
        a                owl:Class ;
        rdfs:subClassOf  :LengthMeasure , :MeasureValue .

:CountMeasure  a         owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:PowerMeasure  a         owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:InductanceMeasure  a    owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

base:measure_schema  a  owl:Ontology ;
        owl:imports  base:support_resource_schema , base:representation_schema .

:RatioMeasure  a         owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:AreaMeasure  a          owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ThermodynamicTemperatureMeasure
        a                owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:AmountOfSubstanceMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:AbsorbedDoseMeasure  a  owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ConductanceMeasure  a   owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:IlluminanceMeasure  a   owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ContextDependentMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:PositiveLengthMeasure
        a                owl:Class ;
        rdfs:subClassOf  :NonNegativeLengthMeasure , :MeasureValue .

:LuminousIntensityMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:GlobalUnitAssignedContext
        a                owl:Class ;
        rdfs:subClassOf  :RepresentationContext .

:FrequencyMeasure  a     owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:DescriptiveMeasure  a   owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:string .

:RadioactivityMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ElectricPotentialMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:MeasureValue  a  owl:Class .

:CapacitanceMeasure  a   owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:PressureMeasure  a      owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:ResistanceMeasure  a    owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:LuminousFluxMeasure  a  owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:SolidAngleMeasure  a    owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:TimeMeasure  a          owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:NumericMeasure  a       owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:MagneticFluxDensityMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:PositivePlaneAngleMeasure
        a                owl:Class ;
        rdfs:subClassOf  :PlaneAngleMeasure , :MeasureValue .

:PositiveRatioMeasure
        a                owl:Class ;
        rdfs:subClassOf  :RatioMeasure , :MeasureValue .

:LengthMeasure  a        owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ElectricChargeMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:EnergyMeasure  a        owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:MagneticFluxMeasure  a  owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:CelsiusTemperatureMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:ParameterValue  a       owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:ElectricCurrentMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:PlaneAngleMeasure  a    owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .

:AccelerationMeasure  a  owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:DoseEquivalentMeasure
        a                owl:Class ;
        rdfs:subClassOf  :MeasureValue , xsd:double .

:VelocityMeasure  a      owl:Class ;
        rdfs:subClassOf  xsd:double , :MeasureValue .
