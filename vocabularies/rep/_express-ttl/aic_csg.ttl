@prefix :      <http://ontology.semanticstep.net/aic_csg#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix base:  <http://ontology.semanticstep.net/> .

base:aic_csg  a      owl:Ontology ;
        owl:imports  base:aic_faceted_brep , base:aic_topologically_bounded_surface , base:topology_schema , base:aic_advanced_brep , base:geometry_schema , base:geometric_model_schema , base:support_resource_schema , base:representation_schema , base:product_property_representation_schema , base:measure_schema .

:CsgShapeRepresentation
        a                owl:Class ;
        rdfs:subClassOf  :ShapeRepresentation .
