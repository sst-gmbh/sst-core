                       owl:unionOf  ( :Axis1Placement :Axis2Placement3D )
                     ] ;
	rdfs:range :Direction .

# ENTITY axis2_placement_2d
#   SUBTYPE OF (placement);
#   ref_direction : OPTIONAL direction;              => :refDirection or :refDirectionDegree
# DERIVE
#   p : LIST[2:2] OF direction := build_2axes(ref_direction);
# WHERE
#   WR1: SELF\geometric_representation_item.dim = 2;
# END_ENTITY;
:Axis2Placement2D
	ssmeta:stepImEntityMap "axis2_placement_2d" ;
