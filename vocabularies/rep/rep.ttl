# ENTITY rectangular_trimmed_surface
#   SUBTYPE OF (bounded_surface);
#   basis_surface : surface;
#   u1 : parameter_value;
#   u2 : parameter_value;
#   v1 : parameter_value;
#   v2 : parameter_value;
#   usense : BOOLEAN;
#   vsense : BOOLEAN;
# WHERE
#   WR1: u1 <> u2;
#   WR2: v1 <> v2;
#   WR3: (('GEOMETRY_SCHEMA.ELEMENTARY_SURFACE' IN TYPEOF(basis_surface)) AND (NOT ('GEOMETRY_SCHEMA.PLANE' IN TYPEOF(basis_surface)))) OR ('GEOMETRY_SCHEMA.SURFACE_OF_REVOLUTION' IN TYPEOF(basis_surface)) OR (usense = (u2 > u1));
#   WR4: (('GEOMETRY_SCHEMA.SPHERICAL_SURFACE' IN TYPEOF(basis_surface)) OR ('GEOMETRY_SCHEMA.TOROIDAL_SURFACE' IN TYPEOF(basis_surface))) OR (vsense = (v2 > v1));
# END_ENTITY;
:RectangularTrimmedSurface
	ssmeta:stepImEntityMap "rectangular_trimmed_surface" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedSurface ;
	ssmeta:stepImMapAttributeOrder ( 
		:u1_1
		:u2_2
		:v1_2
		:v2_1
		:usense
		:vsense ) .

:u1_1   
	ssmeta:stepImAttributeMap "u1" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :RectangularTrimmedSurface ;
	rdfs:range xsd:double .

:u2_2   
	ssmeta:stepImAttributeMap "u2" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :RectangularTrimmedSurface ;
	rdfs:range xsd:double .

:v1_2   
	ssmeta:stepImAttributeMap "v1" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :RectangularTrimmedSurface ;
	rdfs:range xsd:double .

:v2_1   
	ssmeta:stepImAttributeMap "v2" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :RectangularTrimmedSurface ;
	rdfs:range xsd:double .

:usense
	ssmeta:stepImAttributeMap "usense" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :RectangularTrimmedSurface ;
	rdfs:range xsd:boolean .

:vsense
	ssmeta:stepImAttributeMap "vsense" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :RectangularTrimmedSurface ;
	rdfs:range xsd:boolean .

# ENTITY curve_bounded_surface
#   SUBTYPE OF (bounded_surface);
#   basis_surface : surface;
#   boundaries : SET[1:?] OF boundary_curve;
#   implicit_outer : BOOLEAN;
# WHERE
#   WR1: (NOT implicit_outer) OR (SIZEOF (QUERY (temp <* boundaries | 'GEOMETRY_SCHEMA.OUTER_BOUNDARY_CURVE' IN TYPEOF(temp))) = 0);
#   WR2: (NOT(implicit_outer)) OR ('GEOMETRY_SCHEMA.BOUNDED_SURFACE' IN TYPEOF(basis_surface));
#   WR3: SIZEOF(QUERY(temp <* boundaries | 'GEOMETRY_SCHEMA.OUTER_BOUNDARY_CURVE' IN TYPEOF(temp))) <= 1;
#   WR4: SIZEOF(QUERY(temp <* boundaries | (temp\composite_curve_on_surface.basis_surface [1] <> basis_surface))) = 0;
# END_ENTITY;
:CurveBoundedSurface
	ssmeta:stepImEntityMap "curve_bounded_surface" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedSurface ;
	ssmeta:stepImMapAttributeOrder ( 
		:basisSurface
		:boundaries
		:implicitOuter
	 ) .

:boundaries
	ssmeta:stepImAttributeMap "boundaries" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :CurveBoundedSurface ;
	rdfs:range :BoundaryCurve .

:implicitOuter
	ssmeta:stepImAttributeMap "implicit_outer" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :CurveBoundedSurface ;
	rdfs:range xsd:boolean .

