# TYPE boolean_operand = SELECT
#    (boolean_result, 
#     csg_primitive, 
#     half_space_2d, 
#     half_space_solid, 
#     solid_model);
# END_TYPE; 
:BooleanOperand
	ssmeta:stepImSelectMap "boolean_operand" ;
	a owl:Class , ssmeta:SelectClass ;
	owl:unionOf ( :BooleanResult :CsgPrimitive :HalfSpace2D :HalfSpaceSolid :SolidModel ) .

# TYPE boolean_operator = ENUMERATION OF 
#    (union,
#     intersection,
#     difference);
# END_TYPE; 
:BooleanOperator
	a owl:Class , ssmeta:EnumerationClass ;
	owl:oneOf ( :BooleanOperator_Union :BooleanOperator_Intersection :BooleanOperator_Difference ) .
:BooleanOperator_Union
	ssmeta:stepImEnumerationMap "union" ;
	a	:BooleanOperator .
:BooleanOperator_Intersection
	ssmeta:stepImEnumerationMap "intersection" ;
	a	:BooleanOperator .
:BooleanOperator_Difference
	ssmeta:stepImEnumerationMap "difference" ;
	a	:BooleanOperator .

