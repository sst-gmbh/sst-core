# ENTITY context_dependent_over_riding_styled_item
#   SUBTYPE OF (over_riding_styled_item);
#     style_context : LIST[1:?] OF style_context_select;
#   WHERE
#     WR1: 
#SIZEOF(QUERY(sc <* style_context | 'REPRESENTATION_SCHEMA.REPRESENTATION_ITEM' IN TYPEOF(sc)))= 1) OR
#SIZEOF(QUERY(sc <* style_context |
#    ('REPRESENTATION_SCHEMA.MAPPED_ITEM' IN TYPEOF(sc))
# OR ('PRESENTATION_APPEARANCE_SCHEMA.CONTEXT_DEPENDENT_SHAPE_REPRESENTATION' IN TYPEOF(sc))
# OR ('REPRESENTATION_SCHEMA.REPRESENTATION_RELATIONSHIP' IN TYPEOF(sc)) ))
# = SIZEOF(style_context));     
# END_ENTITY;
:ContextDependentOverRidingStyledItem
	ssmeta:stepImEntityMap "context_dependent_over_riding_styled_item" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :OverRidingStyledItem ;
	ssmeta:stepImMapAttributeOrder ( ) .

# ENTITY curve_style
#   SUBTYPE OF (founded_item);
#     name         : label;
#     curve_font   : OPTIONAL curve_font_or_scaled_curve_font_select; # => curveFont
#     curve_width  : OPTIONAL size_select; # => :curveWidth
#     curve_colour : OPTIONAL colour; # => :curveColour
# WHERE
#   WR1: EXISTS(curve_font) OR EXISTS(curve_width) OR EXISTS(curve_colour);
# END_ENTITY;
# see also subtypes; In SST their properties will directly be used for :CurveStyle:
#   curve_style_with_ends_and_corners (presentation_appearance_schema)
#   curve_style_with_extension (presentation_appearance_schema)
#   vector_style (Curve_appearance_mim)
# New vector_style attributes adopted from SVG:
#   vector_start : terminator_symbol_select ;
#   vector_mid : terminator_symbol_select ;
#   vector_end  : terminator_symbol_select ;
:CurveStyle
	ssmeta:stepImEntityMap "curve_style" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FoundedItem ;
	ssmeta:stepImMapAttributeOrder ( rdfs:label :curveFont :curveWidth :curveColour ) .

:curveFont
	ssmeta:stepImAttributeMap "curve_style.curve_font" ; 
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :CurveStyleParameter ;
	rdfs:range :DraughtingPreDefinedCurveFont . # TBD: other cases

:curveColour
	ssmeta:stepImAttributeMap "curve_style.curve_colour" ; 
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :CurveStyleParameter ;
	rdfs:range :Colour ;
.
:vectorStart
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :CurveStyleParameter ;
	rdfs:range :TerminatorSymbolSelect ;
.
:vectorMid
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :CurveStyleParameter ;
	rdfs:range :TerminatorSymbolSelect ;
.
:vectorEnd
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :CurveStyleParameter ;
	rdfs:range :TerminatorSymbolSelect ;
.

