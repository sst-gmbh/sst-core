# ENTITY b_spline_surface_with_knots
#   SUBTYPE OF (b_spline_surface);
#   u_multiplicities : LIST[2:?] OF INTEGER;
#   v_multiplicities : LIST[2:?] OF INTEGER;
#   u_knots : LIST[2:?] OF parameter_value;
#   v_knots : LIST[2:?] OF parameter_value;
#   knot_spec : knot_type;
# DERIVE
#   knot_u_upper : INTEGER := SIZEOF(u_knots);
#   knot_v_upper : INTEGER := SIZEOF(v_knots);
# WHERE
#   WR1: constraints_param_b_spline(SELF\b_spline_surface.u_degree, knot_u_upper, SELF\b_spline_surface.u_upper, u_multiplicities, u_knots);
#   WR2: constraints_param_b_spline(SELF\b_spline_surface.v_degree, knot_v_upper, SELF\b_spline_surface.v_upper, v_multiplicities, v_knots);
#   WR3: SIZEOF(u_multiplicities) = knot_u_upper;
#   WR4: SIZEOF(v_multiplicities) = knot_v_upper;
# END_ENTITY;
:BSplineSurfaceWithKnots
	ssmeta:stepImEntityMap "b_spline_surface_with_knots" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BSplineSurface ;
	ssmeta:stepImMapAttributeOrder ( 
		:uMultiplicities
		:vMultiplicities
		:uKnots
		:vKnots
		:knotSpec ) .

:uMultiplicities
	ssmeta:stepImAttributeMap "u_multiplicities" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineSurfaceWithKnots :BSplineVolumeWithKnots )
                     ] ;
	rdfs:range xsd:int .

:vMultiplicities
	ssmeta:stepImAttributeMap "v_multiplicities" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineSurfaceWithKnots :BSplineVolumeWithKnots )
                     ] ;
	rdfs:range xsd:int .

:uKnots
	ssmeta:stepImAttributeMap "u_knots" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineSurfaceWithKnots :LocallyRefinedSplineSurface :BSplineVolumeWithKnots :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range xsd:double .

:vKnots
	ssmeta:stepImAttributeMap "v_knots" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineSurfaceWithKnots :LocallyRefinedSplineSurface :BSplineVolumeWithKnots :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range xsd:double .

