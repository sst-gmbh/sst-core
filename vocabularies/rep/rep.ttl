# TYPE linearly_independent_enum = ENUMERATION OF 
#   (independent, 
#   not_independent, 
#   not_tested);
# END_TYPE;
:LinearlyIndependentEnum
	a owl:Class , ssmeta:EnumerationClass ;
	owl:oneOf ( :LinearlyIndependentEnum_Independent :LinearlyIndependentEnum_NotIndependent :LinearlyIndependentEnum_NotTested ) .
:LinearlyIndependentEnum_Independent
	ssmeta:stepImEnumerationMap "independent" ;
	a :LinearlyIndependentEnum .
:LinearlyIndependentEnum_NotIndependent
	ssmeta:stepImEnumerationMap "not_independent" ;
	a :LinearlyIndependentEnum .
:LinearlyIndependentEnum_NotTested
	ssmeta:stepImEnumerationMap "not_tested" ;
	a :LinearlyIndependentEnum .

