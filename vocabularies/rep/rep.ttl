# ENTITY rational_b_spline_surface
#   SUBTYPE OF (b_spline_surface);
#   weights_data : LIST[2:?] OF LIST[2:?] OF REAL;
# DERIVE
#   weights : ARRAY[0:u_upper] OF ARRAY[0:v_upper] OF REAL := make_array_of_array(weights_data,0,u_upper,0,v_upper);
# WHERE
#   WR1: (SIZEOF(weights_data) = SIZEOF(SELF\b_spline_surface.control_points_list)) AND (SIZEOF(weights_data[1]) = SIZEOF(SELF\b_spline_surface.control_points_list[1]));
#   WR2: surface_weights_positive(SELF);
# END_ENTITY;
# Note: a RationalBSplineSurface can only be used in combination with one of the other subtypes of BSplineSurface; 
#  therefore it is not a MainClass but an OptionClass.
:RationalBSplineSurface
	ssmeta:stepImEntityMap "rational_b_spline_surface" ;
	a owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf :BSplineSurface ;
	ssmeta:stepImMapAttributeOrder ( :weightsData2D ) .

:weightsData2D
	ssmeta:stepImAttributeMap "weights_data" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :RationalBSplineSurface ;
	rdfs:range :ListOfListOfDouble .

# ENTITY locally_refined_spline_surface
#   SUBTYPE OF (bounded_surface);
#   u_b_splines : LIST[4:?] OF local_b_spline;
#   v_b_splines : LIST[4:?] OF local_b_spline;
#   u_knots : spline_knot_values;
#   v_knots : spline_knot_values;
#   control_points_list : LIST[4:?] OF cartesian_point;
#   scaling_factors : LIST[4:?] OF REAL;
#   linearly_independent : linearly_independent_enum;
#   locally_refined_spline_type : locally_refined_spline_type_enum;
#   self_intersect : LOGICAL;
#   u_closed : LOGICAL;
#   v_closed : LOGICAL;
#   domain : LIST[2:2] OF LIST[2:2] OF REAL;
# WHERE
#   WR1: SIZEOF(u_b_splines) = SIZEOF(control_points_list);
#   WR2: SIZEOF(v_b_splines) = SIZEOF(control_points_list);
#   WR3: SIZEOF(scaling_factors) = SIZEOF(control_points_list);
#   WR4: constraints_scaling(SELF.scaling_factors);
# END_ENTITY;
:LocallyRefinedSplineSurface
	ssmeta:stepImEntityMap "locally_refined_spline_surface" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedSurface ;
	ssmeta:stepImMapAttributeOrder ( 
		:uBSplines
		:vBSplines
		:uKnots
		:vKnots
		:controlPointsList
		:scalingFactors
		:linearlyIndependent
		:LocallyRefinedSplineTypeEnum
		:selfIntersect
		:uClosed
		:vClosed 
		:domain2D ) .
# Note: locally_refined_spline_type_enum maps to an owl.Class and to locally_refined_spline_type is represnted by an rdf:type

:uBSplines
	ssmeta:stepImAttributeMap "u_b_splines" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :LocallyRefinedSplineSurface :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range :LocalBSpline .

:vBSplines
	ssmeta:stepImAttributeMap "v_b_splines" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :LocallyRefinedSplineSurface :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range :LocalBSpline .

:scalingFactors
	ssmeta:stepImAttributeMap "scaling_factors" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :LocallyRefinedSplineCurve :LocallyRefinedSplineSurface :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range xsd:double .

:linearlyIndependent
	ssmeta:stepImAttributeMap "linearly_independent" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :LocallyRefinedSplineSurface :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range :LinearlyIndependentEnum .

:domain2D
	ssmeta:stepImAttributeMap "domain" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :LocallyRefinedSplineSurface ;
	rdfs:range :ListOfListOfDouble .

