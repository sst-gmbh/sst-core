# ENTITY tessellated_connecting_edge
#   SUBTYPE OF (tessellated_edge);
#   smooth : LOGICAL;
#   face1 : tessellated_face;
#   face2 : tessellated_face;
#   line_strip_face1 : LIST[2:?] OF INTEGER;
#   line_strip_face2 : LIST[2:?] OF INTEGER;
# WHERE
#   WR1: SIZEOF(line_strip_face1) = SIZEOF(line_strip_face2);
#   WR2: SIZEOF(line_strip_face1) = SIZEOF(SELF\tessellated_edge.line_strip);
#   WR3: NOT(('GEOMETRIC_MODEL_SCHEMA.CUBIC_BEZIER_TRIANGULATED_FACE') IN TYPEOF(face1));
#   WR4: NOT(('GEOMETRIC_MODEL_SCHEMA.CUBIC_BEZIER_TRIANGULATED_FACE') IN TYPEOF(face2));
# END_ENTITY;
:TessellatedConnectingEdge
	ssmeta:stepImEntityMap "tessellated_connecting_edge" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :TessellatedEdge ;
	ssmeta:stepImMapAttributeOrder ( 
		:smooth
		:face1
		:face2
		:lineStripFace1
		:lineStripFace2
	 ) .

:smooth
	ssmeta:stepImAttributeMap "smooth" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedConnectingEdge :CubicTessellatedConnectingEdge )
                     ] ;
	rdfs:range xsd:boolean .

:face1
	ssmeta:stepImAttributeMap "face1" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedConnectingEdge :CubicTessellatedConnectingEdge )
                     ] ;
	rdfs:range :CubicBezierTriangulatedFace , :TessellatedFace .

:face2
	ssmeta:stepImAttributeMap "face2" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :TessellatedConnectingEdge :CubicTessellatedConnectingEdge )
                     ] ;
	rdfs:range :CubicBezierTriangulatedFace , :TessellatedFace .

:lineStripFace1
	ssmeta:stepImAttributeMap "line_strip_face1" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :TessellatedConnectingEdge ;
	rdfs:range xsd:int .

:lineStripFace2
	ssmeta:stepImAttributeMap "line_strip_face2" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :TessellatedConnectingEdge ;
	rdfs:range xsd:int .

