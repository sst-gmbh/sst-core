# ENTITY cartesian_point
#   SUPERTYPE OF (ONEOF (cylindrical_point,
#                        polar_point,
#                        spherical_point))
#   SUBTYPE OF (point);
#   coordinates : LIST[1:3] OF length_measure;  => :coordinates
# END_ENTITY;
:CartesianPoint
	ssmeta:stepImEntityMap "cartesian_point" ;
	a owl:Class , ssmeta:MainClass , sh:NodeShape ;
	rdfs:subClassOf :TrimmingSelect , :Point ;
	ssmeta:stepImMapAttributeOrder ( :coordinates ) ;
	sh:closed true ;
	sh:ignoredProperties (rdf:type) ;
	sh:property [
		sh:path :coordinates ;
		sh:name "CartesianPoint.coordinates" ;
		sh:minCount 1 ;
		sh:maxCount 1 ] .

:coordinates
	ssmeta:stepImAttributeMap "cartesian_point.coordinates" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :CartesianPoint ;
	rdfs:range :ListOfDouble . 

# ENTITY cylindrical_point
#   SUBTYPE OF (cartesian_point);
#   r : length_measure;           => :r
#   theta : plane_angle_measure;  => :theta
#   z : length_measure;           => :z
# DERIVE
#   SELF\cartesian_point.coordinates : LIST[3:3] OF length_measure := [r*cos(theta), r*sin(theta), z];
# WHERE
#   WR1: r >= 0.0;
# END_ENTITY;
:CylindricalPoint
	ssmeta:stepImEntityMap "cylindrical_point" ;
	a owl:Class , ssmeta:MainClass  ;
	rdfs:subClassOf :Point ;
	ssmeta:stepImMapAttributeOrder ( :r :theta ) .

:r    
	ssmeta:stepImAttributeMap "cylindrical_point.r" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :CylindricalPoint :SphericalPoint :PolarPoint )
                     ] ;
	rdfs:range xsd:double .

:theta
	ssmeta:stepImAttributeMap "cylindrical_point.theta" , "spherical_point.theta" , "polar_point.theta" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :CylindricalPoint :SphericalPoint :PolarPoint )
                     ] ;
	rdfs:range xsd:double .

# ENTITY spherical_point
#   SUBTYPE OF (cartesian_point);
#   r : length_measure;            => :r
#   theta : plane_angle_measure;   => :theta
#   phi : plane_angle_measure;     => :phi
# DERIVE
#   SELF\cartesian_point.coordinates : LIST[3:3] OF length_measure := [r*sin(theta)*cos(phi), r*sin(theta)*sin(phi), r*cos(theta)];
# WHERE
#   WR1: r >= 0.0;
# END_ENTITY;
:SphericalPoint
	ssmeta:stepImEntityMap "spherical_point" ;
	a owl:Class , ssmeta:MainClass  ;
	rdfs:subClassOf :Point ;
	ssmeta:stepImMapAttributeOrder ( :r :theta :phi ) .

:phi  
	ssmeta:stepImAttributeMap "spherical_point.phi" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :SphericalPoint ;
	rdfs:range xsd:double .

# ENTITY polar_point
#   SUBTYPE OF (cartesian_point);
#   r : length_measure;           => :r
#   theta : plane_angle_measure;  => :theta
# DERIVE
#   SELF\cartesian_point.coordinates : LIST[2:2] OF length_measure := [r*cos(theta), r*sin(theta)];
# WHERE
#   WR1: r >= 0.0;
# END_ENTITY;
:PolarPoint
	ssmeta:stepImEntityMap "polar_point" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Point ;
	ssmeta:stepImMapAttributeOrder ( :r :theta ) .

