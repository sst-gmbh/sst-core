	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY oriented_closed_shell
#   SUBTYPE OF (closed_shell);
#   closed_shell_element : closed_shell;
#   orientation          : BOOLEAN;
# DERIVE
#   SELF\connected_face_set.cfs_faces : SET [1:?] OF face
#                                := conditional_reverse(SELF.orientation,
#                                   SELF.closed_shell_element.cfs_faces);
# WHERE
#   WR1: NOT ('TOPOLOGY_SCHEMA.ORIENTED_CLOSED_SHELL' 
#                IN TYPEOF (SELF.closed_shell_element));
# END_ENTITY;
:OrientedClosedShell
	ssmeta:stepImEntityMap "oriented_closed_shell" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ClosedShell ;
	ssmeta:stepImMapAttributeOrder ( 
		:closedShellElement
		:orientation ) .

:closedShellElement
	ssmeta:stepImAttributeMap "closed_shell_element" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :OrientedClosedShell ;
	rdfs:range :ClosedShell .

# ENTITY oriented_edge
#   SUBTYPE OF (edge);
#   edge_element : edge;
#   orientation  : BOOLEAN;
# DERIVE
#   SELF\edge.edge_start : vertex := boolean_choose (SELF.orientation,
#                                            SELF.edge_element.edge_start,
#                                            SELF.edge_element.edge_end);
#   SELF\edge.edge_end   : vertex := boolean_choose (SELF.orientation,
#                                            SELF.edge_element.edge_end,
#                                            SELF.edge_element.edge_start);
# WHERE
#   WR1: NOT ('TOPOLOGY_SCHEMA.ORIENTED_EDGE' IN TYPEOF (SELF.edge_element));
# END_ENTITY;
#
# Note: <path> is not using a list of OrientedEdges, but instead is using list of edges with list of orientations
:OrientedEdge
	ssmeta:stepImEntityMap "oriented_edge" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Edge ;
	ssmeta:stepImMapAttributeOrder ( 
		:edgeElement
		:orientation ) .

:edgeElement
	ssmeta:stepImAttributeMap "edge_element" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :OrientedEdge ;
	rdfs:range :Edge .

# ENTITY oriented_face
#   SUBTYPE OF (face);
#   face_element : face;
#   orientation  : BOOLEAN;
# DERIVE
#   SELF\face.bounds : SET[1:?] OF face_bound
#          := conditional_reverse(SELF.orientation,SELF.face_element.bounds);
# WHERE
#   WR1: NOT ('TOPOLOGY_SCHEMA.ORIENTED_FACE' IN TYPEOF (SELF.face_element));
# END_ENTITY;
:OrientedFace
	ssmeta:stepImEntityMap "oriented_face" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Face ;
	ssmeta:stepImMapAttributeOrder ( 
		:faceElement
		:orientation ) .

:faceElement
	ssmeta:stepImAttributeMap "face_element" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :OrientedFace ;
	rdfs:range :Face .

# ENTITY oriented_open_shell
#   SUBTYPE OF (open_shell);
#   open_shell_element : open_shell;
#   orientation        : BOOLEAN;
# DERIVE
#   SELF\connected_face_set.cfs_faces : SET [1:?] OF face
#                                := conditional_reverse(SELF.orientation,
#                                      SELF.open_shell_element.cfs_faces);
# WHERE
#   WR1: NOT ('TOPOLOGY_SCHEMA.ORIENTED_OPEN_SHELL' 
#                IN TYPEOF (SELF.open_shell_element));
# END_ENTITY;
:OrientedOpenShell
	ssmeta:stepImEntityMap "oriented_open_shell" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :OpenShell ;
	ssmeta:stepImMapAttributeOrder ( 
		:openShellElement
		:orientation ) .

:openShellElement
	ssmeta:stepImAttributeMap "open_shell_element" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :OrientedOpenShell ;
	rdfs:range :OpenShell .

# ENTITY oriented_path
#   SUBTYPE OF (path);
#   path_element : path;
#   orientation  : BOOLEAN;
# DERIVE
#   SELF\path.edge_list : LIST [1:?] OF UNIQUE oriented_edge := conditional_reverse(SELF.orientation, SELF.path_element.edge_list);
# WHERE
#   WR1: NOT ('TOPOLOGY_SCHEMA.ORIENTED_PATH' IN TYPEOF (SELF.path_element));
# END_ENTITY;
:OrientedPath
	ssmeta:stepImEntityMap "oriented_path" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Path ;
	ssmeta:stepImMapAttributeOrder ( 
		:pathElement
		:orientation ) .

:pathElement
	ssmeta:stepImAttributeMap "path_element" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :OrientedPath ;
	rdfs:range :Path .

# ENTITY path
#   SUPERTYPE OF (ONEOF(open_path, edge_loop, oriented_path))
#   SUBTYPE OF (topological_representation_item);
#   edge_list  : LIST [1:?] OF UNIQUE oriented_edge; # => see :edgeList AND :orientationList
# WHERE
#   WR1: path_head_to_tail(SELF);
# END_ENTITY;
# NOTE: edge_list implemented by both, :edgeList and :orientationList because SST does not have OrientedEdge
:Path
	ssmeta:stepImEntityMap "path" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ReversibleTopologyItem , :TopologicalRepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( ssmeta:StepImMapAttributeSpecial ) .
# special handling required as the original LIST of oriented_edge is represented 
#   as two properties, :edgeList and :orientationList

:edgeList
	ssmeta:stepImAttributeMap "edge_list" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :Path ;
	rdfs:range :ListOfEdges .  # CHANGED, originally :OrientedEdge

:ListOfEdges
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of edges" ;
	ssmeta:ofType :Edge .

:orientationList  # ADDED to compensate for EDGE instead of OrientedEdge
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :Path ;
	rdfs:range :ListOfOrientations .  

:ListOfOrientations
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of orientations" ;
	ssmeta:ofType xsd:boolean .

# ENTITY subpath
#   SUBTYPE OF (path);
#   parent_path : path;
# WHERE
#   WR1: SELF :<>: parent_path;
#   WR2: NOT (('TOPOLOGY_SCHEMA.EDGE_LOOP' IN TYPEOF(SELF)) AND ('TOPOLOGY_SCHEMA.OPEN_PATH' IN TYPEOF(parent_path)));
# END_ENTITY;
#--IP1: The domain of the subpath shall be within the domain of the parent_path.
#--IP2: If the subpath is an edge_loop, the domain of the subpath shall be the same as the parent_path.
#--IP3: If the subpath is an edge_loop and the parent_path is an oriented_path, the oriented_path shall be closed to form a loop.
:Subpath
	ssmeta:stepImEntityMap "subpath" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Path ;
	ssmeta:stepImMapAttributeOrder ( :parentPath ) .

:parentPath
	ssmeta:stepImAttributeMap "parent_path" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :Subpath ;
	rdfs:range :Path .

# ENTITY poly_loop
#   SUBTYPE OF (loop,geometric_representation_item);
#   polygon : LIST [3:?] OF UNIQUE cartesian_point; => :points
# END_ENTITY;
:PolyLoop
	ssmeta:stepImEntityMap "poly_loop" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Loop , :GeometricRepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :points ) .

# ENTITY seam_edge
#   SUBTYPE OF (oriented_edge);
#     pcurve_reference : pcurve ; 
# WHERE
#    WR1 : ( 'TOPOLOGY_SCHEMA.EDGE_CURVE' IN TYPEOF (edge_element) )  AND
#                ('TOPOLOGY_SCHEMA.SEAM_CURVE' IN TYPEOF
#                       (edge_element\edge_curve.edge_geometry)) ;
#   WR2 :  pcurve_reference IN edge_element\edge_curve.edge_geometry\
#                                 surface_curve.associated_geometry ;
# END_ENTITY;
:SeamEdge
	ssmeta:stepImEntityMap "seam_edge" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :OrientedEdge ;
	ssmeta:stepImMapAttributeOrder ( :pcurveReference ) .

:pcurveReference
	ssmeta:stepImAttributeMap "pcurve_reference" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :SeamEdge ;
	rdfs:range :Pcurve .

# ENTITY topological_representation_item
#    SUPERTYPE OF (ONEOF(vertex, edge, face_bound, face, vertex_shell,
#                    wire_shell, connected_edge_set, connected_face_set,
#                    connected_volume_set, volume_with_faces,
#                     (loop ANDOR path)))
#    SUBTYPE OF (representation_item);
#--  DERIVE
#--    permanent_id             : identifier := get_id_value(SELF);
#--    permanent_aggregate_id   : identifier := get_aggregate_id_value(SELF);
#--  WHERE
#--    WR1:
#--     SIZEOF(USEDIN(SELF,'BASIC_ATTRIBUTE_SCHEMA.ID_ATTRIBUTE.IDENTIFIED_ITEM')) <= 1;
#--    WR2:
#--     SIZEOF(USEDIN(SELF,'BASIC_ATTRIBUTE_SCHEMA.AGGREGATE_ID_ATTRIBUTE.IDENTIFIED_ITEM')) <= 1;
# END_ENTITY;
:TopologicalRepresentationItem
	ssmeta:stepImEntityMap "topological_representation_item" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY vertex
