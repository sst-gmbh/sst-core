#      ['SKETCH_SCHEMA.POSITIONED_SKETCH','SKETCH_SCHEMA.SUBSKETCH']) = 1)
#     AND 
#     (SIZEOF(QUERY(q <* subsketch_elements |
#      NOT (owning_sketch IN using_items(q,[])))) = 0));
