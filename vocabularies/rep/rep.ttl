############################################################
# from presentation_definition_schema ISO 10303-46
############################################################
#
# TYPE annotation_symbol_occurrence_item = SELECT (
#   annotation_symbol,
#   defined_symbol);
# END_TYPE;
#
# TYPE curve_or_curve_set = SELECT (
#   curve,
#   geometric_curve_set);
# END_TYPE;
#
# TYPE defined_glyph_select = SELECT
#   (pre_defined_character_glyph,
#    externally_defined_character_glyph);
# END_TYPE;
#
# TYPE defined_symbol_select = SELECT
#   (pre_defined_symbol,
#    externally_defined_symbol);
# END_TYPE;
#
# TYPE text_alignment = label;
# END_TYPE;
# => redefined to
# TYPE text_alignment = ENUMERATION OF
#   (baseline_left,   # taken from aic_draughting_annotation, ISO 10303-504
#	baseline_centre,  # taken from aic_draughting_annotation, ISO 10303-504
#	baseline_right,   # taken from aic_draughting_annotation, ISO 10303-504
#	upper_left,
#	upper_centre,
#	upper_right,
#	centre_left,
#	centre_centre,
#	centre_right,
#	lower_left,
#	lower_centre,
#	lower_right);
# END_TYPE;
:TextAlignment
	a owl:Class , ssmeta:EnumerationClass ;
	owl:oneOf ( :TextAlignment_baseline_left :TextAlignment_baseline_centre :TextAlignment_baseline_right
		:TextAlignment_upper_left :TextAlignment_upper_centre :TextAlignment_upper_right
		:TextAlignment_centre_left :TextAlignment_centre_centre :TextAlignment_centre_right
		:TextAlignment_lower_left :TextAlignment_lower_centre :TextAlignment_lower_right ) .
:TextAlignment_baseline_left
	ssmeta:stepImEnumerationMap "baseline left" ;
	a :TextAlignment .
:TextAlignment_baseline_centre
	ssmeta:stepImEnumerationMap "baseline centre" ;
	a :TextAlignment .
:TextAlignment_baseline_right
	ssmeta:stepImEnumerationMap "baseline right" ;
	a :TextAlignment .
:TextAlignment_upper_left
	ssmeta:stepImEnumerationMap "upper left" ;
	a :TextAlignment .
:TextAlignment_upper_centre
	ssmeta:stepImEnumerationMap "upper centre" ;
	a :TextAlignment .
:TextAlignment_upper_right
	ssmeta:stepImEnumerationMap "upper right" ;
	a :TextAlignment .
:TextAlignment_centre_left
	ssmeta:stepImEnumerationMap "centre left" ;
	a :TextAlignment .
:TextAlignment_centre_centre
	ssmeta:stepImEnumerationMap "centre centre" ;
	a :TextAlignment .
:TextAlignment_centre_right
	ssmeta:stepImEnumerationMap "centre right" ;
	a :TextAlignment .
:TextAlignment_lower_left
	ssmeta:stepImEnumerationMap "lower left" ;
	a :TextAlignment .
:TextAlignment_lower_centre
	ssmeta:stepImEnumerationMap "lower centre" ;
	a :TextAlignment .
:TextAlignment_lower_right
	ssmeta:stepImEnumerationMap "lower right" ;
	a :TextAlignment .


