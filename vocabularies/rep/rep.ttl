	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY block_volume
#   SUBTYPE OF (volume);
#   position : axis2_placement_3d;
#   x : positive_length_measure; => :xSize
#   y : positive_length_measure; => :ySize
#   z : positive_length_measure; => :zSize
# END_ENTITY;
:BlockVolume
	ssmeta:stepImEntityMap "block_volume" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Volume ;
	ssmeta:stepImMapAttributeOrder ( 
		:xSize
		:ySize
		:zSize ) .

