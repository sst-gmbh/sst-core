# :usingSurfaces
#	ssmeta:stepImMap "" ;
#	a owl:ObjectProperty , owl:FunctionalProperty ;
#	rdfs:subPropertyOf :interRepItemUsage ;
#         rdfs:domain    :SurfacePatch ;
#         rdfs:range     :RectangularCompositeSurface ;
#         owl:inverseOf  :segments .

# ENTITY surface_patch
#   SUBTYPE OF (founded_item);
#   parent_surface : bounded_surface;
#   u_transition : transition_code;
#   v_transition : transition_code;
#   u_sense : BOOLEAN;
#   v_sense : BOOLEAN;
# INVERSE
#   using_surfaces : BAG[1:?] OF rectangular_composite_surface FOR segments;
# WHERE
#   WR1: (NOT ('GEOMETRY_SCHEMA.CURVE_BOUNDED_SURFACE' IN TYPEOF(parent_surface)));
# END_ENTITY;
:SurfacePatch
	ssmeta:stepImEntityMap "surface_patch" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FoundedItem ;
	ssmeta:stepImMapAttributeOrder ( 
		:parentSurface
		:uTransition
		:vTransition
		:uSense
		:vSense ) .

:parentSurface
	ssmeta:stepImAttributeMap "parent_surface" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :SurfacePatch :SurfaceReplica )
                     ] ;
	rdfs:range :Surface , :BoundedSurface .

:uTransition
	ssmeta:stepImAttributeMap "u_transition" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :SurfacePatch ;
	rdfs:range :TransitionCode .

:vTransition
	ssmeta:stepImAttributeMap "v_transition" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :SurfacePatch ;
	rdfs:range :TransitionCode .

:uSense
	ssmeta:stepImAttributeMap "u_sense" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :SurfacePatch ;
	rdfs:range xsd:boolean .

:vSense
	ssmeta:stepImAttributeMap "v_sense" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :SurfacePatch ;
	rdfs:range xsd:boolean .

:ListOfSurfacePatch
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of surface_patch" ;
	ssmeta:ofType :SurfacePatch .

:ListOfListOfSurfacePatch
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of list of surface_patch" ;
	ssmeta:ofType :ListOfSurfacePatch .

