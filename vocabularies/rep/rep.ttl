# This file contains an Ontology that covers all ISO 10303 IR/AIC/AIM schemas on representation.

# THESE ARE ADDITIONAL SCHEMAS TO SUPPORT THE BELOW ISO 10303-43
# From ISO 10303-41 Fundamentals of product description and support:
# (- support_resource_schema.exp) => coverd by generic RDF capabilities for :Text, :Text, :Identifier
# - ( measure_schema.exp ) => to be covered by ISO80000 quantities & units
# - product_property_representation_schema.exp

# THIS IS THE MAIN SCHEMA COVERED BY THIS ONTOLOGY
# From ISO 10303-43 Representation structures:
# - representation_schema.exp

# THE FOLLOWING SCHEMAS ARE SPECIALISATIONS OF THE ABOVE ISO 10303-43
# From ISO 10303-42 Geometric and topological representation:
# - geometry_schema.exp
# - topology_schema.exp
# - geometric_model_schema.exp
# - scan_data_3d_shape_model_schema.exp
# From ISO 10303-5xx AIC series:
# - aic_advanced_brep.exp 
# - aic_csg.exp
# - aic_curve_swept_solid.exp
# - aic_edge_based_wireframe.exp
# - aic_elementary_brep.exp
# - aic_faceted_brep.exp
# - aic_geometrically_bounded_2d_wireframe.exp
# - aic_geometrically_bounded_surface.exp
# - aic_geometrically_bounded_wireframe.exp
# - aic_manifold_subsurface.exp
# - aic_manifold_surface.exp
# - aic_non_manifold_surface.exp
# - aic_shell_based_wireframe.exp
# - aic_topologically_bounded_surface.exp
# From ISO/TS 10303-1xxx series
# - AM1830: Edge_based_topological_representation_with_length_constraint_mim
# From ISO 10303-108:
# - parameterization_schema
# - explicit_constraint_schema
# - variational_representation_schema
# - explicit_geometric_constraint_schema
# - sketch_schema
# From ISO/TS 10303-1828: 
# - Wiring_harness_assembly_design_mim
# From ISO/TS 10303-1731:
# - Constructive_solid_geometry_2d_mim
# From ISO 10303-46 Visual presentation:
# - presentation_organization_schema.exp
# - presentation_definition_schema.exp
# - presentation_appearance_schema.exp
# - presentation_resource_schema.exp
# From ISO 10303-101 Draughting:
# - drawing_definition_schema.exp
# - draughting_element_schema.exp
# - draughting_dimension_schema.exp
# From ISO/TS 10303-504 Draughting annotation:
# - aic_draughting_annotation.exp
# From ISO/TS 10303-517 Mechanical design shaded presentation:
# - aic_mechanical_design_geometric_presentation.exp
# From ISO 10303-41 
# - external_reference_schema 

# a mandatory LOGICAL value is mapped to an OPTIONAL BOOLEAN


@prefix :      <http://ontology.semanticstep.net/rep#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix lci:   <http://ontology.semanticstep.net/lci#> .
@prefix ssmeta:   <http://ontology.semanticstep.net/ssmeta#> .
@prefix sso:   <http://ontology.semanticstep.net/sso#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix sh:   <http://www.w3.org/ns/shacl#> .

<http://ontology.semanticstep.net/rep>
        rdf:type     owl:Ontology ;
        owl:imports   <http://ontology.semanticstep.net/lci> ;
        owl:versionInfo "0.01" .

:interRepItemUsage
	a owl:ObjectProperty ;
	rdfs:subPropertyOf lci:hasPart ;
	rdfs:domain  :RepresentationItem ;
	rdfs:range :RepresentationItem .
:interRepItemUsageInverse
	a owl:ObjectProperty ;
	rdfs:subPropertyOf lci:partOf ;
	rdfs:domain  :RepresentationItem ;
	rdfs:range :RepresentationItem .

:ListOfDouble
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of REAL" ;
	ssmeta:ofType xsd:double .

:ListOfListOfDouble
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of list of REAL" ;
	ssmeta:ofType :ListOfDouble .

:ListOfListOfListOfDouble
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of list of list of REAL" ;
	ssmeta:ofType :ListOfListOfDouble .

:ListOfInt
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of INTEGER" ;
	ssmeta:ofType xsd:int .

:ListOfListOfInt
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of INTEGER" ;
	ssmeta:ofType :ListOfInt .

############################################################
# from support_resource_schema.exp => coverd by generic RDF capabilities for :Text, :Text, :Identifier
############################################################


############################################################
# from measure_schema.exp  => reference into ssqau ontology for ISO80000 quantities & units
############################################################

# ENTITY global_unit_assigned_context
#    SUBTYPE OF (representation_context);
#    units : SET [1:?] OF unit; ==> :globalUnit to rep:lengthUnit, rep:angleUnit, rep:solidAngleUnit
# END_ENTITY;

:GlobalUnitAssignedContext
	ssmeta:stepImEntityMap "global_unit_assigned_context" ;
	a	owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf :RepresentationContext ;
	ssmeta:stepImMapAttributeOrder ( :globalUnit ) .   # special handling required

# range is any lci:Scale that refers as domain to a 
# - ssqau:Length, e.g. to ssqau:milliMetre
# - ssqau:Angle, e.g. to ssqau:angleDegree
# - ssqau:SolidAngle, e.g. to ssqau:steradian
# Constraint: only one ssqau:Length, one ssqau:Angle, one ssqau:SolidAngle
:globalUnit
	a owl:ObjectProperty ;
	rdfs:subPropertyOf lci:hasPart ;
	rdfs:domain  :RepresentationContext ; ## GlobalUnitAssignedContext ;
	rdfs:range lci:Scale .

############################################################
# from product_property_representation_schema.exp
############################################################

# TYPE pprs_description_attribute_select = SELECT BASED_ON description_attribute_select WITH (
#   context_dependent_shape_representation,
#   property_definition_representation);
# END_TYPE;

# TYPE pprs_name_attribute_select = SELECT BASED_ON name_attribute_select WITH (
#   context_dependent_shape_representation,
#   property_definition_representation);
# END_TYPE;

# TYPE chained_representation_link = SELECT (mapped_item, representation_context, representation_relationship);
# END_TYPE;

# TYPE represented_definition = SELECT (
#   general_property, 
#   property_definition, 
#   property_definition_relationship, 
#   shape_aspect, 
#   shape_aspect_relationship);
# END_TYPE;

# TYPE item_identified_representation_usage_definition = EXTENSIBLE GENERIC_ENTITY SELECT (
#   represented_definition);
# END_TYPE;

# TYPE item_identified_representation_usage_select = SELECT (
#   representation_item,
#   list_representation_item,
#   set_representation_item);
# END_TYPE;  

# ENTITY chain_based_item_identified_representation_usage
#   SUBTYPE OF (item_identified_representation_usage);
#   nodes : LIST [2:?] OF UNIQUE representation;
#   undirected_link : LIST [1:?] OF chained_representation_link;
# DERIVE
#   root : representation := nodes[1];
#   SELF\item_identified_representation_usage.used_representation RENAMED leaf : representation := nodes[HIINDEX(nodes)];
#   directed_link : LIST [1:?] OF representation_relationship := get_directed_link(nodes, undirected_link);
# WHERE
#   WR1 : EXISTS(directed_link);
# END_ENTITY;
# 
# The chain consisting of nodes and undirected_link together with the inherited identified_item
# is turned into a collection that is a path through the RDF graph.
# For now we will represent the full path.
# Later we may potentially allow optimizations by dropping some intermediate nodes.
:chainBasedItemIdentifiedRepresentationUsage
	ssmeta:stepImEntityMap "chain_based_item_identified_representation_usage" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :itemIdentifiedRepresentationUsage ;
	rdfs:domain  lci:Individual ;
	rdfs:range :RepresentationItem ;  # either a single one, or a set or a collection # list TBD LIST
	ssmeta:stepImMapAttributeOrder ( ) . # TO BE ADDED LATER

# ENTITY characterized_chain_based_item_within_representation 
#   SUBTYPE OF (characterized_item_within_representation);
#   nodes : LIST[2:?] OF UNIQUE representation;
#   undirected_link : LIST[1:?] OF chained_representation_link;
# DERIVE
#   root : representation := nodes[1];
#   SELF\characterized_item_within_representation.rep RENAMED leaf : representation := nodes[HIINDEX(nodes)];
#   directed_link : LIST[1:?] OF representation_relationship := get_directed_link(nodes, undirected_link);
# WHERE
#   WR1 : EXISTS(directed_link);
# END_ENTITY;

# ENTITY characterized_item_within_representation
#   SUBTYPE OF (characterized_object);
#   item : representation_item;
#   rep : representation;
# UNIQUE
#   UR1: item, rep;
# WHERE
#   WR1: rep IN using_representations(item);
# END_ENTITY;

# ENTITY context_dependent_shape_representation;
#   representation_relation : shape_representation_relationship; => rdfs:range
#   represented_product_relation : product_definition_shape; => rdfs:domain, 
#     # but note that the product_definition_shape is skipped and instead the domain points
#     # to a PRODUCT_DEFINITION_RELATIONSHIP, typically a NAUO, the product_definition_shape.definition is pointing to.
      # for SST the generic type is lci:assembledPartOf
# DERIVE
#   description : text := get_description_value(SELF);
#   name : label := get_name_value(SELF);
# WHERE
#   WR1: 'PRODUCT_DEFINITION_SCHEMA.PRODUCT_DEFINITION_RELATIONSHIP' IN TYPEOF(SELF.represented_product_relation.definition);
#   WR2: SIZEOF(USEDIN(SELF, 'BASIC_ATTRIBUTE_SCHEMA.' + 'DESCRIPTION_ATTRIBUTE.DESCRIBED_ITEM')) <= 1;
#   WR3: SIZEOF(USEDIN(SELF, 'BASIC_ATTRIBUTE_SCHEMA.' + 'NAME_ATTRIBUTE.NAMED_ITEM')) <= 1;
# END_ENTITY;
:contextDependentShapeRepresentation
	ssmeta:stepImEntityMap "context_dependent_shape_representation" ;
	a owl:ObjectProperty ;
	rdfs:domain  lci:assembledPartOf ; 
	rdfs:range :shapeRepresentationRelationship ;
	ssmeta:stepImMapAttributeOrder ( rdfs:range rdfs:domain ) .

# ENTITY item_identified_representation_usage;
#   name : label;        => rdfs:label
#   description : OPTIONAL text;       => rdfs:comment
#   definition : item_identified_representation_usage_definition; # rdfs:domain
#   used_representation : representation; # skipped, application has to figure out the 
#   identified_item : item_identified_representation_usage_select; # rdfs:range
# UNIQUE
#  UR1: used_representation, identified_item;
#  UR2: used_representation, definition;
# WHERE
#   WR1:NOT (SIZEOF(identified_item) = 1) OR (used_representation IN using_representations(identified_item));
#   WR2: NOT (SIZEOF(identified_item) > 1) OR (used_representation IN get_representations_for_items(identified_item));
# END_ENTITY;
:itemIdentifiedRepresentationUsage
	ssmeta:stepImEntityMap "item_identified_representation_usage" ;
	ssmeta:stepImEntityMap "draughting_model_item_association" ;
	a owl:ObjectProperty ;
	rdfs:domain  lci:Individual ;
	rdfs:range :RepresentationItem ;  # either a single one, or a set or a collection / list
	ssmeta:stepImMapAttributeOrder ( rdfs:label rdfs:comment rdf:nil rdfs:domain rdfs:range ) .

# ENTITY property_definition_representation;
#   definition : represented_definition;
#   used_representation : representation;
# DERIVE
#   description : text := get_description_value(SELF);
#   name : label := get_name_value(SELF);
# WHERE
#   WR1: SIZEOF(USEDIN(SELF, 'BASIC_ATTRIBUTE_SCHEMA.' + 'DESCRIPTION_ATTRIBUTE.DESCRIBED_ITEM')) <= 1;
#   WR2: SIZEOF(USEDIN(SELF, 'BASIC_ATTRIBUTE_SCHEMA.' + 'NAME_ATTRIBUTE.NAMED_ITEM')) <= 1;
# END_ENTITY;
:individualRepresentation
	ssmeta:stepImEntityMap "property_definition_representation" ;
	a owl:ObjectProperty ;
	rdfs:domain  lci:Individual ;
	rdfs:range :Representation ;
	ssmeta:stepImMapAttributeOrder ( rdfs:domain rdfs:range ) .

# ENTITY shape_definition_representation
#   SUBTYPE OF (property_definition_representation);
#   SELF\property_definition_representation.definition : property_definition; # rdfs:domain
#   SELF\property_definition_representation.used_representation : shape_representation; # rdfs:range
# WHERE
#   WR1: ('PRODUCT_PROPERTY_DEFINITION_SCHEMA.PRODUCT_DEFINITION_SHAPE' IN TYPEOF(definition)) OR
#        ('PRODUCT_PROPERTY_DEFINITION_SCHEMA.SHAPE_DEFINITION' IN TYPEOF(definition\property_definition.definition));   
# END_ENTITY;
# ... see :individualRepresentation above

:individualShapeRepresentation
	ssmeta:stepImEntityMap "shape_definition_representation" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :individualRepresentation ;
	rdfs:domain  lci:Individual ;
	rdfs:range :ShapeRepresentation ;
	ssmeta:stepImMapAttributeOrder ( rdfs:domain rdfs:range ) .

# ENTITY shape_representation
#   SUBTYPE OF (representation);
# END_ENTITY;
:ShapeRepresentation
	ssmeta:stepImEntityMap "shape_representation" ;
	ssmeta:stepDmMap "ExternalGeometricModel" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Representation ;
	ssmeta:stepImMapAttributeOrder (  ) .

# not available on IR/MIM level
:GeometricModel
	ssmeta:stepDmMap "GeometricModel" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :GeometricRepresentation , :ShapeRepresentation .

# ENTITY shape_representation_reference
#   SUBTYPE OF (representation_reference);
# END_ENTITY;
# ... no need for this

# ENTITY shape_representation_relationship
#   SUBTYPE OF (representation_relationship);
# WHERE
#   WR1: SIZEOF(['PRODUCT_PROPERTY_REPRESENTATION_SCHEMA.SHAPE_REPRESENTATION',
#                'PRODUCT_PROPERTY_REPRESENTATION_SCHEMA.SHAPE_REPRESENTATION_REFERENCE'] * 
#              (TYPEOF( SELF\representation_relationship.rep_1 ) + 
#               TYPEOF( SELF\representation_relationship.rep_2 ) ) )
#              >= 1;
# END_ENTITY;
:shapeRepresentationRelationship
	ssmeta:stepImEntityMap "shape_representation_relationship" ;
	ssmeta:stepDmMap "GeometricRepresentationRelationship" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :representationRelationship ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY specified_occurrence_context_dependent_shape_representation
#   SUBTYPE OF (context_dependent_shape_representation);
#   sub_element : product_definition_specified_occurrence;
# WHERE
#   WR1: 'PRODUCT_DEFINITION_SCHEMA.PRODUCT_DEFINITION_OCCURRENCE' IN TYPEOF(SELF.represented_product_relation.definition.related_product_definition);
#   WR2: sub_element IN represented_product_relation.definition.related_product_definition.descendant_occurrences;
# END_ENTITY;


############################################################
# from representation_schema.exp
############################################################

#  ENTITY representation_context;
#      context_identifier : identifier; => :id
#      context_type       : text;       => rdfs:label
#    INVERSE
#      representations_in_context : SET [1:?] OF representation FOR context_of_items;
#  END_ENTITY;
:RepresentationContext
	ssmeta:stepImEntityMap "representation_context" ;
	a	owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	ssmeta:stepImMapAttributeOrder ( sso:id rdfs:label ) .

:representationsInContext
	ssmeta:stepImAttributeMap "representation_context.representations_in_context" ;
	a	owl:ObjectProperty ;
	owl:inverseOf  :contextOfItems .

#  ENTITY representation;
#      name             : label; => rdfs:label
#      items            : SET[1:?] OF representation_item; => :item
#      context_of_items : representation_context;
#    DERIVE
#      id               : identifier := get_id_value (SELF); => :id
#      description      : text := get_description_value (SELF); => rdfs:comment
#    WHERE
#      ...
#  END_ENTITY;
:Representation
	ssmeta:stepImEntityMap "representation" ;
	a	owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	ssmeta:stepImMapAttributeOrder ( rdfs:label :item :contextOfItems ) .

:item
	ssmeta:stepImAttributeMap "representation.items" ;
	a	owl:ObjectProperty ;
	rdfs:subPropertyOf lci:hasArrangedPart ;
	rdfs:domain  :Representation ;
	rdfs:range :RepresentationItem . # should be rdfs:List of RepresentationItem, order not important (originally defined as SET)

:item_feature
	ssmeta:stepImAttributeMap "representation.items" ;
	a	owl:ObjectProperty ;
	rdfs:subPropertyOf :item , lci:hasFeature .

:contextOfItems
	ssmeta:stepImAttributeMap "representation.context_of_items" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf lci:partOf ;
	rdfs:domain  :Representation ;
	rdfs:range :RepresentationContext .

#  ENTITY representation_item
#    SUPERTYPE OF(ONEOF(binary_representation_item,
#      compound_representation_item, 
#      mapped_item, 
#      value_representation_item));
#      name : label;                       => rdfs:label
#    WHERE
#      WR1: SIZEOF(using_representations(SELF)) > 0;
#  END_ENTITY;
:RepresentationItem
	ssmeta:stepImEntityMap "representation_item" ;
	a   owl:Class , ssmeta:MainClass;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	ssmeta:stepImMapAttributeOrder ( rdfs:label ) .

# ENTITY measure_representation_item
#   SUBTYPE OF (representation_item, measure_with_unit);
# END_ENTITY; 
# => not directly mapped to SST because of inherited "measure_with_unit"
# => instead support specific usages; e.g. CurveWidth
# ENTITY measure_with_unit
#   SUPERTYPE OF (ONEOF (length_measure_with_unit, mass_measure_with_unit, time_measure_with_unit, electric_current_measure_with_unit, thermodynamic_temperature_measure_with_unit, celsius_temperature_measure_with_unit, amount_of_substance_measure_with_unit, luminous_intensity_measure_with_unit, plane_angle_measure_with_unit, solid_angle_measure_with_unit, area_measure_with_unit, volume_measure_with_unit, ratio_measure_with_unit, acceleration_measure_with_unit, capacitance_measure_with_unit, electric_charge_measure_with_unit, conductance_measure_with_unit, electric_potential_measure_with_unit, energy_measure_with_unit, magnetic_flux_density_measure_with_unit, force_measure_with_unit, frequency_measure_with_unit, illuminance_measure_with_unit, inductance_measure_with_unit, luminous_flux_measure_with_unit, magnetic_flux_measure_with_unit, power_measure_with_unit, pressure_measure_with_unit, resistance_measure_with_unit, velocity_measure_with_unit, absorbed_dose_measure_with_unit, radioactivity_measure_with_unit, dose_equivalent_measure_with_unit));
#   value_component : measure_value; => included in :measureValue
#   unit_component : unit;           => included in :measureValue
# WHERE
#    WR1: valid_units(SELF);
# END_ENTITY;
:MeasureRepresentationItem
	ssmeta:stepImEntityMap "measure_representation_item" ;
	a   owl:Class , ssmeta:MainClass;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( ssmeta:StepImMapAttributeSpecial ssmeta:StepImMapAttributeSpecial ) .  # for value_component and unit_component attributes

:measureValue
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain  :MeasureRepresentationItem ;
	rdfs:range lci:PhysicalQuantity .

# TYPE measure_value = SELECT (
#    absorbed_dose_measure,              => ssqau:AbsorbedDose
#    dose_equivalent_measure,            => ssqau:DoseEquivalent
#    radioactivity_measure,              => ssqau:Activity
#    acceleration_measure,               => ssqau:Acceleration
#    amount_of_substance_measure,        => ssqau:AmountOfSubstance
#    area_measure,                       => ssqau:Area
#    celsius_temperature_measure,        => ssqau:CelsiusTemperature
#    context_dependent_measure,          => SPECIAL
#    count_measure,                      => ssqau:CountQuantity
#    descriptive_measure,                => SPECIAL, NOT a numeric quantity (String)
#    capacitance_measure,                => ssqau:Capacitance
#    electric_charge_measure,            => ssqau:ElectricCharge
#    conductance_measure,                => ssqau:Conductance
#    electric_current_measure,           => ssqau:ElectricCurrent
#    electric_potential_measure,         => ssqau:ElectricPotential
#    energy_measure,                     => ssqau:Energy
#    magnetic_flux_density_measure,      => ssqau:MagneticFluxDensity
#    force_measure,                      => ssqau:Force
#    frequency_measure,                  => ssqau:Frequency
#    illuminance_measure,                => ssqau:Illuminance
#    inductance_measure,                 => ssqau:Inductance
#    length_measure,                     => ssqau:Length
#    luminous_flux_measure,              => ssqau:LuminousFlux
#    luminous_intensity_measure,         => ssqau:LuminousIntensity
#    magnetic_flux_measure,              => ssqau:MagneticFlux
#    mass_measure,                       => ssqau:Mass
#    numeric_measure,                    => SPECIAL, NOT A lci:PhysicalQuantity; just use lci:numericQuantityValue
#    non_negative_length_measure,        => SAME AS length_measure
#    parameter_value,                    => SPECIAL, NOT A lci:PhysicalQuantity; just use lci:numericQuantityValue
#    plane_angle_measure,                => ssqau:Angle
#    positive_length_measure,            => SAME AS length_measure
#    positive_plane_angle_measure,       => SAME AS plane_angle_measure
#    positive_ratio_measure,             => SAME AS ratio_measure
#    power_measure,                      => ssqau:Power
#    pressure_measure,                   => ssqau:StaticPressure
#    ratio_measure,                      => SPECIAL, MIGHT NOT BE A QUANTITY; just use lci:numericQuantityValue
#    resistance_measure,                 => ssqau:Resistance
#    solid_angle_measure,                => ssqau:SolidAngle
#    thermodynamic_temperature_measure,  => ssqau:ThermodynamicTemperature
#    time_measure,                       => ssqau:Time
#    velocity_measure,                   => ssqau:Velocity
#    volume_measure);                    => ssqau:Volume
# END_TYPE;

# TYPE unit = SELECT (
#           derived_unit,
#           named_unit);
# END_TYPE;
# 
# ENTITY named_unit
#   SUPERTYPE OF ((ONEOF (si_unit, conversion_based_unit, context_dependent_unit) 
#   ANDOR ONEOF (
# 		length_unit,                     => ssqau:Length
# 		mass_unit,                       => ssqau:Mass
# 		time_unit,                       => ssqau:Time
# 		electric_current_unit,           => ssqau:ElectricCurrent
# 		thermodynamic_temperature_unit,  => ssqau:ThermodynamicTemperature
# 		amount_of_substance_unit,        => ssqau:AmountOfSubstance 
# 		luminous_flux_unit,              => ssqau:LuminousFlux
# 		luminous_intensity_unit,         => ssqau:LuminousIntensity
# 		plane_angle_unit,                => ssqau:Angle
# 		solid_angle_unit,                => ssqau:SolidAngle
# 		ratio_unit)));                   => SPECIAL, MIGHT NOT BE A QUANTITY; use lci:numericQuantityValue
#   dimensions : dimensional_exponents;
# END_ENTITY;
# 
# ENTITY dimensional_exponents;
# 		length_exponent : REAL; 
# 		mass_exponent : REAL;
# 		time_exponent : REAL;
# 		electric_current_exponent : REAL;
# 		thermodynamic_temperature_exponent : REAL;
# 		amount_of_substance_exponent : REAL;
# 		luminous_intensity_exponent : REAL;
# END_ENTITY;
# 
# ENTITY derived_unit
# 	SUPERTYPE OF (ONEOF (
# 		absorbed_dose_unit,         => ssqau:AbsorbedDose
# 		acceleration_unit,          => ssqau:Acceleration
# 		radioactivity_unit,         => ssqau:Activity
# 		area_unit,                  => ssqau:Area
# 		capacitance_unit,           => ssqau:Capacitance
# 		dose_equivalent_unit,       => ssqau:DoseEquivalent
# 		electric_charge_unit,       => ssqau:ElectricCharge
# 		conductance_unit,           => ssqau:Conductance
# 		electric_potential_unit,    => ssqau:ElectricPotential
# 		energy_unit,                => ssqau:Energy
# 		magnetic_flux_density_unit, => ssqau:MagneticFluxDensity
# 		force_unit,                 => ssqau:Force
# 		frequency_unit,             => ssqau:Frequency
# 		illuminance_unit,           => ssqau:Illuminance
# 		inductance_unit,            => ssqau:Inductance
# 		magnetic_flux_unit,         => ssqau:MagneticFlux
# 		power_unit,                 => ssqau:Power
# 		pressure_unit,              => ssqau:StaticPressure
# 		resistance_unit,            => ssqau:Resistance
# 		velocity_unit,              => ssqau:Velocity
# 		volume_unit));              => ssqau:Volume
# 		
# 		elements : SET [1:?] OF derived_unit_element;
# DERIVE
# 		name : label := get_name_value(SELF);
# WHERE
# 	WR1: (SIZEOF(elements) > 1) OR ((SIZEOF(elements) = 1) AND (elements[1].exponent <> 1.0));
# 	WR2: SIZEOF(USEDIN(SELF, 'BASIC_ATTRIBUTE_SCHEMA.' + 'NAME_ATTRIBUTE.NAMED_ITEM')) <= 1;
# END_ENTITY;
#
# ENTITY context_dependent_unit
#		SUBTYPE OF (named_unit);
#		name : label;
# END_ENTITY; 

#  TYPE founded_item_select = SELECT
#    (founded_item,
#     representation_item);
#  END_TYPE;
:FoundedItemSelect
	ssmeta:stepImSelectMap "founded_item_select" ;
	a owl:Class , ssmeta:SelectClass ;
	owl:unionOf  ( :FoundedItem :RepresentationItem ) .

#  ENTITY founded_item;
#    DERIVE
#      users : SET[0:?] OF founded_item_select := using_items(SELF,[]);
#    WHERE
#      WR1: SIZEOF(users) > 0;
#      WR2: NOT(SELF IN users);  
#  END_ENTITY;
:FoundedItem
	ssmeta:stepImEntityMap "founded_item" ;
	a          owl:Class , ssmeta:AbstractClass ;
	rdfs:subClassOf lci:SpaceTimeIndividual ;
	ssmeta:stepImMapAttributeOrder (  ) .

#  ENTITY representation_relationship;
#      name        : label;           => rdfs:label
#      description : OPTIONAL text;         => rdfs:comment
#      rep_1        : representation_or_representation_reference; == Related (piece part) => rdfs:range
#      rep_2        : representation_or_representation_reference; == Relating (assembly)  => rdfs:domain
#  END_ENTITY;
:representationRelationship
	ssmeta:stepImEntityMap "representation_relationship" ;
	ssmeta:stepDmMap "RepresentationRelationship" ;
	a owl:ObjectProperty ;
	rdfs:domain  :Representation ;
	rdfs:range :Representation ;
	ssmeta:stepImMapAttributeOrder ( rdfs:label rdfs:comment rdfs:range rdfs:domain ) .

#  ENTITY definitional_representation_relationship
#    SUBTYPE OF (representation_relationship);
#     WHERE
#       WR1: acyclic_representation_relationship(SELF,
#         [SELF\representation_relationship.rep_2],
#         'REPRESENTATION_SCHEMA.'+'REPRESENTATION');
#  END_ENTITY;  
:definitionalRepresentationRelationship
	ssmeta:stepImEntityMap "definitional_representation_relationship" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :representationRelationship , lci:hasArrangedPart ;
	ssmeta:stepImMapAttributeOrder (  ) .

#  ENTITY definitional_representation_relationship_with_same_context
#    SUBTYPE OF (definitional_representation_relationship);
#     WHERE
#       WR1: SELF\representation_relationship.rep_1.context_of_items :=: 
#            SELF\representation_relationship.rep_2.context_of_items;
#  END_ENTITY;  
:definitionalRepresentationRelationshipWithSameContext
	ssmeta:stepImEntityMap "definitional_representation_relationship_with_same_context" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :definitionalRepresentationRelationship ;
	ssmeta:stepImMapAttributeOrder (  ) .

#  ENTITY representation_relationship_with_transformation
#    SUBTYPE OF (representation_relationship);
#      transformation_operator : transformation;  => :transformationOperator
#    WHERE
#      WR1: SELF\representation_relationship.rep_1.context_of_items
#           :<>: SELF\representation_relationship.rep_2.context_of_items;
#      WR2: NOT('REPRESENTATION_SCHEMA.ITEM_DEFINED_TRANSFORMATION' IN TYPEOF(transformation_operator)) OR
#              (SELF\representation_relationship.rep_1 IN
#               using_representations(transformation_operator\item_defined_transformation.transform_item_1)) AND
#              (SELF\representation_relationship.rep_2 IN
#               using_representations(transformation_operator\item_defined_transformation.transform_item_2));
#  END_ENTITY;
:representationRelationshipWithTransformation
	ssmeta:stepImEntityMap "representation_relationship_with_transformation" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :representationRelationship ;
	ssmeta:stepImMapAttributeOrder ( :transformationOperator ) .

# transformationOperator enforces "punning" on the domain to be a subproperty of representationRelationshipWithTransformation
# the range is 
:transformationOperator
	ssmeta:stepImAttributeMap "representation_relationship_with_transformation.transformation_operator" ;
	a            owl:ObjectProperty ;
	rdfs:domain [a owl:Restriction ;
		owl:onProperty rdfs:subPropertyOf ;
		owl:hasValue :representationRelationshipWithTransformation] ;
	rdfs:range :TransformationSelect .
	
:shapeRepresentationRelationshipWithTransformation
	ssmeta:stepDmMap "GeneralGeometricRepresentationRelationship" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :representationRelationshipWithTransformation , :shapeRepresentationRelationship .

:shapeRepresentationRelationshipWithCartesianTransformation
	ssmeta:stepDmMap "GeometricRepresentationRelationshipWithCartesianTransformation" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :shapeRepresentationRelationshipWithTransformation .

:shapeRepresentationRelationshipWithPlacementTransformation
	ssmeta:stepDmMap "GeometricRepresentationRelationshipWithPlacementTransformation" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :shapeRepresentationRelationshipWithTransformation .

:shapeRepresentationRelationshipWithSameGeometricRepresentationContext
	ssmeta:stepDmMap "" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :shapeRepresentationRelationship .

#  TYPE transformation = SELECT
#    (item_defined_transformation,
#     functionally_defined_transformation,
#     set_item_defined_transformation); => skip this type, use instead several :transformationOperator properties
#  END_TYPE;
:TransformationSelect  
	ssmeta:stepImSelectMap "transformation" ;
	a owl:Class , ssmeta:SelectClass .
#	owl:unionOf  ( :temDefinedTransformation :FunctionallyDefinedTransformation ) .
#  item_defined_transformation is not a class, can't use in union 	


#  ENTITY item_defined_transformation;
#    name             : label;               => rdfs:label
#    description      : OPTIONAL text;       => rdfs:comment
#    transform_item_1 : representation_item; => :transformItem1
#    transform_item_2 : representation_item; => :transformItem2
#  END_ENTITY;
:itemDefinedTransformation
	ssmeta:stepImEntityMap "item_defined_transformation" ;
	a owl:ObjectProperty ;
	rdfs:domain  :RepresentationItem ;
	rdfs:range :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( rdfs:label rdfs:comment rdfs:range rdfs:domain ) .

#  ENTITY functionally_defined_transformation;
#    name        : label;         => rdfs:label
#    description : OPTIONAL text; => rdfs:comment
#  END_ENTITY;
:FunctionallyDefinedTransformation
	ssmeta:stepImEntityMap "functionally_defined_transformation" ;
	a                owl:Class , ssmeta:AbstractClass ;
	ssmeta:stepImMapAttributeOrder ( rdfs:label rdfs:comment ) .

#  ENTITY binary_representation_item 
#    SUBTYPE OF (representation_item); 
#      binary_value : BINARY;       => :binaryValue
#  END_ENTITY; 
:BinaryRepresentationItem
	ssmeta:stepImEntityMap "binary_representation_item" ;
	a                owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :binaryValue ) .

:binaryValue
	ssmeta:stepImAttributeMap "binary_representation_item.binary_value" ;
	a      owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :BinaryRepresentationItem ;
	rdfs:range xsd:hexBinary .

#  ENTITY bytes_representation_item 
#    SUBTYPE OF (binary_representation_item); 
#    DERIVE 
#      no_of_bytes : INTEGER := BLENGTH(SELF\binary_representation_item.binary_value) DIV 8; 
#    WHERE 
#      WR1: BLENGTH(SELF\binary_representation_item.binary_value) MOD 8 = 0; 
#  END_ENTITY; 
:BytesRepresentationItem
	ssmeta:stepImEntityMap "bytes_representation_item" ;
	a                owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BinaryRepresentationItem , ssmeta:MainClass ;
	ssmeta:stepImMapAttributeOrder (  ) .

#  ENTITY compound_representation_item
#    SUBTYPE OF (representation_item);
#      item_element : compound_item_definition;  => :itemElementList OR :itemElement
#  END_ENTITY;
#
#  TYPE compound_item_definition = SELECT
#    (list_representation_item,
#     set_representation_item);
#  END_TYPE;
#
#  TYPE list_representation_item = LIST [1:?] OF representation_item; => itemElementList
#  END_TYPE;
#
#  TYPE set_representation_item = SET [1:?] OF representation_item; => several :itemElement
#  END_TYPE;
:CompoundRepresentationItem
	ssmeta:stepImEntityMap "compound_representation_item" ;
	a                owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( ( :itemElementList ) ) .

:itemElementList  
	ssmeta:stepImAttributeMap "compound_representation_item.item_element" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain :CompoundRepresentationItem ;
	rdfs:range :ListOfRepresentationItems .

:ListOfRepresentationItems
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of edges" ;
	ssmeta:ofType :RepresentationItem .

:itemElement  
	ssmeta:stepImAttributeMap "compound_representation_item.item_element" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain :CompoundRepresentationItem ;
	rdfs:range :RepresentationItem . 

#  ENTITY mapped_item
#    SUBTYPE OF (representation_item);
#      mapping_source : representation_map;    => :mappingSource
#      mapping_target : representation_item;   => :mappingTarget
#    WHERE
#      WR1: acyclic_mapped_representation(SELF);
#  END_ENTITY;
:MappedItem
	ssmeta:stepImEntityMap "mapped_item" ;
	a           owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :mappingSource :mappingTarget ) .

:mappingSource  
	ssmeta:stepImAttributeMap "mapped_item.mapping_source" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf lci:hasArrangedPart ;
	rdfs:domain  :MappedItem ;
	rdfs:range :RepresentationMap .

:mappingTarget
	ssmeta:stepImAttributeMap "mapped_item.mapping_target" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :MappedItem ;
	rdfs:range :RepresentationItem .

#  ENTITY representation_map;
#      mapping_origin        : representation_item;  => :mappingOrigin
#      mapped_representation : representation;       => :mappedRepresentation
#    INVERSE
#      map_usage : SET[1:?] OF mapped_item FOR mapping_source;
#    WHERE
#      WR1: item_in_context(mapping_origin, mapped_representation\representation.context_of_items);
#  END_ENTITY;
:RepresentationMap  
	ssmeta:stepImEntityMap "representation_map" ;
	a owl:Class , ssmeta:MainClass ;
	ssmeta:stepImMapAttributeOrder ( :mappingOrigin :mappedRepresentation ) .

:mappingOrigin  
	ssmeta:stepImAttributeMap "representation_map.mapping_origin" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain  :RepresentationMap ;
	rdfs:range :RepresentationItem .

:mappedRepresentation
	ssmeta:stepImAttributeMap "representation_map.mapped_representation" ;
	a            owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain  :RepresentationMap ;
	rdfs:range :Representation .

:mapUsage  
	ssmeta:stepImAttributeMap "representation_map.map_usage" ;
	a owl:ObjectProperty ;
	owl:inverseOf  :mappingSource .

#  ENTITY representation_item_relationship;
#    name : label;                    => rdfs:label
#    description : OPTIONAL text;     => rdfs:comment
#    relating_representation_item : representation_item;
#    related_representation_item : representation_item;
#  END_ENTITY;
:representationItemRelationship
	ssmeta:stepImEntityMap "representation_item_relationship" ;
	a owl:ObjectProperty ;
#		rdfs:subPropertyOf :interRepItemUsage ; # NO, such a semantic is not defined in STEP part43
	rdfs:domain  :RepresentationItem ;
	rdfs:range :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( rdfs:domain rdfs:range ) .

#  ENTITY parametric_representation_context
#    SUBTYPE OF (representation_context);
#  END_ENTITY;
:ParametricRepresentationContext
	ssmeta:stepImEntityMap "parametric_representation_context" ;
	a                owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf :RepresentationContext ;
	ssmeta:stepImMapAttributeOrder (  ) .

#  ENTITY value_representation_item
#    SUBTYPE OF (representation_item);
#--      value_component : measure_value;
#--    WHERE
#--      WR1: SIZEOF (QUERY (rep <* using_representations (SELF) |
#--        NOT ('MEASURE_SCHEMA.GLOBAL_UNIT_ASSIGNED_CONTEXT'
#--        IN TYPEOF (rep.context_of_items)
#--        ))) = 0;
#  END_ENTITY;
:ValueRepresentationItem
	ssmeta:stepImEntityMap "value_representation_item" ;
	a                owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( rdf:nil ) .

#  ENTITY definitional_representation
#    SUBTYPE OF (representation);
#    WHERE
#      WR1: 'REPRESENTATION_SCHEMA.PARAMETRIC_REPRESENTATION_CONTEXT' IN
#          TYPEOF (SELF\representation.context_of_items );
#  END_ENTITY;
:DefinitionalRepresentation
	ssmeta:stepImEntityMap "definitional_representation" ;
	a                owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Representation ;
	ssmeta:stepImMapAttributeOrder (  ) .

#  ENTITY global_uncertainty_assigned_context
#    SUBTYPE OF (representation_context);
#    uncertainty : SET[1:?] OF uncertainty_measure_with_unit;  => :globalUncertainty
#  END_ENTITY;
# typical usage:
# :uuid1
#    rdf:type rep:RepresentationContext ;
#    rep:globalUncertainty :uuid2 ;
#    ... .
# :uuid2
#    rdf:type ssqau::Length ;
#    ssqau:milliMetre 0.1 .
:GlobalUncertaintyAssignedContext
	ssmeta:stepImEntityMap "global_uncertainty_assigned_context" ;
	a	owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf :RepresentationContext ;
	ssmeta:stepImMapAttributeOrder ( :globalUncertainty ) .   # special handling required

:globalUncertainty
	rdf:type lci:PhysicalProperty , owl:FunctionalProperty , owl:ObjectProperty ;
	rdfs:domain  :RepresentationContext .

