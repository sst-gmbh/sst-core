	a owl:ObjectProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :StyledItem ;
	rdfs:range :PresentationStyleAssignment .

:itemToStyle
	ssmeta:stepImAttributeMap "styled_item.item" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :StyledItem ;
	rdfs:range :RepresentationItem . # simplification and generalization


