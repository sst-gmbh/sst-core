	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :CompositeCurveSegment ;
	rdfs:range :TransitionCode .

:usingCurves
	ssmeta:stepImAttributeMap "using_curves" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	owl:inverseOf :segments .

