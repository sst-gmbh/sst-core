# TYPE schematic_node_or_port = SELECT (
#   schematic_node,
#   schematic_port,
#   schematic_port_reference
# )
# END_TYPE ;
:SchematicNodeOrPort
	a owl:Class , ssmeta:SelectClass ;
	owl:unionOf ( :SchematicNode :SchematicPort :SchematicPortReference ) .

# A SchematicNode is a VertesPoint where a SchematicConnection can start or end from any direction
# ENTITY schematic_node
#   SUBTYPE OF (vertex_point);
#   SELF\vertex_geometry : cartesian_point ; // the point where a circle or "thick" dot is drawn
# END_ENTITY; 
:SchematicNode
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :VertexPoint , :GeometricRepresentationItem .

# A SchematicPort is a Vertes and MappedItem where a SchematicConnection can start or end from a specific direction
# ENTITY schematic_port
#   ABSTRACT SUPERTYPE OF (ONEOF ExternalSchematicPort, InterPageConnector, IntraPageConnector)
#   SUBTYPE OF (vertex, geometric_representation_item, mapped_item);
#   SELF\mapped_item.mapping_source: symbol_representation_map; # of a SchematicPortRepresentation 
#   SELF\mapped_item.mapping_target: axis2_placement; # the point and direction from where to connect to
# END_ENTITY; 
:SchematicPort
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Vertex , :GeometricRepresentationItem , :MappedItem .
# TBD or considered: replace supertypes by equivalent MappedSymbol

# An ExternalSchematicPort is a SchematicPort of a SchematicSymbolRepresentation or SchematicDrawing to be referenced & connected in a next higher schematic level
:ExternalSchematicPort
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :SchematicPort .

# An InterPageConnector is a SchematicPort to connected between pages of the same schematic drawing
:InterPageConnector
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :SchematicPort .
# An OffPageConnector is a directed InterPageConnector from this page to another page
:OffPageConnector
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :InterPageConnector .
# An OnPageConnector is a directed InterPageConnector from another page to this page.
:OnPageConnector
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :InterPageConnector .

# A IntraPageConnector is a SchematicPort to connected within the same page of a schematic drawing
:IntraPageConnector
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :SchematicPort .
# An IncomingIntraPageConnector is a directed IntraPageConnector from another IntraPageConnector on the same page to this IncomingIntraPageConnector.
:IncomingIntraPageConnector
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :IntraPageConnector .
# An OutgoingIntraPageConnector is a directed IntraPageConnector from this OutgoingIntraPageConnector to another IntraPageConnector on the same page.
:OutgoingIntraPageConnector
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :IntraPageConnector .

# schematic_port_reference is a vertex and geometric_representation_item that represents the usage of a SchematicPort inside the target of a MappedSymbol.
# ENTITY schematic_port_reference
#   SUBTYPE OF (vertex, geometric_representation_item);
#   reference_chain : LIST[1:*] mapped_item ; # => referenceChain; last item must be a SchematicPort, all others must be 
# END_ENTITY; 
:SchematicPortReference
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Vertex , :GeometricRepresentationItem .

:referenceChain
	a owl:ObjectProperty , owl:FunctionalProperty ;
#	rdfs:subPropertyOf lci:hasPart ;
	rdfs:domain  :SchematicPortReference ;
	rdfs:range :ListOfMappedSymbol .

:ListOfMappedSymbol
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ; # so this is a collection
	rdfs:label "list of MappedSymbol" ;
	ssmeta:ofType :MappedSymbol .
# TBD: extended for :SchematicPort 

# NOT IN STEP, see EDIF, ENTITY schematic_symbol_port_representation_template
:SchematicPortRepresentation
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :SymbolRepresentation .

# A schematic_connection represents a line/curve on the drawing that is connecting 2 things
#   this is not part of ISO 10303
# ENTITY schematic_connection
#   SUBTYPE OF (edge_curve);
#   SELF\edge.edge_start : schematic_node_or_port ; # :edgeStart -> :SchematicNodeOrPort
#   SELF\edge.edge_end : schematic_node_or_port ; # :edgeEnd -> :SchematicNodeOrPort
#   SELF\edge_cuve.edge_geometry : bounded_curve ; # :edgeGeometry -> :BoundedCurve
# END_ENTITY;
:SchematicConnection
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :EdgeCurve .

#   this is not part of ISO 10303
# ENTITY schematic_connection_group
#   SUBTYPE OF (compound_representation_item);
#   SELF\compound_representation_item.item_element : schematic_connection_group_element ;
# END_ENTITY;
# TYPE schematic_connection_group_element = SELECT (
#   schematic_connection ,
#   schematic_connection_group ) ;
# END_TYPE ;
# The elements :SchematicNode :SchematicPort :SchematicPortRepresentation become indirectly members of a SchematicConnectionGroup when referenced by a SchematicConnection
:SchematicConnectionGroup
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :CompoundRepresentationItem ;
.
:SchematicConnectionGroupElement
	a owl:Class , ssmeta:SelectClass ;
	owl:unionOf  ( :SchematicConnection :SchematicConnectionGroup ) ;
.
