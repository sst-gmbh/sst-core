	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :Line ;
	rdfs:range :Vector .

# ENTITY conic
#   SUPERTYPE OF (ONEOF (circle,
#                        ellipse,
#                        hyperbola,
#                        parabola))
#   SUBTYPE OF (curve);
#   position : axis2_placement;   => :position
# END_ENTITY;
:Conic
	ssmeta:stepImEntityMap "conic" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Curve ;
	ssmeta:stepImMapAttributeOrder ( :position ) .

:position
	ssmeta:stepImAttributeMap "conic.position" ,  # axis2_placement
	                 "clothoid.position" , # axis2_placement
	                 "circular_involute.position" , # axis2_placement
	                 "elliptic_area.position" , # axis2_placement
	                 "rectangular_area.position" , # axis2_placement

	                 "elementary_surface.position" , # axis2_placement_3d
	                 "block_volume.position" ,  # axis2_placement_3d
	                 "wedge_volume.position" , # axis2_placement_3d
	                 "pyramid_volume.position" , # axis2_placement_3d
	                 "spherical_volume.position" , # axis2_placement_3d
	                 "cylindrical_volume.position" , # axis2_placement_3d
	                 "eccentric_volume.position" , # axis2_placement_3d
	                 "toroidal_volume.position" , # axis2_placement_3d
	                 "ellipsoid_volume.position" , # axis2_placement_3d
	                 "block.position" , # axis2_placement_3d
	                 "right_angular_wedge.position" , # axis2_placement_3d
	                 "rectangular_pyramid.position" , # axis2_placement_3d
	                 "eccentric_cone.position" , # axis2_placement_3d
	                 "ellipsoid.position" , # axis2_placement_3d
	                 "cyclide_segment_solid.position" , # axis2_placement_3d
	                 "repositioned_tessellated_item.position" , # axis2_placement_3d

	                 # "surface_of_revolution.axis_position" , # axis1_placement
	                 "right_circular_cone.position" , # axis1_placement
	                 "right_circular_cylinder.position" , # axis1_placement
	                 "torus.position" ; # axis1_placement
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [a            owl:Class ;
               owl:unionOf (:Conic 
                            :Clothoid 
                            :CircularInvolute 
                            :ElementarySurface 
                            :BlockVolume 
                            :WedgeVolume 
                            :PyramidVolume 
                            :SphericalVolume 
                            :CylindricalVolume 
                            :EccentricConicalVolume 
                            :ToroidalVolume 
                            :EllipsoidVolume 
                            :Block 
                            :RightAngularWedge 
                            :RectangularPyramid 
                            :RightCircularCone 
                            :RightCircularCylinder 
                            :EccentricCone 
                            :Torus 
                            :Ellipsoid 
                            :CyclideSegmentSolid 
                            :EllipticArea 
                            :RectangularArea)
                     ] ;
	rdfs:range :Axis2Placement .
#	rdfs:range :Axis2Placement2D , :Axis1Placement , :Axis2Placement3D .

# ENTITY circle
#   SUBTYPE OF (conic);
#   radius : positive_length_measure;   => :radius
# END_ENTITY;
:Circle
	ssmeta:stepImEntityMap "circle" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Conic ;
	ssmeta:stepImMapAttributeOrder ( :radius ) .

:radius
	ssmeta:stepImAttributeMap "circle.radius" ,
	                 "circular_area.radius" ,
	                 "cylindrical_surface.radius" ,
	                 "cylindrical_volume.radius" ,
	                 "conical_surface.radius" ,
	                 "right_circular_cone.radius" ,
	                 "right_circular_cylinder.radius" ,
	                 "sphere.radius" ,
	                 "spherical_surface.radius" ,
	                 "spherical_volume.radius" ,
	                 "swept_disk_solid.radius" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a owl:Class ;
                owl:unionOf  ( 
                       	:Circle 
                       	:CircularArea
                       	:CylindricalSurface
                       	:CylindricalVolume
                       	:ConicalSurface 
                       	:RightCircularCone
                       	:RightCircularCylinder
                       	:Sphere
                       	:SphericalSurface 
                       	:SphericalVolume 
                       	:SweptDiskSolid )
                     ] ;
	rdfs:range xsd:double .

