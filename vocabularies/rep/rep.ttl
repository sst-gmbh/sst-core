	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :CylindricalPoint :BlockVolume :WedgeVolume :Block :RightAngularWedge )
                     ] ;
	rdfs:range xsd:double .

# ENTITY wedge_volume
