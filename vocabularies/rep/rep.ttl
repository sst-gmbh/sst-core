#   corner : cartesian_point;
#   xlength : positive_length_measure;  => xLength
#   ylength : positive_length_measure;  => yLength
# WHERE
#   WR1: SIZEOF(QUERY(item <* USEDIN(SELF, '')| NOT ('GEOMETRIC_MODEL_SCHEMA.RECTANGLED_HALF_SPACE' IN TYPEOF(item)))) = 0;
# END_ENTITY;
:RectangleDomain
	ssmeta:stepImEntityMap "rectangle_domain" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FoundedItem ;
	ssmeta:stepImMapAttributeOrder ( 
		:corner
		:xLength
		:yLength ) .

:corner
	ssmeta:stepImAttributeMap "corner" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BoxDomain :RectangleDomain )
                     ] ;
	rdfs:range :CartesianPoint .

