# ENTITY scan_3d_model
# SUBTYPE OF (scanned_data_item);
#   scanner_info : SET [1 : ?] OF scanner_property;
#   scanned_points : SET [1: ?] OF scanned_data_item;
# WHERE
#      WR1: SIZEOF(QUERY(tmp <* scanned_points | 'SCAN_DATA_3D_SHAPE_MODEL_SCHEMA.SCAN_3D_MODEL' IN TYPEOF(tmp))) = 0;
# END_ENTITY; 
:Scan3dModel
	ssmeta:stepImEntityMap "scan_3d_model" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ScannedDataItem ;
	ssmeta:stepImMapAttributeOrder ( 
		:scannerInfo
		:scannedPoints ) .

:scannerInfo
	ssmeta:stepImAttributeMap "scanner_info" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain  :Scan3dModel ;
	rdfs:range :ScannerProperty .

:scannedPoints
	ssmeta:stepImAttributeMap "" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :Scan3dModel ;
	rdfs:range :ScannedDataItem .

# ENTITY scanner_property
#     ABSTRACT SUPERTYPE
#     SUBTYPE OF (representation_item);
# END_ENTITY;
:ScannerProperty
	ssmeta:stepImEntityMap "scanned_points" ;
	a owl:Class , ssmeta:AbstractClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY scanner_basic_properties
#    SUBTYPE OF (scanner_property);
#    scanner_identification: label;
#    scanner_location: axis2_placement_3d;
#    scanner_uncertainty: OPTIONAL positive_length_measure;
# END_ENTITY;   
:ScannerBasicProperties
	ssmeta:stepImEntityMap "scanner_basic_properties" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ScannerProperty ;
	ssmeta:stepImMapAttributeOrder ( 
		:scannerIdentification
		:scannerLocation
		:scannerUncertainty ) .

:scannerIdentification
	ssmeta:stepImAttributeMap "scanner_identification" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :ScannerBasicProperties ;
	rdfs:range   rdfs:label .

:scannerLocation
	ssmeta:stepImAttributeMap "scanner_location" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :ScannerBasicProperties ;
	rdfs:range :Axis2Placement3D .

:scannerUncertainty
	ssmeta:stepImAttributeMap "scanner_uncertainty" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :ScannerBasicProperties ;
	rdfs:range xsd:double .


