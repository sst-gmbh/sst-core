# WHERE
#   WR1: (SELF\path.edge_list[1].edge_element.edge_start) :<>:
#                       (SELF\path.edge_list[ne].edge_element.edge_end);
# END_ENTITY;
:OpenPath
	ssmeta:stepImEntityMap "OpenPath" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Path ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY open_shell
#   SUBTYPE OF (connected_face_set);
