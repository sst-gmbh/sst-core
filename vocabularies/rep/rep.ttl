# ENTITY rational_b_spline_curve
#   SUBTYPE OF (b_spline_curve);
#   weights_data : LIST[2:?] OF REAL;   => :weightsData
# DERIVE
#   weights : ARRAY[0:upper_index_on_control_points] OF REAL := list_to_array(weights_data,0, upper_index_on_control_points);
# WHERE
#   WR1: SIZEOF(weights_data) = SIZEOF(SELF\b_spline_curve. control_points_list);
#   WR2: curve_weights_positive(SELF);
# END_ENTITY;
# Note: a RationalBSplineCurve can only be used in combination with one of the other subtypes of BSplineCurve; 
#  therefore it is not a MainClass but an OptionClass.
:RationalBSplineCurve
	ssmeta:stepImEntityMap "rational_b_spline_curve" ;
	a owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf :BSplineCurve ;
	ssmeta:stepImMapAttributeOrder ( :weightsData ) .

:weightsData
	ssmeta:stepImAttributeMap "weights_data" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :RationalBSplineCurve :RationalLocallyRefinedSplineCurve :RationalBSplineSurface :RationalLocallyRefinedSplineSurface :RationalBSplineVolume :RationalLocallyRefinedSplineVolume )
                     ] ;
	rdfs:range :ListOfDouble .

# ENTITY local_b_spline
#   SUBTYPE OF (representation_item);
#   degree : INTEGER;                       => :degree
#   knots : LIST[2:?] OF INTEGER;           => :knots
#   multiplicities : LIST[2:?] OF INTEGER;  => :knotMultiplicities
# WHERE
#   WR1: degree > 0;
#   WR2: SIZEOF(knots) = SIZEOF(multiplicities);
#   WR3: constraints_param_local_b_spline(degree, knots, multiplicities);
# END_ENTITY;
:LocalBSpline
	ssmeta:stepImEntityMap "local_b_spline" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :RepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :degree :knots :knotMultiplicities ) .

:ListOfLocalBSpline
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of local_b_spline" ;
	ssmeta:ofType :LocalBSpline .

# ENTITY locally_refined_spline_curve
#   SUBTYPE OF (bounded_curve);
#   b_splines : LIST[2:?] OF local_b_spline;
#   knot_values : spline_knot_values;
#   control_points_list : LIST[2:?] OF cartesian_point;
#   scaling_factors : LIST[2:?] OF REAL;
#   closed_curve : LOGICAL;
#   locally_refined_spline_type : locally_refined_spline_type_enum;
#   self_intersect : LOGICAL;
#   domain : LIST[2:2] OF REAL;
# WHERE
#   WR1: SIZEOF(b_splines) = SIZEOF(control_points_list);
#   WR2: SIZEOF(scaling_factors) = SIZEOF(control_points_list);
# END_ENTITY;
:LocallyRefinedSplineCurve
	ssmeta:stepImEntityMap "locally_refined_spline_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedCurve ;
	ssmeta:stepImMapAttributeOrder ( 
		:bSplines 
		:knotValues 
		:controlPointsList 
		:scalingFactors 
		:closedCurve 
		:LocallyRefinedSplineTypeEnum 
		:selfIntersect 
		:domain1D ) .
# Note: locally_refined_spline_type_enum maps to an owl.Class and to locally_refined_spline_type is represnted by an rdf:type

:bSplines
	ssmeta:stepImAttributeMap "b_splines" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :LocallyRefinedSplineCurve ;
	rdfs:range :ListOfLocalBSpline .

:knotValues
	ssmeta:stepImAttributeMap "knot_values" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :LocallyRefinedSplineCurve ;
	rdfs:range :SplineKnotValues .

:locallyRefinedSplineType
	ssmeta:stepImAttributeMap "locally_refined_spline_type" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :LocallyRefinedSplineCurve :LocallyRefinedSplineSurface :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range :LocallyRefinedSplineTypeEnum .

:domain1D
	ssmeta:stepImAttributeMap "domain" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :LocallyRefinedSplineCurve ;
	rdfs:range :ListOfDouble .

# ENTITY rational_locally_refined_spline_curve
#   SUBTYPE OF (locally_refined_spline_curve);
#   weights_data : LIST[2:?] OF REAL;
# WHERE
#   WR1: SIZEOF(weights_data) = SIZEOF(SELF\locally_refined_spline_curve. control_points_list);
#   WR2: weights_positive(SELF.weights_data);
# END_ENTITY;
:RationalLocallyRefinedSplineCurve
	ssmeta:stepImEntityMap "rational_locally_refined_spline_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :LocallyRefinedSplineCurve ;
	ssmeta:stepImMapAttributeOrder ( :weightsData ) .

# ENTITY trimmed_curve
#   SUBTYPE OF (bounded_curve);
#   basis_curve : curve;                       => :basisCurve
#   trim_1 : SET[1:2] OF trimming_select;      => :trim1
#   trim_2 : SET[1:2] OF trimming_select;      => :trim2
#   sense_agreement : BOOLEAN;                 => :senseAgreement, OPTIONAL for SST, default = TRUE
#   master_representation : trimming_preference;  => :trimmingMasterRepresentation, OPTIONAL for SST, default TrimmingPreference_Unspecified
# WHERE
#   WR1: (HIINDEX(trim_1) = 1) OR (TYPEOF(trim_1[1]) <> TYPEOF(trim_1[2]));
#   WR2: (HIINDEX(trim_2) = 1) OR (TYPEOF(trim_2[1]) <> TYPEOF(trim_2[2]));
# END_ENTITY;
:TrimmedCurve
	ssmeta:stepImEntityMap "trimmed_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedCurve ;
	ssmeta:stepImMapAttributeOrder ( 
		:basisCurve 
		:trim1 
		:trim2 
		:senseAgreement 
		:trimmingMasterRepresentation ) .

:basisCurve
	ssmeta:stepImAttributeMap "basisCurve" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :PointOnCurve :TrimmedCurve :OffsetCurve2d :OffsetCurve3d )
                     ] ;
	rdfs:range :Curve .

:trim1
	ssmeta:stepImAttributeMap "trim_1" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :TrimmedCurve ;
	rdfs:range :TrimmingSelect .

:trim2
	ssmeta:stepImAttributeMap "trim_2" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :TrimmedCurve ;
	rdfs:range :TrimmingSelect .

:senseAgreement
	ssmeta:stepImAttributeMap "sense_agreement" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :TrimmedCurve ;
	rdfs:range xsd:boolean .

:trimmingMasterRepresentation
	ssmeta:stepImAttributeMap "master_representation" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :TrimmedCurve ;
	rdfs:range :PreferredSurfaceCurveRepresentation .

# ENTITY composite_curve
#   SUBTYPE OF (bounded_curve);
#   segments : LIST[1:?] OF composite_curve_segment;   => :segments
#   self_intersect : LOGICAL;                          => :selfIntersect
# DERIVE
#   n_segments : INTEGER := SIZEOF(segments);
#   closed_curve : LOGICAL := segments[n_segments].transition <> discontinuous;
# WHERE
#   WR1: ((NOT closed_curve) AND (SIZEOF(QUERY(temp <* segments | temp.transition = discontinuous)) = 1)) OR ((closed_curve) AND (SIZEOF(QUERY(temp <* segments | temp.transition = discontinuous)) = 0));
# END_ENTITY;
:CompositeCurve
	ssmeta:stepImEntityMap "composite_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedCurve ;
	ssmeta:stepImMapAttributeOrder ( 
		:segments 
		:selfIntersect ) .

:segments
	ssmeta:stepImAttributeMap "segments" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :CompositeCurve :RectangularCompositeSurface )
                     ] ;
	rdfs:range :SurfacePatch , :CompositeCurveSegment .

# ENTITY composite_curve_segment
#   SUBTYPE OF (founded_item);
#   transition : transition_code;  => :transition
#   same_sense : BOOLEAN;          => :sameSense
#   parent_curve : curve;          => :parentCurve
# INVERSE
#   using_curves : BAG[1:?] OF composite_curve FOR segments;
# WHERE
#   WR1: ('GEOMETRY_SCHEMA.BOUNDED_CURVE' IN TYPEOF(parent_curve));
# END_ENTITY;
