# ENTITY axis2_placement_3d
#   SUBTYPE OF (placement);
#   axis : OPTIONAL direction;              => :axis
#   ref_direction : OPTIONAL direction;     => :refDirection
# DERIVE
#   p : LIST[3:3] OF direction := build_axes(axis,ref_direction);
# WHERE
#   WR1: SELF\placement.location.dim = 3;
#   WR2: (NOT (EXISTS (axis))) OR (axis.dim = 3);
#   WR3: (NOT (EXISTS (ref_direction))) OR (ref_direction.dim = 3);
#   WR4: (NOT (EXISTS (axis))) OR (NOT (EXISTS (ref_direction))) OR (cross_product(axis,ref_direction).magnitude > 0.0);
# END_ENTITY;
:Axis2Placement3D
	ssmeta:stepImEntityMap "axis2_placement_3d" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Axis2Placement , :Placement ;
	ssmeta:stepImMapAttributeOrder ( :axis :refDirection ) .

