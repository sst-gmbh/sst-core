# ENTITY bounded_curve
#   SUPERTYPE OF (ONEOF (polyline,
#                        b_spline_curve,
#                        trimmed_curve,
#                        bounded_pcurve,
#                        bounded_surface_curve,
#                        composite_curve,
#                        locally_refined_spline_curve))
#   SUBTYPE OF (curve);
# END_ENTITY;
:BoundedCurve
	ssmeta:stepImEntityMap "bounded_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Curve ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY polyline
#   SUBTYPE OF (bounded_curve);
#   points : LIST[2:?] OF cartesian_point;    => :points
# END_ENTITY;
:Polyline
	ssmeta:stepImEntityMap "polyline" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedCurve ;
	ssmeta:stepImMapAttributeOrder ( :points ) .

:points
	ssmeta:stepImAttributeMap "points" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :Polyline :HexahedronVolume :FacetedPrimitive )
                     ] ;
	rdfs:range :ListOfCartesianPoints .

# - not in STEP, introduced to support SVG
# ENTITY Polygon
#   SUBTYPE OF (polyline);
# WHERE
#   WR1: ...
# END_ENTITY;
# a polyline is a curve with a closing segment from the last coordinate to the first one
# WR1: the minimum number of points is 3
:Polygon
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Polyline .

# - not in STEP, introduced to support SVG
# ENTITY rectangle
#   SUBTYPE OF (curve);
#   position : axis2_placement_2d;   => :position
#   x : positive_length_measure;  # "width" => :xLength
#   y : positive_length_measure;  # "height" => :yLength
# END_ENTITY;
# - derived from rectangular_area
:Rectangle
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Curve .

# - not in STEP, introduced to support SVG
# ENTITY rounded_rectangle
#   SUBTYPE OF (curve);
#   position : axis2_placement_2d;   => :position
#   x : positive_length_measure;  # "width" => :xLength
#   y : positive_length_measure;  # "height" => :yLength
#   rx : positive_length_measure;  # => :radiusX
#   ry : positive_length_measure;  # => :radiusy
# END_ENTITY;
# - derived from rectangular_area
:RoundedRectangle
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Curve .
:radiusX
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :RoundedRectangle ;
	rdfs:range xsd:double .
:radiusY
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :RoundedRectangle ;
	rdfs:range xsd:double .

# ENTITY b_spline_curve
#   SUPERTYPE OF (ONEOF (uniform_curve,
#                        b_spline_curve_with_knots,
#                        quasi_uniform_curve,
#                        bezier_curve)
#                ANDOR rational_b_spline_curve)
#   SUBTYPE OF (bounded_curve);
#   degree : INTEGER;                                    => :degree
#   control_points_list : LIST[2:?] OF cartesian_point;  => :controlPointsList
#   curve_form : b_spline_curve_form;                    => :curveForm; OPTIONAL, skip for :BSplineCurveFormUnspecified
#   closed_curve : LOGICAL;                              => :closedCurve; OPTIONAL, skip this for logical value UNKNOWN 
#   self_intersect : LOGICAL;                            => :selfIntersect; OPTIONAL, skip this for logical value UNKNOWN 
# DERIVE ...
# WHERE ...
# END_ENTITY;
:BSplineCurve
	ssmeta:stepImEntityMap "b_spline_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BoundedCurve ;
	ssmeta:stepImMapAttributeOrder ( :degree :controlPointsList :curveForm :closedCurve :selfIntersect ) .

:degree
	ssmeta:stepImAttributeMap "b_spline_curve.degree" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineCurve :LocalBSpline )
                     ] ;
	rdfs:range xsd:int .

:controlPointsList
	ssmeta:stepImAttributeMap "b_spline_curve.control_points_list" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineCurve :LocallyRefinedSplineCurve :BSplineSurface :LocallyRefinedSplineSurface :BSplineVolume :LocallyRefinedSplineVolume )
                     ] ;
	rdfs:range :ListOfCartesianPoints .

:curveForm
	ssmeta:stepImAttributeMap "b_spline_curve.curve_form" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :BSplineCurve ;
	rdfs:range :BSplineCurveForm .

:closedCurve
	ssmeta:stepImAttributeMap "b_spline_curve.closed_curve" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineCurve :LocallyRefinedSplineCurve )
                     ] ;
	rdfs:range xsd:boolean .

:selfIntersect
	ssmeta:stepImAttributeMap "b_spline_curve.self_intersect" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineCurve :LocallyRefinedSplineCurve :CompositeCurve :OffsetCurve2d :OffsetCurve3d :BSplineSurface :LocallyRefinedSplineSurface :OffsetSurface )
                     ] ;
	rdfs:range xsd:boolean .

# ENTITY b_spline_curve_with_knots
#   SUBTYPE OF (b_spline_curve);
#   knot_multiplicities : LIST[2:?] OF INTEGER;    => :knotMultiplicities
#   knots : LIST[2:?] OF parameter_value;          => :knots
#   knot_spec : knot_type;                         => :knotSpec
# DERIVE
#   upper_index_on_knots : INTEGER := SIZEOF(knots);
# WHERE
#   WR1: constraints_param_b_spline(degree, upper_index_on_knots, upper_index_on_control_points, knot_multiplicities, knots);
#   WR2: SIZEOF(knot_multiplicities) = upper_index_on_knots;
# END_ENTITY;
:BSplineCurveWithKnots
	ssmeta:stepImEntityMap "b_spline_curve_with_knots" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BSplineCurve ;
	ssmeta:stepImMapAttributeOrder ( :knotMultiplicities :knots :knotSpec ) .

:knotMultiplicities
	ssmeta:stepImAttributeMap "knot_multiplicities" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain  :BSplineCurveWithKnots ;
	rdfs:domain [ a	owl:Class ;
					owl:unionOf  ( :BSplineCurveWithKnots :LocalBSpline )
					] ;
	rdfs:range :ListOfInt .

:knots
	ssmeta:stepImAttributeMap "knots" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineCurveWithKnots :LocalBSpline )
                     ] ;
	rdfs:range :ListOfDouble .

:knotSpec
	ssmeta:stepImAttributeMap "knot_spec" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain [ a            owl:Class ;
                       owl:unionOf  ( :BSplineCurveWithKnots :BSplineSurfaceWithKnots )
                     ] ;
	rdfs:range :KnotType .

# ENTITY uniform_curve
#   SUBTYPE OF (b_spline_curve);
# END_ENTITY;
:UniformCurve
	ssmeta:stepImEntityMap "uniform_curve" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :BSplineCurve ;
	ssmeta:stepImMapAttributeOrder (  ) . # empty

# ENTITY quasi_uniform_curve
#   SUBTYPE OF (b_spline_curve);
