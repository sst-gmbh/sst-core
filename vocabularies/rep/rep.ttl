# ENTITY edge_loop
#   SUBTYPE OF (loop,path);
# DERIVE
#   ne : INTEGER := SIZEOF(SELF\path.edge_list);
# WHERE
#   WR1: (SELF\path.edge_list[1].edge_start) :=:
#        (SELF\path.edge_list[ne].edge_end);
# END_ENTITY;
:EdgeLoop
	ssmeta:stepImEntityMap "edge_loop" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Loop , :Path ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY face
#   SUPERTYPE OF(ONEOF(face_surface, subface, oriented_face))
#   SUBTYPE OF (topological_representation_item);
#   bounds : SET[1:?] OF face_bound;  => :bounds1
# WHERE
#   WR1: NOT (mixed_loop_type_set(list_to_set(list_face_loops(SELF))));
#   WR2: SIZEOF(QUERY(temp <* bounds | 'TOPOLOGY_SCHEMA.FACE_OUTER_BOUND' IN
#                                               TYPEOF(temp))) <= 1;
# END_ENTITY;
:Face
	ssmeta:stepImEntityMap "face" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ReversibleTopologyItem , :TopologicalRepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :bounds1 ) .

:bounds1
	ssmeta:stepImAttributeMap "bounds" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :Face ;
	rdfs:range :FaceBound .

# ENTITY subface
#   SUBTYPE OF (face);
#   parent_face   :  face;
# WHERE
#   WR1: NOT (mixed_loop_type_set(list_to_set(list_face_loops(SELF)) +
#              list_to_set(list_face_loops(parent_face))));
#   WR2: SELF :<>: parent_face;
# END_ENTITY;
:SubFace
	ssmeta:stepImAttributeMap "subface" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :Face ;
	ssmeta:stepImMapAttributeOrder ( :parentFace ) .

:parentFace
	ssmeta:stepImAttributeMap "parent_face" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :SubFace ;
	rdfs:range :Face .

# ENTITY face_bound
#   SUBTYPE OF (topological_representation_item);
#   bound       :  loop;
#   orientation :  BOOLEAN;
# END_ENTITY;
:FaceBound
	ssmeta:stepImEntityMap "face_bound" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ReversibleTopologyItem , :TopologicalRepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :bound :orientation ) .

:bound
	ssmeta:stepImAttributeMap "bound" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf :interRepItemUsage ;
	rdfs:domain  :FaceBound ;
	rdfs:range :Loop .


# ENTITY face_outer_bound
#   SUBTYPE OF (face_bound);
# END_ENTITY;
:FaceOuterBound
	ssmeta:stepImEntityMap "face_outer_bound" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :FaceBound ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY face_surface
