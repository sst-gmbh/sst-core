:Loop
	ssmeta:stepImEntityMap "loop" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :TopologicalRepresentationItem ;
	ssmeta:stepImMapAttributeOrder (  ) .

# ENTITY open_path
