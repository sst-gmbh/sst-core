#     SET[0:1] OF linear_geometry_constraint_element;
# END_ENTITY; 
:ParallelGeometricConstraint
	ssmeta:stepImEntityMap "parallel_geometric_constraint" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ExplicitGeometricConstraint ;
	ssmeta:stepImMapAttributeOrder (  ) .

