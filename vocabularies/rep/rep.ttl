# ENTITY colour_rgb
#   SUBTYPE OF (colour_specification);
#   red   : REAL;
#   green : REAL;
#   blue  : REAL;
# WHERE
#   WR1: {0.0 <= red <= 1.0};
#   WR2: {0.0 <= green <= 1.0};
#   WR3: {0.0 <= blue <= 1.0};
# END_ENTITY;
# Note: the :rgb attribute is taken over from SVG and replaces the original red,gree and blue attributes.
#  STEP :red, :green and :blue values are to be converted into corresponding :rgb values
#  for the the range of the original STEP attributes red, green and blue 
#  that is 0.0 to 1.0 has to be transformed in a range 0..255 (integer) for the:rgb attribute
:ColourRGB
	ssmeta:stepImEntityMap "colour_rgb" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :ColourSpecification ;
	ssmeta:stepImMapAttributeOrder ( :red :green :blue ) .

:red
	ssmeta:stepImAttributeMap "colour_rgb.red" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :ColourRGB ;
	rdfs:range xsd:double .

:green
	ssmeta:stepImAttributeMap "colour_rgb.green" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :ColourRGB ;
	rdfs:range xsd:double .

:blue
	ssmeta:stepImAttributeMap "colour_rgb.blue" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :ColourRGB ;
	rdfs:range xsd:double .

:rgb
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :ColourRGB ;
	rdfs:range :ListOfInt .

