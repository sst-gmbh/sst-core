# ENTITY text_literal
#   SUBTYPE OF (geometric_representation_item);
#     literal   : presentable_text;  => :literal
#     placement : axis2_placement;  => :position
#     alignment : text_alignment; => :alignment
#     path      : text_path;  => :textDirection
#     font      : font_select; => :font -> :TextFont
# END_ENTITY;
:TextLiteral
	ssmeta:stepImEntityMap "text_literal" ;
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :GeometricRepresentationItem ;
	ssmeta:stepImMapAttributeOrder ( :literal :position :alignment :textDirection ssmeta:indeterminateValue ) .

:literal   
	ssmeta:stepImAttributeMap "text_literal.literal" ;
	a owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:domain :TextLiteral ;
	rdfs:range xsd:string .

:alignment
	ssmeta:stepImAttributeMap "text_literal.alignment" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :TextLiteral ;
	rdfs:range :TextAlignment .

:textDirection
	ssmeta:stepImAttributeMap "text_literal.alignment" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :TextLiteral ;
	rdfs:range :TextPath .

:font
	ssmeta:stepImAttributeMap "text_literal.font" ;
	a owl:ObjectProperty , owl:FunctionalProperty ;
	rdfs:domain :TextLiteral ;
	rdfs:range :TextFont .

# A TextParamterLiteral is a TextLiteral that does not define a fiexed test to display but is a placeholder to 
# display some text from the higher usage of this elements within a structure. 
# parameter_id defines the parameter type whose value is to be displayed as literal string.
# parameter_id might also be a combination of several parameter id's together with some constant text to display.
# TO BE SPECIFIED IN MORE DETAIL LATER ON.
#
# ENTITY text_parameter_literal
#   SUBTYPE OF (text_literal);
#   parameter_id : string #  => sso:id
# END_ENTITY;
:TextParamterLiteral
	a owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf :TextLiteral ;
.
# :parameterId
# 	rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
# 	rdfs:subPropertyOf sso:id ;
# 	rdfs:domain :TextParamterLiteral ;
# 	skos:prefLabel "text parameter literal" ;
#   skos:definition "<id> of a <TextParamterLiteral> that is specific ..." .

# ENTITY text_literal_with_associated_curves
#   SUBTYPE OF (text_literal);
#     associated_curves : SET[1:?] of curve;
# END_ENTITY;
:TextLiteralWithAssociatedCurves
