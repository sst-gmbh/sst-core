.
:PreDefinedTerminatorSymbol_filled_dot
	rdfs:label "filled dot" ;
	a :PreDefinedTerminatorSymbol ;
.
:PreDefinedTerminatorSymbol_integral_symbol
	rdfs:label "integral symbol" ;
	a :PreDefinedTerminatorSymbol ;
.
:PreDefinedTerminatorSymbol_open_arrow
	rdfs:label "open arrow" ;
